local function simpleInteract(prompt, customHold)
    if prompt and prompt:IsA("ProximityPrompt") then
        local oldReq = prompt.RequiresLineOfSight
        local oldDist = prompt.MaxActivationDistance
        
        prompt.RequiresLineOfSight = false
        prompt.MaxActivationDistance = math.huge
        
        if type(fireproximityprompt) == "function" then
            fireproximityprompt(prompt, 1, true)
        else
            prompt:InputHoldBegan()
            task.wait(customHold or prompt.HoldDuration or 0.25)
            prompt:InputHoldEnded()
        end
        
        prompt.RequiresLineOfSight = oldReq
        prompt.MaxActivationDistance = oldDist
        task.wait(Config.WaitTime)
    end
    return true
end

local function findActiveRoom()
    local roomsFolder = workspace:FindFirstChild("Rooms")
    local medicalFolder = roomsFolder and roomsFolder:FindFirstChild("Medical")
    if not medicalFolder then return nil end

    for i = 1, Config.MaxRooms do
        local roomName = "Room" .. i
        local room = medicalFolder:FindFirstChild(roomName)
        if room then
            local signLight = room:FindFirstChild("MainSign") and room.MainSign:FindFirstChild("Light")
            if signLight and signLight:IsA("BasePart") then
                if signLight.BrickColor.Name == "Crimson" or signLight.Color == Color3.fromRGB(165, 0, 0) then
                    return room
                end
            end
        end
    end
    return nil
end

local function handleFaintedPatientsIfAny()
    local faintedNPC, carryPP = nil, nil
    
    for _, npc in ipairs(workspace.NPCs:GetChildren()) do
        local pp = npc:FindFirstChild("FaintedPP", true)
        if pp and pp.ActionText:match("Carry") then
            faintedNPC = npc
            carryPP = pp
            break
        end
    end

    if faintedNPC and carryPP then
        setStatus("!! PASIEN PINGSAN DITEMUKAN !!")
        local part = faintedNPC.PrimaryPart or faintedNPC:FindFirstChildWhichIsA("BasePart")
        local char = LocalPlayer.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        
        if root and part then
            setStatus("Menggendong pasien pingsan...")
            root.Anchored = true
            root.CFrame = CFrame.new(part.Position + Vector3.new(0, 3, 0))
            root.Velocity = Vector3.zero
            task.wait(Config.WaitTime)
            root.Anchored = false
            
            simpleInteract(carryPP, 0) 
            task.wait(1.5) 
            
            local targetRoom = findActiveRoom()
            if targetRoom then
                local roomNum = tonumber(targetRoom.Name:match("%d+"))
                setStatus("Membawa pasien ke " .. targetRoom.Name .. "...")
                teleportToSafeRoom(roomNum)
                
                local placePP = faintedNPC:FindFirstChild("FaintedPP", true)
                if placePP then
                    setStatus("Meletakkan pasien pingsan di kasur...")
                    simpleInteract(placePP, 1) 
                    task.wait(2)
                end
            else
                setStatus("Gagal menemukan ruangan untuk pasien pingsan.")
            end
        end
    end
end

local function executeTreatmentCore(roomPath)
    local minigame = roomPath:FindFirstChild("Minigame")
    if not minigame then return end
    
    local roomNum = tonumber(roomPath.Name:match("%d+"))

    local tvUI = minigame:FindFirstChild("TV") and minigame.TV:FindFirstChild("Screen", true)
    if tvUI then
        local treatTextObj = tvUI:FindFirstChild("treatment", true)
        if treatTextObj then
            local cur, max = treatTextObj.Text:match("(%d+)/(%d+)")
            if cur and max and cur == max and max ~= "0" then
                setStatus("SKIPPED: Pasien di " .. roomPath.Name .. " sudah selesai ("..cur.."/"..max..").")
                task.wait(1.5)
                return
            end
        end
    end

    setStatus("--- MEMULAI PENGOBATAN: " .. roomPath.Name .. " ---")
    local bed = minigame:FindFirstChild("Bed") and minigame.Bed:FindFirstChild("InBed")
    local bedPart = bed and (bed:IsA("BasePart") and bed or bed:FindFirstChildWhichIsA("BasePart"))
    local patientIsAnomaly = false

    -- 1. TUNGGU PASIEN & CEK STATUS (SMART RESUME)
    setStatus("1/5 Menunggu pasien rebahan di kasur...")
    teleportToSafeRoom(roomNum) 
    
    local targetNPC = nil
    local waitLimit = 0
    
    while not targetNPC and waitLimit < 30 do
        for _, npc in ipairs(workspace.NPCs:GetChildren()) do
            local part = npc.PrimaryPart or npc:FindFirstChildWhichIsA("BasePart")
            if part and bedPart and (part.Position - bedPart.Position).Magnitude < 40 then
                targetNPC = npc
                break
            end
        end
        if not targetNPC then
            task.wait(0.5)
            waitLimit = waitLimit + 1
        end
    end

    if not targetNPC then
        setStatus("BATAL: Pasien tidak muncul di kasur " .. roomPath.Name .. ".")
        return
    end

    if isAnomaly(targetNPC) then
        patientIsAnomaly = true
        setStatus("!! PERINGATAN !! PASIEN INI ADALAH ANOMALI/MONSTER!")
    else
        setStatus("Pasien terdeteksi normal.")
    end

    local dnaPP = targetNPC:FindFirstChild("PP")
    if dnaPP and dnaPP:IsA("ProximityPrompt") and dnaPP.ActionText:match("DNA") then
        setStatus("Mengambil DNA pasien...")
        simpleInteract(dnaPP, 0.25)
    else
        setStatus("DNA sudah diambil sebelumnya (Melanjutkan progress)...")
    end

    -- 2. Analyzer
    setStatus("2/5 Cek Mesin Analyzer...")
    local analyzer = minigame:FindFirstChild("Analyzer")
    if analyzer and analyzer:FindFirstChild("PP") then
        simpleInteract(analyzer.PP, 0.5)
    end

    -- 3. Monitor
    setStatus("3/5 Cek Komputer Monitor...")
    local monitor = minigame:FindFirstChild("Monitor")
    if monitor and monitor:FindFirstChild("PP2") then
        simpleInteract(monitor.PP2, 0.25)
    end

    -- 4. Tunggu TV Loading
    setStatus("4/5 Membaca Kebutuhan Obat dari TV...")
    if tvUI and tvUI:FindFirstChild("inv", true) then
        local invFolder = tvUI:FindFirstChild("inv", true)
        local waitLimitTV = 0
        while #invFolder:GetChildren() <= 1 and waitLimitTV < 15 do
            task.wait(0.5)
            waitLimitTV = waitLimitTV + 1
        end
    end

    -- 5. Eksekusi Treatment 
    if patientIsAnomaly then
        setStatus("5/5 [ALGOJO MODE] Mencari RACUN untuk Anomali...")
        local initialMeds = getPendingMedicines(tvUI)
        local wrongMedicine = "Medicine"
        
        for _, item in ipairs(ItemList) do
            if not table.find(initialMeds, item) then wrongMedicine = item break end
        end
        
        local hasIt = LocalPlayer.Backpack:FindFirstChild(wrongMedicine) or LocalPlayer.Character:FindFirstChild(wrongMedicine)
        if not hasIt then fetchItem(wrongMedicine) end
        
        if bed and bed:FindFirstChild("PP") then
            teleportToSafeRoom(roomNum) 
            local tool = LocalPlayer.Backpack:FindFirstChild(wrongMedicine) or LocalPlayer.Character:FindFirstChild(wrongMedicine)
            if tool then LocalPlayer.Character.Humanoid:EquipTool(tool) end
            task.wait(0.2)
            
            setStatus("MENYUNTIKKAN OBAT SALAH: " .. wrongMedicine)
            simpleInteract(bed.PP, 0.25)
            setStatus("--- ANOMALI BERHASIL DIBUNUH! ---")
        end

    else
        setStatus("5/5 Memulai pengobatan (Eagle Eye)...")
        while true do
            local pendingMeds = getPendingMedicines(tvUI)
            if #pendingMeds == 0 then
                setStatus("Semua obat sudah tercentang di TV! Pengobatan selesai.")
                break
            end
            
            if tvUI then
                local treatTextObj = tvUI:FindFirstChild("treatment", true)
                if treatTextObj then
                    local cur, max = treatTextObj.Text:match("(%d+)/(%d+)")
                    if cur and max and cur == max and max ~= "0" then
                        setStatus("Progres mencapai maksimum ("..cur.."/"..max.."). Berhenti.")
                        break
                    end
                end
            end

            local medsReadyToGive = {}
            setStatus("Tersisa " .. #pendingMeds .. " obat yang belum tercentang.")
            
            for _, obat in ipairs(pendingMeds) do
                local totalInv, _ = checkTotalInventory()
                local hasIt = LocalPlayer.Backpack:FindFirstChild(obat) or LocalPlayer.Character:FindFirstChild(obat)
                
                if hasIt then
                    table.insert(medsReadyToGive, obat)
                elseif totalInv < Config.MaxInventory then
                    local fetched = fetchItem(obat)
                    if fetched then table.insert(medsReadyToGive, obat) end
                end
            end

            if #medsReadyToGive > 0 and bed and bed:FindFirstChild("PP") then
                teleportToSafeRoom(roomNum) 
                
                setStatus("Menyuntikkan " .. #medsReadyToGive .. " obat sekaligus...")
                for _, obat in ipairs(medsReadyToGive) do
                    local tool = LocalPlayer.Backpack:FindFirstChild(obat) or LocalPlayer.Character:FindFirstChild(obat)
                    if tool then LocalPlayer.Character.Humanoid:EquipTool(tool) end
                    task.wait(0.2)
                    
                    setStatus("Menyuntikkan: " .. obat)
                    simpleInteract(bed.PP, 0.25)
                end
                
                task.wait(1.5)
            else
                if #medsReadyToGive == 0 then
                    setStatus("Gagal mengambil sisa obat. Hentikan operasi.")
                    break
                end
            end
        end
        setStatus("--- PASIEN BERHASIL DIOBATI! ---")
    end
    task.wait(1)
end

-- ==========================================
-- SAFE WRAPPER (ANTI-MOGOK)
-- ==========================================
local function safeTreatPatient(roomPath)
    if isBusy then return end
    isBusy = true
    
    local success, err = pcall(function()
        handleFaintedPatientsIfAny() 
        executeTreatmentCore(roomPath)
    end)
    
    if not success then
        setStatus("System Error: " .. tostring(err))
    end
    
    isBusy = false
end

