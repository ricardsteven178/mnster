local function setStatus(text)
    StatusLabel.Text = "Status: " .. text
    if Config.ShowConsoleLogs then 
        local timeStamp = os.date("%H:%M:%S")
        print("[" .. timeStamp .. "] [Auto-Doctor] " .. text) 
    end
end

-- Teleport ke Ruang Medis
local function teleportToSafeRoom(roomNum)
    local char = LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if root and RoomCFrames[roomNum] then
        root.CFrame = RoomCFrames[roomNum]
        root.Velocity = Vector3.zero
        task.wait(Config.WaitTime)
    end
end

-- Teleport ke Posisi Idle (Lobby)
local function teleportToIdle()
    local char = LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if root then
        root.CFrame = Config.IdleCFrame
        root.Velocity = Vector3.zero
        task.wait(Config.WaitTime)
    end
end

local function getPendingMedicines(tvUI)
    local pending = {}
    if not tvUI then return pending end
    local invFolder = tvUI:FindFirstChild("inv", true)
    if not invFolder then return pending end
    
    for _, itemReq in ipairs(invFolder:GetChildren()) do
        if not itemReq:IsA("UIListLayout") then 
            local checkMark = itemReq:FindFirstChild("check")
            if not checkMark or (checkMark and checkMark.Visible == false) then
                table.insert(pending, itemReq.Name) 
            end
        end
    end
    return pending
end

local function isAnomaly(npc)
    if not npc then return false end
    local attr = npc:GetAttributes()
    if attr.Skinwalker or attr.SkinwalkerEasy or attr.PenaltyWhenLettingIn or attr.PhotoEffect == "CursedPhoto" or attr.PhotoEffect2 == "CursedPhoto" then 
        return true 
    end
    return false
end

-- ==========================================
-- INVENTORY & ITEM FETCHING
-- ==========================================
local function checkTotalInventory()
    local targetCount = 0
    local targetItems = {} 
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    local character = LocalPlayer.Character
    
    local function processTool(item)
        if item:IsA("Tool") and table.find(ItemList, item.Name) then
            targetCount = targetCount + 1
            table.insert(targetItems, item)
        end
    end

    if backpack then for _, item in ipairs(backpack:GetChildren()) do processTool(item) end end
    if character then for _, item in ipairs(character:GetChildren()) do processTool(item) end end
    return targetCount, targetItems
end

local function trashItem(toolToTrash)
    local character = LocalPlayer.Character
    local rootPart = character and character:FindFirstChild("HumanoidRootPart")
    local humanoid = character and character:FindFirstChild("Humanoid")
    local trashBin = workspace:FindFirstChild("Trash")
    
    if not rootPart or not humanoid or not toolToTrash then return false end
    
    if trashBin then
        local prompt = trashBin:FindFirstChild("PP") or trashBin:FindFirstChildWhichIsA("ProximityPrompt", true)
        if prompt and prompt:IsA("ProximityPrompt") then
            setStatus("Kapasitas penuh! Membuang: " .. toolToTrash.Name)
            humanoid:EquipTool(toolToTrash)
            task.wait(0.2)
            
            if trashBin:IsA("Model") and trashBin.PrimaryPart then
                rootPart.CFrame = trashBin.PrimaryPart.CFrame * CFrame.new(0, 3, 0)
            elseif trashBin:IsA("BasePart") then
                rootPart.CFrame = trashBin.CFrame * CFrame.new(0, 3, 0)
            elseif trashBin:FindFirstChildWhichIsA("BasePart") then
                rootPart.CFrame = trashBin:FindFirstChildWhichIsA("BasePart").CFrame * CFrame.new(0, 3, 0)
            end
            
            rootPart.Velocity = Vector3.new(0, 0, 0)
            task.wait(Config.WaitTime)
            
            prompt.RequiresLineOfSight = false
            prompt.MaxActivationDistance = math.huge
            prompt.HoldDuration = 0
            if type(fireproximityprompt) == "function" then fireproximityprompt(prompt, 1, true)
            else prompt:InputHoldBegan() task.wait(0.1) prompt:InputHoldEnded() end
            
            task.wait(Config.WaitTime)
            return true
        end
    end
    return false
end

local function fetchItem(targetName)
    local char = LocalPlayer.Character
    local rootPart = char and char:FindFirstChild("HumanoidRootPart")
    if not rootPart then return false end

    setStatus("Mencoba mengambil: " .. targetName)

    local totalAmount, currentItems = checkTotalInventory()
    if totalAmount >= Config.MaxInventory and #currentItems > 0 then
        local itemToThrowAway = currentItems[1]
        local trashed = trashItem(itemToThrowAway)
        if not trashed then return false end 
    end

    local found = false
    for _, item in ipairs(workspace:GetDescendants()) do
        if item.Name == targetName then
            local prompt = item:FindFirstChild("PP") or item:FindFirstChildWhichIsA("ProximityPrompt")
            local itemPart = item:IsA("BasePart") and item or item:FindFirstChildWhichIsA("BasePart")
            
            if prompt and prompt:IsA("ProximityPrompt") and itemPart then
                found = true
                rootPart.CFrame = itemPart.CFrame * CFrame.new(0, 3, 0)
                rootPart.Velocity = Vector3.new(0, 0, 0)
                task.wait(Config.WaitTime)
                
                prompt.RequiresLineOfSight = false
                prompt.MaxActivationDistance = math.huge
                prompt.HoldDuration = 0
                if type(fireproximityprompt) == "function" then fireproximityprompt(prompt, 1, true)
                else prompt:InputHoldBegan() task.wait(0.1) prompt:InputHoldEnded() end
                
                task.wait(Config.WaitTime)
                setStatus("BERHASIL MENGAMBIL ITEM: " .. targetName)
                break 
            end
        end
    end

    if found then task.wait(0.5) return true else setStatus("GAGAL: " .. targetName .. " tidak ditemukan.") return false end
end

-- ==========================================
-- MEDICAL & ROOM LOGIC
