-- ROOM 7 SPECIFIC LOGIC
-- ==========================================
local function isRoom7Active()
    local room7 = workspace:FindFirstChild("Rooms") and workspace.Rooms:FindFirstChild("Emergency") and workspace.Rooms.Emergency:FindFirstChild("Room7")
    if not room7 then return nil end

    local minigame = room7:FindFirstChild("Minigame")
    local healing = minigame and minigame:FindFirstChild("TV") and minigame.TV:FindFirstChild("Screen") and minigame.TV.Screen:FindFirstChild("UI") and minigame.TV.Screen.UI:FindFirstChild("Healing")
    if healing and healing.Visible == true then return nil end -- Udah sembuh

    local signLight = room7:FindFirstChild("MainSign") and room7.MainSign:FindFirstChild("Light")
    local bed = minigame and minigame:FindFirstChild("Bed") and minigame.Bed:FindFirstChild("InBed")
    
    local isLightRed = signLight and (signLight.BrickColor.Name == "Crimson" or signLight.Color == Color3.fromRGB(165, 0, 0))
    local hasPhysicalPatient = false

    if bed and workspace:FindFirstChild("NPCs") then
        for _, npc in ipairs(workspace.NPCs:GetChildren()) do
            local part = npc.PrimaryPart or npc:FindFirstChildWhichIsA("BasePart")
            if part and (part.Position - bed.Position).Magnitude < 15 then
                hasPhysicalPatient = true; break
            end
        end
    end

    if isLightRed or hasPhysicalPatient then return room7 end
    return nil
end

local function getRoom7PendingMedicines(tvUI)
    local pending = {}
    if not tvUI then return pending end
    local invFolder = tvUI:FindFirstChild("inv", true) -- Workspace.Rooms.Emergency.Room7.Minigame.TV.Screen.UI.Report.inv
    if not invFolder then return pending end
    
    for _, itemReq in ipairs(invFolder:GetChildren()) do
        if not itemReq:IsA("UIListLayout") then 
            local checkMark = itemReq:FindFirstChild("check")
            if not checkMark or (checkMark and checkMark.Visible == false) then table.insert(pending, itemReq.Name) end
        end
    end
    return pending
end

local function executeRoom7(room7)
    local minigame = room7:FindFirstChild("Minigame")
    if not minigame then return end
    
    setStatus("Proses Room 7", "Mulai Sequence 1")
    
    -- TELEPORT 1: Prepare Patient & Set Up
    teleport(Room7_CFrames.Step1)
    local pp2 = minigame:FindFirstChild("Bed") and minigame.Bed:FindFirstChild("InBed") and minigame.Bed.InBed:FindFirstChild("PP2")
    if pp2 then simpleInteract(pp2, 0.25) end
    
    local standIV = minigame:FindFirstChild("StandIV") and minigame.StandIV:FindFirstChild("PP")
    if standIV then simpleInteract(standIV, 0.5) end
    
    -- TELEPORT 2: Turn On & Begin
    setStatus("Proses Room 7", "Mulai Sequence 2")
    teleport(Room7_CFrames.Step2)
    local machine = minigame:FindFirstChild("Machine") and minigame.Machine:FindFirstChild("PP")
    if machine then simpleInteract(machine, 0.5) end
    
    local hm = minigame:FindFirstChild("HeartMonitor") and minigame.HeartMonitor:FindFirstChild("PP")
    if hm then 
        setStatus("Proses Room 7", "Memulai Minigame")
        simpleInteract(hm, 0.25) 
    end
    
    -- Tunggu Minigame muncul dan selesai (Bot bypass otomatis jalan karena isAutoPlaying = true)
    task.wait(2)
    local waitCount = 0
    while PlayerGui:FindFirstChild("Minigame") and waitCount < 30 do
        setStatus("Menunggu Minigame", "Bot Bypass Aktif...")
        task.wait(1)
        waitCount = waitCount + 1
    end
    
    -- TELEPORT 3: Process Results & Collect
    setStatus("Proses Room 7", "Mulai Sequence 3")
    teleport(Room7_CFrames.Step3)
    local monitorPP2 = minigame:FindFirstChild("Monitor") and minigame.Monitor:FindFirstChild("PP2")
    if monitorPP2 then simpleInteract(monitorPP2, 0.25) end
    
    local collectPP = getNilPrompt("PP", "ProximityPrompt")
    if collectPP then 
        setStatus("Proses Room 7", "Collect Hasil")
        simpleInteract(collectPP, 0.5) 
    end
    
    -- TELEPORT 2 (LAGI): Apply Treatment
    setStatus("Proses Room 7", "Apply Treatment")
    teleport(Room7_CFrames.Step2)
    local inBedPP = minigame:FindFirstChild("Bed") and minigame.Bed:FindFirstChild("InBed") and minigame.Bed.InBed:FindFirstChild("PP")
    if inBedPP then simpleInteract(inBedPP, 0.25) end
    
    -- LOOP: Ambil Obat (TV.Screen.UI.Report.inv)
    local tv = minigame:FindFirstChild("TV") and minigame.TV:FindFirstChild("Screen")
    local healingUI = tv and tv:FindFirstChild("UI") and tv.UI:FindFirstChild("Healing")
    local reportUI = tv and tv:FindFirstChild("UI") and tv.UI:FindFirstChild("Report")
    
    local stuckLoop = 0
    while reportUI and (not healingUI or healingUI.Visible == false) and stuckLoop < 20 do
        local pendingMeds = getRoom7PendingMedicines(reportUI)
        if #pendingMeds == 0 then
            setStatus("Proses Room 7", "Obat Tercentang, Tunggu Healing...")
            task.wait(1)
            stuckLoop = stuckLoop + 1
            continue
        end
        
        stuckLoop = 0 -- reset
        for _, obat in ipairs(pendingMeds) do
            local hasIt = LocalPlayer.Backpack:FindFirstChild(obat) or LocalPlayer.Character:FindFirstChild(obat)
            if not hasIt then fetchItem(obat) end
            
            teleport(Room7_CFrames.Step2)
            local tool = LocalPlayer.Backpack:FindFirstChild(obat) or LocalPlayer.Character:FindFirstChild(obat)
            if tool then 
                LocalPlayer.Character.Humanoid:EquipTool(tool)
                task.wait(0.2)
                setStatus("Proses Room 7", "Menyuntikkan " .. obat)
                simpleInteract(inBedPP, 0.25)
                task.wait(0.5)
            end
        end
        task.wait(1.5)
    end
    
    setStatus("Selesai", "Room 7 Tertangani")
end

