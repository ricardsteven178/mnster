local function FireButton(button)
    local wasActive = button.Active
    pcall(function() button.Active = true end)
    if typeof(getconnections) == "function" then
        pcall(function()
            for _, c in ipairs(getconnections(button.MouseButton1Down)) do task.spawn(function() pcall(function() c:Fire() end) end) end
            task.wait(0.05)
            for _, c in ipairs(getconnections(button.Activated)) do task.spawn(function() pcall(function() c:Fire() end) end) end
        end)
    elseif typeof(firesignal) == "function" then
        pcall(function() firesignal(button.MouseButton1Down) task.wait(0.05) firesignal(button.Activated) end)
    else
        local pos = button.AbsolutePosition
        local size = button.AbsoluteSize
        local inset = GuiService:GetGuiInset()
        local x = pos.X + size.X / 2
        local y = pos.Y + size.Y / 2 + inset.Y
        pcall(function()
            VirtualInputManager:SendMouseButtonEvent(x, y, 0, true, game, 0)
            task.wait(0.05)
            VirtualInputManager:SendMouseButtonEvent(x, y, 0, false, game, 0)
        end)
    end
    pcall(function() button.Active = wasActive end)
end

local function FindClickable(container)
    if container:IsA("ImageButton") or container:IsA("TextButton") then return container end
    for _, d in ipairs(container:GetDescendants()) do
        if (d:IsA("ImageButton") or d:IsA("TextButton")) and d.Visible then return d end
    end
    return container
end

local function DeepScan(root)
    local isHand, isSkull = false, false
    local best = root
    local function check(obj)
        if obj:IsA("ImageLabel") or obj:IsA("ImageButton") then
            if obj.Image == ID_HAND  then isHand  = true; best = obj end
            if obj.Image == ID_SKULL then isSkull = true; best = obj end
        end
    end
    check(root)
    for _, d in ipairs(root:GetDescendants()) do check(d) end
    return isHand, isSkull, best
end

local function ProcessMinigameChild(child)
    task.wait(0.03)
    if not child or not child.Parent or not isAutoPlaying then return end

    local isHand, isSkull, _ = DeepScan(child)
    if isHand then
        local button = FindClickable(child)
        FireButton(button)
        totalHand += 1
        HandLbl.Text = "👆 Minigame Clicked: " .. totalHand
    elseif isSkull then
        totalSkull += 1
        SkullLbl.Text = "💀 Minigame Skipped: " .. totalSkull
    end
end

local function HookMinigameFrame(frame)
    table.insert(minigameConnections, frame.ChildAdded:Connect(function(child) task.spawn(function() ProcessMinigameChild(child) end) end))
    for _, child in ipairs(frame:GetChildren()) do task.spawn(function() ProcessMinigameChild(child) end) end
end

local function HookMinigameGui(gui)
    for _, child in ipairs(gui:GetChildren()) do if child:IsA("Frame") then HookMinigameFrame(child) end end
    table.insert(minigameConnections, gui.ChildAdded:Connect(function(child) if child:IsA("Frame") then HookMinigameFrame(child) end end))
end

