local function turboSafeEquip(itemName)
    local char = LocalPlayer.Character
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    local hum = char and char:FindFirstChild("Humanoid")
    if not char or not backpack or not hum then return false end

    if char:FindFirstChild(itemName) then return true end

    hum:UnequipTools()
    local t1 = 0
    while char:FindFirstChildOfClass("Tool") and t1 < 10 do
        task.wait(0.05)
        t1 = t1 + 1
    end

    local tool = backpack:FindFirstChild(itemName) or char:FindFirstChild(itemName)
    if not tool then return false end

    hum:EquipTool(tool)
    local t2 = 0
    while not char:FindFirstChild(itemName) and t2 < 15 do
        task.wait(0.05)
        t2 = t2 + 1
    end

    task.wait(0.1) 
    return char:FindFirstChild(itemName) ~= nil
end

local function simpleInteract(prompt, customHold, autoLock)
    if prompt and prompt:IsA("ProximityPrompt") then
        if autoLock then
            teleportToTarget(prompt)
        end
        
        local oldReq = prompt.RequiresLineOfSight
        local oldDist = prompt.MaxActivationDistance
        
        prompt.RequiresLineOfSight = false
        prompt.MaxActivationDistance = math.huge
        
        if type(fireproximityprompt) == "function" then
            fireproximityprompt(prompt)
        else
            prompt:InputHoldBegan()
            task.wait(customHold or prompt.HoldDuration or 0.1)
            prompt:InputHoldEnded()
        end
        
        GlobalState.LastAction = tick()
        prompt.RequiresLineOfSight = oldReq
        prompt.MaxActivationDistance = oldDist
        task.wait(0.1)
    end
    return true
end

local function checkTotalInventory()
    local targetCount = 0
    local targetItems = {} 
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    local character = LocalPlayer.Character
    
    local function processTool(item)
        if item:IsA("Tool") and table.find(ItemList, item.Name) then
            targetCount = targetCount + 1
            table.insert(targetItems, item)
        end
    end

    if backpack then for _, item in ipairs(backpack:GetChildren()) do processTool(item) end end
    if character then for _, item in ipairs(character:GetChildren()) do processTool(item) end end
    return targetCount, targetItems
end

local function getPromptFromCache(targetName, isTrash)
    if isTrash then
        if _G.UDoc_TrashCache and _G.UDoc_TrashCache.Parent then return _G.UDoc_TrashCache end
        for _, desc in ipairs(workspace:GetDescendants()) do
            if desc:IsA("ProximityPrompt") then
                local actText = string.lower(desc.ActionText or "")
                local objName = string.lower(desc.Parent and desc.Parent.Name or "")
                if actText:match("trash") or actText:match("throw") or actText:match("dispose") or objName:match("trash") then
                    _G.UDoc_TrashCache = desc
                    return desc
                end
            end
        end
    else
        if _G.UDoc_ItemCache[targetName] and _G.UDoc_ItemCache[targetName].Parent then return _G.UDoc_ItemCache[targetName] end
        local tLower = string.lower(targetName)
        for _, desc in ipairs(workspace:GetDescendants()) do
            if desc:IsA("ProximityPrompt") and desc.Enabled then
                local pName = string.lower(desc.Parent and desc.Parent.Name or "")
                local oText = string.lower(desc.ObjectText or "")
                local aText = string.lower(desc.ActionText or "")
                if pName:match(tLower) or oText:match(tLower) or aText:match(tLower) then
                    _G.UDoc_ItemCache[targetName] = desc
                    return desc
                end
            end
        end
    end
    return nil
end

local function trashItem(toolToTrash)
    local char = LocalPlayer.Character
    if not char then return false end
    
    local trashPrompt = getPromptFromCache("Trash", true)
    if trashPrompt then
        LLog("SYS", "Membuang item (Turbo): " .. toolToTrash.Name)
        teleportToTarget(trashPrompt)
        
        if turboSafeEquip(toolToTrash.Name) then
            local oldReq = trashPrompt.RequiresLineOfSight
            local oldDist = trashPrompt.MaxActivationDistance
            trashPrompt.RequiresLineOfSight = false
            trashPrompt.MaxActivationDistance = math.huge
            trashPrompt.HoldDuration = 0
            
            if type(fireproximityprompt) == "function" then 
                fireproximityprompt(trashPrompt)
            else 
                trashPrompt:InputHoldBegan() 
                task.wait(0.05) 
                trashPrompt:InputHoldEnded() 
            end
            
            trashPrompt.RequiresLineOfSight = oldReq
            trashPrompt.MaxActivationDistance = oldDist
            GlobalState.LastAction = tick()
            task.wait(0.1) 
            return true
        end
    end
    return false
end

local function fetchItem(targetName, pendingMedsList)
    local char = LocalPlayer.Character
    if not char then return false end
    
    LLog("SYS", "Mengambil (Insta-Fetch): " .. targetName)
    local totalAmount, currentItems = checkTotalInventory()
    
    if totalAmount >= Config.MaxInventory then
        local itemToThrowAway = nil
        if pendingMedsList then
            for _, item in ipairs(currentItems) do
                if item.Name ~= targetName and not table.find(pendingMedsList, item.Name) then
                    itemToThrowAway = item
                    break
                end
            end
        end
        if not itemToThrowAway then itemToThrowAway = currentItems[1] end
        local trashed = trashItem(itemToThrowAway)
        if not trashed then return false end 
    end

    local promptToUse = getPromptFromCache(targetName, false)
    if promptToUse then
        unequipAll() 
        teleportToTarget(promptToUse) 
        
        local oldReq = promptToUse.RequiresLineOfSight
        local oldDist = promptToUse.MaxActivationDistance
        local oldHold = promptToUse.HoldDuration
        
        promptToUse.RequiresLineOfSight = false
        promptToUse.MaxActivationDistance = math.huge
        promptToUse.HoldDuration = 0
        
        local gotItem = false
        for retry = 1, 15 do
            if type(fireproximityprompt) == "function" then 
                fireproximityprompt(promptToUse)
            else 
                promptToUse:InputHoldBegan() 
                task.wait(0.05) 
                promptToUse:InputHoldEnded() 
            end
            task.wait(0.1) 
            if LocalPlayer.Backpack:FindFirstChild(targetName) or LocalPlayer.Character:FindFirstChild(targetName) then
                gotItem = true
                break
            end
        end
        
        promptToUse.RequiresLineOfSight = oldReq
        promptToUse.MaxActivationDistance = oldDist
        promptToUse.HoldDuration = oldHold
        
        if gotItem then
            GlobalState.LastAction = tick()
            return true
        else
            return false 
        end
    end
    return false
end

