local function getTask()
    if AutoState.Med then
        if workspace:FindFirstChild("NPCs") then
            for _, n in ipairs(workspace.NPCs:GetChildren()) do
                local p1 = n:FindFirstChild("FirePP", true); if p1 and p1.Enabled then return "EmergencyMed", n, p1 end
                local p2 = n:FindFirstChild("FaintedPP", true) or n:FindFirstChildWhichIsA("ProximityPrompt", true)
                if p2 and (p2.Name == "FaintedPP" or (p2.ActionText and p2.ActionText:match("Carry"))) and p2.Enabled then return "FaintedMed", n, p2 end
            end
        end
        local rmF = workspace:FindFirstChild("Rooms") and workspace.Rooms:FindFirstChild("Medical")
        if rmF then
            for i=1,5 do
                if BuggedRoomBlacklist[i] and tick() - BuggedRoomBlacklist[i] > Config.BlacklistDuration then BuggedRoomBlacklist[i] = nil end
                if RoomMemory[i] then
                    local pt = getPatientInRoomMed(i, rmF:FindFirstChild("Room"..i))
                    if not pt or pt:FindFirstChild("PE", true) or (typeof(RoomMemory[i])=="Instance" and pt~=RoomMemory[i]) then RoomMemory[i] = nil end
                end
                if not BuggedRoomBlacklist[i] and not RoomMemory[i] then
                    local r = rmF:FindFirstChild("Room"..i); local sl = r and r:FindFirstChild("MainSign") and r.MainSign:FindFirstChild("Light")
                    if sl and (sl.Color == Color3.fromRGB(165,0,0) or sl.BrickColor.Name == "Crimson") then
                        local mg = r:FindFirstChild("Minigame")
                        local h = mg and mg:FindFirstChild("TV") and mg.TV:FindFirstChild("Screen") and mg.TV.Screen:FindFirstChild("UI") and mg.TV.Screen.UI:FindFirstChild("Healing")
                        if not (h and h.Visible) then return "Med", r, i end
                    end
                end
            end
        end
    end

    local emgF = workspace:FindFirstChild("Rooms") and workspace.Rooms:FindFirstChild("Emergency")
    if emgF then
        if AutoState.R6 then
            local r6 = emgF:FindFirstChild("Room6")
            local sl = r6 and r6:FindFirstChild("MainSign") and r6.MainSign:FindFirstChild("Light")
            if sl and (sl.Color == Color3.fromRGB(165,0,0) or sl.BrickColor.Name == "Crimson") then
                local h = r6:FindFirstChild("Minigame") and r6.Minigame:FindFirstChild("TV") and r6.Minigame.TV:FindFirstChild("Screen") and r6.Minigame.TV.Screen:FindFirstChild("UI") and r6.Minigame.TV.Screen.UI:FindFirstChild("Healing")
                if not (h and h.Visible) then return "R6", r6, nil end
            end
        end
        
        if AutoState.R7 and (not BuggedRoomBlacklist[7] or tick() - BuggedRoomBlacklist[7] > Config.BlacklistDuration) then
            local r7 = emgF:FindFirstChild("Room7")
            local sl = r7 and r7:FindFirstChild("MainSign") and r7.MainSign:FindFirstChild("Light")
            if sl and (sl.Color == Color3.fromRGB(165,0,0) or sl.BrickColor.Name == "Crimson") then
                local h = r7:FindFirstChild("Minigame") and r7.Minigame:FindFirstChild("TV") and r7.Minigame.TV:FindFirstChild("Screen") and r7.Minigame.TV.Screen:FindFirstChild("UI") and r7.Minigame.TV.Screen.UI:FindFirstChild("Healing")
                if not (h and h.Visible) then return "R7", r7, nil end
            end
        end
        
        if AutoState.R8 and (not BuggedRoomBlacklist[8] or tick() - BuggedRoomBlacklist[8] > Config.BlacklistDuration) then
            local r8 = emgF:FindFirstChild("Room8")
            local sl = r8 and r8:FindFirstChild("MainSign") and r8.MainSign:FindFirstChild("Light")
            if sl and (sl.Color == Color3.fromRGB(165,0,0) or sl.BrickColor.Name == "Crimson") then
                local h = r8:FindFirstChild("Minigame") and r8.Minigame:FindFirstChild("TV") and r8.Minigame.TV:FindFirstChild("Screen") and r8.Minigame.TV.Screen:FindFirstChild("UI") and r8.Minigame.TV.Screen.UI:FindFirstChild("Healing")
                if not (h and h.Visible) then return "R8", r8, nil end
            end
        end
    end
    
    return "None", nil, nil
end

