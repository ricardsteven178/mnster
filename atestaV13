local function getPendingMedicinesMed(tvUI)
    local pending = {}
    if not tvUI then return pending end
    local invFolder = tvUI:FindFirstChild("inv", true)
    if not invFolder then return pending end
    
    for _, itemReq in ipairs(invFolder:GetChildren()) do
        if table.find(ItemList, itemReq.Name) then 
            local checkMark = itemReq:FindFirstChild("check")
            if not checkMark or (checkMark and checkMark.Visible == false) then 
                table.insert(pending, itemReq.Name) 
            end
        end
    end
    return pending
end

local function getPromptsNearBedMed(roomPath, bedPart)
    local prompts = {}
    if not roomPath or not bedPart then return prompts end
    local minigame = roomPath:FindFirstChild("Minigame")
    if minigame then
        for _, desc in ipairs(minigame:GetDescendants()) do
            if desc:IsA("ProximityPrompt") and desc.Enabled then table.insert(prompts, desc) end
        end
    end
    if workspace:FindFirstChild("NPCs") then
        for _, npc in ipairs(workspace.NPCs:GetChildren()) do
            local p = npc.PrimaryPart or npc:FindFirstChildWhichIsA("BasePart")
            if p and (p.Position - bedPart.Position).Magnitude <= Config.Radius_Med then
                for _, desc in ipairs(npc:GetDescendants()) do
                    if desc:IsA("ProximityPrompt") and desc.Enabled then table.insert(prompts, desc) end
                end
            end
        end
    end
    return prompts
end

local function isPatientReadyMed(roomPath, bedPart)
    local minigame = roomPath:FindFirstChild("Minigame")
    local tvUI = minigame and minigame:FindFirstChild("TV") and minigame.TV:FindFirstChild("Screen", true)
    local pending = getPendingMedicinesMed(tvUI)
    if #pending > 0 then return true, "TV Aktif (Butuh Obat)" end
    
    local prompts = getPromptsNearBedMed(roomPath, bedPart)
    for _, desc in ipairs(prompts) do
        local actText = string.lower(desc.ActionText or "")
        local name = string.lower(desc.Name or "")
        if actText:match("dna") or name:match("dna") then return true, "Tombol DNA" 
        elseif actText:match("burns") or name == "firepp" then return true, "Tombol Luka Bakar" 
        elseif actText:match("analyze") or actText:match("process") or name:match("analyze") then return true, "Mesin Lab" end
    end
    return false, "Kosong/Healing"
end

local function isRoomDoneMed(roomNum, minigame, roomPath, bedPart, currentPatient)
    if not minigame then return false end
    if roomPath and bedPart then
        local ready, reason = isPatientReadyMed(roomPath, bedPart)
        if ready and reason == "Tombol Luka Bakar" then return false end
    end
    if currentPatient then
        if currentPatient:FindFirstChild("PE", true) then return false end
        if currentPatient:FindFirstChild("Heal", true) then return true end
    end
    local tv = minigame:FindFirstChild("TV")
    local screen = tv and tv:FindFirstChild("Screen")
    local ui = screen and screen:FindFirstChild("UI")
    if ui and ui:IsA("SurfaceGui") and ui.Enabled and ui:FindFirstChild("inv", true) then
        local invFolder = ui:FindFirstChild("inv", true)
        local totalItems = 0
        for _, itemReq in ipairs(invFolder:GetChildren()) do
            if table.find(ItemList, itemReq.Name) then totalItems = totalItems + 1 end
        end
        local pending = getPendingMedicinesMed(ui)
        if totalItems > 0 and #pending == 0 then return true end
    end
    return false
end

local function getPatientInRoomMed(roomNum, roomPath)
    local bedPart = roomPath and roomPath:FindFirstChild("Minigame") and roomPath.Minigame:FindFirstChild("Bed") and roomPath.Minigame.Bed:FindFirstChild("InBed")
    local centerPos = bedPart and bedPart.Position
    if not centerPos and Config.RoomCFrames_Med[roomNum] then centerPos = Config.RoomCFrames_Med[roomNum].Position end
    if not centerPos and roomPath and roomPath.PrimaryPart then centerPos = roomPath.PrimaryPart.Position end
    if not centerPos then return nil end

    local function checkNPC(obj)
        if Players:GetPlayerFromCharacter(obj) then return nil end
        local part = obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")
        if part and (part.Position - centerPos).Magnitude <= Config.Radius_Med then
            local isRealPatient = false
            for _, pp in ipairs(obj:GetDescendants()) do
                if pp:IsA("ProximityPrompt") then
                    local txt = string.lower(pp.ActionText or "")
                    if txt:match("dna") or txt:match("treat") or pp.Name == "FirePP" then
                        isRealPatient = true
                        break
                    end
                end
            end
            if isRealPatient then return obj end
        end
        return nil
    end

    if workspace:FindFirstChild("NPCs") then
        for _, npc in ipairs(workspace.NPCs:GetChildren()) do
            local found = checkNPC(npc)
            if found then return found end
        end
    end
    return nil
end

local function executeMedicalTreatment(roomPath, roomNum)
    local minigame = roomPath:FindFirstChild("Minigame")
    if not minigame then return end
    local bed = minigame:FindFirstChild("Bed") and minigame.Bed:FindFirstChild("InBed")
    LLog("Med", "--- MEMULAI PENGOBATAN R" .. roomNum .. " ---")
    teleportToTarget(Config.RoomCFrames_Med[roomNum]) 

    local lastProgressTime = tick()

    while GlobalState.IsBusy do
        task.wait(0.1) 

        local currentPatient = getPatientInRoomMed(roomNum, roomPath)
        if not currentPatient then
            local signLight = roomPath:FindFirstChild("MainSign") and roomPath.MainSign:FindFirstChild("Light")
            local isLightRed = signLight and (signLight.BrickColor.Name == "Crimson" or signLight.Color == Color3.fromRGB(165, 0, 0))
            if isLightRed then
                LLog("Med", "Pasien sedang berjalan ke kasur... Menunggu.")
                task.wait(1)
            else
                LLog("Med", "Kamar kosong / Ghost Prompt! Skip.")
                BuggedRoomBlacklist[roomNum] = tick() 
                break
            end
        end

        if isRoomDoneMed(roomNum, minigame, roomPath, bed, currentPatient) then
            LLog("Med", "Pengobatan Selesai! Meninggalkan pasien...")
            local patientToLog = currentPatient or "JobDone"
            RoomMemory[roomNum] = patientToLog
            break
        end

        if tick() - lastProgressTime >= Config.StuckTimeout then
            LLog("Med", "Timeout! Skip ruangan.")
            BuggedRoomBlacklist[roomNum] = tick()
            break
        end

        local tvUI = minigame:FindFirstChild("TV") and minigame.TV:FindFirstChild("Screen", true)
        local hasTasks, reason = isPatientReadyMed(roomPath, bed)

        if hasTasks then
