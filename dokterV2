    if isBusy then setStatus("Sedang sibuk!") return end
    task.spawn(function()
        local room = findActiveRoom()
        if room then 
            safeTreatPatient(room) 
            teleportToIdle()
            setStatus("Manual Selesai (Standby).")
        else 
            teleportToIdle()
            setStatus("Tidak ada pasien (Standby).") 
        end
    end)
end)

ToggleAutoBtn.MouseButton1Click:Connect(function()
    autoScanEnabled = not autoScanEnabled
    if autoScanEnabled then
        ToggleAutoBtn.Text = "Auto-Scan: ON"
        ToggleAutoBtn.BackgroundColor3 = Color3.fromRGB(70, 200, 70)
        setStatus("Auto-Scan menyala. Memantau...")
        _G.AutoDoctor_Loop = task.spawn(function()
            while autoScanEnabled do
                if not isBusy then
                    local room = findActiveRoom()
                    if room then 
                        safeTreatPatient(room) 
                    else
                        teleportToIdle()
                        setStatus("Idle (Standby di Base)...")
                        task.wait(Config.ScanDelay)
                    end
                else
                    task.wait(0.5)
                end
            end
        end)
    else
        ToggleAutoBtn.Text = "Auto-Scan: OFF"
        ToggleAutoBtn.BackgroundColor3 = Color3.fromRGB(70, 70, 70)
        if _G.AutoDoctor_Loop then task.cancel(_G.AutoDoctor_Loop) end
        if not isBusy then setStatus("Dimatikan.") end
    end
end)
