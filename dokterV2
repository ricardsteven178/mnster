local function checkTotalInventory()
    local targetCount = 0
    local targetItems = {} 
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    local character = LocalPlayer.Character
    
    local function processTool(item)
        if item:IsA("Tool") and table.find(ItemList, item.Name) then
            targetCount = targetCount + 1
            table.insert(targetItems, item)
        end
    end

    if backpack then for _, item in ipairs(backpack:GetChildren()) do processTool(item) end end
    if character then for _, item in ipairs(character:GetChildren()) do processTool(item) end end
    return targetCount, targetItems
end

local function trashItem(toolToTrash)
    local character = LocalPlayer.Character
    local rootPart = character and character:FindFirstChild("HumanoidRootPart")
    local humanoid = character and character:FindFirstChild("Humanoid")
    local trashBin = workspace:FindFirstChild("Trash")
    
    if not rootPart or not humanoid or not toolToTrash then return false end
    
    if trashBin then
        local prompt = trashBin:FindFirstChild("PP") or trashBin:FindFirstChildWhichIsA("ProximityPrompt", true)
        if prompt and prompt:IsA("ProximityPrompt") then
            setStatus("Kapasitas penuh! Membuang: " .. toolToTrash.Name)
            humanoid:EquipTool(toolToTrash)
            task.wait(0.2)
            
            if trashBin:IsA("Model") and trashBin.PrimaryPart then
                rootPart.CFrame = trashBin.PrimaryPart.CFrame * CFrame.new(0, 3, 0)
            elseif trashBin:IsA("BasePart") then
                rootPart.CFrame = trashBin.CFrame * CFrame.new(0, 3, 0)
            elseif trashBin:FindFirstChildWhichIsA("BasePart") then
                rootPart.CFrame = trashBin:FindFirstChildWhichIsA("BasePart").CFrame * CFrame.new(0, 3, 0)
            end
            
            rootPart.Velocity = Vector3.new(0, 0, 0)
            task.wait(Config.WaitTime)
            
            prompt.RequiresLineOfSight = false
            prompt.MaxActivationDistance = math.huge
            prompt.HoldDuration = 0
            if type(fireproximityprompt) == "function" then fireproximityprompt(prompt, 1, true)
            else prompt:InputHoldBegan() task.wait(0.1) prompt:InputHoldEnded() end
            
            task.wait(Config.WaitTime)
            return true
        end
    end
    return false
end

local function fetchItem(targetName)
    local char = LocalPlayer.Character
    local rootPart = char and char:FindFirstChild("HumanoidRootPart")
    if not rootPart then return false end

    setStatus("Mengambil: " .. targetName)

    local totalAmount, currentItems = checkTotalInventory()
    if totalAmount >= Config.MaxInventory and #currentItems > 0 then
        local itemToThrowAway = currentItems[1]
        local trashed = trashItem(itemToThrowAway)
        if not trashed then return false end 
    end

    local found = false
    for _, item in ipairs(workspace:GetDescendants()) do
        if item.Name == targetName then
            local prompt = item:FindFirstChild("PP") or item:FindFirstChildWhichIsA("ProximityPrompt")
            local itemPart = item:IsA("BasePart") and item or item:FindFirstChildWhichIsA("BasePart")
            
            if prompt and prompt:IsA("ProximityPrompt") and itemPart then
                found = true
                rootPart.CFrame = itemPart.CFrame * CFrame.new(0, 3, 0)
                rootPart.Velocity = Vector3.new(0, 0, 0)
                task.wait(Config.WaitTime)
                
                prompt.RequiresLineOfSight = false
                prompt.MaxActivationDistance = math.huge
                prompt.HoldDuration = 0
                if type(fireproximityprompt) == "function" then fireproximityprompt(prompt, 1, true)
                else prompt:InputHoldBegan() task.wait(0.1) prompt:InputHoldEnded() end
                
                task.wait(Config.WaitTime)
                setStatus("BERHASIL DIAMBIL: " .. targetName)
                break 
            end
        end
    end

    if found then task.wait(0.5) return true else setStatus("GAGAL: " .. targetName .. " tidak ditemukan.") return false end
end

-- ==========================================
-- MEDICAL & ROOM LOGIC
-- ==========================================
local function simpleInteract(prompt, customHold)
    if prompt and prompt:IsA("ProximityPrompt") then
        local oldReq = prompt.RequiresLineOfSight
        local oldDist = prompt.MaxActivationDistance
        
        prompt.RequiresLineOfSight = false
        prompt.MaxActivationDistance = math.huge
        
        if type(fireproximityprompt) == "function" then
            fireproximityprompt(prompt, 1, true)
        else
            prompt:InputHoldBegan()
            task.wait(customHold or prompt.HoldDuration or 0.25)
            prompt:InputHoldEnded()
        end
        
        prompt.RequiresLineOfSight = oldReq
        prompt.MaxActivationDistance = oldDist
        task.wait(Config.WaitTime)
    end
    return true
end

-- [ FIX V25 ]: SMART ROOM FILTER
local function findActiveRoom()
    local roomsFolder = workspace:FindFirstChild("Rooms")
    local medicalFolder = roomsFolder and roomsFolder:FindFirstChild("Medical")
    if not medicalFolder then return nil end

    for i = 1, Config.MaxRooms do
        local roomName = "Room" .. i
        local room = medicalFolder:FindFirstChild(roomName)
        if room then
            local signLight = room:FindFirstChild("MainSign") and room.MainSign:FindFirstChild("Light")
            if signLight and signLight:IsA("BasePart") then
                if signLight.BrickColor.Name == "Crimson" or signLight.Color == Color3.fromRGB(165, 0, 0) then
                    -- CEK APAKAH RUANGAN INI SEDANG DALAM PROSES RECOVERY (HEALING)?
                    local minigame = room:FindFirstChild("Minigame")
                    if not isHealingDone(minigame) then
                        -- Jika TIDAK sedang healing, berarti ini ruangan yang valid!
                        return room
                    end
                end
            end
        end
    end
    return nil -- Kembali ke idle jika semua ruangan hitam ATAU sedang proses healing
end

local function handleFaintedPatientsIfAny()
    local faintedNPC, carryPP = nil, nil
    
    for _, npc in ipairs(workspace.NPCs:GetChildren()) do
        local pp = npc:FindFirstChild("FaintedPP", true)
        if pp and pp.ActionText:match("Carry") then
            faintedNPC = npc
            carryPP = pp
            break
        end
    end

    if faintedNPC and carryPP then
        setStatus("PASIEN PINGSAN DITEMUKAN!")
        local part = faintedNPC.PrimaryPart or faintedNPC:FindFirstChildWhichIsA("BasePart")
        local char = LocalPlayer.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        
        if root and part then
            setStatus("Menggendong pasien...")
            root.Anchored = true
            root.CFrame = CFrame.new(part.Position + Vector3.new(0, 3, 0))
            root.Velocity = Vector3.zero
            task.wait(Config.WaitTime)
            root.Anchored = false
            
            simpleInteract(carryPP, 0) 
            task.wait(1.5) 
            
            local targetRoom = findActiveRoom()
            if targetRoom then
                local roomNum = tonumber(targetRoom.Name:match("%d+"))
                setStatus("Membawa ke " .. targetRoom.Name .. "...")
                teleportToSafeRoom(roomNum)
                
                local placePP = nil
                for _, desc in ipairs(targetRoom:GetDescendants()) do
                    if desc:IsA("ProximityPrompt") and (desc.Name == "FaintedPP" or desc.ActionText:match("Place")) then
                        placePP = desc
                        break
                    end
                end
                
                if placePP then
                    setStatus("Meletakkan di kasur...")
                    simpleInteract(placePP, 1) 
                    task.wait(2)
                else
                    setStatus("Gagal mendeteksi prompt kasur.")
                end
            else
                setStatus("Ruangan penuh, abaikan pasien.")
            end
        end
    end
end

local function executeTreatmentCore(roomPath)
    local minigame = roomPath:FindFirstChild("Minigame")
    if not minigame then return end
    
    local roomNum = tonumber(roomPath.Name:match("%d+"))

    if isHealingDone(minigame) then
        return
    end

    local tvUI = minigame:FindFirstChild("TV") and minigame.TV:FindFirstChild("Screen", true)
    
    setStatus("--- MEMULAI PENGOBATAN: " .. roomPath.Name .. " ---")
    local bed = minigame:FindFirstChild("Bed") and minigame.Bed:FindFirstChild("InBed")
    local bedPart = bed and (bed:IsA("BasePart") and bed or bed:FindFirstChildWhichIsA("BasePart"))
    local patientIsAnomaly = false

    setStatus("1/5 Menunggu pasien rebahan...")
    teleportToSafeRoom(roomNum) 
    
    local targetNPC = nil
    local waitLimit = 0
    
    while not targetNPC and waitLimit < 30 do
        for _, npc in ipairs(workspace.NPCs:GetChildren()) do
            local part = npc.PrimaryPart or npc:FindFirstChildWhichIsA("BasePart")
            if part and bedPart and (part.Position - bedPart.Position).Magnitude < 40 then
                targetNPC = npc
                break
            end
        end
        if not targetNPC then
            task.wait(0.5)
            waitLimit = waitLimit + 1
        end
    end

    if not targetNPC then
        setStatus("BATAL: Pasien tidak muncul.")
        return
    end

    if isAnomaly(targetNPC) then
        patientIsAnomaly = true
        setStatus("!! PASIEN INI ANOMALI/MONSTER !!")
    end

    local dnaPP = targetNPC:FindFirstChild("PP")
    if dnaPP and dnaPP:IsA("ProximityPrompt") and dnaPP.ActionText:match("DNA") then
        setStatus("Mengambil DNA...")
        simpleInteract(dnaPP, 0.25)
    else
        setStatus("DNA sudah diambil (Lanjut)...")
    end

    if isHealingDone(minigame) then return end

    setStatus("2/5 Cek Mesin Analyzer...")
    local analyzer = minigame:FindFirstChild("Analyzer")
    if analyzer and analyzer:FindFirstChild("PP") then
        simpleInteract(analyzer.PP, 0.5)
    end

    if isHealingDone(minigame) then return end

    setStatus("3/5 Cek Monitor...")
    local monitor = minigame:FindFirstChild("Monitor")
    if monitor and monitor:FindFirstChild("PP2") then
        simpleInteract(monitor.PP2, 0.25)
    end

    if isHealingDone(minigame) then return end

    setStatus("4/5 Membaca Kebutuhan dari TV...")
    if tvUI and tvUI:FindFirstChild("inv", true) then
        local invFolder = tvUI:FindFirstChild("inv", true)
        local waitLimitTV = 0
        while #invFolder:GetChildren() <= 1 and waitLimitTV < 15 do
            task.wait(0.5)
            waitLimitTV = waitLimitTV + 1
        end
    end

    if isHealingDone(minigame) then return end

    -- 5. Eksekusi Treatment 
    if patientIsAnomaly then
        setStatus("5/5 [ALGOJO] Mencari RACUN...")
        local initialMeds = getPendingMedicines(tvUI)
        local wrongMedicine = "Medicine"
        
        for _, item in ipairs(ItemList) do
            if not table.find(initialMeds, item) then wrongMedicine = item break end
        end
        
        local hasIt = LocalPlayer.Backpack:FindFirstChild(wrongMedicine) or LocalPlayer.Character:FindFirstChild(wrongMedicine)
        if not hasIt then fetchItem(wrongMedicine) end
        
        if bed and bed:FindFirstChild("PP") then
            teleportToSafeRoom(roomNum) 
            local tool = LocalPlayer.Backpack:FindFirstChild(wrongMedicine) or LocalPlayer.Character:FindFirstChild(wrongMedicine)
            if tool then LocalPlayer.Character.Humanoid:EquipTool(tool) end
            task.wait(0.2)
            
            setStatus("MENYUNTIKKAN OBAT SALAH: " .. wrongMedicine)
            simpleInteract(bed.PP, 0.25)
            setStatus("--- ANOMALI HANGUS! ---")
        end
    else
        setStatus("5/5 Memulai pengobatan pantang mundur...")
        
        local lastProgressTime = tick()
        local lastPendingCount = -1

        while true do
            local signLight = roomPath:FindFirstChild("MainSign") and roomPath.MainSign:FindFirstChild("Light")
            if not signLight or (signLight.BrickColor.Name ~= "Crimson" and signLight.Color ~= Color3.fromRGB(165, 0, 0)) then
                setStatus("FAILSAFE: Lampu ruangan mati. Proses dibatalkan.")
                break
            end
            
            if not targetNPC or not targetNPC.Parent or not targetNPC.PrimaryPart or (targetNPC.PrimaryPart.Position - bedPart.Position).Magnitude > 40 then
                setStatus("FAILSAFE: Pasien hilang dari kasur. Proses dibatalkan.")
                break
            end

            if isHealingDone(minigame) then
                setStatus("Layar Healing menyala! Pengobatan selesai.")
                break
            end

            local pendingMeds = getPendingMedicines(tvUI)
            
            if #pendingMeds ~= lastPendingCount then
                lastPendingCount = #pendingMeds
                lastProgressTime = tick() 
            end

            if tick() - lastProgressTime >= Config.StuckTimeout then
                setStatus("AUTO-RESET: Sistem stuck tanpa progress selama " .. Config.StuckTimeout .. " detik. Mengulang siklus...")
                break
            end

            if #pendingMeds == 0 then
                setStatus("Semua obat tercentang. Menunggu layar Healing...")
                task.wait(1)
                continue
            end

            local medsReadyToGive = {}
            setStatus("Tersisa " .. #pendingMeds .. " obat belum tercentang.")
            
            for _, obat in ipairs(pendingMeds) do
                local totalInv, _ = checkTotalInventory()
                local hasIt = LocalPlayer.Backpack:FindFirstChild(obat) or LocalPlayer.Character:FindFirstChild(obat)
                
                if hasIt then
                    table.insert(medsReadyToGive, obat)
                elseif totalInv < Config.MaxInventory then
                    local fetched = fetchItem(obat)
                    if fetched then table.insert(medsReadyToGive, obat) end
                end
            end

            if #medsReadyToGive > 0 then
                if bed and bed:FindFirstChild("PP") then
                    teleportToSafeRoom(roomNum) 
                    
                    setStatus("Menyuntikkan " .. #medsReadyToGive .. " obat...")
                    for _, obat in ipairs(medsReadyToGive) do
                        local tool = LocalPlayer.Backpack:FindFirstChild(obat) or LocalPlayer.Character:FindFirstChild(obat)
                        if tool then LocalPlayer.Character.Humanoid:EquipTool(tool) end
                        task.wait(0.2)
                        
                        setStatus("Menyuntikkan: " .. obat)
                        simpleInteract(bed.PP, 0.25)
                    end
                    task.wait(1.5)
                else
                    setStatus("Kasur tidak merespon. Mencoba ulang...")
                    task.wait(2)
                end
            else
                setStatus("Menunggu / mencari ulang obat...")
                task.wait(2)
            end
        end
        setStatus("--- PROSES RUANGAN BERAKHIR ---")
    end
    task.wait(1)
end

-- ==========================================
-- SAFE WRAPPER
-- ==========================================
local function safeTreatPatient(roomPath)
    if isBusy then return end
    isBusy = true
    
    local success, err = pcall(function()
        handleFaintedPatientsIfAny() 
        executeTreatmentCore(roomPath)
    end)
    
    if not success then
        setStatus("System Error: " .. tostring(err))
    end
    
    isBusy = false
end

