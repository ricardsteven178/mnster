-- ==========================================
-- EMERGENCY R6 TREATMENT
-- Ported from Room6 standalone reference (Flawless Reset):
-- - Teleport ke Room6CFrame (bukan bed)
-- - Patient detection pakai Room6PatientStandCFrame radius
-- - Bypass: cari "process" di Monitor, force Enabled=true, loop trigger
-- - Collect: scan seluruh minigame descendants cari ActionText "Collect"
-- - Enforce Room6 position setelah setiap operasi
-- ==========================================
local function executeRoom6Treatment(roomPath, activeShift)
    local roomKey = "E6"
    local minigame = roomPath:FindFirstChild("Minigame")
    if not minigame then return end

    setStatus("--- EMERGENCY R6: X-RAY BYPASS ---")
    setRoomLabel("Emergency Room 6 (X-Ray)")

    local root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")

    -- Enforce posisi R6 (dari referensi)
    local function enforceRoom6Position()
        local r = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if r then
            local dist = (r.Position - Config.Room6CFrame.Position).Magnitude
            if dist > 5 then
                r.CFrame = Config.Room6CFrame
                r.AssemblyLinearVelocity = Vector3.zero
                task.wait(0.2)
            end
        end
    end

    -- Teleport ke room6 dulu
    if root then
        root.CFrame = Config.Room6CFrame
        root.AssemblyLinearVelocity = Vector3.zero
        task.wait(0.2)
    end

    -- Tunggu pasien datang — pakai PatientStandCFrame radius (dari referensi)
    setStatus("R6: Menunggu pasien di area stand...")
    local waitNPC = 0
    local patientFound = false
    while waitNPC < 40 do
        if getShiftText() ~= activeShift then return end
        enforceRoom6Position()
        if isAnyNPCNearPosition(Config.Room6PatientStandCFrame.Position, Config.Room6PatientRadius) then
            patientFound = true
            markPatientEntered(roomKey)
            forceResetHealingVisible(minigame)
            setStatus("R6: Pasien terdeteksi! Mulai bypass...")
            break
        end
        task.wait(0.5); waitNPC = waitNPC + 1; _G.AutoDoctor_LastActionTick = tick()
    end

    if not patientFound then
        setStatus("R6: Pasien tidak datang, skip.")
        return
    end

    task.wait(0.3)
    unequipAll()

    -- Helper: cari "process" di Monitor (dari referensi — scan ActionText lower)
    local monitor = minigame:FindFirstChild("Monitor")
    local function findMonitorProcessPrompt()
        if not monitor then return nil end
        for _, desc in ipairs(monitor:GetDescendants()) do
            if desc:IsA("ProximityPrompt") then
                if string.lower(desc.ActionText or ""):match("process") then return desc end
            end
        end
        return nil
    end

    -- Helper: cari "Collect" di seluruh minigame (dari referensi — bukan hanya Printer)
    local function findCollectPrompt()
        for _, desc in ipairs(minigame:GetDescendants()) do
            if desc:IsA("ProximityPrompt") and desc.Enabled then
                if (desc.ActionText or ""):match("Collect") then return desc end
            end
        end
        return nil
    end

    -- BYPASS PHASE: Loop trigger "process" sampai Collect muncul (dari referensi)
    local bypassAttempts = 0
    local bypassDone = false
    while not bypassDone and bypassAttempts < 12 do
        if getShiftText() ~= activeShift then return end
        bypassAttempts = bypassAttempts + 1
        enforceRoom6Position()

        -- Cek Collect sudah muncul
        if findCollectPrompt() then bypassDone = true; break end

        -- Cek TV resep sudah muncul
        local tvCheck = minigame:FindFirstChild("TV") and minigame.TV:FindFirstChild("Screen", true)
        local meds = getPendingMedicines(tvCheck)
        if meds and #meds > 0 then bypassDone = true; break end

        -- Force trigger "process" (force Enabled=true seperti referensi)
        local processPP = findMonitorProcessPrompt()
        if processPP then
            setStatus("R6: BYPASS Process (force) #" .. bypassAttempts .. "...")
            local oldEnabled = processPP.Enabled
            processPP.Enabled = true
            firePromptRaw(processPP)
            processPP.Enabled = oldEnabled
        else
            setStatus("R6: Mencari Monitor process... (" .. bypassAttempts .. ")")
        end
        task.wait(1.5)
        _G.AutoDoctor_LastActionTick = tick()
    end

    -- COLLECT PHASE: Scan seluruh minigame cari "Collect" (dari referensi)
    local collectPP = findCollectPrompt()
    if not collectPP then
        -- Tunggu Collect muncul setelah bypass
        setStatus("R6: Menunggu Collect...")
        local waitC = 0
        while not collectPP and waitC < 20 do
            if getShiftText() ~= activeShift then return end
            task.wait(0.3); waitC = waitC + 1; _G.AutoDoctor_LastActionTick = tick()
            collectPP = findCollectPrompt()
        end
    end

    if collectPP then
        setStatus("R6: Trigger Collect!")
        enforceRoom6Position()
        firePromptRaw(collectPP)
        task.wait(0.8)
        -- Double fire kalau masih enabled
        collectPP = findCollectPrompt()
        if collectPP then firePromptRaw(collectPP); task.wait(0.5) end
    end

    -- Tunggu TV resep
    setStatus("R6: Menunggu TV resep...")
    local tvUI = minigame:FindFirstChild("TV") and minigame.TV:FindFirstChild("Screen", true)
    local waitTV = 0
    while waitTV < 20 do
        if getShiftText() ~= activeShift then return end
        tvUI = minigame:FindFirstChild("TV") and minigame.TV:FindFirstChild("Screen", true)
        local meds = getPendingMedicines(tvUI)
        if meds and #meds > 0 then setStatus("R6: Resep muncul (" .. #meds .. " obat)!"); break end
        enforceRoom6Position()
        task.wait(0.5); waitTV = waitTV + 1; _G.AutoDoctor_LastActionTick = tick()
    end

    -- Treatment loop: cari patientPP dari NPC di area stand, inject
    local lastProgressTimeRef = {tick()}
    local stuckTimer = tick()

    while true do
        task.wait(0.1)
        if getShiftText() ~= activeShift then setStatus("R6: Shift berganti."); break end
        if getFireEmergency() then setStatus("R6: INTERUPSI pasien terbakar!"); break end
        if tick() - stuckTimer >= Config.StuckTimeout then
            setStatus("R6: Timeout! Skip.")
            clearGracePeriod(roomKey)
            break
        end

        if isHealingDone(minigame, roomPath, nil, 6, roomKey) then
            -- For R6, also check NPC still at stand (no bed = use stand position)
            local npcGone = not isAnyNPCNearPosition(Config.Room6PatientStandCFrame.Position, Config.Room6PatientRadius)
            if npcGone then
                setStatus("R6: Pasien pergi.")
                clearGracePeriod(roomKey); break
            end
            setStatus("R6: Pasien sembuh!")
            _G.AutoDoctor_RoomMemory[6] = "PatientLeaving"
            clearGracePeriod(roomKey); break
        end

        -- Cek pasien masih ada (pakai stand CFrame karena tidak ada bed)
        if not isAnyNPCNearPosition(Config.Room6PatientStandCFrame.Position, Config.Room6PatientRadius) then
            setStatus("R6: Pasien pergi.")
            clearGracePeriod(roomKey); break
        end

        tvUI = minigame:FindFirstChild("TV") and minigame.TV:FindFirstChild("Screen", true)
        local pendingMeds = getPendingMedicines(tvUI)

        if #pendingMeds > 0 then
            -- Cari patient PP dari NPC di area (dari referensi getPatientData)
            local patientPP = nil
            if workspace:FindFirstChild("NPCs") then
                for _, npc in ipairs(workspace.NPCs:GetChildren()) do
                    local pt = npc.PrimaryPart or npc:FindFirstChildWhichIsA("BasePart")
                    if pt and (pt.Position - Config.Room6PatientStandCFrame.Position).Magnitude < Config.Room6PatientRadius then
                        for _, desc in ipairs(npc:GetDescendants()) do
                            if desc:IsA("ProximityPrompt") and desc.Enabled then
                                local act = string.lower(desc.ActionText or "")
                                if act:match("treat") or act:match("inject") or act:match("dna") or desc.Name == "PP" then
                                    patientPP = desc; break
                                end
                            end
                        end
                        if not patientPP then
                            patientPP = npc:FindFirstChildWhichIsA("ProximityPrompt", true)
                        end
                    end
                    if patientPP then break end
                end
            end

            if not patientPP then
                setStatus("R6: Menunggu PP pasien muncul..."); task.wait(0.5)
            else
                -- Check anomaly
                local isAnomaly = false
                if workspace:FindFirstChild("NPCs") then
                    for _, npc in ipairs(workspace.NPCs:GetChildren()) do
                        local pt = npc.PrimaryPart or npc:FindFirstChildWhichIsA("BasePart")
                        if pt and (pt.Position - Config.Room6PatientStandCFrame.Position).Magnitude < Config.Room6PatientRadius then
                            local attr = npc:GetAttributes()
                            if attr.Skinwalker or attr.SkinwalkerEasy or attr.PenaltyWhenLettingIn
                                or attr.PhotoEffect == "CursedPhoto" or attr.PhotoEffect2 == "CursedPhoto" then
                                isAnomaly = true; break
                            end
                        end
                    end
                end

                if isAnomaly then
                    local wrongMedicine = "Medicine"
                    for _, item in ipairs(ItemList) do
                        if not table.find(pendingMeds, item) then wrongMedicine = item; break end
                    end
                    local hasIt = LocalPlayer.Backpack:FindFirstChild(wrongMedicine) or LocalPlayer.Character:FindFirstChild(wrongMedicine)
                    if not hasIt then fetchItem(wrongMedicine, {wrongMedicine}); enforceRoom6Position() end
                    if turboSafeEquip(wrongMedicine) then
                        setStatus("R6: MENYUNTIKKAN RACUN: " .. wrongMedicine)
                        firePromptRaw(patientPP)
                        lastProgressTimeRef[1] = tick(); task.wait(2)
                        setStatus("R6: ANOMALI HANGUS!")
                        clearGracePeriod(roomKey); break
                    end
                else
                    -- R6 has NO BED — inject goes to patientPP (NPC's proximity prompt)
                    -- Cannot use runInjectPhase (requires bed.PP)
                    -- Fetch all meds first
                    local reqCounts = {}
                    for _, obat in ipairs(pendingMeds) do reqCounts[obat] = (reqCounts[obat] or 0) + 1 end
                    local _, currentItems = checkTotalInventory()
                    local haveCounts = {}
                    for _, item in ipairs(currentItems) do haveCounts[item.Name] = (haveCounts[item.Name] or 0) + 1 end
                    for obat, needed in pairs(reqCounts) do
                        local have = haveCounts[obat] or 0
                        for _ = 1, math.max(0, needed - have) do
                            fetchItem(obat, pendingMeds)
                        end
                    end
                    enforceRoom6Position()

                    -- Inject one at a time using patientPP, with count-sync wait
                    local freshPending = getPendingMedicines(tvUI)
                    if #freshPending > 0 then
                        local obat = freshPending[1]
                        local hasIt = LocalPlayer.Backpack:FindFirstChild(obat) or LocalPlayer.Character:FindFirstChild(obat)
                        if hasIt and turboSafeEquip(obat) then
                            local activeTool = LocalPlayer.Character:FindFirstChildOfClass("Tool")
                            if activeTool and activeTool.Name == obat then
                                local prevCount = #freshPending
                                setStatus("R6: Suntik " .. obat .. " (" .. prevCount .. " sisa)")
                                firePromptRaw(patientPP)
                                lastProgressTimeRef[1] = tick()
                                stuckTimer = tick()
                                -- Count-sync wait
                                local sw = 0
                                while sw < 30 do
                                    task.wait(0.05)
                                    local np = getPendingMedicines(tvUI)
                                    if #np < prevCount then
                                        setStatus("R6: TV konfirmasi " .. obat .. " OK!")
                                        lastProgressTimeRef[1] = tick()
                                        break
                                    end
                                    if getShiftText() ~= activeShift then break end
                                    sw = sw + 1; _G.AutoDoctor_LastActionTick = tick()
                                end
                            end
                        elseif not hasIt then
                            setStatus("R6: Fetch ulang " .. obat); task.wait(0.3)
                        end
                    end
                end
            end
        else
            task.wait(0.5)
        end
    end
end

-- ==========================================
-- EMERGENCY R7 TREATMENT
-- Ported from Room7 standalone reference (Ultimate Edition):
-- - Teleport ke Room7Step2 (posisi dalam ruangan)
-- - Patient detection: proximity + humanoid (tidak butuh prompt)
-- - Bypass: cek "prepare/set up/turn on/begin" → force enable processPrompt → fire
-- - Collect: jika muncul natural, eksekusi langsung (tidak di-bypass)
-- - Burns dan DNA handling tetap prioritas
-- ==========================================
local function executeRoom7Treatment(roomPath, activeShift)
    local roomKey = "E7"
    local minigame = roomPath:FindFirstChild("Minigame")
    if not minigame then return end

    local bed = minigame:FindFirstChild("Bed") and minigame.Bed:FindFirstChild("InBed")

    setStatus("--- EMERGENCY R7: PREPARE BYPASS ---")
    setRoomLabel("Emergency Room 7 (Prepare)")

    local root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")

    -- Patient finder (dari referensi — proximity + humanoid, tidak butuh prompt)
    local function findPatientR7()
        if not bed then return nil end
        local pos = bed.Position
        local function checkObj(obj)
            if not obj:IsA("Model") or obj == LocalPlayer.Character then return nil end
            local part = obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")
            if part and (part.Position - pos).Magnitude <= Config.Room7PatientRadius then
                if obj:FindFirstChildOfClass("Humanoid") or obj:FindFirstChildWhichIsA("ProximityPrompt", true) then
                    return obj
                end
            end
            return nil
        end
        if workspace:FindFirstChild("NPCs") then
            for _, npc in ipairs(workspace.NPCs:GetChildren()) do
                local found = checkObj(npc); if found then return found end
            end
        end
        for _, obj in ipairs(workspace:GetChildren()) do
            local found = checkObj(obj); if found then return found end
        end
        return nil
    end

    -- Teleport ke Step2 (posisi dalam ruangan, dari referensi)
    if root then
        root.CFrame = Config.Room7Step2
        root.AssemblyLinearVelocity = Vector3.zero
        task.wait(0.3)
    end

    -- Tunggu pasien datang (proximity + humanoid check, bukan prompt)
    setStatus("R7: Menunggu pasien...")
    local waitNPC = 0
    local patientFound = false
    while waitNPC < 40 do
        if getShiftText() ~= activeShift then return end
        if findPatientR7() then
            patientFound = true
            markPatientEntered(roomKey)
            forceResetHealingVisible(minigame)
            setStatus("R7: Pasien terdeteksi! Mulai bypass...")
            break
        end
        task.wait(0.5); waitNPC = waitNPC + 1; _G.AutoDoctor_LastActionTick = tick()
    end

    if not patientFound then
        setStatus("R7: Pasien tidak datang, skip.")
        return
    end

    task.wait(0.3)
    unequipAll()

    -- Helpers dari referensi
    local function findProcessPrompt()
        for _, desc in ipairs(minigame:GetDescendants()) do
            if desc:IsA("ProximityPrompt") then
                if string.lower(desc.ActionText or ""):match("process") then return desc end
            end
        end
        return nil
    end

    local function findCollectPrompt()
        for _, desc in ipairs(minigame:GetDescendants()) do
            if desc:IsA("ProximityPrompt") and desc.Enabled then
                if string.lower(desc.ActionText or ""):match("collect") then return desc end
            end
        end
        return nil
    end

    local function hasEarlyStepPrompt()
        for _, desc in ipairs(minigame:GetDescendants()) do
            if desc:IsA("ProximityPrompt") and desc.Enabled then
                local txt = string.lower(desc.ActionText or "")
                if txt:match("prepare") or txt:match("set up") or txt:match("turn on") or txt:match("begin") then
                    return true
                end
            end
        end
        return false
    end

    -- BYPASS PHASE (dari referensi R7 strict bypass)
    local bypassAttempts = 0
    local bypassDone = false
    while not bypassDone and bypassAttempts < 10 do
        if getShiftText() ~= activeShift then return end
        bypassAttempts = bypassAttempts + 1

        -- Collect sudah muncul natural?
        if findCollectPrompt() then bypassDone = true; break end

        -- TV resep sudah muncul?
        local tvCheck = minigame:FindFirstChild("TV") and minigame.TV:FindFirstChild("Screen", true)
        local meds = getPendingMedicines(tvCheck)
        if meds and #meds > 0 then bypassDone = true; break end

        local processPP = findProcessPrompt()

        if hasEarlyStepPrompt() and processPP then
            -- Force enable processPrompt dan fire (dari referensi R7 strict bypass)
            setStatus("R7: BYPASS — Force trigger Process (skip Prepare) #" .. bypassAttempts)
            local oldEnabled = processPP.Enabled
            processPP.Enabled = true
            if root then root.CFrame = Config.Room7Step2; root.AssemblyLinearVelocity = Vector3.zero end
            firePromptRaw(processPP)
            processPP.Enabled = oldEnabled
            task.wait(1)
        elseif processPP and processPP.Enabled then
            -- Process aktif natural — eksekusi langsung
            setStatus("R7: Process aktif natural, trigger...")
            if root then root.CFrame = Config.Room7Step2; root.AssemblyLinearVelocity = Vector3.zero end
            firePromptRaw(processPP)
            task.wait(1)
        else
            setStatus("R7: Menunggu Monitor siap... (" .. bypassAttempts .. ")")
            task.wait(0.8)
        end
        _G.AutoDoctor_LastActionTick = tick()
    end

    -- COLLECT PHASE (natural — dari referensi: "eksekusi normal collect jika sudah muncul")
    local collectPP = findCollectPrompt()
    if collectPP then
        setStatus("R7: Trigger Collect!")
        if root then root.CFrame = Config.Room7Step2; root.AssemblyLinearVelocity = Vector3.zero; task.wait(0.1) end
        firePromptRaw(collectPP)
        task.wait(0.8)
        collectPP = findCollectPrompt()
        if collectPP then firePromptRaw(collectPP); task.wait(0.5) end
    else
        -- Tunggu collect
        setStatus("R7: Menunggu Collect...")
        local waitC = 0
        while waitC < 15 do
            if getShiftText() ~= activeShift then return end
            task.wait(0.3); waitC = waitC + 1; _G.AutoDoctor_LastActionTick = tick()
            collectPP = findCollectPrompt()
            if collectPP then
                if root then root.CFrame = Config.Room7Step2; root.AssemblyLinearVelocity = Vector3.zero; task.wait(0.1) end
                firePromptRaw(collectPP); task.wait(0.5); break
            end
        end
    end

    -- Tunggu TV resep
    setStatus("R7: Menunggu TV resep...")
    local tvUI = minigame:FindFirstChild("TV") and minigame.TV:FindFirstChild("Screen", true)
    local waitTV = 0
    while waitTV < 20 do
        if getShiftText() ~= activeShift then return end
        tvUI = minigame:FindFirstChild("TV") and minigame.TV:FindFirstChild("Screen", true)
        local meds = getPendingMedicines(tvUI)
        if meds and #meds > 0 then setStatus("R7: Resep muncul (" .. #meds .. " obat)!"); break end
        task.wait(0.5); waitTV = waitTV + 1; _G.AutoDoctor_LastActionTick = tick()
    end

    -- Treatment loop
    local lastProgressTimeRef = {tick()}
    local stuckTimer = tick()

    while true do
        task.wait(0.1)
        if getShiftText() ~= activeShift then setStatus("R7: Shift berganti."); break end
        if getFireEmergency() then setStatus("R7: INTERUPSI pasien terbakar!"); break end
        if tick() - stuckTimer >= Config.StuckTimeout then
            setStatus("R7: Timeout! Skip.")
            clearGracePeriod(roomKey); break
        end

        if isHealingDone(minigame, roomPath, bed, 7, roomKey) then
            setStatus("R7: Pasien sembuh!")
            _G.AutoDoctor_RoomMemory[7] = "PatientLeaving"
            clearGracePeriod(roomKey); break
        end

        if not findPatientR7() then
            setStatus("R7: Pasien pergi.")
            clearGracePeriod(roomKey); break
        end

        -- Burns check (dari referensi — prioritas)
        local currentPatient = findPatientR7()
        if currentPatient then
            for _, desc in ipairs(currentPatient:GetDescendants()) do
                if desc:IsA("ProximityPrompt") and desc.Enabled then
                    local act = string.lower(desc.ActionText or "")
                    local nm = string.lower(desc.Name or "")
                    if nm == "firepp" or act:match("burns") then
                        local hasOintment = LocalPlayer.Backpack:FindFirstChild("Ointment") or LocalPlayer.Character:FindFirstChild("Ointment")
                        if not hasOintment then fetchItem("Ointment", {"Ointment"}) end
                        if root then root.CFrame = Config.Room7Step2; root.AssemblyLinearVelocity = Vector3.zero; task.wait(0.1) end
                        if turboSafeEquip("Ointment") then
                            local tool = LocalPlayer.Character:FindFirstChildOfClass("Tool")
                            if tool and tool.Name == "Ointment" then
                                setStatus("R7: Mengoleskan Ointment (Burns)...")
                                simpleInteract(desc, 3, false)
                                lastProgressTimeRef[1] = tick()
                            end
                        end
                    elseif act:match("dna") or nm:match("dna") then
                        unequipAll()
                        if root then root.CFrame = Config.Room7Step2; root.AssemblyLinearVelocity = Vector3.zero; task.wait(0.1) end
                        setStatus("R7: Take DNA Sample...")
                        simpleInteract(desc, 0.5, false)
                        lastProgressTimeRef[1] = tick(); task.wait(1)
                    end
                end
            end
        end

        tvUI = minigame:FindFirstChild("TV") and minigame.TV:FindFirstChild("Screen", true)
        local pendingMeds = getPendingMedicines(tvUI)

        -- InBed PP untuk inject (dari referensi)
        local inBedPP = nil
        for _, prompt in ipairs(minigame:GetDescendants()) do
            if prompt:IsA("ProximityPrompt") and prompt.Parent and prompt.Parent.Name == "InBed" then
                inBedPP = prompt; break
            end
        end

        if #pendingMeds > 0 then
            if checkAnomalyStatus(bed, bed and bed.Position) then
                local wrongMedicine = "Medicine"
                for _, item in ipairs(ItemList) do
                    if not table.find(pendingMeds, item) then wrongMedicine = item; break end
                end
                local hasIt = LocalPlayer.Backpack:FindFirstChild(wrongMedicine) or LocalPlayer.Character:FindFirstChild(wrongMedicine)
                if not hasIt then fetchItem(wrongMedicine, {wrongMedicine}) end
                if root then root.CFrame = Config.Room7Step2; root.AssemblyLinearVelocity = Vector3.zero; task.wait(0.1) end
                if turboSafeEquip(wrongMedicine) and inBedPP then
                    setStatus("R7: MENYUNTIKKAN RACUN: " .. wrongMedicine)
                    firePromptRaw(inBedPP)
                    lastProgressTimeRef[1] = tick(); task.wait(2)
                    setStatus("R7: ANOMALI HANGUS!")
                    clearGracePeriod(roomKey); break
                end
            else
                -- Fetch semua, lalu inject via InBed PP
                for _, obat in ipairs(pendingMeds) do
                    local hasIt = LocalPlayer.Backpack:FindFirstChild(obat) or LocalPlayer.Character:FindFirstChild(obat)
                    if not hasIt then fetchItem(obat, pendingMeds) end
                end
                if root then root.CFrame = Config.Room7Step2; root.AssemblyLinearVelocity = Vector3.zero; task.wait(0.15) end
                local obat = pendingMeds[1]
                if (LocalPlayer.Backpack:FindFirstChild(obat) or LocalPlayer.Character:FindFirstChild(obat)) and inBedPP then
                    if turboSafeEquip(obat) then
                        local prevCount = #pendingMeds
                        setStatus("R7: Suntik " .. obat)
                        firePromptRaw(inBedPP)
                        lastProgressTimeRef[1] = tick()
                        -- Count sync wait
                        local sw = 0
                        while sw < 30 do
                            task.wait(0.05)
                            local np = getPendingMedicines(tvUI)
                            if #np < prevCount then lastProgressTimeRef[1] = tick(); break end
                            if isHealingDone(minigame, roomPath, bed, 7, roomKey) then break end
                            sw = sw + 1; _G.AutoDoctor_LastActionTick = tick()
                        end
                        stuckTimer = lastProgressTimeRef[1]
                    end
                end
            end
        else
            task.wait(0.5)
        end
    end
end


-- ==========================================
-- ROOM 8 SURGERY TREATMENT (V16 Smart Math)
-- Logic ported from Room8 V16 standalone:
-- - Smart math batch fetch (hitung kebutuhan vs punya)
-- - Count sync wait (tunggu TV count turun, bukan delay fixed)
-- - ensureInRoom8 anchor setelah setiap fetch
-- - Anomaly killer dengan racun yang tepat
-- - Auto idle saat pasien pergi / healing selesai
-- ==========================================
local function executeRoom8Treatment(room8, activeShift)
    local roomKey = "E8"
    local minigame = room8:FindFirstChild("Minigame")
    if not minigame or getShiftText() ~= activeShift then return end

    setStatus("--- ROOM 8: TURBO SURGERY (V16) ---")
    setRoomLabel("Emergency Room 8 (Surgery)")

    local root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")

    -- Anchor ke kasur R8
    local function ensureInRoom8()
        local r = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if r then
            local dist = (r.Position - Config.Room8BedCFrame.Position).Magnitude
            if dist > 20 then
                setStatus("Anchor: Kembali ke kasur R8...")
                r.CFrame = Config.Room8BedCFrame
                r.AssemblyLinearVelocity = Vector3.zero
                task.wait(0.2)
            end
        end
    end

    if root then
        root.CFrame = Config.Room8BedCFrame
        root.AssemblyLinearVelocity = Vector3.zero
    end

    local tvUI = minigame:FindFirstChild("TV") and minigame.TV:FindFirstChild("Screen") and minigame.TV.Screen:FindFirstChild("UI")
    local reportFolder = tvUI and tvUI:FindFirstChild("Report")
    local treatmentText = reportFolder and reportFolder:FindFirstChild("treatment")
    local bed = minigame:FindFirstChild("Bed") and minigame.Bed:FindFirstChild("InBed")

    -- getPendingMedicines untuk R8 menggunakan reportFolder
    local function getPendingR8()
        local pending = {}
        if not reportFolder then return pending end
        local invFolder = reportFolder:FindFirstChild("inv")
        if not invFolder then return pending end
        for _, itemReq in ipairs(invFolder:GetChildren()) do
            if table.find(ItemList, itemReq.Name) then
                local chk = itemReq:FindFirstChild("check")
                if not chk or not chk.Visible then
                    table.insert(pending, itemReq.Name)
                end
            end
        end
        return pending
    end

    local function isR8HealingDone()
        local healing = tvUI and tvUI:FindFirstChild("Healing")
        if healing and healing:IsA("GuiObject") and healing.Visible then
            -- V16 check: juga pastikan NPC masih ada (anti ghost)
            local npcHere = isAnyNPCNearPosition(Config.Room8BedCFrame.Position, Config.PatientBedRadius)
            return npcHere  -- kalau NPC gone → Healing.Visible = stale, return false
        end
        return false
    end

    -- Tunggu pasien datang
    setStatus("R8 1/3: Menunggu pasien di kasur...")
    local waitNPC = 0
    local patientArrived = false
    while waitNPC < 40 do
        if getShiftText() ~= activeShift then return end
        ensureInRoom8()
        if isAnyNPCNearPosition(Config.Room8BedCFrame.Position, Config.PatientBedRadius) then
            patientArrived = true
            markPatientEntered(roomKey)
            forceResetHealingVisible(minigame)
            break
        end
        task.wait(0.5); waitNPC = waitNPC + 1; _G.AutoDoctor_LastActionTick = tick()
    end

    if not patientArrived then
        setStatus("R8: Batal — pasien tidak datang.")
        return
    end

    -- Tidurkan pasien
    setStatus("R8 2/3: Menidurkan pasien...")
    local sleepLimit = 0
    while treatmentText and treatmentText.Text ~= "BEGIN SURGERY:" and sleepLimit < 40 do
        if getShiftText() ~= activeShift then return end
        if isR8HealingDone() then break end
        ensureInRoom8()
        local sleepPP = bed and bed:FindFirstChild("PP2")
        if sleepPP and sleepPP.Enabled then
            firePromptRaw(sleepPP)
        end
        _G.AutoDoctor_LastActionTick = tick()
        task.wait(0.2); sleepLimit = sleepLimit + 1
    end

    setStatus("R8 3/3: Mulai Treatment Loop...")
    local lastProgressTime = tick()

    while true do
        task.wait(0.05)
        _G.AutoDoctor_LastActionTick = tick()
        ensureInRoom8()

        if getShiftText() ~= activeShift then setStatus("R8: Shift berganti."); break end
        if getFireEmergency() then setStatus("R8: INTERUPSI pasien terbakar!"); break end
        if isR8HealingDone() then
            setStatus("R8: Surgery Selesai! Pasien sembuh.")
            clearGracePeriod(roomKey)
            break
        end

        -- Cek pasien sudah pergi (tanpa healing — anomali atau kicked)
        if not isAnyNPCNearPosition(Config.Room8BedCFrame.Position, Config.PatientBedRadius) then
            setStatus("R8: Pasien tidak ada, selesai.")
            clearGracePeriod(roomKey)
            break
        end

        -- Cek lampu masih merah
        local signLight = room8:FindFirstChild("MainSign") and room8.MainSign:FindFirstChild("Light")
        if not signLight or (signLight.BrickColor.Name ~= "Crimson" and signLight.Color ~= Color3.fromRGB(165, 0, 0)) then
            setStatus("R8: Lampu tidak merah, selesai.")
            clearGracePeriod(roomKey)
            break
        end

        if tick() - lastProgressTime >= Config.StuckTimeout then
            setStatus("R8: Timeout! Skip.")
            clearGracePeriod(roomKey)
            break
        end

        local pendingMeds = getPendingR8()

        -- ANOMALY KILLER
        if checkAnomalyStatus(bed, Config.Room8BedCFrame.Position) and #pendingMeds > 0 then
            local wrongMedicine = "Medicine"
            for _, item in ipairs(ItemList) do
                if not table.find(pendingMeds, item) then wrongMedicine = item; break end
            end
            local hasIt = LocalPlayer.Backpack:FindFirstChild(wrongMedicine) or LocalPlayer.Character:FindFirstChild(wrongMedicine)
            if not hasIt then fetchItem(wrongMedicine, {wrongMedicine}); ensureInRoom8() end
            local hasNow = LocalPlayer.Backpack:FindFirstChild(wrongMedicine) or LocalPlayer.Character:FindFirstChild(wrongMedicine)
            if hasNow and bed and bed:FindFirstChild("PP") then
                if turboSafeEquip(wrongMedicine) then
                    setStatus("R8: MENYUNTIKKAN RACUN: " .. wrongMedicine)
                    firePromptRaw(bed.PP)
                    lastProgressTime = tick()
                    task.wait(1.5)
                    setStatus("R8: ANOMALI HANGUS!")
                    clearGracePeriod(roomKey)
                    break
                end
            end

        elseif #pendingMeds > 0 then
            -- V16 SMART MATH: hitung kebutuhan vs yang ada di bag
            local reqCounts = {}
            for _, obat in ipairs(pendingMeds) do reqCounts[obat] = (reqCounts[obat] or 0) + 1 end

            local _, currentItems = checkTotalInventory()
            local haveCounts = {}
            for _, item in ipairs(currentItems) do haveCounts[item.Name] = (haveCounts[item.Name] or 0) + 1 end

            -- Fetch semua yang kurang
            local fetchedAny = false
            for obat, needed in pairs(reqCounts) do
                local have = haveCounts[obat] or 0
                for i = 1, math.max(0, needed - have) do
                    setStatus("R8 Fetch: " .. obat .. " (" .. (have + i) .. "/" .. needed .. ")")
                    fetchItem(obat, pendingMeds)
                    ensureInRoom8()
                    fetchedAny = true
                end
            end
            if fetchedAny then task.wait(0.1) end

            -- Inject obat pertama dari pending
            local obatToInject = pendingMeds[1]
            local hasIt = LocalPlayer.Backpack:FindFirstChild(obatToInject) or LocalPlayer.Character:FindFirstChild(obatToInject)

            if hasIt and bed and bed:FindFirstChild("PP") then
                if turboSafeEquip(obatToInject) then
                    task.wait(0.1)
                    local prevCount = #pendingMeds
                    setStatus("R8 Apply: " .. obatToInject)
                    firePromptRaw(bed.PP)
                    lastProgressTime = tick()

                    -- V16 COUNT SYNC: tunggu TV count turun, bukan delay fixed
                    setStatus("R8: Menunggu TV konfirmasi...")
                    local syncWait = 0
                    while syncWait < 30 do
                        task.wait(0.05)
                        local newPending = getPendingR8()
                        if #newPending < prevCount then
                            setStatus("R8: TV konfirmasi " .. obatToInject .. " OK!")
                            lastProgressTime = tick()
                            break
                        end
                        if isR8HealingDone() or getShiftText() ~= activeShift then break end
                        syncWait = syncWait + 1
                        _G.AutoDoctor_LastActionTick = tick()
                    end
                    if syncWait >= 30 then setStatus("R8: WARN TV tidak konfirmasi, lanjut...") end
                else
                    setStatus("R8: FAILSAFE equip " .. obatToInject); task.wait(0.5)
                end
            else
                setStatus("R8: Retry fetch " .. obatToInject); task.wait(0.5)
            end
        end
    end
end


-- ==========================================
-- MEDICAL ROOM 1-5 TREATMENT ENGINE
-- ==========================================
local function executeMedicalTreatment(roomPath, roomNum, activeShift)
    local roomKey = "M" .. roomNum
    local minigame = roomPath:FindFirstChild("Minigame")
    if not minigame then return end
    local bed = minigame:FindFirstChild("Bed") and minigame.Bed:FindFirstChild("InBed")

    setStatus("--- PENGOBATAN: " .. roomPath.Name .. " ---")
    setRoomLabel("Medical Room " .. roomNum)
    teleportToRoomCenter(roomNum, roomPath)

    local patientMarked = false
    local lastProgressTime = tick()
    local justProcessedTick = 0

    while true do
        task.wait(0.1)

        if getShiftText() ~= activeShift then setStatus("Shift berganti!"); break end
        -- Priority interrupt: fire patient or fainting patient — exit medical immediately
        if getFireEmergency() then setStatus("INTERUPSI: Pasien terbakar!"); break end
        if getPlacePatientPrompt() then setStatus("INTERUPSI: Kasur butuh diisi!"); break end
        if getFaintedPatient() then setStatus("INTERUPSI: Pasien pingsan!"); break end

        local currentPatient = getPatientInRoom(roomNum, roomPath, bed, nil)

        if not currentPatient then
            local signLight = roomPath:FindFirstChild("MainSign") and roomPath.MainSign:FindFirstChild("Light")
            local isLightRed = signLight and (signLight.BrickColor.Name == "Crimson" or signLight.Color == Color3.fromRGB(165, 0, 0))
            if isLightRed then
                setStatus("Pasien menuju kasur..."); task.wait(1)
            else
                setStatus("Kamar kosong/Ghost! Skip.")
                BuggedRoomBlacklist[roomNum] = tick()
                clearGracePeriod(roomKey)
                break
            end
        else
            if not patientMarked then
                patientMarked = true
                markPatientEntered(roomKey)
            end
        end

        -- v115: isRoomDone check — Heal particle OR all TV meds checked → LANGSUNG PERGI
        -- Tidak perlu tunggu NPC keluar range, itu buang waktu
        if isRoomDone(roomNum, minigame, roomPath, bed, currentPatient) then
            setStatus("Pengobatan Selesai! Lanjut ke prioritas lain...")
            -- Store NPC instance (v115 approach) — memory cleared when patient changes
            _G.AutoDoctor_RoomMemory[roomNum] = currentPatient or true
            clearGracePeriod(roomKey)
            break
        end

        if tick() - lastProgressTime >= Config.StuckTimeout then
            setStatus("Timeout! Skip.")
            BuggedRoomBlacklist[roomNum] = tick()
            clearGracePeriod(roomKey)
            break
        end

        local tvUI = minigame:FindFirstChild("TV") and minigame.TV:FindFirstChild("Screen", true)
        local pendingMeds = getPendingMedicines(tvUI)

        local reportFolder = tvUI and tvUI:FindFirstChild("Report")
        if reportFolder and reportFolder:IsA("GuiObject") and reportFolder.Visible and #pendingMeds == 0 then
            setStatus("Menunggu layar Recovering..."); task.wait(0.5)
        end

        local hasTasks, reason = isPatientReady(roomPath, bed)

        if hasTasks then
            if reason == "TV Aktif (Butuh Obat)" then
                if checkAnomalyStatus(bed, nil) then
                    local killed = handleAnomaly(bed, pendingMeds, roomNum, roomPath, roomKey, activeShift)
                    if killed then _G.AutoDoctor_RoomMemory[roomNum] = currentPatient or true; break end
                else
                    if #pendingMeds > 0 then
                        -- v115 fetch: one by one, verify each item enters bag
                        local reqCounts = {}
                        for _, obat in ipairs(pendingMeds) do reqCounts[obat] = (reqCounts[obat] or 0) + 1 end
                        for obat, needed in pairs(reqCounts) do
                            local have = 0
                            local bp = LocalPlayer:FindFirstChild("Backpack")
                            local ch = LocalPlayer.Character
                            if bp then for _, v in ipairs(bp:GetChildren()) do if v:IsA("Tool") and v.Name == obat then have = have + 1 end end end
                            if ch then for _, v in ipairs(ch:GetChildren()) do if v:IsA("Tool") and v.Name == obat then have = have + 1 end end end
                            for _ = 1, math.max(0, needed - have) do
                                fetchItem(obat, pendingMeds)
                            end
                        end

                        -- Teleport to patient once after all fetches
                        teleportToRoomCenter(roomNum, roomPath)
                        task.wait(0.15)

                        -- Inject loop with count-sync wait (v16/v115 approach)
                        local applyPP = bed and bed:FindFirstChild("PP")
                        if applyPP then
                            local freshPending = getPendingMedicines(tvUI)
                            if #freshPending > 0 then
                                local obat = freshPending[1]
                                local hasIt = LocalPlayer.Backpack:FindFirstChild(obat) or LocalPlayer.Character:FindFirstChild(obat)
                                if hasIt and turboSafeEquip(obat) then
                                    local activeTool = LocalPlayer.Character:FindFirstChildOfClass("Tool")
                                    if activeTool and activeTool.Name == obat then
                                        local prevCount = #freshPending
                                        setStatus("Suntik: " .. obat .. " (" .. prevCount .. " sisa)")
                                        firePromptRaw(applyPP)
                                        lastProgressTime = tick()
                                        justProcessedTick = tick()
                                        -- Count-sync wait
                                        local sw = 0
                                        while sw < 30 do
                                            task.wait(0.05)
                                            local np = getPendingMedicines(tvUI)
                                            if #np < prevCount then lastProgressTime = tick(); break end
                                            if isRoomDone(roomNum, minigame, roomPath, bed, currentPatient) then break end
                                            if getShiftText() ~= activeShift then break end
                                            sw = sw + 1; _G.AutoDoctor_LastActionTick = tick()
                                        end
                                    end
                                elseif not hasIt then
                                    setStatus("EDGE: " .. obat .. " hilang, fetch ulang..."); task.wait(0.3)
                                end
                            end
                        end
                    end
                end
            else
                local acted = false
                local prompts = getPromptsNearBed(roomPath, bed)
                local handledBurn = false

                for _, desc in ipairs(prompts) do
                    local actText = string.lower(desc.ActionText or "")
                    local name = string.lower(desc.Name or "")
                    if name == "firepp" or actText:match("burns") then
                        if not (LocalPlayer.Backpack:FindFirstChild("Ointment") or LocalPlayer.Character:FindFirstChild("Ointment")) then
                            fetchItem("Ointment", {"Ointment"})
                        end
                        teleportToRoomCenter(roomNum, roomPath)
                        if turboSafeEquip("Ointment") then
                            local activeTool = LocalPlayer.Character:FindFirstChildOfClass("Tool")
                            if activeTool and activeTool.Name == "Ointment" then
                                setStatus("Mengoleskan Ointment...")
                                simpleInteract(desc, 3, false)
                                local burnWait = 0
                                while burnWait < 60 do
                                    task.wait(0.2); burnWait = burnWait + 1
                                    _G.AutoDoctor_LastActionTick = tick()
                                    local stillBurning = false
                                    local freshPrompts = getPromptsNearBed(roomPath, bed)
                                    for _, fp in ipairs(freshPrompts) do
                                        local fat = string.lower(fp.ActionText or "")
                                        local fn = string.lower(fp.Name or "")
                                        if fn == "firepp" or fat:match("burns") then stillBurning = true; break end
                                    end
                                    if not stillBurning then
                                        setStatus("Burns selesai!"); lastProgressTime = tick(); break
                                    end
                                    if burnWait % 10 == 0 then
                                        if not (LocalPlayer.Backpack:FindFirstChild("Ointment") or LocalPlayer.Character:FindFirstChild("Ointment")) then
                                            fetchItem("Ointment", {"Ointment"})
                                        end
                                        if turboSafeEquip("Ointment") then
                                            local reTool = LocalPlayer.Character:FindFirstChildOfClass("Tool")
                                            if reTool and reTool.Name == "Ointment" and desc and desc.Parent then
                                                simpleInteract(desc, 3, false)
                                            end
                                        end
                                    end
                                end
                                handledBurn = true; break
                            end
                        end
                    end
                end

                if not handledBurn then
                    -- DNA handler (from v95/v115 reference)
                    -- Click DNA prompt, then wait for TV to appear before next loop
                    local handledDNA = false
                    for _, desc in ipairs(prompts) do
                        local actText = string.lower(desc.ActionText or "")
                        local name = string.lower(desc.Name or "")
                        if actText:match("dna") or name:match("dna") then
                            unequipAll()
                            teleportToRoomCenter(roomNum, roomPath)
                            task.wait(0.1)
                            setStatus("Take DNA Sample...")
                            firePromptRaw(desc)
                            lastProgressTime = tick()
                            justProcessedTick = tick()
                            -- Wait for TV or Monitor to respond after DNA click
                            local dnaWait = 0
                            while dnaWait < 30 do
                                task.wait(0.2); dnaWait = dnaWait + 1
                                _G.AutoDoctor_LastActionTick = tick()
                                -- Check if TV now has meds
                                local tvCheck = minigame:FindFirstChild("TV") and minigame.TV:FindFirstChild("Screen", true)
                                if getPendingMedicines(tvCheck) and #getPendingMedicines(tvCheck) > 0 then break end
                                -- Check if Monitor is now processing
                                local monCheck = minigame:FindFirstChild("Monitor")
                                local msCheck = monCheck and monCheck:FindFirstChild("Screen")
                                local muCheck = msCheck and msCheck:FindFirstChild("UI")
                                if muCheck and muCheck.Enabled then break end
                                -- Check if DNA prompt is gone (consumed)
                                local dnaGone = true
                                local freshPrompts = getPromptsNearBed(roomPath, bed)
                                for _, fp in ipairs(freshPrompts) do
                                    local ft = string.lower(fp.ActionText or "")
                                    local fn = string.lower(fp.Name or "")
                                    if ft:match("dna") or fn:match("dna") then dnaGone = false; break end
                                end
                                if dnaGone then break end
                            end
                            handledDNA = true
                            acted = true
                            break
                        end
                    end

                    if not handledDNA then
                    local monitor = minigame:FindFirstChild("Monitor")
                    local pp2_obj = monitor and monitor:FindFirstChild("PP2")
                    local actualPP2 = pp2_obj and (pp2_obj:IsA("ProximityPrompt") and pp2_obj or pp2_obj:FindFirstChildOfClass("ProximityPrompt"))

                    if actualPP2 then
                        local monitorScreen = monitor:FindFirstChild("Screen")
                        local monitorUI = monitorScreen and monitorScreen:FindFirstChild("UI")
                        local isMonitorBusy = monitorUI and (monitorUI.Enabled or (monitorUI:FindFirstChild("Report") and monitorUI.Report.Visible))
                        if monitorScreen and not isMonitorBusy then
                            for _, desc in ipairs(monitorScreen:GetDescendants()) do
                                if desc:IsA("TextLabel") and desc.Name == "header" and desc.Text:match("Finalizing") then
                                    isMonitorBusy = true; break
                                end
                            end
                        end
                        local tvScreen = minigame:FindFirstChild("TV") and minigame.TV:FindFirstChild("Screen")
                        local activeTvUI = tvScreen and tvScreen:FindFirstChild("UI")
                        local isTVBusy = activeTvUI and activeTvUI:IsA("SurfaceGui") and activeTvUI.Enabled

                        if isMonitorBusy or isTVBusy then
                            setStatus("Menunggu Lab/TV diproses..."); task.wait(1); acted = true
                        else
                            unequipAll(); teleportToRoomCenter(roomNum, roomPath); task.wait(0.3)
                            setStatus("BYPASS: Trigger Process Results...")
                            local bypassSuccess = false
                            for retry = 1, 3 do
                                firePromptRaw(actualPP2); task.wait(0.5)
                                local cekScreen = monitor:FindFirstChild("Screen")
                                if cekScreen then
                                    local ui = cekScreen:FindFirstChild("UI")
                                    if ui and ((ui:IsA("SurfaceGui") and ui.Enabled) or (ui:FindFirstChild("Report") and ui.Report.Visible)) then
                                        bypassSuccess = true
                                    end
                                    if not bypassSuccess then
                                        for _, desc in ipairs(cekScreen:GetDescendants()) do
                                            if desc:IsA("TextLabel") and desc.Name == "header" and desc.Text:match("Finalizing") then
                                                bypassSuccess = true; break
                                            end
                                        end
                                    end
                                end
                                if bypassSuccess then break end
                                setStatus("Bypass retry (" .. retry .. "/3)...")
                            end
                            if bypassSuccess then setStatus("Bypass OK!"); justProcessedTick = tick()
                            else setStatus("GAGAL Bypass Monitor.") end
                            acted = true
                        end
                    else
                        setStatus("Menunggu Monitor Siap..."); acted = false
                    end
                    end -- handledDNA
                else
                    acted = true
                end -- handledBurn
            end
        else
            task.wait(1)
        end
    end
end

-- ==========================================
-- FAINTING PATIENT HANDLER
-- ==========================================
local function processFaintedPatient(faintedPart, carryPP, activeShift)
    setStatus("! PRIORITAS 2: Pasien Pingsan !")
    unequipAll()

    -- Teleport langsung ke posisi NPC (bukan +3Y) agar masuk carry range
    local root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if root then
        local faintedBase = faintedPart.PrimaryPart or faintedPart:FindFirstChildWhichIsA("BasePart")
        if faintedBase then
            root.CFrame = CFrame.new(faintedBase.Position + Vector3.new(0, 1, 0))
            root.AssemblyLinearVelocity = Vector3.zero
            task.wait(0.2)
        end
    end

    setStatus("Menggendong pasien...")
    -- Force enable carryPP dan fire (pasien pingsan kadang prompt tidak enabled)
    if carryPP and carryPP:IsA("ProximityPrompt") then
        local oldEnabled = carryPP.Enabled
        local oldReq = carryPP.RequiresLineOfSight
        local oldDist = carryPP.MaxActivationDistance
        carryPP.Enabled = true
        carryPP.RequiresLineOfSight = false
        carryPP.MaxActivationDistance = math.huge
        firePromptRaw(carryPP)
        carryPP.Enabled = oldEnabled
        carryPP.RequiresLineOfSight = oldReq
        carryPP.MaxActivationDistance = oldDist
    end
    task.wait(1.5)

    local placePrompt, targetRoomName, targetRoomNum, targetRoomPath
    local waitLimit = 0
    while not placePrompt and waitLimit < 20 do
        if getShiftText() ~= activeShift then return end
        setStatus("Mencari kasur kosong...")
        placePrompt, targetRoomName, targetRoomNum, targetRoomPath = getPlacePatientPrompt()
        if not placePrompt then task.wait(1.5); waitLimit = waitLimit + 1; _G.AutoDoctor_LastActionTick = tick() end
        task.wait(0.1)
    end
    if placePrompt and targetRoomNum and targetRoomPath then
        setStatus("Bawa ke " .. targetRoomName)
        unequipAll(); teleportToRoomCenter(targetRoomNum, targetRoomPath); task.wait(0.3)
        simpleInteract(placePrompt, 1, true); task.wait(1.5)
        setStatus("Pasien ditempatkan!")
    else
        setStatus("GAGAL menaruh pasien.")
    end
end

-- ==========================================
-- MAIN BOT CYCLE
-- Priority chain (strict, no concurrent):
-- 1. Fire patient (PRIORITAS 1 — interrupt anything)
-- 2. Place patient prompt (carry to bed)
-- 3. Fainting patient (carry + place)
-- 4. Emergency rooms R8 → R6 → R7 (light red = active)
-- 5. Medical rooms M1-M5 (ready + not done)
-- 6. Idle
-- ==========================================
local function botCycle()
    local activeShift = getShiftText()

    -- PRIORITAS 1: Fire patient — always checked first
    local fireNPC, firePP = getFireEmergency()
    if fireNPC then
        _G.AutoDoctor_IsIdle = false
        pcall(function()
            unequipAll()
            setStatus("! PRIORITAS 1: Padamkan Pasien Terbakar !")
            local targetNode = fireNPC.PrimaryPart or fireNPC:FindFirstChildWhichIsA("BasePart")
            if targetNode then
                local root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                if root then
                    root.CFrame = CFrame.new(targetNode.Position + Vector3.new(0, 2, 0))
                    root.AssemblyLinearVelocity = Vector3.zero
                    task.wait(0.2)
                end
            end
            simpleInteract(firePP, 3.2, false)
            task.wait(1.5)
        end)
        return
    end

    -- PRIORITAS 2: Place patient prompt (patient already being carried, needs a bed)
    local placePrompt, targetRoomName = getPlacePatientPrompt()
    if placePrompt then
        _G.AutoDoctor_IsIdle = false
        pcall(function()
            unequipAll()
            setStatus("Meletakkan pasien ke " .. tostring(targetRoomName))
            task.wait(0.2)
            simpleInteract(placePrompt, 1, true)
            task.wait(1.5)
        end)
        return
    end

    -- PRIORITAS 3: Fainting patient — pick up and carry to room
    local faintedPart, carryPP = getFaintedPatient()
    if faintedPart then
        _G.AutoDoctor_IsIdle = false
        pcall(function() processFaintedPatient(faintedPart, carryPP, activeShift) end)
        return
    end

    -- PRIORITAS 4: Emergency rooms (R8 → R6 → R7)
    local emergRoom, emergNum = findEmergencyRoom()
    if emergRoom and emergNum then
        _G.AutoDoctor_IsIdle = false
        if emergNum == 8 then
            pcall(function() executeRoom8Treatment(emergRoom, activeShift) end)
        elseif emergNum == 6 then
            pcall(function() executeRoom6Treatment(emergRoom, activeShift) end)
        elseif emergNum == 7 then
            pcall(function() executeRoom7Treatment(emergRoom, activeShift) end)
        end
        return
    end

    -- PRIORITAS 5: Medical rooms M1-M5
    local medRoom, medRoomNum = findMedicalRoom()
    if medRoom and medRoomNum then
        _G.AutoDoctor_IsIdle = false
        pcall(function() executeMedicalTreatment(medRoom, medRoomNum, activeShift) end)
        return
    end

    -- IDLE
    if not _G.AutoDoctor_IsIdle then
        unequipAll(); teleportToIdle(); _G.AutoDoctor_IsIdle = true; setRoomLabel("-")
        _G.LastStatus = ""
        setStatus("Idle (Memantau)...")
        printRadarReport(true)
    else
        setStatus("Idle (Memantau)...")
        printRadarReport()
    end
    task.wait(Config.ScanDelay)
end

-- ==========================================
-- WORKER & WATCHDOG
-- ==========================================
local function startWorker()
    if _G.AutoDoctor_Worker then task.cancel(_G.AutoDoctor_Worker) end
    _G.AutoDoctor_Worker = task.spawn(function()
        while autoScanEnabled do
            if not isBusy then
                isBusy = true
                _G.AutoDoctor_LastActionTick = tick()
                pcall(botCycle)
                isBusy = false
            end
            task.wait(0.1)
        end
    end)
end

