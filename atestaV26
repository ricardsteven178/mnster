local function setStatus(text)
    if _G.LastStatus == text then return end
    _G.LastStatus = text
    StatusLabel.Text = "Status: " .. text
    if Config.ShowConsoleLogs then
        print("[" .. os.date("%H:%M:%S") .. "] [AutoDoctor] " .. text)
    end
end

local function setRoomLabel(text)
