local function findMedicalRoom()
    local roomsFolder = workspace:FindFirstChild("Rooms")
    local medicalFolder = roomsFolder and roomsFolder:FindFirstChild("Medical")
    if not medicalFolder then return nil, nil end

    for i = 1, Config.MaxRooms do
        local room = medicalFolder:FindFirstChild("Room" .. i)
        if room then
            local isBlacklisted = BuggedRoomBlacklist[i] and (tick() - BuggedRoomBlacklist[i] < Config.BlacklistDuration)
            if not isBlacklisted then
                local minigame = room:FindFirstChild("Minigame")
                local bed = minigame and minigame:FindFirstChild("Bed") and minigame.Bed:FindFirstChild("InBed")
                local roomKey = "M" .. i
                local currentPatient = getPatientInRoom(i, room, bed, nil)
                local mem = _G.AutoDoctor_RoomMemory[i]

                -- v115 memory clear logic: clear if no patient, new patient, or patient has PE (still sick)
                if mem then
                    if not currentPatient then
                        _G.AutoDoctor_RoomMemory[i] = nil; clearGracePeriod(roomKey)
                    elseif typeof(mem) == "Instance" and currentPatient ~= mem then
                        _G.AutoDoctor_RoomMemory[i] = nil; clearGracePeriod(roomKey)
                    elseif currentPatient:FindFirstChild("PE", true) then
                        _G.AutoDoctor_RoomMemory[i] = nil; clearGracePeriod(roomKey)
                    end
                end

                if not _G.AutoDoctor_RoomMemory[i] then
                    local ready, reason = isPatientReady(room, bed)
                    local done = isRoomDone(i, minigame, room, bed, currentPatient)
                    if ready and not done then
                        if Config.ShowConsoleLogs then print("[RADAR] Target: " .. room.Name .. " (" .. reason .. ")") end
                        return room, i
                    end
                end
            end
        end
    end
    return nil, nil
end

local function findEmergencyRoom()
    local roomsFolder = workspace:FindFirstChild("Rooms")
    local emergencyFolder = roomsFolder and roomsFolder:FindFirstChild("Emergency")
    if not emergencyFolder then return nil, nil end

    -- R8 priority: check light + NPC near bed
    local room8 = emergencyFolder:FindFirstChild("Room8")
    if room8 then
        local signLight = room8:FindFirstChild("MainSign") and room8.MainSign:FindFirstChild("Light")
        local isLightRed = signLight and (signLight.BrickColor.Name == "Crimson" or signLight.Color == Color3.fromRGB(165, 0, 0))
        if isLightRed and not isHealingDone(room8:FindFirstChild("Minigame"), room8, nil, 8, "E8") then
            return room8, 8
        end
    end

    -- R6: use PatientStandCFrame for NPC detection (matches R6 standalone reference)
    local room6 = emergencyFolder:FindFirstChild("Room6")
    if room6 then
        local signLight = room6:FindFirstChild("MainSign") and room6.MainSign:FindFirstChild("Light")
        local isLightRed = signLight and (signLight.BrickColor.Name == "Crimson" or signLight.Color == Color3.fromRGB(165, 0, 0))
        local isBlacklisted = BuggedRoomBlacklist[6] and (tick() - BuggedRoomBlacklist[6] < Config.BlacklistDuration)
        if isLightRed and not isBlacklisted then
            local minigame = room6:FindFirstChild("Minigame")
            if not isHealingDone(minigame, room6, nil, 6, "E6") then
                return room6, 6
            end
        end
    end

    -- R7: use bed position for NPC detection (matches R7 standalone reference)
    local room7 = emergencyFolder:FindFirstChild("Room7")
    if room7 then
        local signLight = room7:FindFirstChild("MainSign") and room7.MainSign:FindFirstChild("Light")
        local isLightRed = signLight and (signLight.BrickColor.Name == "Crimson" or signLight.Color == Color3.fromRGB(165, 0, 0))
        local isBlacklisted = BuggedRoomBlacklist[7] and (tick() - BuggedRoomBlacklist[7] < Config.BlacklistDuration)
        local minigame = room7:FindFirstChild("Minigame")
        local bed = minigame and minigame:FindFirstChild("Bed") and minigame.Bed:FindFirstChild("InBed")
        if isLightRed and not isBlacklisted and not isHealingDone(minigame, room7, bed, 7, "E7") then
            return room7, 7
        end
    end

    return nil, nil
end

local function printRadarReport(forceprint)
    if not Config.ShowConsoleLogs then return end
    local report = "[RADAR] "
    local rooms = workspace:FindFirstChild("Rooms")
    local medical = rooms and rooms:FindFirstChild("Medical")
    if medical then
        for i = 1, Config.MaxRooms do
            local room = medical:FindFirstChild("Room" .. i)
            local status = "[-]"
            if room then
                local minigame = room:FindFirstChild("Minigame")
                local bed = minigame and minigame:FindFirstChild("Bed") and minigame.Bed:FindFirstChild("InBed")
                local roomKey = "M" .. i
                local isBlacklisted = BuggedRoomBlacklist[i] and (tick() - BuggedRoomBlacklist[i] < Config.BlacklistDuration)
                local currentPatient = getPatientInRoom(i, room, bed, nil)
                local mem = _G.AutoDoctor_RoomMemory[i]
                local done = isRoomDone(i, minigame, room, bed, currentPatient)
                local ready, reason = isPatientReady(room, bed)
                local signLight = room:FindFirstChild("MainSign") and room.MainSign:FindFirstChild("Light")
                local isLightRed = signLight and (signLight.BrickColor.Name == "Crimson" or signLight.Color == Color3.fromRGB(165, 0, 0))

                -- v115 particle debug info
                local pState = ""
                if currentPatient then
                    if currentPatient:FindFirstChild("PE", true) then pState = "[PE-Biru]"
                    elseif currentPatient:FindFirstChild("Heal", true) then pState = "[Heal✓]"
                    else pState = "[NPC]" end
                end

                if isBlacklisted then status = "[BLACKLIST]"
                elseif mem and done then status = "[SELESAI/IDLE]" .. pState
                elseif mem then status = "[MEMORI-SKIP]" .. pState
                elseif done then status = "[DONE]" .. pState
                elseif ready then status = "[" .. reason .. "]" .. pState
                elseif currentPatient then status = "[PASIEN-PROSES]" .. pState
                elseif isLightRed then status = "[PASIEN MENUJU]"
                else status = "[Kosong]" end
            end
            report = report .. "M" .. i .. ":" .. status .. " "
        end
    end
    local emergency = rooms and rooms:FindFirstChild("Emergency")
    if emergency then
        for _, rn in ipairs(Config.EmergencyRooms) do
            local room = emergency:FindFirstChild("Room" .. rn)
            local status = "[-]"
            if room then
                local signLight = room:FindFirstChild("MainSign") and room.MainSign:FindFirstChild("Light")
                local isLightRed = signLight and (signLight.BrickColor.Name == "Crimson" or signLight.Color == Color3.fromRGB(165, 0, 0))
                local minigame = room:FindFirstChild("Minigame")
                local bed = minigame and minigame:FindFirstChild("Bed") and minigame.Bed:FindFirstChild("InBed")
                local bedPos = nil
                if rn == 6 then bedPos = Config.Room6PatientStandCFrame.Position
                elseif bed then bedPos = bed.Position
                else
                    local ap = minigame and minigame:FindFirstChildWhichIsA("BasePart", true)
                        or room:FindFirstChildWhichIsA("BasePart", true)
                    if ap then bedPos = ap.Position end
                end
                local hasNPC = bedPos and isAnyNPCNearPosition(bedPos, rn == 6 and Config.Room6PatientRadius or (rn == 7 and Config.Room7PatientRadius or Config.PatientBedRadius))
                if hasNPC then status = "[AKTIF-PASIEN]"
                elseif isLightRed then status = "[LAMPU MERAH]"
                else status = "[Kosong]" end
            end
            report = report .. "E" .. rn .. ":" .. status .. " "
        end
    end
    if forceprint or _G.LastRadarReport ~= report then
        _G.LastRadarReport = report
        print("[" .. os.date("%H:%M:%S") .. "] [AutoDoctor] " .. report)
    end
end

