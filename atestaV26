task.spawn(function()
    local pGui = LocalPlayer:WaitForChild("PlayerGui", 10)
    if not pGui then return end
    local notifMain = pGui:WaitForChild("Notifications", 10)
    if not notifMain then return end
    local notifSub = notifMain:WaitForChild("Notifications", 10)
    local feed = notifSub and notifSub:WaitForChild("Feed", 10)
    if feed then
        _G.AutoDoctor_NotifLoop = feed.ChildAdded:Connect(function(child)
            if child:IsA("TextLabel") or child:IsA("TextButton") then
                task.wait(0.1)
                local text = string.lower(child.Text)
                if text:match("can't carry any more") or text:match("full") then
                    local _, maxItem = string.match(text, "%((%d+)/(%d+)%)")
                    if maxItem then
                        local lim = tonumber(maxItem)
