end

local function unequipAll()
    pcall(function()
        local char = LocalPlayer.Character
        local hum = char and char:FindFirstChild("Humanoid")
        if hum then
            hum:UnequipTools()
            local t = 0
            while char:FindFirstChildOfClass("Tool") and t < 10 do
                task.wait(0.05); t = t + 1
            end
        end
    end)
end

local function turboSafeEquip(itemName)
    local char = LocalPlayer.Character
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    local hum = char and char:FindFirstChild("Humanoid")
    if not char or not backpack or not hum then return false end
    if char:FindFirstChild(itemName) then return true end
    hum:UnequipTools()
    local t1 = 0
    while char:FindFirstChildOfClass("Tool") and t1 < 10 do
        task.wait(0.05); t1 = t1 + 1
    end
    local tool = backpack:FindFirstChild(itemName) or char:FindFirstChild(itemName)
    if not tool then return false end
    hum:EquipTool(tool)
    local t2 = 0
    while not char:FindFirstChild(itemName) and t2 < 15 do
        task.wait(0.05); t2 = t2 + 1
    end
    task.wait(0.05)
    return char:FindFirstChild(itemName) ~= nil
end

local function firePromptRaw(p)
    if not p or not p:IsA("ProximityPrompt") then return end
    if type(fireproximityprompt) == "function" then
        fireproximityprompt(p)
    else
        local oldReq = p.RequiresLineOfSight
        local oldDist = p.MaxActivationDistance
        p.RequiresLineOfSight = false
        p.MaxActivationDistance = math.huge
        p:InputHoldBegan() task.wait(0.05) p:InputHoldEnded()
        p.RequiresLineOfSight = oldReq
        p.MaxActivationDistance = oldDist
    end
    _G.AutoDoctor_LastActionTick = tick()
end

local function teleportTo(target)
    local char = LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root or not target then return end
    local pos
    if typeof(target) == "CFrame" then pos = target.Position
    elseif typeof(target) == "Vector3" then pos = target
    elseif target:IsA("BasePart") then pos = target.Position
    elseif target:IsA("Model") then
        local p = target.PrimaryPart or target:FindFirstChildWhichIsA("BasePart", true)
        if p then pos = p.Position end
    elseif target:IsA("ProximityPrompt") then
        local par = target.Parent
        if par then
            if par:IsA("BasePart") then pos = par.Position
            elseif par:IsA("Model") then
                local pt = par.PrimaryPart or par:FindFirstChildWhichIsA("BasePart", true)
                if pt then pos = pt.Position end
            end
        end
    end
    if pos then
        root.CFrame = CFrame.new(pos + Vector3.new(0, 3, 0))
        root.AssemblyLinearVelocity = Vector3.zero
        task.wait(0.1)
    end
end

local function teleportToRoomCenter(roomNum, roomPath)
    local root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not root then return end
    if RoomCFrames[roomNum] then
        root.CFrame = RoomCFrames[roomNum]
    elseif roomPath then
        local bed = roomPath:FindFirstChild("Minigame") and roomPath.Minigame:FindFirstChild("Bed")
        local pos = bed and bed.Position or (roomPath.PrimaryPart and roomPath.PrimaryPart.Position)
        if pos then root.CFrame = CFrame.new(pos + Vector3.new(0, 3, 0)) end
    end
    root.AssemblyLinearVelocity = Vector3.zero
    task.wait(0.1)
end

local function teleportToIdle()
