-- ==========================================
-- DIAGNOSTIC / STATE DETECTION
-- ==========================================
local function getPendingMedicines(tvUI)
    local pending = {}
    if not tvUI then return pending end
    local invFolder = tvUI:FindFirstChild("inv", true)
    if not invFolder then return pending end
    for _, itemReq in ipairs(invFolder:GetChildren()) do
        if table.find(ItemList, itemReq.Name) then
            local checkMark = itemReq:FindFirstChild("check")
            if not checkMark or (checkMark and checkMark.Visible == false) then
                table.insert(pending, itemReq.Name)
            end
        end
    end
    return pending
end

local function getPromptsNearBed(roomPath, bedPart)
    local prompts = {}
    if not roomPath or not bedPart then return prompts end
    local minigame = roomPath:FindFirstChild("Minigame")
    if minigame then
        for _, desc in ipairs(minigame:GetDescendants()) do
            if desc:IsA("ProximityPrompt") and desc.Enabled then table.insert(prompts, desc) end
        end
    end
    if workspace:FindFirstChild("NPCs") then
        for _, npc in ipairs(workspace.NPCs:GetChildren()) do
            local p = npc.PrimaryPart or npc:FindFirstChildWhichIsA("BasePart")
            if p and (p.Position - bedPart.Position).Magnitude <= Config.PatientBedRadius then
                for _, desc in ipairs(npc:GetDescendants()) do
                    if desc:IsA("ProximityPrompt") and desc.Enabled then table.insert(prompts, desc) end
                end
            end
        end
    end
    return prompts
end

local function isPatientReady(roomPath, bedPart)
    local minigame = roomPath:FindFirstChild("Minigame")
    local tvUI = minigame and minigame:FindFirstChild("TV") and minigame.TV:FindFirstChild("Screen", true)
    local pending = getPendingMedicines(tvUI)
    if #pending > 0 then return true, "TV Aktif (Butuh Obat)" end
    local prompts = getPromptsNearBed(roomPath, bedPart)
    for _, desc in ipairs(prompts) do
        local actText = string.lower(desc.ActionText or "")
        local name = string.lower(desc.Name or "")
        if actText:match("inspect") then
        elseif actText:match("dna") or name:match("dna") then return true, "Tombol DNA"
        elseif actText:match("burns") or name == "firepp" then return true, "Tombol Luka Bakar"
        elseif actText:match("analyze") or actText:match("process") or name:match("analyze") then return true, "Mesin Lab"
        end
    end
    return false, "Kosong/Healing"
end

-- getPatientInRoom: v115 approach — proximity check only, no prompt requirement.
-- Prompts aren't reliable (new patients don't have them yet, bypass keeps them always on).
-- Returns NPC instance if found near bed center, nil otherwise.
local function getPatientInRoom(roomNum, roomPath, bedPart, centerPos)
    if not centerPos and bedPart then centerPos = bedPart.Position end
    if not centerPos and RoomCFrames[roomNum] then centerPos = RoomCFrames[roomNum].Position end
    if not centerPos and roomPath then
        local anyPart = roomPath:FindFirstChildWhichIsA("BasePart", true)
        if anyPart then centerPos = anyPart.Position end
    end
    if not centerPos then return nil end

    local function checkNPC(obj)
        if Players:GetPlayerFromCharacter(obj) then return nil end
        local part = obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")
        if part and (part.Position - centerPos).Magnitude <= Config.PatientBedRadius then
            -- Must have Humanoid OR at least one ProximityPrompt (any kind)
            if obj:FindFirstChildOfClass("Humanoid") or obj:FindFirstChildWhichIsA("ProximityPrompt", true) then
                return obj
            end
        end
        return nil
    end

    if workspace:FindFirstChild("NPCs") then
        for _, npc in ipairs(workspace.NPCs:GetChildren()) do
            local found = checkNPC(npc); if found then return found end
        end
    end
    for _, obj in ipairs(workspace:GetChildren()) do
        if obj:IsA("Model") and obj ~= LocalPlayer.Character
            and obj.Name ~= "Rooms" and obj.Name ~= "Misc" then
            local found = checkNPC(obj); if found then return found end
        end
    end
    return nil
end

-- isRoomDone: v115 approach — PE particle = still sick, Heal particle = done, TV all-checked = done.
-- No Bandages detection (caused false positives on NPC spawn).
local function isRoomDone(roomNum, minigame, roomPath, bedPart, currentPatient)
    if not minigame then return false end

    -- Burns must be treated first — never consider room done if burns prompt exists
    if roomPath and bedPart then
        local ready, reason = isPatientReady(roomPath, bedPart)
        if ready and reason == "Tombol Luka Bakar" then return false end
    end

    if currentPatient then
        -- PE particle = patient still sick/blue = absolutely not done
        if currentPatient:FindFirstChild("PE", true) then
            return false
        end
        -- Heal particle = confirmed done
        if currentPatient:FindFirstChild("Heal", true) then
            return true
        end
    end

    -- TV all-checked = done (only if TV is showing medicines)
    local tv = minigame:FindFirstChild("TV")
    local screen = tv and tv:FindFirstChild("Screen")
    local ui = screen and screen:FindFirstChild("UI")
    if ui and ui:IsA("SurfaceGui") and ui.Enabled then
        local invFolder = ui:FindFirstChild("inv", true)
        if invFolder then
            local totalItems = 0
            for _, itemReq in ipairs(invFolder:GetChildren()) do
                if table.find(ItemList, itemReq.Name) then totalItems = totalItems + 1 end
            end
            local pending = getPendingMedicines(ui)
            if totalItems > 0 and #pending == 0 then
                return true
            end
        end
    end

    return false
end

-- ==========================================
-- forceResetHealingVisible
-- Directly sets Healing.Visible = false on the room's TV UI.
-- Called whenever a new patient enters to prevent the server-side
-- flicker bug where Healing.Visible = true on patient arrival.
-- ==========================================
local function forceResetHealingVisible(minigame)
    pcall(function()
        if not minigame then return end
        local tv = minigame:FindFirstChild("TV")
        local screen = tv and tv:FindFirstChild("Screen")
        local ui = screen and screen:FindFirstChild("UI")
        local healing = ui and ui:FindFirstChild("Healing")
        if healing and healing:IsA("GuiObject") then
            healing.Visible = false
            if Config.ShowConsoleLogs then
                print("[GraceGuard] forceResetHealingVisible — Healing.Visible dipaksa false")
            end
        end
    end)
end

-- ==========================================
-- isAnyNPCNearPosition
-- Simple proximity check — does NOT require DNA/treat prompts.
-- Used by isHealingDone Layer 2 to check if any NPC is near
-- the bed center. This avoids the false negative from
-- getPatientInRoom() which requires prompts that new patients
-- don't have yet.
-- ==========================================
local function isAnyNPCNearPosition(centerPos, radius)
    if not centerPos then return false end
    if workspace:FindFirstChild("NPCs") then
        for _, npc in ipairs(workspace.NPCs:GetChildren()) do
            local p = npc.PrimaryPart or npc:FindFirstChildWhichIsA("BasePart")
            if p and (p.Position - centerPos).Magnitude <= radius then
                return true
            end
        end
    end
    -- Also check loose models in workspace
    for _, obj in ipairs(workspace:GetChildren()) do
        if obj:IsA("Model") and obj ~= LocalPlayer.Character
            and obj.Name ~= "Rooms" and obj.Name ~= "Misc"
            and obj:FindFirstChild("Humanoid") then
            local p = obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")
            if p and (p.Position - centerPos).Magnitude <= radius then
                return true
            end
        end
    end
    return false
end

-- ==========================================
-- isHealingDone — HYBRID GUARD (v118)
--
-- Medical rooms (M1-M5): Grace Period + v95 logic
--   Grace period blocks flicker on arrival.
--   After grace: if Healing.Visible=true but patient still has
--   non-TV tasks (DNA/burns/lab) → treat as bug, return false.
--   (v95 approach — works for medical rooms where prompts
--   disappear naturally after treatment)
--
-- Emergency rooms (E6-E8): NPC proximity check only
--   Bypass keeps prompts always enabled/visible, so
--   isPatientReady will always return true → can't use v95 logic.
--   Instead: just verify an NPC is physically present.
--   If no NPC near bed → Healing.Visible is stale, return false.
-- ==========================================
local function isHealingDone(minigame, roomPath, bed, roomNum, roomKey)
    if not minigame then return false end

    local tv = minigame:FindFirstChild("TV")
    local screen = tv and tv:FindFirstChild("Screen")
    local ui = screen and screen:FindFirstChild("UI")
    local healing = ui and ui:FindFirstChild("Healing")

    if not healing or not healing:IsA("GuiObject") or not healing.Visible then
        return false
    end

    local isEmergency = roomKey and (roomKey:sub(1,1) == "E")

    if not isEmergency then
        -- MEDICAL ROOMS: Grace Period guard
        if roomKey and isInGracePeriod(roomKey) then
            local elapsed = RoomPatientEntryTick[roomKey] and (tick() - RoomPatientEntryTick[roomKey]) or 0
            if Config.ShowConsoleLogs then
                print("[GraceGuard] " .. roomKey .. " — Healing.Visible IGNORED + RESET (grace "
                    .. string.format("%.1f", elapsed) .. "s/" .. Config.GracePeriod .. "s)")
            end
            forceResetHealingVisible(minigame)
            return false
        end

        -- v95 logic: Healing.Visible=true but patient still has non-TV tasks → bug
        if roomPath then
            local bedPart = bed
            local ready, reason = isPatientReady(roomPath, bedPart)
            if ready and reason ~= "TV Aktif (Butuh Obat)" then
                if Config.ShowConsoleLogs then
                    print("[HealCheck] " .. (roomKey or "?") .. " — Healing.Visible=true tapi masih ada task (" .. reason .. "), dianggap bug.")
                end
                return false
            end
        end
    else
        -- EMERGENCY ROOMS: Simple NPC proximity check only
        -- (bypass keeps prompts visible, can't use isPatientReady)
        local centerPos = (bed and bed.Position)
            or (roomPath and roomPath.PrimaryPart and roomPath.PrimaryPart.Position)
        if centerPos then
            local npcPresent = isAnyNPCNearPosition(centerPos, Config.PatientBedRadius)
            if not npcPresent then
                if Config.ShowConsoleLogs then
                    print("[HealCheck] " .. (roomKey or "?") .. " — Emergency: Healing.Visible=true tapi tidak ada NPC, dianggap ghost.")
                end
                return false
            end
        end
    end

    return true
end

local function checkAnomalyStatus(bedPart, centerPos)
