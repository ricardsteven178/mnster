-- SHARED FETCH PHASE
-- ==========================================
local function runFetchPhase(pendingMeds)
    local reqCounts = {}
    for _, obat in ipairs(pendingMeds) do reqCounts[obat] = (reqCounts[obat] or 0) + 1 end

    setStatus("FETCH PHASE: Kumpulkan semua obat...")
    for obat, needed in pairs(reqCounts) do
        local haveCount = 0
        local bp = LocalPlayer:FindFirstChild("Backpack")
        local ch = LocalPlayer.Character
        if bp then for _, v in ipairs(bp:GetChildren()) do if v:IsA("Tool") and v.Name == obat then haveCount = haveCount + 1 end end end
        if ch then for _, v in ipairs(ch:GetChildren()) do if v:IsA("Tool") and v.Name == obat then haveCount = haveCount + 1 end end end

        for _ = 1, math.max(0, needed - haveCount) do
            fetchItem(obat, pendingMeds)
            haveCount = haveCount + 1
        end
        setStatus("FETCH OK: " .. obat .. " x" .. needed)
    end
end

-- ==========================================
-- SHARED INJECT PHASE
-- ==========================================
local function runInjectPhase(tvUI, bed, minigame, roomPath, roomNum, roomKey, activeShift, lastProgressTimeRef, isEmergency)
    local applyPP = bed and bed:FindFirstChild("PP")
    if not applyPP then setStatus("GAGAL: PP bed tidak ditemukan!"); return end

    local root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if isEmergency then
        if root and bed then
            root.CFrame = CFrame.new(bed.Position + Vector3.new(0, 3, 0))
            root.AssemblyLinearVelocity = Vector3.zero
            task.wait(0.15)
        end
    else
        teleportToRoomCenter(roomNum, roomPath)
        task.wait(0.15)
    end

    local injectAttempts = 0
    while injectAttempts < 20 do
        if getShiftText() ~= activeShift then break end

        local freshPending = getPendingMedicines(tvUI)
        if #freshPending == 0 then
            setStatus("Semua obat dicentang TV! Menunggu Healing...")
            -- Mark room sebagai meds done — boleh ditinggal meski masih ada prompt visible
            _G.AutoDoctor_MedsDone = _G.AutoDoctor_MedsDone or {}
            if roomNum then _G.AutoDoctor_MedsDone[roomNum] = true end
            lastProgressTimeRef[1] = tick()
            local healWait = 0
            while healWait < 40 do
                if isHealingDone(minigame, roomPath, bed, roomNum, roomKey) then break end
                if getShiftText() ~= activeShift then break end
                task.wait(0.05); healWait = healWait + 1
                _G.AutoDoctor_LastActionTick = tick()
            end
            break
        end

        local nextObat = freshPending[1]
        local hasInBag = LocalPlayer.Backpack:FindFirstChild(nextObat) or LocalPlayer.Character:FindFirstChild(nextObat)

        if not hasInBag then
            setStatus("EDGE CASE: " .. nextObat .. " hilang, fetch ulang...")
            fetchItem(nextObat, freshPending)
            local ev = 0
            while ev < 30 do
                task.wait(0.05)
                if LocalPlayer.Backpack:FindFirstChild(nextObat) or LocalPlayer.Character:FindFirstChild(nextObat) then break end
                ev = ev + 1; _G.AutoDoctor_LastActionTick = tick()
            end
            if isEmergency then
                if root and bed then
                    root.CFrame = CFrame.new(bed.Position + Vector3.new(0, 3, 0))
                    root.AssemblyLinearVelocity = Vector3.zero
                    task.wait(0.15)
                end
            else
                teleportToRoomCenter(roomNum, roomPath)
                task.wait(0.15)
            end
        end

        if turboSafeEquip(nextObat) then
            local activeTool = LocalPlayer.Character:FindFirstChildOfClass("Tool")
            if activeTool and activeTool.Name == nextObat then
                setStatus("Suntik: " .. nextObat .. " (" .. #freshPending .. " sisa)")
                simpleInteract(applyPP, 0.1, false)
                lastProgressTimeRef[1] = tick()

                local prevCount = #freshPending
                local verifyInject = 0
                while verifyInject < 40 do
                    task.wait(0.05)
                    local after = getPendingMedicines(tvUI)
                    if #after < prevCount then
                        setStatus("TV Confirm: " .. nextObat .. " masuk!")
                        lastProgressTimeRef[1] = tick()
                        break
                    end
                    if isHealingDone(minigame, roomPath, bed, roomNum, roomKey) then break end
                    if getShiftText() ~= activeShift then break end
                    verifyInject = verifyInject + 1
                    _G.AutoDoctor_LastActionTick = tick()
                end
                if verifyInject >= 40 then setStatus("WARN: TV tidak konfirmasi " .. nextObat) end
            end
        else
            setStatus("FAILSAFE: Gagal equip " .. nextObat .. ", retry...")
            task.wait(0.3)
        end

        injectAttempts = injectAttempts + 1
        task.wait(0.05)
    end
end

-- ==========================================
-- ANOMALY HANDLER (SHARED)
-- ==========================================
local function handleAnomaly(bed, pendingMeds, roomNum, roomPath, roomKey, activeShift)
    local prescribedMeds = {}
    for _, m in ipairs(pendingMeds) do table.insert(prescribedMeds, m) end
    local wrongMedicine = nil
    for _, item in ipairs(ItemList) do
        if not table.find(prescribedMeds, item) then
            if getPromptFromCache(item, false) then wrongMedicine = item; break end
        end
    end
    if not wrongMedicine then wrongMedicine = "Medicine" end
    local hasIt = LocalPlayer.Backpack:FindFirstChild(wrongMedicine) or LocalPlayer.Character:FindFirstChild(wrongMedicine)
    if not hasIt then fetchItem(wrongMedicine, {wrongMedicine}) end
    if bed and bed:FindFirstChild("PP") then
        local root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if roomNum then
            teleportToRoomCenter(roomNum, roomPath)
        elseif root and bed then
            root.CFrame = CFrame.new(bed.Position + Vector3.new(0, 3, 0))
            root.AssemblyLinearVelocity = Vector3.zero
            task.wait(0.15)
        end
        if turboSafeEquip(wrongMedicine) then
            local activeTool = LocalPlayer.Character:FindFirstChildOfClass("Tool")
            if activeTool and activeTool.Name == wrongMedicine then
                setStatus("MENYUNTIKKAN RACUN: " .. wrongMedicine)
                simpleInteract(bed.PP, 0.1, false)
                task.wait(2)
                setStatus("--- ANOMALI HANGUS! ---")
                clearGracePeriod(roomKey)
                return true
            end
        end
    end
    return false
end

