-- ==========================================
-- LOGIKA ESP & ANALISA STATUS (MERAH/ORANYE/HIJAU)
-- ==========================================

-- Cek status NPC dan tentukan warna
local function checkNpcStatus(npc)
	local attr = npc:GetAttributes()
	local reasons = {}
	local isMonster = false
	local isPenalty = false

	-- Deteksi Monster Asli
	if attr.Skinwalker then table.insert(reasons, "Skinwalker"); isMonster = true end
	if attr.SkinwalkerEasy then table.insert(reasons, "SkinwalkerEasy"); isMonster = true end
	if attr.PhotoEffect == "CursedPhoto" then table.insert(reasons, "Photo1(Cursed)"); isMonster = true end
	if attr.PhotoEffect2 == "CursedPhoto" then table.insert(reasons, "Photo2(Cursed)"); isMonster = true end

	-- Deteksi Manusia Bermasalah (Salah Dokumen)
	if attr.PenaltyWhenLettingIn then 
		table.insert(reasons, "PenaltyWhenLettingIn")
		isPenalty = true 
	end

	-- Menentukan Warna dan Teks berdasarkan hasil deteksi
	if isMonster then
		-- MERAH: Fix Monster / Anomali
		return table.concat(reasons, " | "), Color3.fromRGB(255, 70, 70) 
	elseif isPenalty then
		-- ORANYE: Manusia biasa tapi dokumennya salah
		return "Dokumen Salah / Expired", Color3.fromRGB(255, 170, 0)
	else
		-- HIJAU: Manusia biasa & dokumen aman
		return "Aman (Clear)", Color3.fromRGB(70, 255, 70)
	end
end

local function removeEsp(npc)
	if npc:FindFirstChild("PurityHighlight") then npc.PurityHighlight:Destroy() end
	if npc:FindFirstChild("PurityESP") then npc.PurityESP:Destroy() end
end

local function addEsp(npc, reasonText, espColor)
	if npc:FindFirstChild("PurityHighlight") then return end

	local root = npc.PrimaryPart or npc:FindFirstChild("HumanoidRootPart") or npc:FindFirstChildWhichIsA("BasePart")
	if not root then return end

	-- Highlight dengan warna dinamis
	local highlight = Instance.new("Highlight")
	highlight.Name = "PurityHighlight"
	highlight.FillTransparency = 1
	highlight.OutlineTransparency = 0
	highlight.OutlineColor = espColor -- Warna dari fungsi checkNpcStatus
	highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
	highlight.Parent = npc

	-- Billboard Teks Detail
	local billboard = Instance.new("BillboardGui")
	billboard.Name = "PurityESP"
	billboard.Adornee = root
	billboard.AlwaysOnTop = true
	billboard.Size = UDim2.fromOffset(250, 40)
	billboard.StudsOffset = Vector3.new(0, 3.5, 0)
	billboard.MaxDistance = math.huge
	billboard.Parent = npc

	local label = Instance.new("TextLabel")
	label.BackgroundTransparency = 1
	label.Size = UDim2.fromScale(1, 1)
	label.Font = Enum.Font.GothamBold
	-- Teks Putih untuk alasan agar kontras, warna utama untuk Nama NPC
	label.Text = "[ " .. (npc.Name or "Unknown") .. " ]\n<font size='12' color='#FFFFFF'>" .. reasonText .. "</font>"
	label.RichText = true
	label.TextColor3 = espColor -- Warna judul sesuai status
	label.TextStrokeTransparency = 0
	label.TextScaled = false
	label.TextSize = 14
	label.Parent = billboard
end

local function processNpc(npc)
	if not npc:IsA("Model") then return end
	if npc.Name:lower() == "doctor" then return end -- Abaikan NPC Dokter

	removeEsp(npc)

	if espEnabled then
		local reason, color = checkNpcStatus(npc)
		addEsp(npc, reason, color)
	end
end

local function refreshAllNPCs()
	for _, npc in ipairs(npcsFolder:GetChildren()) do
		processNpc(npc)
	end
end

-- ==========================================
-- FUNGSI TOMBOL GUI
-- ==========================================

ToggleBtn.MouseButton1Click:Connect(function()
	espEnabled = not espEnabled
	
	if espEnabled then
		ToggleBtn.Text = "ESP: ON"
		ToggleBtn.BackgroundColor3 = Color3.fromRGB(70, 200, 70)
		
		_G.PurityESP_ChildConn = npcsFolder.ChildAdded:Connect(function(npc)
			task.wait(0.5) -- Tunggu atribut di-load oleh game
			processNpc(npc)
		end)
	else
		ToggleBtn.Text = "ESP: OFF"
		ToggleBtn.BackgroundColor3 = Color3.fromRGB(70, 70, 70)
		
		if _G.PurityESP_ChildConn then
			_G.PurityESP_ChildConn:Disconnect()
		end
	end
	
	refreshAllNPCs()
end)

