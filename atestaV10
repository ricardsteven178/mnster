            if isAnomaly(pt) then
                local wMed = "Medicine"; for _, v in ipairs(ItemList) do if not table.find(meds, v) then wMed=v break end end
                smartFetch(wMed, {wMed}); teleportTo(Config.CF_R8)
                if safeEquip(wMed) and bed and bed:FindFirstChild("PP") then simpleInteract(bed.PP, 0.1); task.wait(2); break end
            else
                local req = {}; for _, o in ipairs(meds) do req[o] = (req[o] or 0) + 1 end
                local _, cur = checkTotalInv()
                local hav = {}; for _, i in ipairs(cur) do hav[i.Name] = (hav[i.Name] or 0) + 1 end
                
                local mis = false
                for ob, n in pairs(req) do
                    if (hav[ob] or 0) < n then for i=1, (n-(hav[ob] or 0)) do smartFetch(ob, meds); mis=true end end
                end
                if mis then continue end

                local inJ = meds[1]; local app = bed and bed:FindFirstChild("PP")
                if (LocalPlayer.Backpack:FindFirstChild(inJ) or LocalPlayer.Character:FindFirstChild(inJ)) and app then
                    teleportTo(Config.CF_R8)
                    if safeEquip(inJ) then
                        local pv = #meds; simpleInteract(app, 0.1); stT = tick()
                        while true do
                            local nm = getPendingMedsTV(tv and tv:FindFirstChild("UI")); if #nm < pv then break end
                            if isHealingDone(mg) or tick()-stT > 10 then break end
                            task.wait(0.1)
                        end
                    end
                end
            end
        end
    end
end

