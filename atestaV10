local function exeMed(rm, rNum)
    local mg = rm:FindFirstChild("Minigame"); if not mg then return end
    local bed = mg:FindFirstChild("Bed") and mg.Bed:FindFirstChild("InBed")
    LLog("Med", "Mengobati R" .. rNum)
    teleportTo(Config.CF_Med[rNum]); local stT = tick()
    
    while AutoState.Med do
        task.wait(0.2)
        if tick() - stT > Config.StuckTimeout then BuggedRoomBlacklist[rNum]=tick(); break end
        
        local pt, ptPP = getRealPatient(Config.CF_Med[rNum].Position, Config.RadMed)
        if pt and pt:FindFirstChild("Heal", true) then RoomMemory[rNum]=pt; break end
        
        local tvUI = mg:FindFirstChild("TV") and mg.TV:FindFirstChild("Screen", true)
        local meds = getPendingMedsTV(tvUI)
        
        if #meds > 0 then
            if isAnomaly(pt) then
                local wMed = "Medicine"
                for _, v in ipairs(ItemList) do if not table.find(meds, v) then wMed=v break end end
                smartFetch(wMed, {wMed}); teleportTo(bed and bed.CFrame or Config.CF_Med[rNum])
                if safeEquip(wMed) and bed:FindFirstChild("PP") then simpleInteract(bed.PP, 0.1); task.wait(2); RoomMemory[rNum]=pt; break end
            else
                for _, o in ipairs(meds) do
                    if not (LocalPlayer.Backpack:FindFirstChild(o) or LocalPlayer.Character:FindFirstChild(o)) then smartFetch(o, meds) end
                end
                local nMd = getPendingMedsTV(tvUI)
                if #nMd > 0 then
                    teleportTo(bed and bed.CFrame or Config.CF_Med[rNum])
                    if safeEquip(nMd[1]) and bed:FindFirstChild("PP") then LLog("Med", "Suntik "..nMd[1]); simpleInteract(bed.PP, 0.1); task.wait(Config.InjectionDelay) end
                end
            end
        elseif ptPP then
            local act = string.lower(ptPP.ActionText or "")
            if ptPP.Name == "FirePP" or act:match("burns") then
                smartFetch("Ointment", {"Ointment"}); teleportTo(ptPP.Parent and ptPP.Parent:IsA("BasePart") and ptPP.Parent.CFrame or Config.CF_Med[rNum])
                if safeEquip("Ointment") then simpleInteract(ptPP, 3); task.wait(1) end
            elseif act:match("dna") then simpleInteract(ptPP, 0.5); task.wait(1) end
        else
            local mon = mg:FindFirstChild("Monitor"); local pp2 = mon and mon:FindFirstChild("PP2") and (mon.PP2:IsA("ProximityPrompt") and mon.PP2 or mon.PP2:FindFirstChildOfClass("ProximityPrompt"))
            if pp2 then simpleInteract(pp2, 0.2); task.wait(0.5)
            else
                local hUI = tvUI and tvUI:FindFirstChild("UI") and tvUI.UI:FindFirstChild("Healing"); if hUI and hUI.Visible then RoomMemory[rNum]=pt; break end
            end
        end
    end
end

