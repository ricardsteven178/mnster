local function teleportTo(targetCFrame)
    local char = LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if root and targetCFrame then
        root.CFrame = CFrame.new(targetCFrame.Position + Vector3.new(0, 3, 0))
        root.AssemblyLinearVelocity = Vector3.zero
        task.wait(0.1)
    end
end

local function unequipAll()
    pcall(function()
        local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid")
        if hum then hum:UnequipTools(); task.wait(0.1) end
    end)
end

local function safeEquip(itemName)
    local char = LocalPlayer.Character; local bp = LocalPlayer:FindFirstChild("Backpack"); local hum = char and char:FindFirstChild("Humanoid")
    if not hum or not bp then return false end
    if char:FindFirstChild(itemName) then return true end
    hum:UnequipTools(); task.wait(0.1)
    local tool = bp:FindFirstChild(itemName)
    if not tool then return false end
    hum:EquipTool(tool); task.wait(0.2)
    return char:FindFirstChild(itemName) ~= nil
end

local function simpleInteract(prompt, holdTime)
    if not prompt or not prompt:IsA("ProximityPrompt") then return end
    local oldReq = prompt.RequiresLineOfSight; local oldDist = prompt.MaxActivationDistance
    prompt.RequiresLineOfSight = false; prompt.MaxActivationDistance = math.huge
    if type(fireproximityprompt) == "function" then fireproximityprompt(prompt, 1, true)
    else prompt:InputHoldBegan() task.wait(holdTime or 0.2) prompt:InputHoldEnded() end
    prompt.RequiresLineOfSight = oldReq; prompt.MaxActivationDistance = oldDist; task.wait(0.1)
end

-- Deteksi Pasien Anti-Ghost
local function getRealPatient(centerPos, radius)
    local function checkObj(obj)
        if Players:GetPlayerFromCharacter(obj) then return nil end
        local p = obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")
        if p and (p.Position - centerPos).Magnitude <= radius then
            for _, pp in ipairs(obj:GetDescendants()) do
                if pp:IsA("ProximityPrompt") and pp.Enabled then
                    local act = string.lower(pp.ActionText or "")
                    if act:match("dna") or act:match("treat") or act:match("burns") or act:match("inject") or pp.Name == "FirePP" then return obj, pp end
                end
            end
            local fpp = obj:FindFirstChild("PP") or obj:FindFirstChildWhichIsA("ProximityPrompt", true)
            if fpp and fpp.Enabled then return obj, fpp end
        end
        return nil
    end
    if workspace:FindFirstChild("NPCs") then
        for _, n in ipairs(workspace.NPCs:GetChildren()) do local o,p = checkObj(n); if o then return o,p end end
    end
    for _, o in ipairs(workspace:GetChildren()) do
        if o:IsA("Model") and o.Name ~= "Rooms" then local ro, rp = checkObj(o); if ro then return ro, rp end end
    end
    return nil, nil
end

local function isAnomaly(npc)
    if not npc then return false end
    local attr = npc:GetAttributes()
    return attr.Skinwalker or attr.SkinwalkerEasy or attr.PenaltyWhenLettingIn or attr.PhotoEffect == "CursedPhoto" or attr.PhotoEffect2 == "CursedPhoto"
end

local function checkTotalInv()
    local count = 0; local items = {}
    local function p(it) if it:IsA("Tool") and table.find(ItemList, it.Name) then count = count + 1; table.insert(items, it) end end
    local bp = LocalPlayer:FindFirstChild("Backpack"); if bp then for _, v in ipairs(bp:GetChildren()) do p(v) end end
    local char = LocalPlayer.Character; if char then for _, v in ipairs(char:GetChildren()) do p(v) end end
    return count, items
end

local function smartTrash(itemToTrash)
    local tp = nil
    for _, d in ipairs(workspace:GetDescendants()) do
        if d:IsA("ProximityPrompt") and (string.lower(d.ActionText or ""):match("trash") or string.lower(d.Parent and d.Parent.Name or ""):match("trash")) then
            tp = d; break
        end
    end
    if tp and itemToTrash then
        teleportTo(tp.Parent and tp.Parent:IsA("BasePart") and tp.Parent.CFrame or LocalPlayer.Character.PrimaryPart.CFrame)
        if safeEquip(itemToTrash.Name) then simpleInteract(tp, 0); task.wait(0.2); return true end
    end
    return false
end

local function smartFetch(targetName, pendingList)
    local tot, cur = checkTotalInv()
    if tot >= Config.MaxInventory then
        local toTrash = nil
        if pendingList then
            local req = {}; for _, v in ipairs(pendingList) do req[v] = (req[v] or 0) + 1 end
            local hav = {}; for _, v in ipairs(cur) do hav[v.Name] = (hav[v.Name] or 0) + 1 end
            for _, v in ipairs(cur) do if (hav[v.Name] or 0) > (req[v.Name] or 0) then toTrash = v; break end end
        end
        if not toTrash then toTrash = cur[1] end
        smartTrash(toTrash)
    end

    local pu = nil
    for _, d in ipairs(workspace:GetDescendants()) do
        if d:IsA("ProximityPrompt") and (d.Parent.Name == targetName or (d.ObjectText or ""):match(targetName) or (d.ActionText or ""):match(targetName)) then
            pu = d; break
        end
    end
    if pu then
        unequipAll()
        teleportTo(pu.Parent and pu.Parent:IsA("BasePart") and pu.Parent.CFrame or LocalPlayer.Character.PrimaryPart.CFrame)
        simpleInteract(pu, 0); task.wait(0.2); return true
    end
    return false
end

local function getPendingMedsTV(ui)
    local pend = {}; local inv = ui and ui:FindFirstChild("inv", true)
    if inv then
        for _, r in ipairs(inv:GetChildren()) do
            if table.find(ItemList, r.Name) then
                local chk = r:FindFirstChild("check")
                if not chk or not chk.Visible then table.insert(pend, r.Name) end
            end
        end
    end
    return pend
end

local function isHealingDone(mg)
    if not mg then return false end
    local h = mg:FindFirstChild("TV") and mg.TV:FindFirstChild("Screen") and mg.TV.Screen:FindFirstChild("UI") and mg.TV.Screen.UI:FindFirstChild("Healing")
    return h and h:IsA("GuiObject") and h.Visible
end

local function getShift()
    local pGui = LocalPlayer:FindFirstChild("PlayerGui"); local sUI = pGui and pGui:FindFirstChild("Shift")
    local h = sUI and sUI:FindFirstChild("Frame") and sUI.Frame:FindFirstChild("header")
