	if string.find(obj.Name, "CoffeeMachine") then setupMachine(obj) end
end

local addedConn = miscFolder.ChildAdded:Connect(function(obj)
	if isAutoRunning and string.find(obj.Name, "CoffeeMachine") then
		task.wait(1) 
		setupMachine(obj)
	end
end)
table.insert(connections, addedConn)

task.spawn(function()
	while isAutoRunning do
		updateMachineStatusUI() 
		handleCoffeeDrinking()
		
		if isSystemActive and countMyCoffee() < Config.MaxKopiDiTas then
			for _, machine in ipairs(trackedMachines) do
				if isMachineReady(machine) then
					-- 🛡️ SERVER SYNC DELAY: Wajib tunggu 2.5 Detik agar Server sadar kopi sudah matang
					ActionLog.Text = "⏳ Menunggu Sinkronisasi Server..."
					task.wait(Config.ServerSyncDelay)
					
					-- Setelah menunggu, pastikan teks masih "ready"
					if isMachineReady(machine) then
						takeCoffee(machine)
					end
					
					task.wait(1) 
					if countMyCoffee() >= Config.MaxKopiDiTas then break end
				end
			end
		end
		
		task.wait(1) 
	end
end)

