local function isMachineReady(machine)
	local statusUI = machine:FindFirstChild("Attachment") 
		and machine.Attachment:FindFirstChild("UI") 
		and machine.Attachment.UI:FindFirstChild("status")

	if statusUI then
		local cleanText = string.lower(string.gsub(statusUI.Text, "<[^>]+>", ""))
		
		-- Kalau ada "brewing" atau ada angka (countdown), langsung tolak
		if string.find(cleanText, "brewing") or string.match(cleanText, "%d+") then
			return false
		end
		
		-- Cuma lolos kalau murni bilang "ready"
		if string.find(cleanText, "ready") then 
			return true 
		end
	end
	return false
end

local function getMachineInfo(machineName)
	local machine = workspace.Misc:FindFirstChild(machineName)
	if not machine then return "-" end
	
	if isMachineReady(machine) then
		return '<font color="rgb(50, 255, 50)">Ready</font>'
	end
	
	local statusUI = machine:FindFirstChild("Attachment") 
		and machine.Attachment:FindFirstChild("UI") 
		and machine.Attachment.UI:FindFirstChild("status")
		
	if statusUI then
		local cleanText = string.gsub(statusUI.Text, "<[^>]+>", "") 
		local timeMatch = string.match(cleanText, "%d+s") 
		if timeMatch then return timeMatch end
	end
	return "Wait"
end

local function updateMachineStatusUI()
	local k1 = getMachineInfo("CoffeeMachine")
	local k2 = getMachineInfo("CoffeeMachine2")
	MachineStatus.Text = "K1: " .. k1 .. " | K2: " .. k2
end

-- ==========================================
-- FUNGSI INVENTORY & SANITY
-- ==========================================
local function countMyCoffee()
	local totalKopi = 0
	local character = LocalPlayer.Character
	local backpack = LocalPlayer:FindFirstChild("Backpack")
	
	if backpack then
		for _, item in pairs(backpack:GetChildren()) do
			if item:IsA("Tool") and string.find(string.lower(item.Name), "coffee") then totalKopi += 1 end
		end
	end
	if character then
		for _, item in pairs(character:GetChildren()) do
			if item:IsA("Tool") and string.find(string.lower(item.Name), "coffee") then totalKopi += 1 end
		end
	end
	return totalKopi
end

local function getCurrentSanity()
	local PlayerGui = LocalPlayer:FindFirstChild("PlayerGui")
	if not PlayerGui then return 100 end
	
	local amountUI = PlayerGui:FindFirstChild("Sanity")
		and PlayerGui.Sanity:FindFirstChild("Frame")
		and PlayerGui.Sanity.Frame:FindFirstChild("Frame")
		and PlayerGui.Sanity.Frame.Frame:FindFirstChild("textbox")
		and PlayerGui.Sanity.Frame.Frame.textbox:FindFirstChild(Config.TargetSanityUI)
		
	if amountUI then
		local num = tonumber(string.match(amountUI.Text, "%d+"))
		return num or 100
	end
	return 100 
end

local function handleCoffeeDrinking()
	if not isSystemActive then return end 
	
	local currentSanity = getCurrentSanity()
	local totalKopi = countMyCoffee()
	
	SanityStatus.Text = "🧠 Sanity: " .. currentSanity .. "% | Limit Tas: " .. Config.MaxKopiDiTas
	FarmStatus.Text = "🎒 Stok Kopi: " .. totalKopi .. " / " .. Config.MaxKopiDiTas
	
	local character = LocalPlayer.Character
	local humanoid = character and character:FindFirstChildOfClass("Humanoid")
	local backpack = LocalPlayer:FindFirstChild("Backpack")
	if not character or not humanoid or not backpack then return end

	if currentSanity <= Config.BatasMinum then
		local heldTool = nil
		for _, item in pairs(character:GetChildren()) do
			if item:IsA("Tool") and string.find(string.lower(item.Name), "coffee") then
				heldTool = item
				break
			end
		end
		
		if not heldTool then
			for _, item in pairs(backpack:GetChildren()) do
				if item:IsA("Tool") and string.find(string.lower(item.Name), "coffee") then
					humanoid:EquipTool(item)
					heldTool = item
					task.wait(0.2) 
					break
				end
			end
		end
		
		if heldTool then
			heldTool:Activate() 
			ActionLog.Text = "☕ Teguk Kopi! Sanity: " .. currentSanity .. "%"
			task.wait(Config.JedaMinum) 
		end
	else
		for _, item in pairs(character:GetChildren()) do
			if item:IsA("Tool") and string.find(string.lower(item.Name), "coffee") then
				humanoid:UnequipTools()
				break
			end
		end
	end
end

-- ==========================================
-- LOGIKA TELEPORT & AMBIL KOPI 
-- ==========================================
local coffeeStandCFrame = CFrame.new(-120.387688, 3.41253161, 8.78784466, -0.144494131, 3.65239181e-08, 0.989505649, -4.04447071e-08, 1, -4.28172804e-08, -0.989505649, -4.62071128e-08, -0.144494131)

local function takeCoffee(machine)
	if not isAutoRunning or not isSystemActive then return end
	if countMyCoffee() >= Config.MaxKopiDiTas then return end
	
	-- Cek Teks (Harus murni ready)
	if not isMachineReady(machine) then return end

	-- 🛡️ MENCARI PROMPT YANG BENAR (Filter Teks Prompt)
	local prompt = nil
	for _, obj in pairs(machine:GetDescendants()) do
		if obj:IsA("ProximityPrompt") and obj.Enabled then
			local actText = string.lower(obj.ActionText)
			local objText = string.lower(obj.ObjectText)
			-- Jangan ambil prompt yang punya teks Instant, Buy, atau Robux
			if not string.find(actText, "buy") and not string.find(objText, "instant") then
				prompt = obj
				break
			end
		end
	end

	if not prompt then return end

	local character = LocalPlayer.Character
	local rootPart = character and character:FindFirstChild("HumanoidRootPart")
	
	if rootPart then
		local originalPos = rootPart.CFrame
		rootPart.CFrame = coffeeStandCFrame
		
		task.wait(Config.DelayTeleport) 
		
		-- Cek terakhir sebelum ngeklik!
		if isMachineReady(machine) and prompt.Enabled then
			fireproximityprompt(prompt)
			ActionLog.Text = "⚡ Mengambil Kopi dari " .. machine.Name
		else
			ActionLog.Text = "🛑 Batal! Mesin nge-glitch (Desync)."
		end
		
		task.wait(Config.DelayKembali)
		rootPart.CFrame = originalPos
	end
end

local function setupMachine(machine)
	if machine:GetAttribute("TrackedByV14") then return end
	machine:SetAttribute("TrackedByV14", true)
	table.insert(trackedMachines, machine)
end

