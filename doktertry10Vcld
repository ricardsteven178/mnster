                local hasNPC = bed and isAnyNPCNearPosition(bed.Position, Config.PatientBedRadius)

                if isBlacklisted then
                    status = "[BLACKLIST]"
                elseif healing then
                    status = "[HEALING✓]"
                elseif medsDone then
                    status = "[OBAT SELESAI→Healing]"
                elseif _G.AutoDoctor_RoomMemory[i] == "PatientLeaving" then
                    status = "[PASIEN KELUAR]"
                elseif ready then
                    status = "[BUTUH: " .. reason .. "]"
                elseif hasNPC then
                    status = "[PASIEN ADA/PROSES]"
                elseif isLightRed then
                    status = "[PASIEN BARU MENUJU]"
                else
                    status = "[Kosong]"
                end
            end
            report = report .. "M" .. i .. ":" .. status .. " "
        end
    end
    local emergency = rooms and rooms:FindFirstChild("Emergency")
    if emergency then
        for _, rn in ipairs(Config.EmergencyRooms) do
            local room = emergency:FindFirstChild("Room" .. rn)
            local status = "[-]"
            if room then
                local signLight = room:FindFirstChild("MainSign") and room.MainSign:FindFirstChild("Light")
                local isLightRed = signLight and (signLight.BrickColor.Name == "Crimson" or signLight.Color == Color3.fromRGB(165, 0, 0))
                local minigame = room:FindFirstChild("Minigame")
                local bed = minigame and minigame:FindFirstChild("Bed") and minigame.Bed:FindFirstChild("InBed")
                local bedPos = bed and bed.Position
                if not bedPos and room.PrimaryPart then bedPos = room.PrimaryPart.Position end
                local hasNPC = bedPos and isAnyNPCNearPosition(bedPos, Config.PatientBedRadius)
                if hasNPC then status = "[AKTIF-PASIEN]"
                elseif isLightRed then status = "[LAMPU MERAH]"
                else status = "[Kosong]" end
            end
            report = report .. "E" .. rn .. ":" .. status .. " "
        end
    end
    if forceprint or _G.LastRadarReport ~= report then
        _G.LastRadarReport = report
        print("[" .. os.date("%H:%M:%S") .. "] [AutoDoctor] " .. report)
    end
end

-- ==========================================
-- EMERGENCY R6 & R7 TREATMENT
--
-- R6 (X-Ray room): Bypass "Begin X-Ray"
--   → Force-trigger Monitor's "process" prompt (force Enabled=true like R6 standalone)
--   → Wait for + collect Printer.PP
--   → Fetch obat + inject ke pasien
--
-- R7 (Prepare room): Bypass "Prepare Patient"
--   → Detect early-step prompts (prepare/set up/begin/turn on)
--   → Force-enable + trigger "process" prompt on Monitor
--   → Collect naturally when it appears
--   → Fetch obat + inject ke pasien
-- ==========================================
local function executeEmergencyTreatment67(roomPath, roomNum, activeShift)
    local roomKey = "E" .. roomNum
    local minigame = roomPath:FindFirstChild("Minigame")
    if not minigame then return end

    local monitor = minigame:FindFirstChild("Monitor")
    local printer = minigame:FindFirstChild("Printer")
    local bed = minigame:FindFirstChild("Bed") and minigame.Bed:FindFirstChild("InBed")

    -- Robust bedCenterPos fallback
    local bedCenterPos = nil
    if bed then bedCenterPos = bed.Position
    elseif minigame then
        local anyBed = minigame:FindFirstChild("Bed")
        if anyBed and anyBed:IsA("BasePart") then bedCenterPos = anyBed.Position
        elseif anyBed then
            local bp = anyBed:FindFirstChildWhichIsA("BasePart", true)
            if bp then bedCenterPos = bp.Position end
        end
    end
    if not bedCenterPos and roomPath.PrimaryPart then bedCenterPos = roomPath.PrimaryPart.Position end
    if not bedCenterPos then
        local ap = roomPath:FindFirstChildWhichIsA("BasePart", true)
        if ap then bedCenterPos = ap.Position end
    end

    local roomLabel = roomNum == 6 and "Emergency R6 (X-Ray Bypass)" or "Emergency R7 (Prepare Bypass)"
    setStatus("--- " .. roomLabel .. " ---")
    setRoomLabel(roomLabel)

    local root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if root and bedCenterPos then
        root.CFrame = CFrame.new(bedCenterPos + Vector3.new(0, 3, 0))
        root.AssemblyLinearVelocity = Vector3.zero
        task.wait(0.2)
    end

    -- Tunggu pasien datang — simple NPC proximity
    setStatus("R" .. roomNum .. ": Menunggu pasien datang...")
    local waitNPC = 0
    local patientFound = false
    while waitNPC < 40 do
        if getShiftText() ~= activeShift then return end
        if bedCenterPos and isAnyNPCNearPosition(bedCenterPos, Config.PatientBedRadius) then
            patientFound = true
            markPatientEntered(roomKey)
            forceResetHealingVisible(minigame)
            setStatus("R" .. roomNum .. ": Pasien terdeteksi! Mulai bypass...")
            break
        end
        task.wait(0.5); waitNPC = waitNPC + 1; _G.AutoDoctor_LastActionTick = tick()
    end

    if not patientFound then
        setStatus("R" .. roomNum .. ": Pasien tidak datang, skip.")
        return
    end

    task.wait(0.3)
    unequipAll()

    -- Helper: cari "process" prompt di Monitor
    local function findProcessPrompt()
        if not monitor then return nil end
        for _, desc in ipairs(monitor:GetDescendants()) do
            if desc:IsA("ProximityPrompt") then
                if string.lower(desc.ActionText or ""):match("process") then return desc end
            end
        end
        return nil
    end

    -- Helper: cari "collect" prompt di Printer
    local function findCollectPrompt()
        if not printer then return nil end
        for _, desc in ipairs(printer:GetDescendants()) do
            if desc:IsA("ProximityPrompt") then
                local txt = string.lower(desc.ActionText or "")
                if txt:match("collect") or txt:match("take") or txt:match("grab") then return desc end
            end
        end
        return printer:FindFirstChild("PP")
    end

    -- BYPASS PHASE
    local bypassDone = false
    local bypassAttempts = 0

    while not bypassDone and bypassAttempts < 10 do
        if getShiftText() ~= activeShift then return end
        bypassAttempts = bypassAttempts + 1

        -- Cek collect sudah muncul
        local collectPP = findCollectPrompt()
        if collectPP and collectPP.Enabled then
            setStatus("R" .. roomNum .. ": Collect aktif, bypass selesai!")
            bypassDone = true; break
        end

        -- Cek TV sudah ada resep
        local tvCheck = minigame:FindFirstChild("TV") and minigame.TV:FindFirstChild("Screen", true)
        local tvMeds = getPendingMedicines(tvCheck)
        if tvMeds and #tvMeds > 0 then
            setStatus("R" .. roomNum .. ": TV resep sudah muncul!")
            bypassDone = true; break
        end

        local processPP = findProcessPrompt()

        if roomNum == 7 then
            -- R7: cek ada early-step prompt
            local hasEarlyStep = false
            for _, desc in ipairs(minigame:GetDescendants()) do
                if desc:IsA("ProximityPrompt") and desc.Enabled then
                    local txt = string.lower(desc.ActionText or "")
                    if txt:match("prepare") or txt:match("set up") or txt:match("turn on") or txt:match("begin") then
                        hasEarlyStep = true; break
                    end
                end
            end
            if hasEarlyStep and processPP then
                setStatus("R7: BYPASS — Force trigger Process (skip Prepare " .. bypassAttempts .. ")...")
                local oldEnabled = processPP.Enabled
                processPP.Enabled = true
                firePromptRaw(processPP)
                processPP.Enabled = oldEnabled
                task.wait(1)
            elseif processPP and processPP.Enabled then
                setStatus("R7: Process aktif natural, trigger...")
                firePromptRaw(processPP)
                task.wait(1)
            else
                task.wait(0.8)
            end
        else
            -- R6: paksa trigger "process" di Monitor (force Enabled=true)
            if processPP then
                setStatus("R6: BYPASS — Force trigger Process (skip X-Ray " .. bypassAttempts .. ")...")
                local oldEnabled = processPP.Enabled
                processPP.Enabled = true
                firePromptRaw(processPP)
                processPP.Enabled = oldEnabled
                task.wait(1)
            else
                setStatus("R6: Mencari Monitor process prompt... (" .. bypassAttempts .. ")")
                task.wait(0.8)
            end
        end
    end

    -- COLLECT PHASE
    local collectPP = findCollectPrompt()
    if collectPP then
        setStatus("R" .. roomNum .. ": Menunggu Collect aktif...")
        local waitC = 0
        while not collectPP.Enabled and waitC < 25 do
            if getShiftText() ~= activeShift then return end
            task.wait(0.3); waitC = waitC + 1; _G.AutoDoctor_LastActionTick = tick()
        end
        if collectPP.Enabled then
            setStatus("R" .. roomNum .. ": Trigger Collect!")
            firePromptRaw(collectPP)
            task.wait(0.8)
            if collectPP.Enabled then firePromptRaw(collectPP); task.wait(0.5) end
        end
    end

    -- Tunggu TV resep
    setStatus("R" .. roomNum .. ": Menunggu TV resep...")
    local tvUI = minigame:FindFirstChild("TV") and minigame.TV:FindFirstChild("Screen", true)
    local waitTV = 0
    while waitTV < 20 do
        if getShiftText() ~= activeShift then return end
        tvUI = minigame:FindFirstChild("TV") and minigame.TV:FindFirstChild("Screen", true)
        local meds = getPendingMedicines(tvUI)
        if meds and #meds > 0 then setStatus("R" .. roomNum .. ": Resep muncul (" .. #meds .. " obat)!"); break end
        task.wait(0.5); waitTV = waitTV + 1; _G.AutoDoctor_LastActionTick = tick()
    end

    -- Treatment loop: fetch + inject
    local lastProgressTimeRef = {tick()}
    local stuckTimer = tick()

    while true do
        task.wait(0.1)
        if getShiftText() ~= activeShift then setStatus("Shift berganti."); break end
        if tick() - stuckTimer >= Config.StuckTimeout then
            setStatus("Timeout R" .. roomNum .. "! Skip.")
            BuggedRoomBlacklist[roomNum] = tick()
            clearGracePeriod(roomKey)
            break
        end

        if isHealingDone(minigame, roomPath, bed, roomNum, roomKey) then
            setStatus("Pasien R" .. roomNum .. " sembuh!")
            _G.AutoDoctor_RoomMemory[roomNum] = "PatientLeaving"
            clearGracePeriod(roomKey)
            break
        end

        tvUI = minigame:FindFirstChild("TV") and minigame.TV:FindFirstChild("Screen", true)
        local pendingMeds = getPendingMedicines(tvUI)

        if #pendingMeds > 0 then
            if checkAnomalyStatus(bed, bedCenterPos) then
                local killed = handleAnomaly(bed, pendingMeds, nil, roomPath, roomKey, activeShift)
                if killed then _G.AutoDoctor_RoomMemory[roomNum] = "PatientLeaving" end
                break
            else
                runFetchPhase(pendingMeds)
                runInjectPhase(tvUI, bed, minigame, roomPath, roomNum, roomKey, activeShift, lastProgressTimeRef, true)
                stuckTimer = lastProgressTimeRef[1]
            end
        else
            task.wait(0.5)
        end
    end
end

-- ==========================================
-- ROOM 8 SURGERY TREATMENT
-- ==========================================
local function executeRoom8Treatment(room8, activeShift)
    local roomKey = "E8"
    local minigame = room8:FindFirstChild("Minigame")
    if not minigame or getShiftText() ~= activeShift then return end

    setStatus("--- ROOM 8: TURBO SURGERY ---")
    setRoomLabel("Emergency Room 8 (Surgery)")

    local root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if root then
        root.CFrame = Config.Room8BedCFrame
        root.AssemblyLinearVelocity = Vector3.zero
    end

    local tvUI = minigame:FindFirstChild("TV") and minigame.TV:FindFirstChild("Screen") and minigame.TV.Screen:FindFirstChild("UI")
    local reportFolder = tvUI and tvUI:FindFirstChild("Report")
    local treatmentText = reportFolder and reportFolder:FindFirstChild("treatment")
    local bed = minigame:FindFirstChild("Bed") and minigame.Bed:FindFirstChild("InBed")

    setStatus("R8: Menunggu pasien...")
    local waitNPC = 0
    while waitNPC < 30 do
        if getShiftText() ~= activeShift then return end
        if workspace:FindFirstChild("NPCs") then
            for _, npc in ipairs(workspace.NPCs:GetChildren()) do
                local part = npc.PrimaryPart or npc:FindFirstChildWhichIsA("BasePart")
                if part and (part.Position - Config.Room8BedCFrame.Position).Magnitude < Config.PatientBedRadius then
                    markPatientEntered(roomKey)
                    waitNPC = 999; break
                end
            end
        end
        if waitNPC ~= 999 then task.wait(0.5); waitNPC = waitNPC + 1; _G.AutoDoctor_LastActionTick = tick() end
    end

    if waitNPC ~= 999 and waitNPC >= 30 then setStatus("BATAL R8: Pasien gagal sampai."); return end

    setStatus("R8: Menidurkan pasien...")
    local sleepLimit = 0
    while treatmentText and treatmentText.Text ~= "BEGIN SURGERY:" and sleepLimit < 40 do
        if isHealingDone(minigame, room8, bed, 8, roomKey) or getShiftText() ~= activeShift then return end
        local sleepPP = bed and bed:FindFirstChild("PP2")
        if sleepPP and sleepPP.Enabled then simpleInteract(sleepPP, 0.1, false) end
        _G.AutoDoctor_LastActionTick = tick()
        task.wait(0.2); sleepLimit = sleepLimit + 1
    end

    setStatus("R8: Mulai Treatment Loop...")
    local lastProgressTimeRef = {tick()}

    while true do
        task.wait(0.05)
        _G.AutoDoctor_LastActionTick = tick()

        if getShiftText() ~= activeShift then setStatus("Shift berganti."); break end
        if isHealingDone(minigame, room8, bed, 8, roomKey) then
            setStatus("R8: Surgery Selesai!")
            clearGracePeriod(roomKey)
            break
        end

        local signLight = room8:FindFirstChild("MainSign") and room8.MainSign:FindFirstChild("Light")
        if not signLight or (signLight.BrickColor.Name ~= "Crimson" and signLight.Color ~= Color3.fromRGB(165, 0, 0)) then break end

        if tick() - lastProgressTimeRef[1] >= Config.StuckTimeout then setStatus("R8: Timeout! Skip."); break end

        local pendingMeds = getPendingMedicines(reportFolder)

        if checkAnomalyStatus(bed, Config.Room8BedCFrame.Position) and #pendingMeds > 0 then
            local wrongMedicine = "Medicine"
            for _, item in ipairs(ItemList) do
                if not table.find(pendingMeds, item) then wrongMedicine = item; break end
            end
            if not (LocalPlayer.Backpack:FindFirstChild(wrongMedicine) or LocalPlayer.Character:FindFirstChild(wrongMedicine)) then
                fetchItem(wrongMedicine, {wrongMedicine})
            end
            if root then root.CFrame = Config.Room8BedCFrame; root.AssemblyLinearVelocity = Vector3.zero; task.wait(0.1) end
            if turboSafeEquip(wrongMedicine) then
                setStatus("R8: MENYUNTIKKAN RACUN: " .. wrongMedicine)
                simpleInteract(bed.PP, 0.1, false)
                lastProgressTimeRef[1] = tick()
                task.wait(1.5)
                setStatus("R8: ANOMALI HANGUS!")
                clearGracePeriod(roomKey)
                break
            end
        elseif #pendingMeds > 0 then
            local reqCounts = {}
            local _, currentItems = checkTotalInventory()
            local haveCounts = {}
            for _, obat in ipairs(pendingMeds) do reqCounts[obat] = (reqCounts[obat] or 0) + 1 end
            for _, item in ipairs(currentItems) do haveCounts[item.Name] = (haveCounts[item.Name] or 0) + 1 end
            for obat, needed in pairs(reqCounts) do
                local have = haveCounts[obat] or 0
                for _ = 1, math.max(0, needed - have) do fetchItem(obat, pendingMeds) end
            end

            if root then root.CFrame = Config.Room8BedCFrame; root.AssemblyLinearVelocity = Vector3.zero; task.wait(0.1) end
            local obatToInject = pendingMeds[1]
            if (LocalPlayer.Backpack:FindFirstChild(obatToInject) or LocalPlayer.Character:FindFirstChild(obatToInject)) and bed and bed:FindFirstChild("PP") then
                if turboSafeEquip(obatToInject) then
                    task.wait(0.1)
                    local prevCount = #pendingMeds
                    setStatus("R8: Apply: " .. obatToInject)
                    simpleInteract(bed.PP, 0.1, false)
                    lastProgressTimeRef[1] = tick()
                    local wc = 0
                    while wc < 30 do
                        local newP = getPendingMedicines(reportFolder)
                        if #newP < prevCount then break end
                        if isHealingDone(minigame, room8, bed, 8, roomKey) or getShiftText() ~= activeShift then break end
                        task.wait(0.05); wc = wc + 1; _G.AutoDoctor_LastActionTick = tick()
                    end
                else
                    setStatus("R8: FAILSAFE equip " .. obatToInject); task.wait(0.5)
                end
            else
                setStatus("R8: Retry fetch " .. obatToInject); task.wait(0.5)
            end
        end
    end
end

-- ==========================================
-- MEDICAL ROOM 1-5 TREATMENT ENGINE
-- ==========================================
local function executeMedicalTreatment(roomPath, roomNum, activeShift)
    local roomKey = "M" .. roomNum
    local minigame = roomPath:FindFirstChild("Minigame")
    if not minigame then return end
    local bed = minigame:FindFirstChild("Bed") and minigame.Bed:FindFirstChild("InBed")

    setStatus("--- PENGOBATAN: " .. roomPath.Name .. " ---")
    setRoomLabel("Medical Room " .. roomNum)
    teleportToRoomCenter(roomNum, roomPath)

    local patientMarked = false
    local lastProgressTimeRef = {tick()}
    local justProcessedTick = 0

    while true do
        task.wait(0.1)

        if getShiftText() ~= activeShift then setStatus("Shift berganti!"); break end
        if getFireEmergency() or getPlacePatientPrompt() then setStatus("INTERUPSI DARURAT!"); break end

        local currentPatient = getPatientInRoom(roomNum, roomPath, bed, nil)
        if not currentPatient then
            local signLight = roomPath:FindFirstChild("MainSign") and roomPath.MainSign:FindFirstChild("Light")
            local isLightRed = signLight and (signLight.BrickColor.Name == "Crimson" or signLight.Color == Color3.fromRGB(165, 0, 0))
            if isLightRed then
                setStatus("Pasien menuju kasur..."); task.wait(1)
            else
                setStatus("Kamar kosong/Ghost! Skip.")
                BuggedRoomBlacklist[roomNum] = tick()
                clearGracePeriod(roomKey)
                break
            end
        else
            -- Mark grace period the moment patient NPC is first detected
            if not patientMarked then
                patientMarked = true
                markPatientEntered(roomKey)
            end
        end

        if isHealingDone(minigame, roomPath, bed, roomNum, roomKey) then
            if tick() - justProcessedTick < 5 then
                setStatus("Menunggu sinkronisasi TV..."); task.wait(1)
            else
                setStatus("Pasien Sembuh!")
                _G.AutoDoctor_RoomMemory[roomNum] = "PatientLeaving"
                _G.AutoDoctor_MedsDone = _G.AutoDoctor_MedsDone or {}
                _G.AutoDoctor_MedsDone[roomNum] = nil
                clearGracePeriod(roomKey)
                break
            end
        end

        if tick() - lastProgressTimeRef[1] >= Config.StuckTimeout then
            setStatus("Timeout! Skip.")
            BuggedRoomBlacklist[roomNum] = tick()
            clearGracePeriod(roomKey)
            break
        end

        local tvUI = minigame:FindFirstChild("TV") and minigame.TV:FindFirstChild("Screen", true)
        local pendingMeds = getPendingMedicines(tvUI)

        local reportFolder = tvUI and tvUI:FindFirstChild("Report")
        if reportFolder and reportFolder:IsA("GuiObject") and reportFolder.Visible and #pendingMeds == 0 then
            setStatus("Menunggu layar Recovering..."); task.wait(0.5); continue
        end

        local hasTasks, reason = isPatientReady(roomPath, bed)

        if hasTasks then
            if reason == "TV Aktif (Butuh Obat)" then
                if checkAnomalyStatus(bed, nil) then
                    local killed = handleAnomaly(bed, pendingMeds, roomNum, roomPath, roomKey, activeShift)
                    if killed then _G.AutoDoctor_RoomMemory[roomNum] = "PatientLeaving"; break end
                else
                    if #pendingMeds > 0 then
                        runFetchPhase(pendingMeds)
                        runInjectPhase(tvUI, bed, minigame, roomPath, roomNum, roomKey, activeShift, lastProgressTimeRef, false)
                        justProcessedTick = tick()
                    end
                end
            else
                local acted = false
                local prompts = getPromptsNearBed(roomPath, bed)
                local handledBurn = false

                for _, desc in ipairs(prompts) do
                    local actText = string.lower(desc.ActionText or "")
                    local name = string.lower(desc.Name or "")
                    if name == "firepp" or actText:match("burns") then
                        if not (LocalPlayer.Backpack:FindFirstChild("Ointment") or LocalPlayer.Character:FindFirstChild("Ointment")) then
                            fetchItem("Ointment", {"Ointment"})
                        end
                        teleportToRoomCenter(roomNum, roomPath)
                        if turboSafeEquip("Ointment") then
                            local activeTool = LocalPlayer.Character:FindFirstChildOfClass("Tool")
                            if activeTool and activeTool.Name == "Ointment" then
                                setStatus("Mengoleskan Ointment...")
                                simpleInteract(desc, 3, false)
                                -- Poll sampai FirePP hilang — jangan anggap selesai sampai prompt benar-benar gone
                                local burnWait = 0
                                while burnWait < 60 do
                                    task.wait(0.2)
                                    burnWait = burnWait + 1
                                    _G.AutoDoctor_LastActionTick = tick()
                                    -- Cek apakah prompt burns masih ada
                                    local stillBurning = false
                                    local freshPrompts = getPromptsNearBed(roomPath, bed)
                                    for _, fp in ipairs(freshPrompts) do
                                        local fat = string.lower(fp.ActionText or "")
                                        local fn = string.lower(fp.Name or "")
                                        if fn == "firepp" or fat:match("burns") then
                                            stillBurning = true; break
                                        end
                                    end
                                    if not stillBurning then
                                        setStatus("Burns selesai! Lanjut treatment...")
                                        lastProgressTimeRef[1] = tick()
                                        break
                                    end
                                    -- Re-apply ointment kalau prompt masih ada
                                    if burnWait % 10 == 0 then
                                        local hasSalep = LocalPlayer.Backpack:FindFirstChild("Ointment") or LocalPlayer.Character:FindFirstChild("Ointment")
                                        if not hasSalep then fetchItem("Ointment", {"Ointment"}) end
                                        if turboSafeEquip("Ointment") then
                                            local reTool = LocalPlayer.Character:FindFirstChildOfClass("Tool")
                                            if reTool and reTool.Name == "Ointment" and desc and desc.Parent then
                                                setStatus("Re-apply Ointment...")
                                                simpleInteract(desc, 3, false)
                                            end
                                        end
                                    end
                                end
                                handledBurn = true; break
                            end
                        end
                    end
                end

                if not handledBurn then
                    local monitor = minigame:FindFirstChild("Monitor")
                    local pp2_obj = monitor and monitor:FindFirstChild("PP2")
                    local actualPP2 = pp2_obj and (pp2_obj:IsA("ProximityPrompt") and pp2_obj or pp2_obj:FindFirstChildOfClass("ProximityPrompt"))

                    if actualPP2 then
                        local monitorScreen = monitor:FindFirstChild("Screen")
                        local monitorUI = monitorScreen and monitorScreen:FindFirstChild("UI")
                        local isMonitorBusy = monitorUI and (monitorUI.Enabled or (monitorUI:FindFirstChild("Report") and monitorUI.Report.Visible))
                        if monitorScreen and not isMonitorBusy then
                            for _, desc in ipairs(monitorScreen:GetDescendants()) do
                                if desc:IsA("TextLabel") and desc.Name == "header" and desc.Text:match("Finalizing") then
                                    isMonitorBusy = true; break
                                end
                            end
                        end
                        local tvScreen = minigame:FindFirstChild("TV") and minigame.TV:FindFirstChild("Screen")
                        local activeTvUI = tvScreen and tvScreen:FindFirstChild("UI")
                        local isTVBusy = activeTvUI and activeTvUI:IsA("SurfaceGui") and activeTvUI.Enabled

                        if isMonitorBusy or isTVBusy then
                            setStatus("Menunggu Lab/TV diproses..."); task.wait(1); acted = true
                        else
                            unequipAll(); teleportToRoomCenter(roomNum, roomPath); task.wait(0.5)
                            setStatus("BYPASS: Trigger Process Results...")
                            local bypassSuccess = false
                            for retry = 1, 3 do
                                firePromptRaw(actualPP2); task.wait(0.5)
                                local cekScreen = monitor:FindFirstChild("Screen")
                                if cekScreen then
                                    local ui = cekScreen:FindFirstChild("UI")
                                    if ui and ((ui:IsA("SurfaceGui") and ui.Enabled) or (ui:FindFirstChild("Report") and ui.Report.Visible)) then
                                        bypassSuccess = true
                                    end
                                    if not bypassSuccess then
                                        for _, desc in ipairs(cekScreen:GetDescendants()) do
                                            if desc:IsA("TextLabel") and desc.Name == "header" and desc.Text:match("Finalizing") then
                                                bypassSuccess = true; break
                                            end
                                        end
                                    end
                                end
                                if bypassSuccess then break end
                                setStatus("Bypass retry (" .. retry .. "/3)...")
                            end
                            if bypassSuccess then setStatus("Bypass OK!"); justProcessedTick = tick()
                            else setStatus("GAGAL Bypass Monitor.") end
                            acted = true
                        end
                    else
                        setStatus("Menunggu Monitor Siap..."); acted = false
                    end
                else
                    acted = true
                end
                if acted then lastProgressTimeRef[1] = tick(); task.wait(0.5) end
            end
        else
            task.wait(1)
        end
    end
end

-- ==========================================
-- FAINTING PATIENT HANDLER
-- ==========================================
local function processFaintedPatient(faintedPart, carryPP, activeShift)
    setStatus("! PRIORITAS 2: Pasien Pingsan !")
    unequipAll()
    teleportTo(faintedPart.PrimaryPart or faintedPart:FindFirstChildWhichIsA("BasePart"))
    simpleInteract(carryPP, 0, true)
    task.wait(1.5)
    local placePrompt, targetRoomName, targetRoomNum, targetRoomPath
    local waitLimit = 0
    while not placePrompt and waitLimit < 20 do
        if getShiftText() ~= activeShift then return end
        setStatus("Mencari kasur kosong...")
        placePrompt, targetRoomName, targetRoomNum, targetRoomPath = getPlacePatientPrompt()
        if not placePrompt then task.wait(1.5); waitLimit = waitLimit + 1; _G.AutoDoctor_LastActionTick = tick() end
        task.wait(0.1)
    end
    if placePrompt and targetRoomNum and targetRoomPath then
        setStatus("Bawa ke " .. targetRoomName)
        unequipAll(); teleportToRoomCenter(targetRoomNum, targetRoomPath); task.wait(0.3)
        simpleInteract(placePrompt, 1, true); task.wait(1.5)
        setStatus("Pasien ditempatkan!")
    else
        setStatus("GAGAL menaruh pasien.")
    end
end

-- ==========================================
-- MAIN BOT CYCLE
-- ==========================================
local function botCycle()
    local activeShift = getShiftText()
    local fireNPC, firePP = getFireEmergency()
    if fireNPC then
        _G.AutoDoctor_IsIdle = false
        pcall(function()
            unequipAll()
            setStatus("! PRIORITAS 1: Padamkan Pasien Terbakar !")
            simpleInteract(firePP, 3.2, fireNPC.PrimaryPart or fireNPC:FindFirstChildWhichIsA("BasePart"))
            task.wait(1.5)
        end)
        return
    end
    local placePrompt, targetRoomName = getPlacePatientPrompt()
    if placePrompt then
        _G.AutoDoctor_IsIdle = false
        pcall(function()
            unequipAll()
            setStatus("Meletakkan pasien ke " .. tostring(targetRoomName))
            task.wait(0.2); simpleInteract(placePrompt, 1, true); task.wait(1.5)
        end)
        return
    end
    local faintedPart, carryPP = getFaintedPatient()
    if faintedPart then
        _G.AutoDoctor_IsIdle = false
        pcall(function() processFaintedPatient(faintedPart, carryPP, activeShift) end)
        return
    end
    local emergRoom, emergNum = findEmergencyRoom()
    if emergRoom and emergNum then
        _G.AutoDoctor_IsIdle = false
        if emergNum == 8 then
            pcall(function() executeRoom8Treatment(emergRoom, activeShift) end)
        else
            pcall(function() executeEmergencyTreatment67(emergRoom, emergNum, activeShift) end)
        end
        return
    end
    local medRoom, medRoomNum = findMedicalRoom()
    if medRoom and medRoomNum then
        _G.AutoDoctor_IsIdle = false
        pcall(function() executeMedicalTreatment(medRoom, medRoomNum, activeShift) end)
        return
    end
    if not _G.AutoDoctor_IsIdle then
        unequipAll(); teleportToIdle(); _G.AutoDoctor_IsIdle = true; setRoomLabel("-")
        -- Reset LastStatus agar "Idle" selalu terprint saat pertama kali idle
        _G.LastStatus = ""
        setStatus("Idle (Memantau)...")
        -- Force print radar report saat pertama masuk idle
        printRadarReport(true)
    else
        setStatus("Idle (Memantau)...")
        printRadarReport()
    end
    task.wait(Config.ScanDelay)
end

-- ==========================================
-- WORKER & WATCHDOG
-- ==========================================
local function startWorker()
    if _G.AutoDoctor_Worker then task.cancel(_G.AutoDoctor_Worker) end
    _G.AutoDoctor_Worker = task.spawn(function()
        while autoScanEnabled do
            if not isBusy then
                isBusy = true
                _G.AutoDoctor_LastActionTick = tick()
                pcall(botCycle)
                isBusy = false
            end
            task.wait(0.1)
        end
    end)
end

