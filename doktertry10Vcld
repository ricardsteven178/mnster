-- ==========================================
-- GRACE PERIOD SYSTEM (v115)
-- Tracks when a patient entered a room.
-- Prevents false Healing.Visible on patient arrival.
-- ==========================================
local RoomPatientEntryTick = {}

local function markPatientEntered(roomKey, minigame)
    RoomPatientEntryTick[roomKey] = tick()
    if Config.ShowConsoleLogs then
        print("[GraceGuard] " .. roomKey .. " — grace period start (" .. Config.GracePeriod .. "s)")
    end
    -- forceResetHealingVisible dipanggil di sini juga,
    -- tapi forceResetHealingVisible didefinisikan setelah fungsi ini.
    -- Pakai pcall deferred agar tidak crash kalau belum defined.
    -- Actual reset terjadi di isHealingDone saat grace period aktif.
end

local function clearGracePeriod(roomKey)
    RoomPatientEntryTick[roomKey] = nil
end

local function isInGracePeriod(roomKey)
    local t = RoomPatientEntryTick[roomKey]
    if not t then return false end
    local elapsed = tick() - t
    if elapsed < Config.GracePeriod then
        return true
    else
        RoomPatientEntryTick[roomKey] = nil
        return false
    end
end

