local function updateVisualRadar(id, pos, radius, color, isVisible)
    if not isVisible then
        if _G.AutoDoctor_Radars[id] then _G.AutoDoctor_Radars[id]:Destroy(); _G.AutoDoctor_Radars[id] = nil end
        return
    end
    local radar = _G.AutoDoctor_Radars[id]
    if not radar or not radar.Parent then
        radar = Instance.new("Part")
        radar.Name = "Radar_" .. id
        radar.Shape = Enum.PartType.Cylinder
        radar.Anchored = true; radar.CanCollide = false; radar.CanQuery = false
        radar.CastShadow = false; radar.Material = Enum.Material.Neon
        radar.Transparency = 0.85; radar.Color = color; radar.Parent = workspace
        _G.AutoDoctor_Radars[id] = radar
    end
    radar.Size = Vector3.new(0.1, radius * 2, radius * 2)
    radar.CFrame = CFrame.new(pos.X, pos.Y - 1.45, pos.Z) * CFrame.Angles(0, 0, math.rad(90))
end

_G.AutoDoctor_RadarLoop = task.spawn(function()
    while task.wait(1) do
        pcall(function()
            local rooms = workspace:FindFirstChild("Rooms")
            local medical = rooms and rooms:FindFirstChild("Medical")
            if medical then
                for i = 1, Config.MaxRooms do
                    local room = medical:FindFirstChild("Room"..i)
                    local bed = room and room:FindFirstChild("Minigame") and room.Minigame:FindFirstChild("Bed") and room.Minigame.Bed:FindFirstChild("InBed")
                    local pos = bed and bed.Position or (RoomCFrames[i] and RoomCFrames[i].Position)
                    if pos then updateVisualRadar("Room"..i, pos, Config.PatientBedRadius, Color3.fromRGB(0, 255, 255), isRadarVisible) end
                end
            end
            local emergency = rooms and rooms:FindFirstChild("Emergency")
            if emergency then
                for _, rn in ipairs(Config.EmergencyRooms) do
                    local room = emergency:FindFirstChild("Room"..rn)
                    if room then
                        -- Try multiple path strategies for emergency room position
                        local pos = nil
                        local minigame = room:FindFirstChild("Minigame")
                        if minigame then
                            local bedFolder = minigame:FindFirstChild("Bed")
                            local inBed = bedFolder and bedFolder:FindFirstChild("InBed")
                            if inBed then pos = inBed.Position end
                            if not pos and bedFolder and bedFolder:IsA("BasePart") then pos = bedFolder.Position end
                            if not pos then
                                local anyPart = minigame:FindFirstChildWhichIsA("BasePart", true)
                                if anyPart then pos = anyPart.Position end
                            end
                        end
                        if not pos and room.PrimaryPart then pos = room.PrimaryPart.Position end
                        if not pos then
                            local anyPart = room:FindFirstChildWhichIsA("BasePart", true)
                            if anyPart then pos = anyPart.Position end
                        end
                        -- Always show radar even without confirmed pos — use a static fallback offset
                        if pos then
                            updateVisualRadar("ERm"..rn, pos, Config.PatientBedRadius, Color3.fromRGB(255, 150, 0), isRadarVisible)
                        end
                    end
                end
            end
        end)
    end
end)

