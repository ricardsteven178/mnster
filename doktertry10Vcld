local function findMedicalRoom()
    local roomsFolder = workspace:FindFirstChild("Rooms")
    local medicalFolder = roomsFolder and roomsFolder:FindFirstChild("Medical")
    if not medicalFolder then return nil, nil end
    _G.AutoDoctor_MedsDone = _G.AutoDoctor_MedsDone or {}

    for i = 1, Config.MaxRooms do
        local room = medicalFolder:FindFirstChild("Room" .. i)
        if room then
            local isBlacklisted = BuggedRoomBlacklist[i] and (tick() - BuggedRoomBlacklist[i] < Config.BlacklistDuration)
            if not isBlacklisted then
                local minigame = room:FindFirstChild("Minigame")
                local bed = minigame and minigame:FindFirstChild("Bed") and minigame.Bed:FindFirstChild("InBed")
                local roomKey = "M" .. i
                local healing = isHealingDone(minigame, room, bed, i, roomKey)

                -- Kalau meds sudah selesai (semua obat tercentang):
                -- cek apakah NPC masih ada. Kalau sudah pergi → clear MedsDone dan RoomMemory.
                -- Skip room ini — jangan diproses ulang meski masih ada prompt visible.
                if _G.AutoDoctor_MedsDone[i] then
                    local bedPos = bed and bed.Position or (RoomCFrames[i] and RoomCFrames[i].Position)
                    local npcStillHere = bedPos and isAnyNPCNearPosition(bedPos, Config.PatientBedRadius)
                    if not npcStillHere then
                        -- Pasien sudah pergi, clear state
                        _G.AutoDoctor_MedsDone[i] = nil
                        _G.AutoDoctor_RoomMemory[i] = nil
                        clearGracePeriod(roomKey)
                    else
                        -- Pasien masih di sini tapi semua obat sudah → skip, tunggu healing
                        if Config.ShowConsoleLogs then
                            print("[RADAR] M" .. i .. ": MedsDone, skip (tunggu healing/pasien pergi)")
                        end
                    end
                    goto continue
                end

                local ready, reason = isPatientReady(room, bed)
                if ready and not healing then
                    _G.AutoDoctor_RoomMemory[i] = nil
                    if Config.ShowConsoleLogs then print("[RADAR] Target: " .. room.Name .. " (" .. reason .. ")") end
                    return room, i
                end

                local signLight = room:FindFirstChild("MainSign") and room.MainSign:FindFirstChild("Light")
                local isLightRed = signLight and (signLight.BrickColor.Name == "Crimson" or signLight.Color == Color3.fromRGB(165, 0, 0))
                if not isLightRed and _G.AutoDoctor_RoomMemory[i] == "PatientLeaving" then
                    _G.AutoDoctor_RoomMemory[i] = nil
                end

                ::continue::
            end
        end
    end
    return nil, nil
end

