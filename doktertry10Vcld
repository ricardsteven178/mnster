-- ==========================================
-- CACHE & ITEM FINDER
-- ==========================================
local function getPromptFromCache(targetName, isTrash)
    if isTrash then
        if _G.AutoDoctor_TrashCache and _G.AutoDoctor_TrashCache.Parent then return _G.AutoDoctor_TrashCache end
        local bestPrompt, minDist = nil, math.huge
        for _, desc in ipairs(workspace:GetDescendants()) do
            if desc:IsA("ProximityPrompt") then
                local actText = string.lower(desc.ActionText or "")
                local objName = string.lower(desc.Parent and desc.Parent.Name or "")
                if actText:match("trash") or actText:match("throw") or actText:match("dispose") or objName:match("trash") then
                    local pos = desc.Parent:IsA("BasePart") and desc.Parent.Position
                        or (desc.Parent:FindFirstChildWhichIsA("BasePart", true) and desc.Parent:FindFirstChildWhichIsA("BasePart", true).Position)
                    if pos then
                        local dist = (pos - Config.Room8BedCFrame.Position).Magnitude
                        if dist < minDist then minDist = dist; bestPrompt = desc end
                    end
                end
            end
        end
        if bestPrompt then _G.AutoDoctor_TrashCache = bestPrompt end
        return bestPrompt
    else
        if _G.AutoDoctor_ItemCache[targetName] and _G.AutoDoctor_ItemCache[targetName].Parent then
            return _G.AutoDoctor_ItemCache[targetName]
        end
        local tLower = string.lower(targetName)
        local isRoom8Item = table.find(Room8Items, targetName) ~= nil
        local root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        local charPos = root and root.Position or Vector3.zero
        local bestPrompt, minDist = nil, math.huge
        for _, desc in ipairs(workspace:GetDescendants()) do
            if desc:IsA("ProximityPrompt") and desc.Enabled then
                local pName = string.lower(desc.Parent and desc.Parent.Name or "")
                local oText = string.lower(desc.ObjectText or "")
                local aText = string.lower(desc.ActionText or "")
                if pName:match(tLower) or oText:match(tLower) or aText:match(tLower) then
                    local pos = desc.Parent:IsA("BasePart") and desc.Parent.Position
                        or (desc.Parent:FindFirstChildWhichIsA("BasePart", true) and desc.Parent:FindFirstChildWhichIsA("BasePart", true).Position)
                    if pos then
                        local dist = isRoom8Item and (pos - Config.Room8BedCFrame.Position).Magnitude or (pos - charPos).Magnitude
                        if dist < minDist then minDist = dist; bestPrompt = desc end
                    end
                end
            end
        end
        if bestPrompt then _G.AutoDoctor_ItemCache[targetName] = bestPrompt end
        return bestPrompt
    end
end

-- ==========================================
-- INVENTORY MANAGEMENT
-- ==========================================
local function checkTotalInventory()
    local count = 0
    local items = {}
    local function proc(item)
        if item:IsA("Tool") and table.find(ItemList, item.Name) then
            count = count + 1; table.insert(items, item)
        end
    end
    local bp = LocalPlayer:FindFirstChild("Backpack")
    local ch = LocalPlayer.Character
    if bp then for _, v in ipairs(bp:GetChildren()) do proc(v) end end
    if ch then for _, v in ipairs(ch:GetChildren()) do proc(v) end end
    return count, items
end

local function trashItem(toolToTrash)
    local char = LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not char or not root or not toolToTrash then return false end
    local trashPrompt = getPromptFromCache("Trash", true)
    if not trashPrompt then setStatus("GAGAL: Tempat sampah tidak ditemukan!"); return false end
    setStatus("Membuang: " .. toolToTrash.Name)
    if turboSafeEquip(toolToTrash.Name) then
        local originalPos = root.CFrame
        root.CFrame = Config.Room8BedCFrame
        root.AssemblyLinearVelocity = Vector3.zero
        task.wait(0.2)
        firePromptRaw(trashPrompt)
        task.wait(0.1)
        root.CFrame = originalPos
        root.AssemblyLinearVelocity = Vector3.zero
        task.wait(0.05)
        return true
    end
    return false
end

local function fetchItem(targetName, pendingMedsList)
    local char = LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not char or not root then return false end

    local totalAmount, currentItems = checkTotalInventory()
    if totalAmount >= Config.MaxInventory then
        local reqCounts = {}
        if pendingMedsList then
            for _, o in ipairs(pendingMedsList) do reqCounts[o] = (reqCounts[o] or 0) + 1 end
        end
        local haveCounts = {}
        local itemToThrow = nil
        for _, item in ipairs(currentItems) do
            haveCounts[item.Name] = (haveCounts[item.Name] or 0) + 1
            if haveCounts[item.Name] > (reqCounts[item.Name] or 0) then itemToThrow = item end
        end
        if not itemToThrow then itemToThrow = currentItems[1] end
        if not trashItem(itemToThrow) then return false end
    end

    local promptToUse = getPromptFromCache(targetName, false)
    if not promptToUse then
        setStatus("GAGAL: " .. targetName .. " tidak ditemukan.")
        return false
    end

    local isRoom8Item = table.find(Room8Items, targetName) ~= nil

    local function countInBag()
        local n = 0
        local bp = LocalPlayer:FindFirstChild("Backpack")
        local ch = LocalPlayer.Character
        if bp then for _, v in ipairs(bp:GetChildren()) do if v:IsA("Tool") and v.Name == targetName then n = n + 1 end end end
        if ch then for _, v in ipairs(ch:GetChildren()) do if v:IsA("Tool") and v.Name == targetName then n = n + 1 end end end
        return n
    end

    local before = countInBag()

    if isRoom8Item then
        setStatus("Fetch R8: " .. targetName)
        root.CFrame = Config.Room8BedCFrame
    else
        setStatus("Fetch Rak: " .. targetName)
        local itemPart = promptToUse.Parent:IsA("BasePart") and promptToUse.Parent
            or promptToUse.Parent:FindFirstChildWhichIsA("BasePart", true)
        if itemPart then root.CFrame = itemPart.CFrame * CFrame.new(0, 3, 0) end
    end
    root.AssemblyLinearVelocity = Vector3.zero

    firePromptRaw(promptToUse)

    local verified = false
    for _ = 1, 20 do
        task.wait(0.05)
        if countInBag() > before then verified = true; break end
        _G.AutoDoctor_LastActionTick = tick()
    end

    if not verified then
        setStatus("RETRY fetch: " .. targetName)
        firePromptRaw(promptToUse)
        for _ = 1, 20 do
            task.wait(0.05)
            if countInBag() > before then verified = true; break end
            _G.AutoDoctor_LastActionTick = tick()
        end
    end

    if verified then
        setStatus("CONFIRMED: " .. targetName)
    else
        setStatus("GAGAL CONFIRM: " .. targetName)
    end

    return verified
end

