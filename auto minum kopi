-- ==========================================
local coffeeStandCFrame = CFrame.new(-120.387688, 3.41253161, 8.78784466, -0.144494131, 3.65239181e-08, 0.989505649, -4.04447071e-08, 1, -4.28172804e-08, -0.989505649, -4.62071128e-08, -0.144494131)

local function takeCoffee(machine)
	if not isAutoRunning then return end
	
	-- CEK DULU ISI TAS SEBELUM TELEPORT & AMBIL!
	local totalKopi = countMyCoffee()
	if totalKopi >= Config.MaxKopiDiTas then
		ActionLog.Text = "🛑 Tas penuh (" .. totalKopi .. "/" .. Config.MaxKopiDiTas .. "). Biarkan mesin."
		return -- Langsung batalkan eksekusi ngambil kopi
	end
	
	local character = LocalPlayer.Character
	local rootPart = character and character:FindFirstChild("HumanoidRootPart")
	
	if rootPart then
		local originalPos = rootPart.CFrame
		rootPart.CFrame = coffeeStandCFrame
		task.wait(Config.DelayTeleport) 
		
		local prompt = machine:FindFirstChild("PP", true)
		if prompt and prompt:IsA("ProximityPrompt") then
			fireproximityprompt(prompt)
			ActionLog.Text = "⚡ Merampas Kopi dari " .. machine.Name
		end
		
		task.wait(0.1)
		rootPart.CFrame = originalPos
	end
end

local function setupMachine(machine)
	if machine:GetAttribute("TrackedByV6") then return end
	machine:SetAttribute("TrackedByV6", true)

	if machine:GetAttribute("Brewing") == false then
		takeCoffee(machine)
	end
	
	local conn = machine:GetAttributeChangedSignal("Brewing"):Connect(function()
		if machine:GetAttribute("Brewing") == false and isAutoRunning then
			task.wait(0.5) 
			takeCoffee(machine)
		end
	end)
	
	table.insert(connections, conn)
end

