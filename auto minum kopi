-- ==========================================
-- FUNGSI PENGHITUNG KOPI DI TAS & TANGAN
-- ==========================================
local function countMyCoffee()
	local totalKopi = 0
	local character = LocalPlayer.Character
	local backpack = LocalPlayer:FindFirstChild("Backpack")
	
	-- 1. Hitung kopi yang disimpen di tas
	if backpack then
		for _, item in pairs(backpack:GetChildren()) do
			if item:IsA("Tool") and string.find(string.lower(item.Name), "coffee") then
				totalKopi = totalKopi + 1
			end
		end
	end
	
	-- 2. Hitung kopi yang lagi dipegang (equip)
	if character then
		for _, item in pairs(character:GetChildren()) do
			if item:IsA("Tool") and string.find(string.lower(item.Name), "coffee") then
				totalKopi = totalKopi + 1
			end
		end
	end
	
	return totalKopi
end

-- ==========================================
-- FUNGSI BACA SANITY & AUTO-DRINK
-- ==========================================
local function getCurrentSanity()
	local PlayerGui = LocalPlayer:FindFirstChild("PlayerGui")
	if not PlayerGui then return 100 end
	
	local amountUI = PlayerGui:FindFirstChild("Sanity")
		and PlayerGui.Sanity:FindFirstChild("Frame")
		and PlayerGui.Sanity.Frame:FindFirstChild("Frame")
		and PlayerGui.Sanity.Frame.Frame:FindFirstChild("textbox")
		and PlayerGui.Sanity.Frame.Frame.textbox:FindFirstChild(Config.TargetSanityUI)
		
	if amountUI then
		local num = tonumber(string.match(amountUI.Text, "%d+"))
		return num or 100
	end
	return 100 
end

local function drinkCoffeeIfNeeded()
	local currentSanity = getCurrentSanity()
	local totalKopi = countMyCoffee()
	
	SanityStatus.Text = "🧠 Sanity: " .. currentSanity .. "% | Limit Tas: " .. Config.MaxKopiDiTas
	FarmStatus.Text = "🎒 Stok Kopi: " .. totalKopi .. " / " .. Config.MaxKopiDiTas
	
	if currentSanity <= Config.BatasMinum then
		local character = LocalPlayer.Character
		local backpack = LocalPlayer:FindFirstChild("Backpack")
		local humanoid = character and character:FindFirstChildOfClass("Humanoid")
		
		if not character or not humanoid or not backpack then return end
		
		local heldTool = nil
		for _, item in pairs(character:GetChildren()) do
			if item:IsA("Tool") and string.find(string.lower(item.Name), "coffee") then
				heldTool = item
				break
			end
		end
		
		if not heldTool then
			for _, item in pairs(backpack:GetChildren()) do
				if item:IsA("Tool") and string.find(string.lower(item.Name), "coffee") then
					humanoid:EquipTool(item)
					heldTool = item
					task.wait(0.2) 
					break
				end
			end
		end
		
		if heldTool then
			heldTool:Activate() 
			ActionLog.Text = "☕ Teguk Kopi! Sanity: " .. currentSanity .. "%"
			task.wait(Config.JedaMinum) 
		end
	end
end

