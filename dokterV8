local function checkTotalInventory()
    local targetCount = 0
    local targetItems = {} 
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    local character = LocalPlayer.Character
    
    local function processTool(item)
        if item:IsA("Tool") and table.find(ItemList, item.Name) then
            targetCount = targetCount + 1
            table.insert(targetItems, item)
        end
    end

    if backpack then for _, item in ipairs(backpack:GetChildren()) do processTool(item) end end
    if character then for _, item in ipairs(character:GetChildren()) do processTool(item) end end
    return targetCount, targetItems
end

local function trashItem(toolToTrash)
    local character = LocalPlayer.Character
    local rootPart = character and character:FindFirstChild("HumanoidRootPart")
    local humanoid = character and character:FindFirstChild("Humanoid")
    
    if not rootPart or not humanoid or not toolToTrash then return false end
    
    local trashBin = nil
    local trashPrompt = nil
    
    for _, desc in ipairs(workspace:GetDescendants()) do
        if desc:IsA("ProximityPrompt") then
            local actText = string.lower(desc.ActionText or "")
            local objName = string.lower(desc.Parent and desc.Parent.Name or "")
            if actText:match("trash") or actText:match("throw") or actText:match("dispose") or objName:match("trash") then
                trashBin = desc.Parent
                trashPrompt = desc
                break
            end
        end
    end
    
    if trashBin and trashPrompt then
        setStatus("Membuang item: " .. toolToTrash.Name)
        humanoid:EquipTool(toolToTrash)
        task.wait(0.2)
        
        if trashBin:IsA("Model") and trashBin.PrimaryPart then
            rootPart.CFrame = trashBin.PrimaryPart.CFrame * CFrame.new(0, 3, 0)
        elseif trashBin:IsA("BasePart") then
            rootPart.CFrame = trashBin.CFrame * CFrame.new(0, 3, 0)
        end
        
        rootPart.Velocity = Vector3.new(0, 0, 0)
        task.wait(Config.WaitTime)
        
        local oldReq = trashPrompt.RequiresLineOfSight
        local oldDist = trashPrompt.MaxActivationDistance
        
        trashPrompt.RequiresLineOfSight = false
        trashPrompt.MaxActivationDistance = math.huge
        trashPrompt.HoldDuration = 0
        
        if type(fireproximityprompt) == "function" then fireproximityprompt(trashPrompt, 1, true)
        else trashPrompt:InputHoldBegan() task.wait(0.1) trashPrompt:InputHoldEnded() end
        
        trashPrompt.RequiresLineOfSight = oldReq
        trashPrompt.MaxActivationDistance = oldDist
        
        _G.AutoDoctor_LastActionTick = tick()
        task.wait(Config.WaitTime)
        return true
    end
    
    setStatus("GAGAL: Tempat sampah tidak ditemukan!")
    return false
end

