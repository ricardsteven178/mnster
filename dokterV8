local function fetchItem(targetName, pendingMedsList)
    local char = LocalPlayer.Character
    local rootPart = char and char:FindFirstChild("HumanoidRootPart")
    if not rootPart then return false end

    setStatus("Mengambil: " .. targetName)

    local totalAmount, currentItems = checkTotalInventory()
    
    -- Jika tas kita mau penuh atau sudah penuh, saatnya cuci gudang barang yg tidak perlu
    if totalAmount >= Config.MaxInventory then
        local itemToThrowAway = nil
        
        -- Cari barang di tas yang TIDAK ADA di TV sama sekali
        if pendingMedsList then
            for _, item in ipairs(currentItems) do
                if item.Name ~= targetName and not table.find(pendingMedsList, item.Name) then
                    itemToThrowAway = item
                    break
                end
            end
        end
        
        -- Kalau semua kepakai (mustahil sih), buang barang aja sembarang
        if not itemToThrowAway then itemToThrowAway = currentItems[1] end
        
        local trashed = trashItem(itemToThrowAway)
        if not trashed then return false end 
    end

    local found = false
    for _, item in ipairs(workspace:GetDescendants()) do
        if item.Name == targetName then
            local prompt = item:FindFirstChildWhichIsA("ProximityPrompt", true)
            local itemPart = item:IsA("BasePart") and item or item:FindFirstChildWhichIsA("BasePart")
            
            if prompt and itemPart then
                found = true
                rootPart.CFrame = itemPart.CFrame * CFrame.new(0, 3, 0)
                rootPart.Velocity = Vector3.new(0, 0, 0)
                task.wait(Config.WaitTime)
                
                prompt.RequiresLineOfSight = false
                prompt.MaxActivationDistance = math.huge
                prompt.HoldDuration = 0
                if type(fireproximityprompt) == "function" then fireproximityprompt(prompt, 1, true)
                else prompt:InputHoldBegan() task.wait(0.1) prompt:InputHoldEnded() end
                
                _G.AutoDoctor_LastActionTick = tick()
                task.wait(Config.WaitTime)
                setStatus("BERHASIL DIAMBIL: " .. targetName)
                break 
            end
        end
    end

    if found then task.wait(0.5) return true else setStatus("GAGAL: " .. targetName .. " tidak ditemukan.") return false end
end

