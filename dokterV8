local function simpleInteract(prompt, customHold)
    if prompt and prompt:IsA("ProximityPrompt") then
        local oldReq = prompt.RequiresLineOfSight
        local oldDist = prompt.MaxActivationDistance
        
        prompt.RequiresLineOfSight = false
        prompt.MaxActivationDistance = math.huge
        
        if type(fireproximityprompt) == "function" then
            fireproximityprompt(prompt, 1, true)
        else
            prompt:InputHoldBegan()
            task.wait(customHold or prompt.HoldDuration or 0.25)
            prompt:InputHoldEnded()
        end
        
        _G.AutoDoctor_LastActionTick = tick()
        prompt.RequiresLineOfSight = oldReq
        prompt.MaxActivationDistance = oldDist
        task.wait(Config.WaitTime)
    end
    return true
end

local function getPatientInRoom(roomNum)
    local roomsFolder = workspace:FindFirstChild("Rooms")
    local medicalFolder = roomsFolder and roomsFolder:FindFirstChild("Medical")
    local room = medicalFolder and medicalFolder:FindFirstChild("Room" .. roomNum)
    local bedPart = room and room:FindFirstChild("Minigame") and room.Minigame:FindFirstChild("Bed") and room.Minigame.Bed:FindFirstChild("InBed")
    
    local centerPos = bedPart and bedPart.Position or RoomCFrames[roomNum].Position
    local radius = Config.PatientBedRadius

    local function checkNPC(npc)
        if Players:GetPlayerFromCharacter(npc) then return nil end

        local part = npc.PrimaryPart or npc:FindFirstChildWhichIsA("BasePart")
        if part and (part.Position - centerPos).Magnitude <= radius then
            local pp = npc:FindFirstChildWhichIsA("ProximityPrompt", true)
            if not (pp and (pp.Name == "FaintedPP" or (pp.ActionText and (pp.ActionText:match("Carry") or pp.ActionText:match("Fire"))))) then
                return npc
            end
        end
        return nil
    end

    if workspace:FindFirstChild("NPCs") then
        for _, npc in ipairs(workspace.NPCs:GetChildren()) do
            local found = checkNPC(npc)
            if found then return found end
        end
    end
    for _, obj in ipairs(workspace:GetChildren()) do
        if obj:IsA("Model") and obj ~= LocalPlayer.Character then
            local found = checkNPC(obj)
            if found then return found end
        end
    end
    return nil
end

local function getFireEmergency()
    if workspace:FindFirstChild("NPCs") then
        for _, npc in ipairs(workspace.NPCs:GetChildren()) do
            local pp = npc:FindFirstChild("FirePP", true)
            if pp and pp.ActionText and pp.ActionText:match("Fire") then return npc, pp end
        end
    end
    for _, obj in ipairs(workspace:GetChildren()) do
        if obj:IsA("Model") and obj:FindFirstChild("Humanoid") then
            local pp = obj:FindFirstChild("FirePP", true)
            if pp and pp.ActionText and pp.ActionText:match("Fire") then return obj, pp end
        end
    end
    return nil, nil
end

local function findActiveRoom()
    local roomsFolder = workspace:FindFirstChild("Rooms")
    local medicalFolder = roomsFolder and roomsFolder:FindFirstChild("Medical")
    if not medicalFolder then return nil end

    for i = 1, Config.MaxRooms do
        local room = medicalFolder:FindFirstChild("Room" .. i)
        if room then
            local minigame = room:FindFirstChild("Minigame")
            local bed = minigame and minigame:FindFirstChild("Bed") and minigame.Bed:FindFirstChild("InBed")
            local bedPart = bed and (bed:IsA("BasePart") and bed or bed:FindFirstChildWhichIsA("BasePart"))
            
            if not isHealingDone(minigame) then
                local signLight = room:FindFirstChild("MainSign") and room.MainSign:FindFirstChild("Light")
                local isLightRed = signLight and (signLight.BrickColor.Name == "Crimson" or signLight.Color == Color3.fromRGB(165, 0, 0))
                
                local hasPhysicalPatient = false
                if bedPart and workspace:FindFirstChild("NPCs") then
                    for _, npc in ipairs(workspace.NPCs:GetChildren()) do
                        local part = npc.PrimaryPart or npc:FindFirstChildWhichIsA("BasePart")
                        if part and (part.Position - bedPart.Position).Magnitude < Config.PatientBedRadius then
                            local pp = npc:FindFirstChildWhichIsA("ProximityPrompt", true)
                            if not (pp and (pp.Name == "FaintedPP" or (pp.ActionText and (pp.ActionText:match("Carry") or pp.ActionText == "Fire")))) then
                                hasPhysicalPatient = true
                                break
                            end
                        end
                    end
                end

                if isLightRed or hasPhysicalPatient then return room end
            end
        end
    end
    return nil 
end

local function getFaintedPatient()
    if workspace:FindFirstChild("NPCs") then
        for _, npc in ipairs(workspace.NPCs:GetChildren()) do
            local pp = npc:FindFirstChild("FaintedPP", true) or npc:FindFirstChildWhichIsA("ProximityPrompt", true)
            if pp and (pp.Name == "FaintedPP" or (pp.ActionText and pp.ActionText:match("Carry"))) then return npc, pp end
        end
    end
    for _, obj in ipairs(workspace:GetChildren()) do
        if obj:IsA("Model") and obj:FindFirstChild("Humanoid") then
            local pp = obj:FindFirstChild("FaintedPP", true) or obj:FindFirstChildWhichIsA("ProximityPrompt", true)
            if pp and (pp.Name == "FaintedPP" or (pp.ActionText and pp.ActionText:match("Carry"))) then return obj, pp end
        end
    end
    return nil, nil
end

local function processFaintedPatient(faintedPart, carryPP, activeShift)
    setStatus("! PRIORITAS 2: Mengurus Pasien Pingsan !")
    local char = LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root or not faintedPart then return end

    setStatus("Menggendong pasien...")
    local primPart = faintedPart.PrimaryPart or faintedPart:FindFirstChildWhichIsA("BasePart")
    if primPart then
        root.CFrame = primPart.CFrame * CFrame.new(0, 3, 0)
        root.Velocity = Vector3.zero
        task.wait(Config.WaitTime)
    end
    
    simpleInteract(carryPP, 0)
    task.wait(1.5)

    local placePrompt = nil
    local targetRoomNum = nil
    local waitLimit = 0
    
    while not placePrompt and waitLimit < 20 do
        if getShiftText() ~= activeShift then return end
        setStatus("Mencari kasur kosong (Place Patient)...")
        
        local roomsFolder = workspace:FindFirstChild("Rooms")
        local medicalFolder = roomsFolder and roomsFolder:FindFirstChild("Medical")
        
        if medicalFolder then
            for i = 1, Config.MaxRooms do
                local room = medicalFolder:FindFirstChild("Room" .. i)
                if room then
                    for _, desc in ipairs(room:GetDescendants()) do
                        if desc:IsA("ProximityPrompt") then
                            local actText = desc.ActionText or ""
                            if desc.Name == "FaintedPP" or actText:match("Place") or actText:match("place") then
                                placePrompt = desc
                                targetRoomNum = i
                                break
                            end
                        end
                    end
                end
                if placePrompt then break end
            end
        end
        
        if not placePrompt then
            task.wait(1.5)
            waitLimit = waitLimit + 1
            _G.AutoDoctor_LastActionTick = tick()
        end
    end

    if placePrompt and targetRoomNum then
        setStatus("Membawa ke Room " .. targetRoomNum .. "...")
        teleportToSafeRoom(targetRoomNum)
        task.wait(0.5)
        
        setStatus("Meletakkan di kasur...")
        simpleInteract(placePrompt, 1)
        task.wait(1.5)
        
        setStatus("Berhasil menaruh pasien pingsan!")
        _G.TreatingFainted = true
    else
        setStatus("GAGAL menaruh pasien. Kasur penuh / shift ganti.")
    end
end

local function executeTreatmentCore(roomPath, activeShift)
    local minigame = roomPath:FindFirstChild("Minigame")
    if not minigame then return end
    
    local roomNum = tonumber(roomPath.Name:match("%d+"))
    if isHealingDone(minigame) or getShiftText() ~= activeShift then return end

    local tvUI = minigame:FindFirstChild("TV") and minigame.TV:FindFirstChild("Screen", true)
    
    setStatus("--- MEMULAI PENGOBATAN: " .. roomPath.Name .. " ---")
    local bed = minigame:FindFirstChild("Bed") and minigame.Bed:FindFirstChild("InBed")
    local bedPart = bed and (bed:IsA("BasePart") and bed or bed:FindFirstChildWhichIsA("BasePart"))
    local patientIsAnomaly = false

    setStatus("1/5 Mengecek pasien di kasur...")
    teleportToSafeRoom(roomNum) 
    
    local targetNPC = nil
    local waitLimit = 0
    
    while not targetNPC and waitLimit < 20 do
        if getShiftText() ~= activeShift then return end
        
        if workspace:FindFirstChild("NPCs") then
            for _, npc in ipairs(workspace.NPCs:GetChildren()) do
                local part = npc.PrimaryPart or npc:FindFirstChildWhichIsA("BasePart")
                if part and bedPart and (part.Position - bedPart.Position).Magnitude < Config.PatientBedRadius then
                    targetNPC = npc
                    break
                end
            end
        end
        if not targetNPC then
            task.wait(0.5)
            waitLimit = waitLimit + 1
        end
    end

    if not targetNPC then
        setStatus("BATAL: Pasien tidak ditemukan di kasur.")
        return
    end

    if isAnomaly(targetNPC) then
        patientIsAnomaly = true
        setStatus("!! PASIEN INI ANOMALI/MONSTER !!")
    end

    -- [ FIX V46 ]: PENDETEKSI LUKA BAKAR WAJIB SEDANG AKTIF (ENABLED)
    local needsOintment = false
    local treatPrompt = nil

    if targetNPC then
        for _, desc in ipairs(targetNPC:GetDescendants()) do
            -- Abaikan tombol yang disembunyikan/dimatikan sistem!
            if desc:IsA("ProximityPrompt") and desc.Enabled then
                local actText = desc.ActionText or ""
                if desc.Name == "FirePP" or actText:match("Burns") or actText:match("burns") then
                    needsOintment = true
                    treatPrompt = desc
                    break
                end
            end
        end
    end

    if needsOintment and treatPrompt then
        setStatus("Darurat Luka Bakar! Butuh Ointment.")
        
        local hasOintment = LocalPlayer.Backpack:FindFirstChild("Ointment") or LocalPlayer.Character:FindFirstChild("Ointment")
        if not hasOintment then fetchItem("Ointment", {"Ointment"}) end
        
        teleportToSafeRoom(roomNum) 
        
        local tool = LocalPlayer.Backpack:FindFirstChild("Ointment") or LocalPlayer.Character:FindFirstChild("Ointment")
        if tool then 
            LocalPlayer.Character.Humanoid:UnequipTools()
            task.wait(0.1)
            LocalPlayer.Character.Humanoid:EquipTool(tool) 
        end
        task.wait(0.2)

        setStatus("Mengoleskan Ointment (Treat Burns)...")
        simpleInteract(treatPrompt, 3)
        task.wait(2)
    end

    if isHealingDone(minigame) or getShiftText() ~= activeShift then return end

    if not isTvActive(tvUI) then
        local dnaPP = targetNPC:FindFirstChildWhichIsA("ProximityPrompt", true)
        if dnaPP and (dnaPP.ActionText:match("DNA") or dnaPP.ActionText:match("dna")) then
            setStatus("Mengambil DNA...")
            simpleInteract(dnaPP, 0.25)
        else
            setStatus("DNA sudah diambil (Lanjut)...")
        end

        if isHealingDone(minigame) or getShiftText() ~= activeShift then return end

        setStatus("2/5 Cek Mesin Analyzer...")
        local analyzer = minigame:FindFirstChild("Analyzer")
        if analyzer and analyzer:FindFirstChild("PP") then
            simpleInteract(analyzer.PP, 0.5)
        end

        if isHealingDone(minigame) or getShiftText() ~= activeShift then return end

        setStatus("3/5 Cek Monitor...")
        local monitor = minigame:FindFirstChild("Monitor")
        if monitor and monitor:FindFirstChild("PP2") then
            simpleInteract(monitor.PP2, 0.25)
        end
    else
        setStatus("Smart Co-op: Tahap 1-3 di-skip. Langsung ambil obat!")
    end

    if isHealingDone(minigame) or getShiftText() ~= activeShift then return end

    setStatus("4/5 Membaca Kebutuhan dari TV...")
    if tvUI and tvUI:FindFirstChild("inv", true) then
        local invFolder = tvUI:FindFirstChild("inv", true)
        local waitLimitTV = 0
        while #invFolder:GetChildren() <= 1 and waitLimitTV < 15 do
            if getShiftText() ~= activeShift then return end
            task.wait(0.5)
            waitLimitTV = waitLimitTV + 1
        end
    end

    if isHealingDone(minigame) or getShiftText() ~= activeShift then return end

    -- 5. Eksekusi Treatment 
    if patientIsAnomaly then
        setStatus("5/5 [ALGOJO] Mencari RACUN...")
        local initialMeds = getPendingMedicines(tvUI)
        local wrongMedicine = "Medicine"
        
        for _, item in ipairs(ItemList) do
            if not table.find(initialMeds, item) then wrongMedicine = item break end
        end
        
        local hasIt = LocalPlayer.Backpack:FindFirstChild(wrongMedicine) or LocalPlayer.Character:FindFirstChild(wrongMedicine)
        if not hasIt then fetchItem(wrongMedicine, {wrongMedicine}) end
        
        if bed and bed:FindFirstChild("PP") then
            teleportToSafeRoom(roomNum) 
            local tool = LocalPlayer.Backpack:FindFirstChild(wrongMedicine) or LocalPlayer.Character:FindFirstChild(wrongMedicine)
            if tool then 
                LocalPlayer.Character.Humanoid:UnequipTools()
                task.wait(0.1)
                LocalPlayer.Character.Humanoid:EquipTool(tool) 
            end
            task.wait(0.2)
            
            setStatus("MENYUNTIKKAN OBAT SALAH: " .. wrongMedicine)
            simpleInteract(bed.PP, 0.25)
            setStatus("--- ANOMALI HANGUS! ---")
        end
    else
        setStatus("5/5 Memulai pengobatan pantang mundur...")
        
        local lastProgressTime = tick()
        local lastPendingCount = -1

        while true do
            if getShiftText() ~= activeShift then 
                setStatus("Shift berganti! Membatalkan pengobatan.")
                break 
            end

            if isHealingDone(minigame) then
                setStatus("Layar Healing menyala! Selesai.")
                break
            end

            local pendingMeds = getPendingMedicines(tvUI)
            
            if #pendingMeds ~= lastPendingCount then
                lastPendingCount = #pendingMeds
                lastProgressTime = tick() 
            end

            if tick() - lastProgressTime >= Config.StuckTimeout then
                setStatus("Loop Stuck " .. Config.StuckTimeout .. " detik. Skip ruangan ini.")
                break
            end

            if #pendingMeds == 0 then
                setStatus("Obat tercentang. Tunggu layar Healing...")
                task.wait(1)
                continue
            end

            local medsReadyToGive = {}
            setStatus("Tersisa " .. #pendingMeds .. " obat belum tercentang.")
            
            for _, obat in ipairs(pendingMeds) do
                local hasIt = LocalPlayer.Backpack:FindFirstChild(obat) or LocalPlayer.Character:FindFirstChild(obat)
                
                if hasIt then
                    table.insert(medsReadyToGive, obat)
                else
                    local fetched = fetchItem(obat, pendingMeds)
                    if fetched then table.insert(medsReadyToGive, obat) end
                end
            end

            if #medsReadyToGive > 0 then
                if bed and bed:FindFirstChild("PP") then
                    teleportToSafeRoom(roomNum) 
                    
                    setStatus("Suntik " .. #medsReadyToGive .. " obat...")
                    for _, obat in ipairs(medsReadyToGive) do
                        local currentPending = getPendingMedicines(tvUI)
                        if table.find(currentPending, obat) then
                            local tool = LocalPlayer.Backpack:FindFirstChild(obat) or LocalPlayer.Character:FindFirstChild(obat)
                            
                            -- [ FIX V46 ]: ANTI-SALAH SUNTIK & WRONG TREATMENT PREVENTER
                            if tool then 
                                LocalPlayer.Character.Humanoid:UnequipTools() -- Bersihkan tangan dulu
                                task.wait(0.1)
                                LocalPlayer.Character.Humanoid:EquipTool(tool) -- Pegang obat yang benar
                            end
                            task.wait(0.2)
                            
                            -- Cek ke tangan secara langsung, apakah benar-benar memegang obat yang dibutuhkan?
                            local heldTool = LocalPlayer.Character:FindFirstChildOfClass("Tool")
                            if heldTool and heldTool.Name == obat then
                                setStatus("Suntik: " .. obat)
                                simpleInteract(bed.PP, 0.25)
                                task.wait(0.5) 
                            else
                                setStatus("FAILSAFE: Gagal memegang " .. obat .. "! Batal suntik untuk mencegah pasien mati.")
                                task.wait(0.5)
                            end
                        else
                            setStatus("SKIP: " .. obat .. " sudah diberikan player lain!")
                        end
                    end
                    task.wait(1.5)
                else
                    setStatus("Kasur error. Coba ulang...")
                    task.wait(2)
                end
            else
                setStatus("Menunggu obat...")
                task.wait(2)
            end
        end
        if getShiftText() == activeShift then setStatus("--- PROSES SELESAI ---") end
    end
    task.wait(1)
end

-- ==========================================
-- SAFE MAIN EXECUTOR (WORKER THREAD)
-- ==========================================
local function botCycle()
    local activeShift = getShiftText()
    if not activeShift then
        teleportToIdle()
        setStatus("Menunggu shift dimulai (Istirahat)...")
        task.wait(2)
        return
    end

    local fireNPC, firePP = getFireEmergency()
    if fireNPC then
        pcall(function() 
            setStatus("! PRIORITAS 1: Memadamkan Pasien Terbakar !")
            local char = LocalPlayer.Character
            local root = char and char:FindFirstChild("HumanoidRootPart")
            if root then
                local prim = fireNPC.PrimaryPart or fireNPC:FindFirstChildWhichIsA("BasePart")
                if prim then
                    root.CFrame = prim.CFrame * CFrame.new(0, 3, 0)
                    root.Velocity = Vector3.zero
                    task.wait(Config.WaitTime)
                end
                setStatus("Menyemprotkan pemadam...")
                simpleInteract(firePP, 3.2)
                task.wait(1.5)
            end
        end)
        return
    end

    local faintedPart, carryPP = getFaintedPatient()
    if faintedPart then
        _G.TreatingFainted = false
        pcall(function() processFaintedPatient(faintedPart, carryPP, activeShift) end)
        
        if _G.TreatingFainted and getShiftText() == activeShift then
            local room = findActiveRoom()
            if room then pcall(function() executeTreatmentCore(room, activeShift) end) end
        end
        return
    end
    
    local room = findActiveRoom()
    if room then 
        pcall(function() executeTreatmentCore(room, activeShift) end)
    else
        teleportToIdle()
        setStatus("Idle (Memantau " .. activeShift .. ")...")
        task.wait(Config.ScanDelay)
    end
end

local function startWorker()
    if _G.AutoDoctor_Worker then task.cancel(_G.AutoDoctor_Worker) end
    _G.AutoDoctor_Worker = task.spawn(function()
        while autoScanEnabled do
            if not isBusy then
                isBusy = true
                _G.AutoDoctor_LastActionTick = tick() 
                pcall(botCycle)
                isBusy = false
            else
                task.wait(0.5)
            end
        end
    end)
end

