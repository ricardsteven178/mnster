    RadarBtn.Text = isRadarVisible and "SHOW RADAR: ON" or "SHOW RADAR: OFF"; RadarBtn.BackgroundColor3 = isRadarVisible and Color3.fromRGB(70, 200, 70) or Color3.fromRGB(70, 70, 70)
    if not isRadarVisible then for _, r in pairs(_G.AutoDoctor_Radars) do if r then r:Destroy() end end; _G.AutoDoctor_Radars = {} end
end)

ScanOnceBtn.MouseButton1Click:Connect(function()
    if autoScanEnabled then setStatus("Matikan Auto-Scan dulu!"); return end
    if isBusy then return end
    task.spawn(function() isBusy = true; _G.AutoDoctor_IsIdle = false; botCycle(); if not StatusLabel.Text:match("Idle") then teleportToIdle(); setStatus("Manual Selesai (Standby).") end; isBusy = false end)
end)

ToggleAutoBtn.MouseButton1Click:Connect(function()
    autoScanEnabled = not autoScanEnabled
    if autoScanEnabled then
        ToggleAutoBtn.Text = "Auto-Scan: ON"; ToggleAutoBtn.BackgroundColor3 = Color3.fromRGB(70, 200, 70); setStatus("Auto-Scan menyala...")
        isBusy = false; _G.AutoDoctor_IsIdle = false; _G.AutoDoctor_LastActionTick = tick(); _G.LastRadarReport = ""; BuggedRoomBlacklist = {}; _G.AutoDoctor_RoomMemory = {}
        startWorker()
        if _G.AutoDoctor_Watchdog then task.cancel(_G.AutoDoctor_Watchdog) end
        _G.AutoDoctor_Watchdog = task.spawn(function()
            local lastShift = getShiftText()
            while autoScanEnabled do
                task.wait(1)
                local currentShift = getShiftText(); local isShiftChanged = (currentShift ~= lastShift and currentShift ~= nil and lastShift ~= nil); local isStuck = isBusy and (tick() - _G.AutoDoctor_LastActionTick > Config.GlobalStuckTimeout)
                if isShiftChanged or isStuck then
                    if isShiftChanged then setStatus("Shift Berganti! AUTO HARD-RESET..."); Config.MaxInventory = 5 else setStatus("STUCK DETECTED! HARD-RESET...") end
                    if _G.AutoDoctor_Worker then task.cancel(_G.AutoDoctor_Worker) end
                    BuggedRoomBlacklist = {}; _G.AutoDoctor_RoomMemory = {}; isBusy = false; _G.AutoDoctor_IsIdle = false; lastShift = currentShift; teleportToIdle(); task.wait(2)
                    if autoScanEnabled then _G.AutoDoctor_LastActionTick = tick(); startWorker() end
                end
                if currentShift then lastShift = currentShift end
            end
        end)
    else
        ToggleAutoBtn.Text = "Auto-Scan: OFF"; ToggleAutoBtn.BackgroundColor3 = Color3.fromRGB(70, 70, 70)
        pcall(function() if _G.AutoDoctor_Watchdog then task.cancel(_G.AutoDoctor_Watchdog) end end); pcall(function() if _G.AutoDoctor_Worker then task.cancel(_G.AutoDoctor_Worker) end end)
        isBusy = false; _G.AutoDoctor_IsIdle = false; setStatus("Dimatikan.")
    end
end)
