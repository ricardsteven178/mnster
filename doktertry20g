local function firePromptRaw(prompt)
    if not prompt or not prompt:IsA("ProximityPrompt") then return end
    if type(fireproximityprompt) == "function" then
        fireproximityprompt(prompt)
    else
        local oldReq = prompt.RequiresLineOfSight; local oldDist = prompt.MaxActivationDistance
        prompt.RequiresLineOfSight = false; prompt.MaxActivationDistance = math.huge
        prompt:InputHoldBegan(); task.wait(prompt.HoldDuration > 0 and prompt.HoldDuration or 0.1); prompt:InputHoldEnded()
        prompt.RequiresLineOfSight = oldReq; prompt.MaxActivationDistance = oldDist
    end
    _G.AutoDoctor_LastActionTick = tick()
end

local function simpleInteract(prompt, customHold, autoLock)
    if prompt and prompt:IsA("ProximityPrompt") then
        if autoLock then teleportToTarget(prompt) end
        local oldReq = prompt.RequiresLineOfSight; local oldDist = prompt.MaxActivationDistance
        prompt.RequiresLineOfSight = false; prompt.MaxActivationDistance = math.huge
        if type(fireproximityprompt) == "function" then fireproximityprompt(prompt)
        else prompt:InputHoldBegan(); task.wait(customHold or prompt.HoldDuration or 0.1); prompt:InputHoldEnded() end
        prompt.RequiresLineOfSight = oldReq; prompt.MaxActivationDistance = oldDist
        _G.AutoDoctor_LastActionTick = tick(); task.wait(0.1)
    end
    return true
end

local function getPromptFromCache(targetName, isTrash)
    if isTrash then
        if _G.AutoDoctor_TrashCache and _G.AutoDoctor_TrashCache.Parent then return _G.AutoDoctor_TrashCache end
        for _, desc in ipairs(workspace:GetDescendants()) do
            if desc:IsA("ProximityPrompt") then
                local actText = string.lower(desc.ActionText or ""); local objName = string.lower(desc.Parent and desc.Parent.Name or "")
                if actText:match("trash") or actText:match("throw") or actText:match("dispose") or objName:match("trash") then
                    _G.AutoDoctor_TrashCache = desc; return desc
                end
            end
        end
    else
        if _G.AutoDoctor_ItemCache[targetName] and _G.AutoDoctor_ItemCache[targetName].Parent then return _G.AutoDoctor_ItemCache[targetName] end
        local tLower = string.lower(targetName)
        for _, desc in ipairs(workspace:GetDescendants()) do
            if desc:IsA("ProximityPrompt") and desc.Enabled then
                local pName = string.lower(desc.Parent and desc.Parent.Name or ""); local oText = string.lower(desc.ObjectText or ""); local aText = string.lower(desc.ActionText or "")
                if pName:match(tLower) or oText:match(tLower) or aText:match(tLower) then _G.AutoDoctor_ItemCache[targetName] = desc; return desc end
            end
        end
    end
    return nil
end

