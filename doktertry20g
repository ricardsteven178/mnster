    return false
end

local function printRadarReport()
    if not Config.ShowConsoleLogs then return end
    local report = "[RADAR] Live Scan: "; local roomList = getRoomList()
    table.sort(roomList, function(a, b) return a.num < b.num end)
    for _, data in ipairs(roomList) do
        local i = data.num; local room = data.room; local status = "[-]"
        if room then
            local minigame = room:FindFirstChild("Minigame")
            local isBlacklisted = BuggedRoomBlacklist[i] and (tick() - BuggedRoomBlacklist[i] < Config.BlacklistDuration)
            local isHealing = isHealingDone(minigame)
            local ready, reason = isPatientReady(room, i)

            if ready and not isHealing then _G.AutoDoctor_RoomMemory[i] = nil; status = "[" .. reason .. "]"
            elseif isBlacklisted then status = "[BLACKLIST]"
            elseif _G.AutoDoctor_RoomMemory[i] == "PatientLeaving" then status = "[MEMORI: Pasien Lama Keluar]"
            elseif isHealing then status = "[HEALING]"
            else
                local signLight = room:FindFirstChild("MainSign") and room.MainSign:FindFirstChild("Light")
                if signLight and (signLight.BrickColor.Name == "Crimson" or signLight.Color == Color3.fromRGB(165, 0, 0)) then status = "[AKTIF: Pasien Menuju]" else status = "[Kosong]" end
            end
        end
        report = report .. "R" .. i .. ":" .. status .. " "
    end
    if _G.LastRadarReport ~= report then _G.LastRadarReport = report; print("[" .. os.date("%H:%M:%S") .. "] [Auto-Doctor] " .. report) end
end

-- ==========================================
-- FETCHING ENGINE
-- ==========================================
local function fetchItem(targetName, pendingMedsList)
    local char = LocalPlayer.Character; local root = char and char:FindFirstChild("HumanoidRootPart")
    if not char or not root then return false end

    local totalAmount, currentItems = checkTotalInventory()
    if totalAmount >= Config.MaxInventory then
        local reqCounts = {}; if pendingMedsList then for _, o in ipairs(pendingMedsList) do reqCounts[o] = (reqCounts[o] or 0) + 1 end end
        local haveCounts = {}; local itemToThrowAway = nil
        for _, item in ipairs(currentItems) do
            haveCounts[item.Name] = (haveCounts[item.Name] or 0) + 1
            if haveCounts[item.Name] > (reqCounts[item.Name] or 0) then itemToThrowAway = item end
        end
        if not itemToThrowAway then itemToThrowAway = currentItems[1] end
        if not trashItem(itemToThrowAway) then return false end
    end

    local promptToUse = getPromptFromCache(targetName, false)
    if not promptToUse then setStatus("GAGAL: " .. targetName .. " tidak ditemukan."); return false end

    unequipAll()
    local isRoom8Item = table.find(Room8Items, targetName) ~= nil
    local function countInBag()
        local n = 0; local bp = LocalPlayer:FindFirstChild("Backpack"); local ch = LocalPlayer.Character
        if bp then for _, v in ipairs(bp:GetChildren()) do if v:IsA("Tool") and v.Name == targetName then n = n + 1 end end end
        if ch then for _, v in ipairs(ch:GetChildren()) do if v:IsA("Tool") and v.Name == targetName then n = n + 1 end end end
        return n
    end
    local beforeCount = countInBag()

    setStatus("Fetch: " .. targetName)
    if isRoom8Item then root.CFrame = Config.Room8BedCFrame else
        local itemPart = promptToUse.Parent:IsA("BasePart") and promptToUse.Parent or promptToUse.Parent:FindFirstChildWhichIsA("BasePart", true)
        if itemPart then root.CFrame = itemPart.CFrame * CFrame.new(0, 3, 0) end
    end
    root.AssemblyLinearVelocity = Vector3.zero; task.wait(0.2)

    local function firePrompt(p)
        if type(fireproximityprompt) == "function" then fireproximityprompt(p) else
            local oldReq = p.RequiresLineOfSight; local oldDist = p.MaxActivationDistance
            p.RequiresLineOfSight = false; p.MaxActivationDistance = math.huge
            p:InputHoldBegan(); task.wait(0.05); p:InputHoldEnded(); p.RequiresLineOfSight = oldReq; p.MaxActivationDistance = oldDist
        end
        _G.AutoDoctor_LastActionTick = tick()
    end

    firePrompt(promptToUse)
    local verified = false
    for _ = 1, 20 do task.wait(0.05); if countInBag() > beforeCount then verified = true; break end; _G.AutoDoctor_LastActionTick = tick() end

    if not verified then
        setStatus("RETRY: " .. targetName); firePrompt(promptToUse)
        for _ = 1, 20 do task.wait(0.05); if countInBag() > beforeCount then verified = true; break end; _G.AutoDoctor_LastActionTick = tick() end
    end
    return verified
end

