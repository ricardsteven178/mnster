-- MAIN ENGINE (R1-R7)
-- ==========================================
local function executeTreatmentCore(roomPath, roomNum, activeShift)
    local minigame = roomPath:FindFirstChild("Minigame")
    if not minigame then return end

    setStatus("--- MEMULAI PENGOBATAN: " .. roomPath.Name .. " ---")
    
    -- [ FIX ]: Langsung TP ke Monitor PP2 jika R6/R7 di awal sesi
    if roomNum == 6 or roomNum == 7 then
        local monitor = minigame:FindFirstChild("Monitor")
        local pp2 = monitor and monitor:FindFirstChild("PP2") or getNil("PP2", "ProximityPrompt")
        if pp2 then teleportToTarget(pp2) else teleportToRoomCenter(roomNum, roomPath) end
    else
        teleportToRoomCenter(roomNum, roomPath)
    end
    
    local lastProgressTime = tick()

    while true do
        task.wait(0.1)

        if getShiftText() ~= activeShift or getFireEmergency() or getPlacePatientPrompt() or getFaintedPatient() then break end

        local currentPatient = getPatientInRoom(roomNum, roomPath)
        if not currentPatient then
            local signLight = roomPath:FindFirstChild("MainSign") and roomPath.MainSign:FindFirstChild("Light")
            if signLight and (signLight.BrickColor.Name == "Crimson" or signLight.Color == Color3.fromRGB(165, 0, 0)) then task.wait(1)
            else BuggedRoomBlacklist[roomNum] = tick(); break end
        end

        if isHealingDone(minigame) then setStatus("Pasien Sembuh! Move on..."); _G.AutoDoctor_RoomMemory[roomNum] = "PatientLeaving"; break end
        if tick() - lastProgressTime >= Config.StuckTimeout then BuggedRoomBlacklist[roomNum] = tick(); break end

        local activeUI = getActiveUI(minigame)
        local pendingMeds = getPendingMedicines(activeUI)
        local hasTasks, reason = isPatientReady(roomPath, roomNum)

        if hasTasks then
            if reason == "Layar Aktif (Butuh Obat)" then
                if checkAnomalyStatus(roomNum, roomPath) then
                    local prescribedMeds = {}
                    if activeUI then local tvInv = activeUI:FindFirstChild("inv", true); if tvInv then for _, req in ipairs(tvInv:GetChildren()) do if table.find(ItemList, req.Name) then table.insert(prescribedMeds, req.Name) end end end end
                    local wrongMedicine = "Medicine"
                    for _, item in ipairs(ItemList) do if not table.find(prescribedMeds, item) and getPromptFromCache(item, false) then wrongMedicine = item; break end end
                    if not (LocalPlayer.Backpack:FindFirstChild(wrongMedicine) or LocalPlayer.Character:FindFirstChild(wrongMedicine)) then fetchItem(wrongMedicine, {wrongMedicine}) end
                    local applyPP = getApplyPrompt(minigame, roomNum, roomPath)
                    if applyPP then
                        teleportToTarget(applyPP)
                        task.wait(0.15)
                        if turboSafeEquip(wrongMedicine) then setStatus("MENYUNTIKKAN RACUN: " .. wrongMedicine); simpleInteract(applyPP, 0.1, false); lastProgressTime = tick(); task.wait(2); _G.AutoDoctor_RoomMemory[roomNum] = "PatientLeaving"; break end
                    end
                else
                    if #pendingMeds > 0 then
                        local reqCounts = {}
                        for _, obat in ipairs(pendingMeds) do reqCounts[obat] = (reqCounts[obat] or 0) + 1 end
                        setStatus("FETCH PHASE: Kumpulkan obat...")
                        for obat, needed in pairs(reqCounts) do
                            local haveCount = 0; local bp = LocalPlayer:FindFirstChild("Backpack"); local ch = LocalPlayer.Character
                            if bp then for _, v in ipairs(bp:GetChildren()) do if v:IsA("Tool") and v.Name == obat then haveCount = haveCount + 1 end end end
                            if ch then for _, v in ipairs(ch:GetChildren()) do if v:IsA("Tool") and v.Name == obat then haveCount = haveCount + 1 end end end
                            for _ = 1, math.max(0, needed - haveCount) do fetchItem(obat, pendingMeds) end
                        end

                        setStatus("INJECT PHASE: Menyuntik...")
                        local applyPP = getApplyPrompt(minigame, roomNum, roomPath)
                        if applyPP then
                            teleportToTarget(applyPP)
                            task.wait(0.15)
                            local injectAttempts = 0
                            while injectAttempts < 20 do
                                if getShiftText() ~= activeShift then break end
                                local freshPending = getPendingMedicines(getActiveUI(minigame))
                                if #freshPending == 0 or isHealingDone(minigame) then lastProgressTime = tick(); break end
                                local nextObat = freshPending[1]
                                if not (LocalPlayer.Backpack:FindFirstChild(nextObat) or LocalPlayer.Character:FindFirstChild(nextObat)) then fetchItem(nextObat, freshPending); teleportToTarget(applyPP); task.wait(0.15) end
                                if turboSafeEquip(nextObat) then
                                    setStatus("Suntik: " .. nextObat); simpleInteract(applyPP, 0.1, false); lastProgressTime = tick()
                                    local prevCount = #freshPending; local wc = 0
                                    while wc < 40 do task.wait(0.05); if #getPendingMedicines(getActiveUI(minigame)) < prevCount or isHealingDone(minigame) then break end; wc = wc + 1; _G.AutoDoctor_LastActionTick = tick() end
                                end
                                injectAttempts = injectAttempts + 1; task.wait(0.05)
                            end
                        end
                    end
                end
            else
                local acted = false
                local prompts = getPromptsNearCenter(roomNum, roomPath)
                local handledBurn = false
                for _, desc in ipairs(prompts) do
                    local actText = string.lower(desc.ActionText or ""); local name = string.lower(desc.Name or "")
                    if name == "firepp" or actText:match("burns") then
                        if not (LocalPlayer.Backpack:FindFirstChild("Ointment") or LocalPlayer.Character:FindFirstChild("Ointment")) then fetchItem("Ointment", {"Ointment"}) end
                        teleportToTarget(desc)
                        if turboSafeEquip("Ointment") then setStatus("Treat Burns..."); simpleInteract(desc, 3, false); handledBurn = true; break end
                    end
                end

                if not handledBurn then
                    local monitor = minigame:FindFirstChild("Monitor")
                    local printer = minigame:FindFirstChild("Printer")
                    local actualPP2 = (monitor and monitor:FindFirstChild("PP2")) or getNil("PP2", "ProximityPrompt")

                    if actualPP2 then
                        if roomNum == 6 or roomNum == 7 then
                            unequipAll(); setStatus("BYPASS EMERG: Monitor PP2...")
                            
                            -- Langsung nempel ke Monitor!
                            teleportToTarget(actualPP2); task.wait(0.2)
                            firePromptRaw(actualPP2); task.wait(1.5)

                            local collectPP = nil
                            local waitPrinter = 0
                            while waitPrinter < 20 do
                                setStatus("Menunggu Printer Ready...")
                                for _, pp in ipairs(minigame:GetDescendants()) do
                                    if pp:IsA("ProximityPrompt") and pp.Enabled and string.match(string.lower(pp.ActionText or ""), "collect") then collectPP = pp; break end
                                end
                                if collectPP then break end
                                local pPP = getNil("PP", "ProximityPrompt")
                                if pPP and pPP.Enabled then collectPP = pPP; break end
                                task.wait(0.2); waitPrinter = waitPrinter + 1
                            end
                            
                            if collectPP then
                                setStatus("BYPASS EMERG: Collect Kertas...")
                                -- Langsung nempel ke Printer!
                                teleportToTarget(collectPP); task.wait(0.2)
                                firePromptRaw(collectPP); task.wait(0.5)
                            end
                            acted = true
                        else
                            local monitorUI = monitor and monitor:FindFirstChild("Screen") and monitor.Screen:FindFirstChild("UI")
                            if monitorUI and (monitorUI.Enabled or (monitorUI:FindFirstChild("Report") and monitorUI.Report.Visible)) then task.wait(1); acted = true
                            else
                                unequipAll(); teleportToRoomCenter(roomNum, roomPath); task.wait(0.5); setStatus("BYPASS MEDICAL: Process Results...")
                                for retry = 1, 3 do
                                    firePromptRaw(actualPP2); task.wait(0.5)
                                    local mUI = monitor and monitor:FindFirstChild("Screen") and monitor.Screen:FindFirstChild("UI")
                                    if mUI and ((mUI:IsA("SurfaceGui") and mUI.Enabled) or (mUI:FindFirstChild("Report") and mUI.Report.Visible)) then break end
                                end
                                acted = true
                            end
                        end
                    else acted = false end
                else acted = true end
                if acted then lastProgressTime = tick() task.wait(0.5) end
            end
        else task.wait(1) end
    end
end

-- ==========================================
-- SAFE MAIN EXECUTOR (WORKER THREAD)
-- ==========================================
local function botCycle()
    local activeShift = getShiftText()
    local fireNPC, firePP = getFireEmergency()
    if fireNPC then
        _G.AutoDoctor_IsIdle = false; pcall(function() unequipAll(); setStatus("! PRIORITAS 1: Pasien Terbakar !"); simpleInteract(firePP, 3.2, true); task.wait(1.5) end)
        return
    end

    local placePrompt, targetRoomName = getPlacePatientPrompt()
    if placePrompt then
        _G.AutoDoctor_IsIdle = false; pcall(function() setStatus("Membawa ke " .. tostring(targetRoomName)); teleportToTarget(placePrompt); task.wait(0.3); simpleInteract(placePrompt, 1, false); task.wait(1.5) end)
        return
    end

    local faintedPart, carryPP = getFaintedPatient()
    if faintedPart then
        _G.AutoDoctor_IsIdle = false; pcall(function() setStatus("! PRIORITAS 2: Gendong Pingsan !"); unequipAll(); teleportToTarget(faintedPart.PrimaryPart or faintedPart:FindFirstChildWhichIsA("BasePart")); simpleInteract(carryPP, 0, false); task.wait(1.5) end)
        return
    end

    local room, roomNum = findActiveRoom()
    if room and roomNum then
        _G.AutoDoctor_IsIdle = false
        if roomNum == 8 then pcall(function() executeRoom8Treatment(room, activeShift) end)
        else pcall(function() executeTreatmentCore(room, roomNum, activeShift) end) end
    else
        if not _G.AutoDoctor_IsIdle then unequipAll(); teleportToIdle(); _G.AutoDoctor_IsIdle = true end
        setStatus("Idle (Memantau)..."); printRadarReport(); task.wait(Config.ScanDelay)
    end
end

local function startWorker()
    if _G.AutoDoctor_Worker then task.cancel(_G.AutoDoctor_Worker) end
    _G.AutoDoctor_Worker = task.spawn(function()
        while autoScanEnabled do
            if not isBusy then isBusy = true; _G.AutoDoctor_LastActionTick = tick(); pcall(botCycle); isBusy = false end; task.wait(0.1)
        end
    end)
end

