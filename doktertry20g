-- EMERGENCY FINDERS
-- ==========================================
local function getPlacePatientPrompt()
    local roomsFolder = workspace:FindFirstChild("Rooms")
    if not roomsFolder then return nil, nil, nil, nil end
    local medicalFolder = roomsFolder:FindFirstChild("Medical")
    if medicalFolder then
        for i = 1, Config.MaxRooms do
            local room = medicalFolder:FindFirstChild("Room" .. i)
            if room then for _, desc in ipairs(room:GetDescendants()) do if desc:IsA("ProximityPrompt") and desc.Enabled and string.lower(desc.ActionText or ""):match("place") then return desc, room.Name, i, room end end end
        end
    end
    local emergencyFolder = roomsFolder:FindFirstChild("Emergency")
    if emergencyFolder and Config.EmergencyRooms then
        for _, i in ipairs(Config.EmergencyRooms) do
            local room = emergencyFolder:FindFirstChild("Room" .. i)
            if room then for _, desc in ipairs(room:GetDescendants()) do if desc:IsA("ProximityPrompt") and desc.Enabled and string.lower(desc.ActionText or ""):match("place") then return desc, room.Name, tonumber(i), room end end end
        end
    end
    return nil, nil, nil, nil
end

local function getFireEmergency()
    if workspace:FindFirstChild("NPCs") then
        for _, npc in ipairs(workspace.NPCs:GetChildren()) do local pp = npc:FindFirstChild("FirePP", true); if pp and pp.ActionText and pp.ActionText:match("Fire") then return npc, pp end end
    end
    for _, obj in ipairs(workspace:GetChildren()) do
        if obj:IsA("Model") and obj:FindFirstChild("Humanoid") then local pp = obj:FindFirstChild("FirePP", true); if pp and pp.ActionText and pp.ActionText:match("Fire") then return obj, pp end end
    end
    return nil, nil
end

local function getFaintedPatient()
    if workspace:FindFirstChild("NPCs") then
        for _, npc in ipairs(workspace.NPCs:GetChildren()) do local pp = npc:FindFirstChild("FaintedPP", true) or npc:FindFirstChildWhichIsA("ProximityPrompt", true); if pp and (pp.Name == "FaintedPP" or (pp.ActionText and pp.ActionText:match("Carry"))) then return npc, pp end end
    end
    for _, obj in ipairs(workspace:GetChildren()) do
        if obj:IsA("Model") then local pp = obj:FindFirstChild("FaintedPP", true) or obj:FindFirstChildWhichIsA("ProximityPrompt", true); if pp and (pp.Name == "FaintedPP" or (pp.ActionText and pp.ActionText:match("Carry"))) then return obj, pp end end
    end
    return nil, nil
end

local function findActiveRoom()
    local roomList = getRoomList()
    for _, data in ipairs(roomList) do
        local i = data.num; local room = data.room
        local isBlacklisted = BuggedRoomBlacklist[i] and (tick() - BuggedRoomBlacklist[i] < Config.BlacklistDuration)
        if not isBlacklisted then
            local minigame = room:FindFirstChild("Minigame")
            if i == 8 then
                local signLight = room:FindFirstChild("MainSign") and room.MainSign:FindFirstChild("Light")
                if signLight and (signLight.BrickColor.Name == "Crimson" or signLight.Color == Color3.fromRGB(165, 0, 0)) and not isHealingDone(minigame) then return room, i end
            else
                local ready, reason = isPatientReady(room, i)
                if ready and not isHealingDone(minigame) then _G.AutoDoctor_RoomMemory[i] = nil; return room, i end
                local signLight = room:FindFirstChild("MainSign") and room.MainSign:FindFirstChild("Light")
                if not (signLight and (signLight.BrickColor.Name == "Crimson" or signLight.Color == Color3.fromRGB(165, 0, 0))) and _G.AutoDoctor_RoomMemory[i] == "PatientLeaving" then _G.AutoDoctor_RoomMemory[i] = nil end
            end
        end
    end
    return nil, nil
end

-- [ STRICT APPLY PROMPT ]: Melarang Keras Nembak Ke Printer / Monitor
local function getApplyPrompt(minigame, roomNum, roomPath)
    local patient = getPatientInRoom(roomNum, roomPath)
    if patient then
        for _, desc in ipairs(patient:GetDescendants()) do
            if desc:IsA("ProximityPrompt") and desc.Enabled then
                local act = string.lower(desc.ActionText or "")
                if act:match("treat") or act:match("inject") or desc.Name == "PP" then return desc end
            end
        end
    end
    if not minigame then return nil end
    local bed = minigame:FindFirstChild("Bed") or minigame:FindFirstChild("Scanner") or minigame:FindFirstChild("MRI")
    if bed and bed:FindFirstChild("PP") then return bed.PP end
    for _, desc in ipairs(minigame:GetDescendants()) do
        if desc:IsA("ProximityPrompt") and (desc.Name == "PP" or desc.Name == "TreatPP") then
            local pName = desc.Parent and string.lower(desc.Parent.Name) or ""
            if pName ~= "printer" and pName ~= "monitor" then return desc end
        end
    end
    return nil
end

