-- ROOM 6 — LOGIC FROM SCRIPT 2
-- (NPC detection uses Script 1 style getPatientInRoom adapted for Emergency path)
-- ==========================================
local function getEmergencyRoom(roomNum)
    local rooms = workspace:FindFirstChild("Rooms")
    local emerg = rooms and rooms:FindFirstChild("Emergency")
    return emerg and emerg:FindFirstChild("Room" .. roomNum)
end

local function getPatientInEmergency(roomNum, centerCFrame, radius)
    local center = centerCFrame.Position
    radius = radius or Config.PatientBedRadius

    local function checkNPC(obj)
        if Players:GetPlayerFromCharacter(obj) then return nil, nil end
        if not obj:IsA("Model") then return nil, nil end
        local part = obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")
        if not part then return nil, nil end
        if (part.Position - center).Magnitude > radius then return nil, nil end

        -- R8 khusus: NPC bisa punya PP2 (Sleep Patient) atau PP (inject)
        -- Scan semua prompt aktif tanpa filter ketat
        local bestPP = nil
        for _, pp in ipairs(obj:GetDescendants()) do
            if pp:IsA("ProximityPrompt") and pp.Enabled then
                local txt  = string.lower(pp.ActionText or "")
                local name = string.lower(pp.Name or "")
                -- Priority match: prompt medis spesifik
                if txt:match("dna") or txt:match("treat") or txt:match("burns")
                or txt:match("inject") or txt:match("sleep")
                or name == "firepp" or name == "pp" or name == "pp2" then
                    return obj, pp
                end
                if not bestPP then bestPP = pp end
            end
        end
        -- Fallback: NPC ada di radius, kembalikan saja walau tidak ada prompt spesifik
        if bestPP then return obj, bestPP end
        -- Fallback terakhir: NPC ada di radius, kembalikan tanpa PP
        if obj:FindFirstChildOfClass("Humanoid") then return obj, nil end
        return nil, nil
    end

    -- Scan NPCs folder
    if workspace:FindFirstChild("NPCs") then
        for _, npc in ipairs(workspace.NPCs:GetChildren()) do
            local found, pp = checkNPC(npc)
            if found then return found, pp end
        end
    end

    -- Fallback: scan seluruh workspace (R8 / emergency NPC bisa di root workspace)
    for _, obj in ipairs(workspace:GetChildren()) do
        if obj ~= LocalPlayer.Character and obj.Name ~= "Rooms" and obj.Name ~= "Misc"
        and obj.Name ~= "NPCs" and obj.Name ~= "Camera" then
            local found, pp = checkNPC(obj)
            if found then return found, pp end
        end
    end

    return nil, nil
end

-- ==========================================
-- EMERGENCY ROOM PATIENT MEMORY SYSTEM
-- Mencegah re-treat pasien lama yang masih ada di ruangan
-- Mirror dari Medical RoomMemory tapi untuk R6/R7/R8
-- ==========================================

-- Dipanggil saat treatment selesai — catat pasien yang sudah ditangani
local function erMemorySet(roomNum, patientInstance)
    _G.ER_Memory[roomNum] = {
        patient = patientInstance or "done",
        tick    = tick(),
    }
end

-- Dipanggil saat mau cek apakah perlu treat — return true = skip (pasien lama)
-- Logic sama dengan Medical:
--   - Kalau memory kosong          → boleh treat (pasien baru / belum pernah)
--   - Kalau memory ada tapi NPC sudah pergi          → hapus memory, boleh treat
--   - Kalau NPC beda dari yang di memory             → hapus memory, boleh treat (pasien baru)
--   - Kalau NPC sama DAN masih punya PE (biru/sakit) → hapus memory (perlu re-treat)
--   - Kalau NPC sama DAN tidak PE                    → SKIP (pasien lama belum pergi)
local function erMemoryCheck(roomNum, currentNPC)
    local mem = _G.ER_Memory[roomNum]
    if not mem then return false end  -- tidak ada memory → boleh treat

    local memPatient = mem.patient

    -- Memory "done" string (pasien tidak terdeteksi saat selesai)
    if memPatient == "done" then
        if not currentNPC then
            -- Pasien sudah pergi, hapus memory
            _G.ER_Memory[roomNum] = nil
            return false
        else
            -- Ada NPC baru masuk setelah pasien lama done
            _G.ER_Memory[roomNum] = nil
            return false
        end
    end

    -- Memory adalah Instance
    if typeof(memPatient) == "Instance" then
        if not currentNPC then
            -- Pasien lama sudah pergi
            _G.ER_Memory[roomNum] = nil
            return false
        end
        if currentNPC ~= memPatient then
            -- NPC berbeda → pasien baru
            _G.ER_Memory[roomNum] = nil
            return false
        end
        -- NPC sama → cek apakah dia sakit lagi (punya particle PE)
        if currentNPC:FindFirstChild("PE", true) then
            _G.ER_Memory[roomNum] = nil
            return false  -- sakit lagi → perlu re-treat
        end
        -- NPC sama, tidak PE → ini pasien lama yang belum pergi, SKIP
        return true
    end

    -- Fallback: hapus memory yang formatnya tidak dikenal
    _G.ER_Memory[roomNum] = nil
    return false
end

-- Reset semua ER memory (dipanggil saat shift berganti atau hard-reset)
local function erMemoryReset()
    _G.ER_Memory = { [6] = nil, [7] = nil, [8] = nil }
end

local function checkAnomalyStatus_Em(npcOrPos, isPos)
    if workspace:FindFirstChild("NPCs") then
        for _, npc in ipairs(workspace.NPCs:GetChildren()) do
            local check = false
            if isPos then
                local p = npc.PrimaryPart or npc:FindFirstChildWhichIsA("BasePart")
                if p and (p.Position - npcOrPos).Magnitude <= 12 then check = true end
            else
                check = (npc == npcOrPos)
            end
            if check then
                local attr = npc:GetAttributes()
                if attr.Skinwalker or attr.SkinwalkerEasy or attr.PenaltyWhenLettingIn or attr.PhotoEffect == "CursedPhoto" or attr.PhotoEffect2 == "CursedPhoto" then
                    return true
                end
            end
        end
    end
    return false
end

-- R6 Utilities
local function enforceRoom6Position()
    local char = LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if root then
        local dist = (root.Position - EmergencyCFrames[6].Room.Position).Magnitude
        if dist > 5 then
            root.CFrame = EmergencyCFrames[6].Room
            root.Velocity = Vector3.zero
            task.wait(0.2)
        end
    end
end

local function interact_R6(prompt, holdTime)
    if not prompt or not prompt:IsA("ProximityPrompt") then return end
    local oldReq     = prompt.RequiresLineOfSight
    local oldDist    = prompt.MaxActivationDistance
    local oldEnabled = prompt.Enabled
    prompt.RequiresLineOfSight   = false
    prompt.MaxActivationDistance = math.huge
    prompt.Enabled               = true
    if type(fireproximityprompt) == "function" then fireproximityprompt(prompt, 1, true)
    else prompt:InputHoldBegan() task.wait(holdTime or 0.25) prompt:InputHoldEnded() end
    prompt.RequiresLineOfSight   = oldReq
    prompt.MaxActivationDistance = oldDist
    prompt.Enabled               = oldEnabled
    task.wait(0.2)
end

local function isHealingDone_R6(minigame)
    if not minigame then return false end
    local tv      = minigame:FindFirstChild("TV")
    local screen  = tv and tv:FindFirstChild("Screen")
    local ui      = screen and screen:FindFirstChild("UI")
    local healing = ui and ui:FindFirstChild("Healing")
    if healing and healing:IsA("GuiObject") and healing.Visible == true then return true end
    return false
end

local function fetchItem_R6(targetName, pendingMedsList)
    InventoryMutex:lock("R6-fetch")
    setStatus("Mengambil: " .. targetName, "R6")
    local totalAmount, currentItems = checkTotalInventory()
    if totalAmount >= Config.MaxInventory then
        local itemToThrowAway = nil
        if pendingMedsList then
            for _, item in ipairs(currentItems) do
                if item.Name ~= targetName and not table.find(pendingMedsList, item.Name) then
                    itemToThrowAway = item; break
                end
            end
        end
        if not itemToThrowAway then itemToThrowAway = currentItems[1] end
        if itemToThrowAway then
            local char = LocalPlayer.Character
            local hum  = char and char:FindFirstChild("Humanoid")
            if hum then hum:EquipTool(itemToThrowAway) end
            task.wait(0.1)
            local trashPrompt = nil
            for _, desc in ipairs(workspace:GetDescendants()) do
                if desc:IsA("ProximityPrompt") then
                    local actText = string.lower(desc.ActionText or "")
                    local objName = string.lower(desc.Parent and desc.Parent.Name or "")
                    if actText:match("trash") or actText:match("throw") or objName:match("trash") then
                        trashPrompt = desc; break
                    end
                end
            end
            if trashPrompt then
                teleportToTarget(trashPrompt)
                task.wait(0.2)
                interact_R6(trashPrompt, 0)
            end
        end
    end
    local promptToUse = nil
    for _, desc in ipairs(workspace:GetDescendants()) do
        if desc:IsA("ProximityPrompt") then
            local pName = desc.Parent and desc.Parent.Name or ""
            local oText = desc.ObjectText or ""
            local aText = desc.ActionText or ""
            if pName == targetName or oText:match(targetName) or aText:match(targetName) then
                promptToUse = desc; break
            end
        end
    end
    if promptToUse then
        teleportToTarget(promptToUse)
        task.wait(0.2)
        -- Retry loop: berusaha sampai item benar-benar masuk inventory
        local gotItem = false
        for retry = 1, 15 do
            interact_R6(promptToUse, 0)
            task.wait(0.15)
