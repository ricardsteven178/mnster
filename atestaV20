-- ==========================================
-- INVENTORY MUTEX
-- Hanya serialize aksi ambil/buang item.
-- Treatment tiap room tetap paralel penuh.
-- R6/R7/R8 bisa rawat pasien bersamaan,
-- tapi giliran saat butuh ambil/buang obat.
-- ==========================================
local InventoryMutex = {
    _locked   = false,
    _owner    = nil,
    _lockTime = 0,
    _timeout  = 15,  -- force release setelah 15 detik
}

function InventoryMutex:lock(owner)
    local waited = 0
    while self._locked do
        -- Force release kalau pemilik lama stuck
        if tick() - self._lockTime > self._timeout then
            warn("[InvMutex] Force-release dari " .. tostring(self._owner))
            self._locked = false; self._owner = nil; break
        end
        task.wait(0.1); waited = waited + 0.1
        if waited > 10 then
            warn("[InvMutex] " .. owner .. " timeout tunggu, force lanjut")
            break
        end
    end
    self._locked = true; self._owner = owner; self._lockTime = tick()
end

function InventoryMutex:unlock(owner)
    if self._owner == owner then
        self._locked = false; self._owner = nil
    end
end

-- Hapus GlobalMutex yang lama (tidak dipakai lagi)
local GlobalMutex = InventoryMutex  -- alias agar tidak ada ref error

