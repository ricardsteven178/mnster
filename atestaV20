local function ensureInRoom8()
    local char = LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if root then
        local distance = (root.Position - EmergencyCFrames[8].Bed.Position).Magnitude
        if distance > 20 then
            setStatus("Anchor: Kembali ke kasur R8...", "R8")
            root.CFrame = EmergencyCFrames[8].Bed
            root.AssemblyLinearVelocity = Vector3.zero
            task.wait(0.2)
        end
    end
end

local function safeEquip_R8(itemName)
    local char    = LocalPlayer.Character
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    local hum     = char and char:FindFirstChild("Humanoid")
    if not char or not backpack or not hum then return false end
    if char:FindFirstChild(itemName) then return true end
    hum:UnequipTools()
    local tool = backpack:FindFirstChild(itemName)
    if not tool then return false end
    hum:EquipTool(tool)
    local t2 = 0
    while not char:FindFirstChild(itemName) and t2 < 15 do task.wait(0.05); t2 = t2 + 1 end
    task.wait(0.1)
    return char:FindFirstChild(itemName) ~= nil
end

local function simpleInteract_R8(prompt, customHold, autoLock)
    if prompt and prompt:IsA("ProximityPrompt") then
        if autoLock then ensureInRoom8() end
        local oldReq  = prompt.RequiresLineOfSight
        local oldDist = prompt.MaxActivationDistance
        prompt.RequiresLineOfSight   = false
        prompt.MaxActivationDistance = math.huge
        if type(fireproximityprompt) == "function" then fireproximityprompt(prompt, 1, true)
        else prompt:InputHoldBegan() task.wait(customHold or prompt.HoldDuration or 0.1) prompt:InputHoldEnded() end
        _G.Room8Auto_LastActionTick  = tick()
        prompt.RequiresLineOfSight   = oldReq
        prompt.MaxActivationDistance = oldDist
    end
end

local function smartTrash_R8(toolToTrash)
    InventoryMutex:lock("R8-trash")
    local char = LocalPlayer.Character
    local hum  = char and char:FindFirstChild("Humanoid")
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not hum or not root or not toolToTrash then return false end
    local prompt = getPromptFromCache("Trash", true, nil, _G.Room8_TrashCache)
    if not prompt then
        for _, desc in ipairs(workspace:GetDescendants()) do
            if desc:IsA("ProximityPrompt") then
                local actText = string.lower(desc.ActionText or "")
                local objName = string.lower(desc.Parent and desc.Parent.Name or "")
                if actText:match("trash") or actText:match("throw") or actText:match("dispose") or objName:match("trash") then
                    _G.Room8_TrashCache = desc; prompt = desc; break
                end
            end
        end
    else
        _G.Room8_TrashCache = prompt
    end
    if prompt then
        setStatus("Buang Item R8: " .. toolToTrash.Name, "R8")
        hum:EquipTool(toolToTrash)
        task.wait(0.05)
        local targetPart = prompt.Parent:IsA("BasePart") and prompt.Parent or prompt.Parent:FindFirstChildWhichIsA("BasePart", true)
        local dist       = targetPart and (root.Position - targetPart.Position).Magnitude or 0
        local originalPos = root.CFrame
        if dist > 14 and targetPart then
            root.CFrame = targetPart.CFrame * CFrame.new(0, 3, 0)
            root.AssemblyLinearVelocity = Vector3.zero
            task.wait(0.05)
        end
        local oldReq  = prompt.RequiresLineOfSight
        local oldDist = prompt.MaxActivationDistance
        prompt.RequiresLineOfSight   = false
        prompt.MaxActivationDistance = math.huge
        prompt.HoldDuration          = 0
        if type(fireproximityprompt) == "function" then fireproximityprompt(prompt, 1, true)
        else prompt:InputHoldBegan() task.wait(0.05) prompt:InputHoldEnded() end
        prompt.RequiresLineOfSight   = oldReq
        prompt.MaxActivationDistance = oldDist
        _G.Room8Auto_LastActionTick  = tick()
        task.wait(0.05)
        if dist > 14 then root.CFrame = originalPos; root.AssemblyLinearVelocity = Vector3.zero; task.wait(0.05) end
        InventoryMutex:unlock("R8-trash")
        return true
    end
    InventoryMutex:unlock("R8-trash")
    return false
end

local function smartFetch_R8(targetName, pendingMedsList)
    InventoryMutex:lock("R8-fetch")
    local char = LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not char or not root then InventoryMutex:unlock("R8-fetch"); return false end
    ensureInRoom8()
    local totalAmount, currentItems = checkTotalInventory()
    if totalAmount >= Config.MaxInventory then
        local reqCounts = {}
        if pendingMedsList then
            for _, o in ipairs(pendingMedsList) do reqCounts[o] = (reqCounts[o] or 0) + 1 end
        end
        local haveCounts    = {}
        local itemToThrowAway = nil
        for _, item in ipairs(currentItems) do
            haveCounts[item.Name] = (haveCounts[item.Name] or 0) + 1
            local needed = reqCounts[item.Name] or 0
            if haveCounts[item.Name] > needed then itemToThrowAway = item end
        end
        if not itemToThrowAway then itemToThrowAway = currentItems[1] end
        smartTrash_R8(itemToThrowAway)
    end
    local promptToUse = getPromptFromCache(targetName, false, _G.Room8_ItemCache, nil)
    if not promptToUse then
        for _, desc in ipairs(workspace:GetDescendants()) do
            if desc:IsA("ProximityPrompt") then
                local pName = desc.Parent and desc.Parent.Name or ""
                local oText = desc.ObjectText or ""
                local aText = desc.ActionText or ""
                if pName == targetName or oText:match(targetName) or aText:match(targetName) then
                    _G.Room8_ItemCache[targetName] = desc; promptToUse = desc; break
                end
            end
        end
    end
    if promptToUse then
        local hum     = char:FindFirstChild("Humanoid")
        if hum then hum:UnequipTools() end
        local itemPart = promptToUse.Parent:IsA("BasePart") and promptToUse.Parent or promptToUse.Parent:FindFirstChildWhichIsA("BasePart", true)
        local dist     = itemPart and (root.Position - itemPart.Position).Magnitude or 0
        local originalPos = root.CFrame
        if dist > 14 and itemPart then
            root.CFrame = itemPart.CFrame * CFrame.new(0, 3, 0)
            root.AssemblyLinearVelocity = Vector3.zero
            task.wait(0.05)
        end
        local oldReq  = promptToUse.RequiresLineOfSight
        local oldDist = promptToUse.MaxActivationDistance
        promptToUse.RequiresLineOfSight   = false
        promptToUse.MaxActivationDistance = math.huge
        promptToUse.HoldDuration          = 0
        if type(fireproximityprompt) == "function" then fireproximityprompt(promptToUse, 1, true)
        else promptToUse:InputHoldBegan() task.wait(0.05) promptToUse:InputHoldEnded() end
        promptToUse.RequiresLineOfSight   = oldReq
        promptToUse.MaxActivationDistance = oldDist
        _G.Room8Auto_LastActionTick = tick()
        task.wait(0.1)
        if dist > 14 then root.CFrame = originalPos; root.AssemblyLinearVelocity = Vector3.zero; task.wait(0.05) end
        InventoryMutex:unlock("R8-fetch")
        return true
    end
    setStatus("GAGAL: " .. targetName .. " tidak ditemukan.", "R8")
    InventoryMutex:unlock("R8-fetch")
    return false
end

local function getPendingMedicinesRoom8(reportFolder)
    local pending = {}
    if not reportFolder then return pending end
    local invFolder = reportFolder:FindFirstChild("inv")
    if not invFolder then return pending end
    for _, itemReq in ipairs(invFolder:GetChildren()) do
        if table.find(ItemList, itemReq.Name) then
            local checkMark = itemReq:FindFirstChild("check")
            if not checkMark or (checkMark and checkMark.Visible == false) then table.insert(pending, itemReq.Name) end
        end
    end
    return pending
end

local function isRoom8HealingDone(room8)
    if not room8 then return false end
    local ui      = room8:FindFirstChild("Minigame") and room8.Minigame:FindFirstChild("TV") and room8.Minigame.TV:FindFirstChild("Screen") and room8.Minigame.TV.Screen:FindFirstChild("UI")
    local healing = ui and ui:FindFirstChild("Healing")
    if healing and healing:IsA("GuiObject") and healing.Visible == true then return true end
    return false
end

local function executeRoom8Treatment(room8, activeShift)
    local minigame = room8:FindFirstChild("Minigame")
    if not minigame or getShiftText() ~= activeShift then return end
    setStatus("--- TURBO SURGERY R8 DIMULAI ---", "R8")
    local root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if root then
        root.CFrame = EmergencyCFrames[8].Bed
        root.AssemblyLinearVelocity = Vector3.zero
    end
    local ui           = minigame:FindFirstChild("TV") and minigame.TV:FindFirstChild("Screen") and minigame.TV.Screen:FindFirstChild("UI")
    local reportFolder = ui and ui:FindFirstChild("Report")
    local treatmentText = reportFolder and reportFolder:FindFirstChild("treatment")
    local bed          = minigame:FindFirstChild("Bed") and minigame.Bed:FindFirstChild("InBed")
    setStatus("1/3 Menunggu fisik pasien di kasur...", "R8")
    local targetNPC = nil
    local waitNPC   = 0
    local MAX_NPC_WAIT = 20  -- maksimal 20x0.5 = 10 detik tunggu pasien
    while not targetNPC and waitNPC < MAX_NPC_WAIT do
        ensureInRoom8()
        if getShiftText() ~= activeShift then return end
        local found, _ = getPatientInEmergency(8, EmergencyCFrames[8].Bed, EmergencyCFrames[8].Radius)
        if found then
            targetNPC = found
        else
            -- Fallback radius lebih besar
            if workspace:FindFirstChild("NPCs") then
                for _, npc in ipairs(workspace.NPCs:GetChildren()) do
                    local p = npc.PrimaryPart or npc:FindFirstChildWhichIsA("BasePart")
                    if p and (p.Position - EmergencyCFrames[8].Bed.Position).Magnitude <= 20 then
                        targetNPC = npc; break
                    end
                end
            end
        end
        if not targetNPC then
            _G.Room8Auto_LastActionTick = tick()
            task.wait(0.5); waitNPC = waitNPC + 1
        end
    end
    if not targetNPC then
        setStatus("BATAL: Pasien tidak kunjung tiba di kasur R8. Kembali idle.", "R8")
        isBotIdle_R8 = false  -- reset agar bisa re-scan
        return
    end
    setStatus("2/3 Menidurkan pasien...", "R8")
    local waitLimit = 0
    local function findSleepPP()
        if bed then
            local pp2 = bed:FindFirstChild("PP2")
            if pp2 and pp2:IsA("ProximityPrompt") and pp2.Enabled then return pp2 end
        end
        for _, desc in ipairs(minigame:GetDescendants()) do
            if desc:IsA("ProximityPrompt") and desc.Enabled then
                local txt  = string.lower(desc.ActionText or "")
                local name = string.lower(desc.Name or "")
                if txt:match("sleep") or name == "pp2" or txt:match("anest") then return desc end
            end
        end
        if targetNPC then
            for _, desc in ipairs(targetNPC:GetDescendants()) do
                if desc:IsA("ProximityPrompt") and desc.Enabled then
                    local txt = string.lower(desc.ActionText or "")
                    if txt:match("sleep") or txt:match("anest") then return desc end
                end
            end
        end
        return nil
    end
    while waitLimit < 60 do
        ensureInRoom8()
        _G.Room8Auto_LastActionTick = tick()
        if isRoom8HealingDone(room8) or getShiftText() ~= activeShift then return end
        if treatmentText and treatmentText.Text == "BEGIN SURGERY:" then break end
        if reportFolder and #getPendingMedicinesRoom8(reportFolder) > 0 then break end
        local sleepPP = findSleepPP()
        if sleepPP then
            simpleInteract_R8(sleepPP, 0.1, false)
        else
            setStatus("2/3 Menunggu Sleep PP muncul...", "R8")
        end
        task.wait(0.3); waitLimit = waitLimit + 1
    end
    setStatus("3/3 Mulai Apply Treatment...", "R8")
    local lastProgressTime = tick()
    while true do
        task.wait(0.05)
        _G.Room8Auto_LastActionTick = tick()
        ensureInRoom8()
        if getShiftText() ~= activeShift then setStatus("Shift berganti. Stop R8.", "R8"); break end
        if isRoom8HealingDone(room8) then
            setStatus("Surgery Selesai! Layar Hijau.", "R8")
            erMemorySet(8, targetNPC)
            break
        end
        local signLight = room8:FindFirstChild("MainSign") and room8.MainSign:FindFirstChild("Light")
        if not signLight or (signLight.BrickColor.Name ~= "Crimson" and signLight.Color ~= Color3.fromRGB(165, 0, 0)) then break end
        if tick() - lastProgressTime >= Config.StuckTimeout then setStatus("Local Loop Timeout R8. Skip.", "R8"); break end
        local patientIsAnomaly = checkAnomalyStatus_Em(EmergencyCFrames[8].Bed.Position, true)
        local currentPending   = getPendingMedicinesRoom8(reportFolder)
        if patientIsAnomaly and Config.AnomalyKiller and #currentPending > 0 then
            local wrongMedicine = "Medicine"
            for _, item in ipairs(ItemList) do
                if not table.find(currentPending, item) then wrongMedicine = item; break end
            end
            local hasIt = LocalPlayer.Backpack:FindFirstChild(wrongMedicine) or LocalPlayer.Character:FindFirstChild(wrongMedicine)
            if not hasIt then setStatus("Telekinesis Racun: " .. wrongMedicine, "R8"); smartFetch_R8(wrongMedicine, {wrongMedicine}) end
            local hasItNow = LocalPlayer.Backpack:FindFirstChild(wrongMedicine) or LocalPlayer.Character:FindFirstChild(wrongMedicine)
            if hasItNow then
                if bed and bed:FindFirstChild("PP") then
                    ensureInRoom8()
                    if safeEquip_R8(wrongMedicine) then
                        setStatus("MENYUNTIKKAN RACUN: " .. wrongMedicine, "R8")
                        simpleInteract_R8(bed.PP, 0.1, true)
                        lastProgressTime = tick()
                        task.wait(1.5)
                        setStatus("--- ANOMALI HANGUS! ---", "R8")
                        erMemorySet(8, targetNPC)
                        break
                    else setStatus("FAILSAFE: Gagal pegang racun.", "R8"); task.wait(0.5) end
                end
            else setStatus("Gagal mengambil racun: " .. wrongMedicine, "R8"); task.wait(0.5) end
        else
            if #currentPending == 0 then continue end
            local reqCounts = {}
            for _, obat in ipairs(currentPending) do reqCounts[obat] = (reqCounts[obat] or 0) + 1 end
            local _, currentItems = checkTotalInventory()
            local haveCounts = {}
            for _, item in ipairs(currentItems) do haveCounts[item.Name] = (haveCounts[item.Name] or 0) + 1 end
            local isMissingItems = false
            for obat, needed in pairs(reqCounts) do
                local have = haveCounts[obat] or 0
                if have < needed then
                    for i = 1, (needed - have) do
                        setStatus("Telekinesis: " .. obat .. " (" .. (have + i) .. "/" .. needed .. ")", "R8")
                        smartFetch_R8(obat, currentPending)
                        isMissingItems = true
                    end
                end
            end
            if isMissingItems then task.wait(0.1) end
            local obatToInject = currentPending[1]
            local hasItNow     = LocalPlayer.Backpack:FindFirstChild(obatToInject) or LocalPlayer.Character:FindFirstChild(obatToInject)
            if hasItNow then
                -- Cari PP inject secara aktif di bed, minigame, dan NPC
                local applyPP = bed and bed:FindFirstChild("PP")
                if not applyPP then
                    for _, desc in ipairs(minigame:GetDescendants()) do
                        if desc:IsA("ProximityPrompt") and desc.Enabled then
                            local name = string.lower(desc.Name or "")
                            local txt  = string.lower(desc.ActionText or "")
                            if name == "pp" or txt:match("inject") or txt:match("apply") or txt:match("treat") then
                                applyPP = desc; break
                            end
                        end
                    end
                end
                if not applyPP and targetNPC then
                    for _, desc in ipairs(targetNPC:GetDescendants()) do
                        if desc:IsA("ProximityPrompt") and desc.Enabled then
                            applyPP = desc; break
                        end
                    end
                end
                if applyPP then
                    ensureInRoom8()
                    if safeEquip_R8(obatToInject) then
                        task.wait(0.2)
                        local previousPendingCount = #currentPending
                        setStatus("Menerapkan: " .. obatToInject, "R8")
                        simpleInteract_R8(applyPP, 0.1, true)
                        lastProgressTime = tick()
                        setStatus("Menunggu obat terproses di TV...", "R8")
                        local waitCheckLimit = 0
                        while waitCheckLimit < 30 do
                            local newPending = getPendingMedicinesRoom8(reportFolder)
                            if #newPending < previousPendingCount then break end
                            if isRoom8HealingDone(room8) or getShiftText() ~= activeShift then break end
                            task.wait(0.05)
                            waitCheckLimit = waitCheckLimit + 1
                            _G.Room8Auto_LastActionTick = tick()
                        end
                    else setStatus("FAILSAFE: Gagal pegang " .. obatToInject, "R8"); task.wait(0.5) end
                end
            else setStatus("Gagal Telekinesis " .. obatToInject, "R8"); task.wait(0.5) end
        end
    end
end

local function botCycleRoom8()
    local activeShift = getShiftText()
    if activeShift == "" or not activeShift or activeShift:match("Istirahat") then
        if not isBotIdle_R8 then teleportToIdle(); isBotIdle_R8 = true end
        setStatus("Istirahat/Luar Shift...", "R8")
        task.wait(2); return
    end
    local room8 = getEmergencyRoom(8)
    local roomActive = nil
    if room8 and not isRoom8HealingDone(room8) then
        -- WAJIB: NPC harus sudah fisik ada di radius kasur dulu baru trigger
        local npcFound, _ = getPatientInEmergency(8, EmergencyCFrames[8].Bed, EmergencyCFrames[8].Radius)
        if npcFound then
            roomActive = room8
        else
            -- Fallback: TV sudah punya obat pending (NPC prompt mungkin lambat spawn)
            local minigame8     = room8:FindFirstChild("Minigame")
            local ui8           = minigame8 and minigame8:FindFirstChild("TV") and minigame8.TV:FindFirstChild("Screen") and minigame8.TV.Screen:FindFirstChild("UI")
            local reportFolder8 = ui8 and ui8:FindFirstChild("Report")
            if reportFolder8 and #getPendingMedicinesRoom8(reportFolder8) > 0 then
                roomActive = room8
            end
            -- Lampu merah saja = JANGAN trigger, pasien masih dalam perjalanan
        end
    end
    if roomActive then
        -- ── MEMORY CHECK: jangan re-treat pasien lama yang belum pergi ────
        local currentNPC_R8, _ = getPatientInEmergency(8, EmergencyCFrames[8].Bed, EmergencyCFrames[8].Radius)
        if erMemoryCheck(8, currentNPC_R8) then
            if not isBotIdle_R8 then teleportToIdle(); isBotIdle_R8 = true end
            setStatus("R8: Menunggu pasien lama pergi...", "R8")
            task.wait(1)
            return
        end
        isBotIdle_R8 = false
        pcall(function() executeRoom8Treatment(roomActive, activeShift) end)
    else
        if not isBotIdle_R8 then teleportToIdle(); isBotIdle_R8 = true end
        setStatus("Menunggu Kasus R8 (" .. activeShift .. ")...", "R8")
        task.wait(Config.ScanDelay)
    end
end

local function startWorkerRoom8()
    if _G.Room8Auto_Worker then task.cancel(_G.Room8Auto_Worker) end
    _G.Room8Auto_Worker = task.spawn(function()
        while autoEnabled_R8 do
            if not isBusy_R8 then
                isBusy_R8 = true
                _G.Room8Auto_LastActionTick = tick()
