local function executeRoom6()
    local success, err = pcall(function()
        local path     = getEmergencyRoom(6)
        local minigame = path and path:FindFirstChild("Minigame")
        if not path or not minigame then return end

        -- Check active
        local isRoomActive = false
        if not isHealingDone_R6(minigame) then
            -- Check prompts
            for _, pp in ipairs(minigame:GetDescendants()) do
                if pp:IsA("ProximityPrompt") and pp.Enabled then
                    local txt = string.lower(pp.ActionText or "")
                    if txt:match("x%-ray") or txt:match("process") or txt:match("collect") then
                        isRoomActive = true; break
                    end
                end
            end
            -- Check TV meds
            if not isRoomActive then
                local tvScreen = minigame:FindFirstChild("TV") and minigame.TV:FindFirstChild("Screen", true)
                local invUI    = tvScreen and tvScreen:FindFirstChild("inv", true)
                if invUI and #invUI:GetChildren() > 1 then
                    local pending = getPendingMeds_R6(tvScreen and tvScreen:FindFirstChild("UI") or tvScreen)
                    if #pending > 0 then isRoomActive = true end
                end
            end
            -- Check patient fisik (WAJIB ADA sebelum trigger)
            if not isRoomActive then
                local patNPC, _ = getPatientInEmergency(6, EmergencyCFrames[6].Patient, EmergencyCFrames[6].Radius)
                if patNPC then isRoomActive = true end
            end
            -- Lampu merah SAJA tidak cukup → pasien masih dalam perjalanan, jangan teleport
        end

        if not isRoomActive then
            if not _G.Room6_IsIdle then unequipAll(); teleportToIdle(); _G.Room6_IsIdle = true end
            setStatus("Idle (Standby memantau R6)...", "R6")
            task.wait(1)
            return
        end

        -- ── MEMORY CHECK: skip kalau pasien lama belum pergi ─────────────
        local currentNPC_R6, _ = getPatientInEmergency(6, EmergencyCFrames[6].Patient, EmergencyCFrames[6].Radius)
        if erMemoryCheck(6, currentNPC_R6) then
            if not _G.Room6_IsIdle then unequipAll(); teleportToIdle(); _G.Room6_IsIdle = true end
            setStatus("R6: Menunggu pasien lama pergi...", "R6")
            task.wait(1)
            return
        end

        _G.Room6_IsIdle = false
        setStatus("Room 6 Aktif! Menyiapkan...", "R6")
        enforceRoom6Position()

        local isDone           = false
        local lastProgressTime = tick()
        local lastPendingCount = -1
        local emptyCounter     = 0

        while not isDone and autoEnabled_R6 do
            task.wait(0.3)
            enforceRoom6Position()

            if isHealingDone_R6(minigame) then
                setStatus("✅ Healing TV menyala! Kembali Idle...", "R6")
                local doneNPC, _ = getPatientInEmergency(6, EmergencyCFrames[6].Patient, EmergencyCFrames[6].Radius)
                erMemorySet(6, doneNPC)
                isDone = true; break
            end

            -- Re-check active
            local stillActive = false
            if not isHealingDone_R6(minigame) then
                for _, pp in ipairs(minigame:GetDescendants()) do
                    if pp:IsA("ProximityPrompt") and pp.Enabled then
                        local txt = string.lower(pp.ActionText or "")
                        if txt:match("x%-ray") or txt:match("process") or txt:match("collect") then stillActive = true; break end
                    end
                end
                if not stillActive then
                    local tvScreen = minigame:FindFirstChild("TV") and minigame.TV:FindFirstChild("Screen", true)
                    local tvUI     = tvScreen and tvScreen:FindFirstChild("UI")
                    local pending  = getPendingMeds_R6(tvUI)
                    if #pending > 0 then stillActive = true end
                end
                if not stillActive then
                    local patNPC, _ = getPatientInEmergency(6, EmergencyCFrames[6].Patient, EmergencyCFrames[6].Radius)
                    if patNPC then stillActive = true end
                end
            end

            if not stillActive then
                emptyCounter = emptyCounter + 1
                if emptyCounter >= 3 then
                    setStatus("✅ R6 Kosong (Clear). Kembali Idle...", "R6")
                    erMemorySet(6, nil)  -- pasien sudah pergi, catat "done"
                    isDone = true; break
                end
            else
                emptyCounter = 0
            end

            local patNPC, patPP = getPatientInEmergency(6, EmergencyCFrames[6].Patient, EmergencyCFrames[6].Radius)
            local tvScreen      = minigame:FindFirstChild("TV") and minigame.TV:FindFirstChild("Screen", true)
            local tvUI          = tvScreen and tvScreen:FindFirstChild("UI")
            local pending       = getPendingMeds_R6(tvUI)

            -- 1. CEK SUNTIK OBAT
            if #pending > 0 then
                if #pending ~= lastPendingCount then lastPendingCount = #pending; lastProgressTime = tick() end
                if not patPP then setStatus("⚠️ Menunggu NPC untuk disuntik...", "R6"); continue end

                if checkAnomalyStatus_Em(patNPC) and Config.AnomalyKiller then
                    setStatus("!! ANOMALI TERDETEKSI !!", "R6")
                    local wrongMedicine = "Medicine"
                    for _, item in ipairs(ItemList) do
                        if not table.find(pending, item) then wrongMedicine = item; break end
                    end
                    local hasIt = LocalPlayer.Backpack:FindFirstChild(wrongMedicine) or LocalPlayer.Character:FindFirstChild(wrongMedicine)
                    if not hasIt then fetchItem_R6(wrongMedicine, {wrongMedicine}) end
                    enforceRoom6Position()
                    local tool = LocalPlayer.Backpack:FindFirstChild(wrongMedicine) or LocalPlayer.Character:FindFirstChild(wrongMedicine)
                    if tool then
                        local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid")
                        if hum then unequipAll(); task.wait(0.1); hum:EquipTool(tool) end
                    end
                    task.wait(0.2)
                    setStatus("MENYUNTIKKAN RACUN: " .. wrongMedicine, "R6")
                    interact_R6(patPP, 0.25)
                    setStatus("--- ANOMALI HANGUS! ---", "R6")
                    erMemorySet(6, patNPC)
                    continue
                end

                for _, obat in ipairs(pending) do
                    local hasItem = LocalPlayer.Backpack:FindFirstChild(obat) or (LocalPlayer.Character and LocalPlayer.Character:FindFirstChild(obat))
                    if not hasItem then fetchItem_R6(obat, pending) end
                    enforceRoom6Position()
                    local tool = LocalPlayer.Backpack:FindFirstChild(obat)
                    local hum  = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid")
                    if tool and hum then unequipAll(); task.wait(0.1); hum:EquipTool(tool) end
                    task.wait(0.2)
                    setStatus("Menyuntikkan: " .. obat, "R6")
                    interact_R6(patPP, 0.25)
                end
                task.wait(1.5)
                continue
            end

            -- 2. CEK COLLECT
            local collected = false
            for _, pp in ipairs(minigame:GetDescendants()) do
                if pp:IsA("ProximityPrompt") and pp.ActionText:match("Collect") and pp.Enabled then
                    setStatus("Mengambil Hasil (Collect)...", "R6")
                    enforceRoom6Position()
                    interact_R6(pp, 0.5)
                    lastProgressTime = tick()
                    collected = true
                    task.wait(1.5)
                    break
                end
            end
            if collected then continue end

            -- 3. BYPASS PROCESS
            local bypassBerhasil = false
            local monitor = minigame:FindFirstChild("Monitor")
            if monitor then
                for _, pp in ipairs(monitor:GetDescendants()) do
                    if pp:IsA("ProximityPrompt") and string.lower(pp.ActionText or ""):match("process") then
                        setStatus("BYPASS AKTIF: Process Instan...", "R6")
                        enforceRoom6Position()
                        interact_R6(pp, 0.25)
                        lastProgressTime = tick()
                        task.wait(1.5)
                        bypassBerhasil = true
                        break
                    end
                end
            end
            if bypassBerhasil then continue end

            -- 4. ANTI-STUCK
            if tick() - lastProgressTime >= Config.StuckTimeout then
                setStatus("⚠️ Timeout R6! Mereset...", "R6")
                enforceRoom6Position()
                forceFailMinigame_R6()
                isDone = true; break
            else
                setStatus("Menunggu Collect/Process... (Auto-reset jika stuck)", "R6")
            end
        end

        stopColorTracker = true
        if not _G.Room6_IsIdle then unequipAll(); teleportToIdle(); _G.Room6_IsIdle = true end
    end)
    if not success then
        setStatus("❌ ERROR R6: " .. tostring(err), "R6")
        task.wait(3)
    end
end

