    if workspace:FindFirstChild("NPCs") then
        for _, npc in ipairs(workspace.NPCs:GetChildren()) do
            local p = npc.PrimaryPart or npc:FindFirstChildWhichIsA("BasePart")
            if p and (p.Position - bedPart.Position).Magnitude <= Config.PatientBedRadius then
                local attr = npc:GetAttributes()
                if attr.Skinwalker or attr.SkinwalkerEasy or attr.PenaltyWhenLettingIn or attr.PhotoEffect == "CursedPhoto" or attr.PhotoEffect2 == "CursedPhoto" then
                    return true
                end
            end
        end
    end
    return false
end

local function findActiveRoom_Med()
    local roomsFolder   = workspace:FindFirstChild("Rooms")
    local medicalFolder = roomsFolder and roomsFolder:FindFirstChild("Medical")
    if not medicalFolder then return nil, nil end

    local lightRedRooms = {}  -- ruangan dengan lampu merah tapi pasien belum sampai

    for i = 1, Config.MaxRooms do
        local room     = medicalFolder:FindFirstChild("Room" .. i)
        if room then
            local minigame = room:FindFirstChild("Minigame")
            local bed      = minigame and minigame:FindFirstChild("Bed") and minigame.Bed:FindFirstChild("InBed")

            -- Update memory
            local currentPatient = getPatientInRoom_Med(i, room)
            local mem = _G.AutoDoctor_RoomMemory[i]
            if mem then
                if not currentPatient then _G.AutoDoctor_RoomMemory[i] = nil
                elseif typeof(mem) == "Instance" and currentPatient ~= mem then _G.AutoDoctor_RoomMemory[i] = nil
                elseif currentPatient:FindFirstChild("PE", true) then _G.AutoDoctor_RoomMemory[i] = nil
                end
            end

            local isBlacklisted = BuggedRoomBlacklist[i] and (tick() - BuggedRoomBlacklist[i] < Config.BlacklistDuration)
            if isBlacklisted or _G.AutoDoctor_RoomMemory[i] then continue end

            -- PRIORITAS 1: Pasien sudah FISIK ada di kasur → langsung kerjain
            if currentPatient then
                local ready, reason = isPatientReady(room, bed)
                if ready then return room, i end
            end

            -- PRIORITAS 2: TV sudah aktif (bisa dari shift sebelumnya, pasien sudah di kasur walau prompt lambat spawn)
            local tvUI    = minigame and minigame:FindFirstChild("TV") and minigame.TV:FindFirstChild("Screen", true)
            local pending = getPendingMedicines(tvUI)
            if #pending > 0 then return room, i end

            -- CATAT: lampu merah tapi pasien belum sampai (jangan teleport dulu)
            local signLight  = room:FindFirstChild("MainSign") and room.MainSign:FindFirstChild("Light")
            local isLightRed = signLight and (signLight.BrickColor.Name == "Crimson" or signLight.Color == Color3.fromRGB(165, 0, 0))
            if isLightRed and not currentPatient then
                table.insert(lightRedRooms, i)
            end
        end
    end

    -- Tidak ada pasien yang sudah sampai → return nil (idle)
    -- lightRedRooms hanya dicatat untuk info, tidak trigger teleport
    return nil, nil
end

local function getFireEmergency_Med()
    if workspace:FindFirstChild("NPCs") then
        for _, npc in ipairs(workspace.NPCs:GetChildren()) do
            local pp = npc:FindFirstChild("FirePP", true)
            if pp and pp.ActionText and pp.ActionText:match("Fire") then return npc, pp end
        end
    end
    return nil, nil
end

local function getPlacePatientPrompt_Med()
    local roomsFolder = workspace:FindFirstChild("Rooms")
    if not roomsFolder then return nil, nil, nil, nil end
    local medicalFolder = roomsFolder:FindFirstChild("Medical")
    if medicalFolder then
        for i = 1, Config.MaxRooms do
            local room = medicalFolder:FindFirstChild("Room" .. i)
            if room then
                for _, desc in ipairs(room:GetDescendants()) do
                    if desc:IsA("ProximityPrompt") and desc.Enabled then
                        local actText = string.lower(desc.ActionText or "")
                        if actText:match("place") then return desc, room.Name, i, room end
                    end
                end
            end
        end
    end
    return nil, nil, nil, nil
end

local function getFaintedPatient_Med()
    if workspace:FindFirstChild("NPCs") then
        for _, npc in ipairs(workspace.NPCs:GetChildren()) do
            local pp = npc:FindFirstChild("FaintedPP", true) or npc:FindFirstChildWhichIsA("ProximityPrompt", true)
            if pp and (pp.Name == "FaintedPP" or (pp.ActionText and pp.ActionText:match("Carry"))) then return npc, pp end
        end
    end
    return nil, nil
end

local function processFaintedPatient_Med(faintedPart, carryPP, activeShift)
    setStatus("! PRIORITAS 2: Mengurus Pasien Pingsan !")
    unequipAll()
    teleportToTarget(faintedPart.PrimaryPart or faintedPart:FindFirstChildWhichIsA("BasePart"))
    setStatus("Menggendong pasien...")
    simpleInteract_Med(carryPP, 0, true)
    task.wait(1.5)
    local placePrompt, targetRoomName, targetRoomNum, targetRoomPath = nil, nil, nil, nil
    local waitLimit = 0
    while not placePrompt and waitLimit < 20 do
        if getShiftText() ~= activeShift then return end
        setStatus("Mencari kasur kosong...")
        placePrompt, targetRoomName, targetRoomNum, targetRoomPath = getPlacePatientPrompt_Med()
        if not placePrompt then task.wait(1.5); waitLimit = waitLimit + 1 end
        _G.AutoDoctor_LastActionTick = tick()
        task.wait(0.1)
    end
    if placePrompt and targetRoomNum and targetRoomPath then
        setStatus("Membawa ke " .. targetRoomName .. "...")
        unequipAll()
        teleportToRoomCenter(targetRoomNum, targetRoomPath)
        task.wait(0.3)
        setStatus("Meletakkan di kasur...")
        simpleInteract_Med(placePrompt, 1, true)
        task.wait(1.5)
        setStatus("Berhasil menaruh pasien!")
    else
        setStatus("GAGAL menaruh pasien.")
    end
end

local function executeTreatmentCore_Med(roomPath, roomNum, activeShift)
    local minigame = roomPath:FindFirstChild("Minigame")
    if not minigame then return end
    local bed = minigame:FindFirstChild("Bed") and minigame.Bed:FindFirstChild("InBed")
    setStatus("--- MEMULAI PENGOBATAN: " .. roomPath.Name .. " ---")
    teleportToRoomCenter(roomNum, roomPath)
    local lastProgressTime = tick()
    local waitingForPatientSince = nil  -- kapan mulai nunggu pasien
    local MAX_PATIENT_WAIT = 12  -- detik maksimal nunggu pasien jalan ke kasur

    while true do
        task.wait(0.1)
        if getShiftText() ~= activeShift then setStatus("Shift berganti!"); break end
        if getFireEmergency_Med() or getPlacePatientPrompt_Med() then setStatus("INTERUPSI DARURAT!"); break end

        local currentPatient = getPatientInRoom_Med(roomNum, roomPath)
        if not currentPatient then
            local signLight  = roomPath:FindFirstChild("MainSign") and roomPath.MainSign:FindFirstChild("Light")
            local isLightRed = signLight and (signLight.BrickColor.Name == "Crimson" or signLight.Color == Color3.fromRGB(165, 0, 0))

            -- Cek juga TV masih punya obat pending (pasien sudah dirawat sebagian)
            local tvUI2   = minigame:FindFirstChild("TV") and minigame.TV:FindFirstChild("Screen", true)
            local pending2 = getPendingMedicines(tvUI2)
            if #pending2 > 0 then
                -- TV masih butuh obat, mungkin NPC prompt lambat spawn, tetap tunggu sebentar
                if not waitingForPatientSince then waitingForPatientSince = tick() end
                if tick() - waitingForPatientSince > MAX_PATIENT_WAIT then
                    setStatus("Timeout tunggu NPC prompt. Skip.")
                    BuggedRoomBlacklist[roomNum] = tick(); break
                end
                setStatus("Menunggu NPC prompt muncul..."); task.wait(0.5); continue
            end

            if isLightRed then
                -- Lampu merah = pasien masih jalan, tunggu tapi ada batas waktu
                if not waitingForPatientSince then waitingForPatientSince = tick() end
                if tick() - waitingForPatientSince > MAX_PATIENT_WAIT then
                    setStatus("Pasien tidak kunjung datang. Kembali idle.")
                    BuggedRoomBlacklist[roomNum] = tick(); break
                end
                setStatus("Pasien menuju kasur... (" .. math.floor(MAX_PATIENT_WAIT - (tick() - waitingForPatientSince)) .. "s)")
                task.wait(0.5); continue
            else
                setStatus("Kamar kosong! Skip.")
                BuggedRoomBlacklist[roomNum] = tick(); break
            end
        else
            -- Pasien sudah ada, reset timer tunggu
            waitingForPatientSince = nil
        end
        if isRoomDone_Med(roomNum, minigame, roomPath, bed, currentPatient) then
            setStatus("Pengobatan Selesai!")
            _G.AutoDoctor_RoomMemory[roomNum] = currentPatient or "JobDone"
            break
        end
        if tick() - lastProgressTime >= Config.StuckTimeout then
            setStatus("Timeout! Skip ruangan.")
            BuggedRoomBlacklist[roomNum] = tick()
            break
        end
        local tvUI      = minigame:FindFirstChild("TV") and minigame.TV:FindFirstChild("Screen", true)
        local hasTasks, reason = isPatientReady(roomPath, bed)
        if hasTasks then
            if reason == "TV Aktif (Butuh Obat)" then
                local patientIsAnomaly = Config.AnomalyKiller and checkAnomalyStatus_Med(bed)
                if patientIsAnomaly then
                    local prescribedMeds = {}
                    local tvInv = tvUI:FindFirstChild("inv", true)
                    if tvInv then
                        for _, req in ipairs(tvInv:GetChildren()) do
                            if table.find(ItemList, req.Name) then table.insert(prescribedMeds, req.Name) end
                        end
                    end
                    local wrongMedicine = nil
                    for _, item in ipairs(ItemList) do
                        if not table.find(prescribedMeds, item) then
                            local p = getPromptFromCache(item, false, _G.AutoDoctor_ItemCache, nil)
                            if p then wrongMedicine = item; break end
                        end
                    end
                    if not wrongMedicine then wrongMedicine = "Medicine" end
                    local hasIt = LocalPlayer.Backpack:FindFirstChild(wrongMedicine) or LocalPlayer.Character:FindFirstChild(wrongMedicine)
                    if not hasIt then
                        local s = fetchItem_Med(wrongMedicine, {wrongMedicine})
                        hasIt = s and (LocalPlayer.Backpack:FindFirstChild(wrongMedicine) or LocalPlayer.Character:FindFirstChild(wrongMedicine))
                    end
                    if hasIt and bed and bed:FindFirstChild("PP") then
                        teleportToTarget(bed:FindFirstChild("PP").Parent)
                        if turboSafeEquip(wrongMedicine) then
                            local activeTool = LocalPlayer.Character:FindFirstChildOfClass("Tool")
                            if activeTool and activeTool.Name == wrongMedicine then
                                setStatus("MENYUNTIKKAN RACUN: " .. wrongMedicine)
                                simpleInteract_Med(bed.PP, 0.1, false)
                                lastProgressTime = tick()
                                task.wait(2)
                                setStatus("--- ANOMALI HANGUS! ---")
                                _G.AutoDoctor_RoomMemory[roomNum] = currentPatient or "JobDone"
                                break
                            end
                        end
                    end
                else
                    local currentPending = getPendingMedicines(tvUI)
                    for _, obat in ipairs(currentPending) do
                        local hasIt = LocalPlayer.Backpack:FindFirstChild(obat) or LocalPlayer.Character:FindFirstChild(obat)
                        if not hasIt then
                            local totalCount, currentItems = checkTotalInventory()
                            local hasTrash = false
                            for _, item in ipairs(currentItems) do
                                if not table.find(currentPending, item.Name) then hasTrash = true; break end
                            end
                            if totalCount < Config.MaxInventory or hasTrash then
                                fetchItem_Med(obat, currentPending)
                                task.wait(0.1)
                            end
                        end
                    end
                    local medsWeHaveAndNeed = {}
                    currentPending = getPendingMedicines(tvUI)
                    for _, obat in ipairs(currentPending) do
                        if LocalPlayer.Backpack:FindFirstChild(obat) or LocalPlayer.Character:FindFirstChild(obat) then
                            table.insert(medsWeHaveAndNeed, obat)
                        end
                    end
                    if #medsWeHaveAndNeed > 0 then
                        local obatToInject = medsWeHaveAndNeed[1]
                        if bed and bed:FindFirstChild("PP") then
                            teleportToTarget(bed:FindFirstChild("PP").Parent)
                            if turboSafeEquip(obatToInject) then
                                local activeTool = LocalPlayer.Character:FindFirstChildOfClass("Tool")
                                if activeTool and activeTool.Name == obatToInject then
                                    setStatus("Suntik: " .. obatToInject)
                                    simpleInteract_Med(bed.PP, 0.1, false)
                                    lastProgressTime = tick()
                                    task.wait(Config.InjectionDelay)
                                end
                            end
                        end
                    else
                        setStatus("Menunggu obat terisi...")
                        task.wait(0.5)
                    end
                end
            else
                local acted = false
                local prompts = getPromptsNearBed(roomPath, bed)
                local handledBurn = false
                for _, desc in ipairs(prompts) do
                    local actText = string.lower(desc.ActionText or "")
                    local name    = string.lower(desc.Name or "")
                    if name == "firepp" or actText:match("burns") then
                        local hasOintment = LocalPlayer.Backpack:FindFirstChild("Ointment") or LocalPlayer.Character:FindFirstChild("Ointment")
                        if not hasOintment then
                            local s = fetchItem_Med("Ointment", {"Ointment"})
                            hasOintment = s and (LocalPlayer.Backpack:FindFirstChild("Ointment") or LocalPlayer.Character:FindFirstChild("Ointment"))
                        end
                        if hasOintment then
                            teleportToTarget(desc.Parent)
                            if turboSafeEquip("Ointment") then
                                local activeTool = LocalPlayer.Character:FindFirstChildOfClass("Tool")
                                if activeTool and activeTool.Name == "Ointment" then
                                    setStatus("Mengoleskan Ointment...")
                                    simpleInteract_Med(desc, 3, false)
                                    acted = true; handledBurn = true; break
                                end
                            end
                        end
                    end
                end
                if not handledBurn then
                    local monitor   = minigame:FindFirstChild("Monitor")
                    local pp2_obj   = monitor and monitor:FindFirstChild("PP2")
                    local actualPP2 = nil
                    if pp2_obj then
                        actualPP2 = pp2_obj:IsA("ProximityPrompt") and pp2_obj or pp2_obj:FindFirstChildOfClass("ProximityPrompt")
                    end
                    if actualPP2 then
                        local monitorScreen = monitor:FindFirstChild("Screen")
                        local monitorUI     = monitorScreen and monitorScreen:FindFirstChild("UI")
                        local isMonitorBusy = false
                        if monitorUI and (monitorUI.Enabled or (monitorUI:FindFirstChild("Report") and monitorUI.Report.Visible)) then isMonitorBusy = true end
                        if monitorScreen then
                            for _, desc in ipairs(monitorScreen:GetDescendants()) do
                                if desc:IsA("TextLabel") and desc.Name == "header" and string.match(desc.Text, "Finalizing") then isMonitorBusy = true; break end
                            end
                        end
                        local tvScreen    = minigame:FindFirstChild("TV") and minigame.TV:FindFirstChild("Screen")
                        local activeTvUI  = tvScreen and tvScreen:FindFirstChild("UI")
                        local isTVBusy    = activeTvUI and activeTvUI:IsA("SurfaceGui") and activeTvUI.Enabled
                        if isMonitorBusy or isTVBusy then
                            setStatus("Menunggu Data Lab/TV diproses...")
                            task.wait(1); acted = true
                        else
                            unequipAll()
                            teleportToRoomCenter(roomNum, roomPath)
                            task.wait(0.5)
                            setStatus("BYPASS EXPLOIT: Memaksa Process Results...")
                            local bypassSuccess = false
                            for retry = 1, 3 do
                                if type(fireproximityprompt) == "function" then fireproximityprompt(actualPP2)
                                else
                                    local oldReq  = actualPP2.RequiresLineOfSight
                                    local oldDist = actualPP2.MaxActivationDistance
                                    actualPP2.RequiresLineOfSight   = false
                                    actualPP2.MaxActivationDistance = math.huge
                                    actualPP2:InputHoldBegan() task.wait(0.2) actualPP2:InputHoldEnded()
                                    actualPP2.RequiresLineOfSight   = oldReq
                                    actualPP2.MaxActivationDistance = oldDist
                                end
                                task.wait(0.5)
                                local cekScreen = monitor:FindFirstChild("Screen")
                                if cekScreen then
                                    local ui = cekScreen:FindFirstChild("UI")
                                    if (ui and ui:IsA("SurfaceGui") and ui.Enabled) or (ui and ui:FindFirstChild("Report") and ui.Report.Visible) then bypassSuccess = true end
                                    if not bypassSuccess then
                                        for _, desc in ipairs(cekScreen:GetDescendants()) do
                                            if desc:IsA("TextLabel") and desc.Name == "header" and string.match(desc.Text, "Finalizing") then bypassSuccess = true; break end
                                        end
                                    end
                                end
                                if bypassSuccess then break end
                                setStatus("Bypass meleset! Retry (" .. retry .. "/3)...")
                            end
                            if bypassSuccess then setStatus("Bypass Berhasil!")
                            else setStatus("GAGAL Bypass Monitor.") end
                            acted = true
                        end
                    else
                        setStatus("Menunggu Monitor Siap...")
                        acted = false
                    end
                end
                if acted then lastProgressTime = tick(); task.wait(0.5) end
            end
        else
            task.wait(1)
        end
    end
end

local function botCycle_Med()
    local activeShift = getShiftText()
    local fireNPC, firePP = getFireEmergency_Med()
    if fireNPC then
        _G.AutoDoctor_IsIdle = false
        pcall(function()
            unequipAll()
            local targetNode = fireNPC.PrimaryPart or fireNPC:FindFirstChildWhichIsA("BasePart")
            setStatus("! PRIORITAS 1: Memadamkan Pasien Terbakar !")
            simpleInteract_Med(firePP, 3.2, targetNode)
            task.wait(1.5)
        end)
        return
    end
    local placePrompt, targetRoomName, _, _ = getPlacePatientPrompt_Med()
    if placePrompt then
        _G.AutoDoctor_IsIdle = false
        pcall(function()
            unequipAll()
            setStatus("Membawa pasien pingsan ke " .. tostring(targetRoomName) .. "...")
            task.wait(0.2)
            simpleInteract_Med(placePrompt, 1, true)
            task.wait(1.5)
        end)
        return
    end
    local faintedPart, carryPP = getFaintedPatient_Med()
    if faintedPart then
        _G.AutoDoctor_IsIdle = false
        pcall(function() processFaintedPatient_Med(faintedPart, carryPP, activeShift) end)
        return
    end
    local room, roomNum = findActiveRoom_Med()
    if room and roomNum then
        _G.AutoDoctor_IsIdle = false
        pcall(function() executeTreatmentCore_Med(room, roomNum, activeShift) end)
    else
        if not _G.AutoDoctor_IsIdle then
            unequipAll()
            teleportToIdle()
            _G.AutoDoctor_IsIdle = true
        end
        setStatus("Idle (Memantau Medical)...")
        task.wait(Config.ScanDelay)
    end
end

local function startWorker_Med()
    if _G.AutoDoctor_Worker then task.cancel(_G.AutoDoctor_Worker) end
    _G.AutoDoctor_Worker = task.spawn(function()
        while autoScanEnabled do
            if not isBusy_Medical then
                isBusy_Medical = true
                _G.AutoDoctor_LastActionTick = tick()
                pcall(botCycle_Med)
                isBusy_Medical = false
            end
            task.wait(0.1)
        end
    end)
end

