local function setStatus(text, target)
    if target == "R6" then
        if _G.LastRoom6Status == text then return end
        _G.LastRoom6Status = text
        StatusR6.Text = "Status: " .. text
    elseif target == "R7" then
        if _G.AutoRoom7_LastStatus == text then return end
        _G.AutoRoom7_LastStatus = text
        StatusR7.Text = "Status: " .. text
    elseif target == "R8" then
        StatusR8.Text = "Status: " .. text
    else
        if _G.LastStatus == text then return end
        _G.LastStatus = text
        StatusMedical.Text = "Status: " .. text
    end
    if Config.ShowConsoleLogs then
        print("[" .. os.date("%H:%M:%S") .. "] [AutoDoc-" .. (target or "Med") .. "] " .. text)
    end
end

