local function checkRoom7Status()
    local room7 = getEmergencyRoom(7)
    if not room7 then return nil, false end
    if _G.AutoRoom7_BlacklistTime > 0 and (tick() - _G.AutoRoom7_BlacklistTime < Config.BlacklistDuration) then return nil, false end
    local minigame = room7:FindFirstChild("Minigame")
    local bed      = minigame and minigame:FindFirstChild("Bed") and minigame.Bed:FindFirstChild("InBed")
    local currentPatient, _ = getPatientInEmergency(7, EmergencyCFrames[7].Step2, EmergencyCFrames[7].Radius)
    local signLight  = room7:FindFirstChild("MainSign") and room7.MainSign:FindFirstChild("Light")
    local isLightRed = signLight and (signLight.BrickColor.Name == "Crimson" or signLight.Color == Color3.fromRGB(165, 0, 0))
    if currentPatient ~= _G.AutoRoom7_LastPatient then
        _G.AutoRoom7_LastPatient  = currentPatient
        _G.AutoRoom7_LegitHealing = false
    end
    local tv        = minigame and minigame:FindFirstChild("TV") and minigame.TV:FindFirstChild("Screen")
    local healingUI = tv and tv:FindFirstChild("UI") and tv.UI:FindFirstChild("Healing")
    local isHealing = (healingUI and healingUI.Visible == true)
    if not isHealing then _G.AutoRoom7_LegitHealing = true end
    if not currentPatient then
        -- Kalau pasien pergi, hapus memory supaya pasien berikutnya bisa dilayani
        _G.ER_Memory[7] = nil
        -- Lampu merah saja TIDAK cukup untuk trigger — tunggu NPC benar-benar hadir
        return nil, false
    end
    -- ── MEMORY CHECK: pasien lama yang belum pergi ───────────────────────
    if erMemoryCheck(7, currentPatient) then
        return nil, false  -- skip, pasien lama masih ada
    end
    if isHealing and _G.AutoRoom7_LegitHealing then
        -- Set memory: pasien ini sudah selesai dirawat
        erMemorySet(7, currentPatient)
        return nil, true
    end
    -- Check prompts
    local hasValid = false
    if currentPatient then
        for _, desc in ipairs(currentPatient:GetDescendants()) do
            if desc:IsA("ProximityPrompt") and desc.Enabled then
                local actText = string.lower(desc.ActionText or "")
                local name    = string.lower(desc.Name or "")
                if name == "firepp" or actText:match("burns") or actText:match("dna") or name:match("dna") then hasValid = true; break end
            end
        end
    end
    if not hasValid and minigame then
        local validKeywords = {"prepare", "set up", "turn on", "begin", "process", "collect"}
        for _, prompt in ipairs(minigame:GetDescendants()) do
            if prompt:IsA("ProximityPrompt") and prompt.Enabled then
                local actText = string.lower(prompt.ActionText or "")
                for _, kw in ipairs(validKeywords) do
                    if actText:match(kw) then hasValid = true; break end
                end
            end
            if hasValid then break end
        end
    end
    if not hasValid and minigame then
        local tv2     = minigame:FindFirstChild("TV") and minigame.TV:FindFirstChild("Screen")
        local repUI   = tv2 and tv2:FindFirstChild("UI") and tv2.UI:FindFirstChild("Report")
        if repUI and repUI.Visible then
            local pending = getRoom7PendingMedicines(repUI)
            if #pending > 0 then hasValid = true end
        end
    end
    if hasValid or currentPatient then return room7, false end
    return nil, false
end

