        local function processTool(item)
            if item:IsA("Tool") and table.find(ItemList, item.Name) then
                targetCount = targetCount + 1
                table.insert(targetItems, item)
            end
        end
        if backpack then for _, item in ipairs(backpack:GetChildren()) do processTool(item) end end
        if character then for _, item in ipairs(character:GetChildren()) do processTool(item) end end
        return targetCount, targetItems
    end

    local function trashItem(toolToTrash)
        local char = LocalPlayer.Character
        if not char then return false end
        local trashPrompt = getPromptFromCache("Trash", true)
        if trashPrompt then
            setStatus("Membuang item (Turbo): " .. toolToTrash.Name)
            teleportToTarget(trashPrompt)
            if turboSafeEquip(toolToTrash.Name) then
                local oldReq = trashPrompt.RequiresLineOfSight
                local oldDist = trashPrompt.MaxActivationDistance
                trashPrompt.RequiresLineOfSight = false
                trashPrompt.MaxActivationDistance = math.huge
                trashPrompt.HoldDuration = 0
                if type(fireproximityprompt) == "function" then fireproximityprompt(trashPrompt)
                else trashPrompt:InputHoldBegan() task.wait(0.05) trashPrompt:InputHoldEnded() end
                trashPrompt.RequiresLineOfSight = oldReq
                trashPrompt.MaxActivationDistance = oldDist
                _G.AutoDoctor_LastActionTick = tick()
                task.wait(0.1) 
                return true
            end
        end
        setStatus("GAGAL: Tempat sampah tidak ditemukan / Gagal pegang item!")
        return false
    end

    local function fetchItem(targetName, pendingMedsList)
        local char = LocalPlayer.Character
        if not char then return false end
        setStatus("Mengambil (Insta-Fetch): " .. targetName)
        local totalAmount, currentItems = checkTotalInventory()
        if totalAmount >= Config.MaxInventory then
            local itemToThrowAway = nil
            if pendingMedsList then
                for _, item in ipairs(currentItems) do
                    if item.Name ~= targetName and not table.find(pendingMedsList, item.Name) then
                        itemToThrowAway = item
                        break
                    end
                end
            end
            if not itemToThrowAway then itemToThrowAway = currentItems[1] end
            local trashed = trashItem(itemToThrowAway)
            if not trashed then return false end 
        end
        local promptToUse = getPromptFromCache(targetName, false)
        if promptToUse then
            unequipAll() 
            teleportToTarget(promptToUse) 
            local oldReq = promptToUse.RequiresLineOfSight
            local oldDist = promptToUse.MaxActivationDistance
            local oldHold = promptToUse.HoldDuration
            promptToUse.RequiresLineOfSight = false
            promptToUse.MaxActivationDistance = math.huge
            promptToUse.HoldDuration = 0
            local gotItem = false
            for retry = 1, 15 do
                if type(fireproximityprompt) == "function" then 
                    fireproximityprompt(promptToUse)
                else 
                    promptToUse:InputHoldBegan() 
                    task.wait(0.05) 
                    promptToUse:InputHoldEnded() 
                end
                task.wait(0.1) 
                if LocalPlayer.Backpack:FindFirstChild(targetName) or LocalPlayer.Character:FindFirstChild(targetName) then
                    gotItem = true
                    break
                end
            end
            promptToUse.RequiresLineOfSight = oldReq
            promptToUse.MaxActivationDistance = oldDist
            promptToUse.HoldDuration = oldHold
            if gotItem then
                setStatus("Berhasil Mengambil: " .. targetName)
                _G.AutoDoctor_LastActionTick = tick()
                return true
            else
                setStatus("GAGAL Mengambil: " .. targetName)
                return false 
            end
        end
        setStatus("GAGAL: " .. targetName .. " tidak ditemukan.")
        return false
    end

    local function simpleInteract(prompt, customHold, autoLock)
        if prompt and prompt:IsA("ProximityPrompt") then
            if autoLock then
                teleportToTarget(prompt)
            end
            local oldReq = prompt.RequiresLineOfSight
            local oldDist = prompt.MaxActivationDistance
            prompt.RequiresLineOfSight = false
            prompt.MaxActivationDistance = math.huge
            if type(fireproximityprompt) == "function" then
                fireproximityprompt(prompt)
            else
                prompt:InputHoldBegan()
                task.wait(customHold or prompt.HoldDuration or 0.1)
                prompt:InputHoldEnded()
            end
            _G.AutoDoctor_LastActionTick = tick()
            prompt.RequiresLineOfSight = oldReq
            prompt.MaxActivationDistance = oldDist
            task.wait(0.1)
        end
        return true
    end

    local function getPlacePatientPrompt()
        local roomsFolder = workspace:FindFirstChild("Rooms")
        if not roomsFolder then return nil, nil, nil, nil end
        local medicalFolder = roomsFolder:FindFirstChild("Medical")
        if medicalFolder then
            for i = 1, Config.MaxRooms do
                local room = medicalFolder:FindFirstChild("Room" .. i)
                if room then
                    for _, desc in ipairs(room:GetDescendants()) do
                        if desc:IsA("ProximityPrompt") and desc.Enabled then
                            local actText = string.lower(desc.ActionText or "")
                            if actText:match("place") then return desc, room.Name, i, room end
                        end
                    end
                end
            end
        end
        local emergencyFolder = roomsFolder:FindFirstChild("Emergency")
        if emergencyFolder and Config.EmergencyRooms then
            for _, i in ipairs(Config.EmergencyRooms) do
                local room = emergencyFolder:FindFirstChild("Room" .. i)
                if room then
                    for _, desc in ipairs(room:GetDescendants()) do
                        if desc:IsA("ProximityPrompt") and desc.Enabled then
                            local actText = string.lower(desc.ActionText or "")
                            if actText:match("place") then return desc, room.Name, tonumber(i), room end
                        end
                    end
                end
            end
        end
        return nil, nil, nil, nil
    end

    local function getFireEmergency()
        if workspace:FindFirstChild("NPCs") then
            for _, npc in ipairs(workspace.NPCs:GetChildren()) do
                local pp = npc:FindFirstChild("FirePP", true)
                if pp and pp.ActionText and pp.ActionText:match("Fire") then return npc, pp end
            end
        end
        for _, obj in ipairs(workspace:GetChildren()) do
            if obj:IsA("Model") and obj:FindFirstChild("Humanoid") then
                local pp = obj:FindFirstChild("FirePP", true)
                if pp and pp.ActionText and pp.ActionText:match("Fire") then return obj, pp end
            end
        end
        return nil, nil
    end

    local function findActiveRoom()
        local roomsFolder = workspace:FindFirstChild("Rooms")
        local medicalFolder = roomsFolder and roomsFolder:FindFirstChild("Medical")
        if not medicalFolder then return nil, nil end
        for i = 1, Config.MaxRooms do
            local room = medicalFolder:FindFirstChild("Room" .. i)
            if room then
                local minigame = room:FindFirstChild("Minigame")
                local bed = minigame and minigame:FindFirstChild("Bed") and minigame.Bed:FindFirstChild("InBed")
                local currentPatient = getPatientInRoom(i, room)
                local mem = _G.AutoDoctor_RoomMemory[i]

                if mem then
                    if not currentPatient then
                        _G.AutoDoctor_RoomMemory[i] = nil
                    elseif typeof(mem) == "Instance" and currentPatient ~= mem then
                        _G.AutoDoctor_RoomMemory[i] = nil
                    elseif currentPatient:FindFirstChild("PE", true) then
                        _G.AutoDoctor_RoomMemory[i] = nil
                    end
                end

                local isBlacklisted = BuggedRoomBlacklist[i] and (tick() - BuggedRoomBlacklist[i] < Config.BlacklistDuration)
                if not isBlacklisted and not _G.AutoDoctor_RoomMemory[i] then
                    local ready, reason = isPatientReady(room, bed)
                    if ready then return room, i end
                end
            end
        end
        return nil, nil 
    end

    local function getFaintedPatient()
        if workspace:FindFirstChild("NPCs") then
            for _, npc in ipairs(workspace.NPCs:GetChildren()) do
                local pp = npc:FindFirstChild("FaintedPP", true) or npc:FindFirstChildWhichIsA("ProximityPrompt", true)
                if pp and (pp.Name == "FaintedPP" or (pp.ActionText and pp.ActionText:match("Carry"))) then return npc, pp end
            end
        end
        for _, obj in ipairs(workspace:GetChildren()) do
            if obj:IsA("Model") then
                local pp = obj:FindFirstChild("FaintedPP", true) or obj:FindFirstChildWhichIsA("ProximityPrompt", true)
                if pp and (pp.Name == "FaintedPP" or (pp.ActionText and pp.ActionText:match("Carry"))) then return obj, pp end
            end
        end
        return nil, nil
    end

    local function processFaintedPatient(faintedPart, carryPP, activeShift)
        setStatus("! PRIORITAS 2: Mengurus Pasien Pingsan !")
        unequipAll()
        teleportToTarget(faintedPart.PrimaryPart or faintedPart:FindFirstChildWhichIsA("BasePart"))
        setStatus("Menggendong pasien...")
        simpleInteract(carryPP, 0, true)
        task.wait(1.5)
        local placePrompt, targetRoomName, targetRoomNum, targetRoomPath = nil, nil, nil, nil
        local waitLimit = 0
        while not placePrompt and waitLimit < 20 do
            if getShiftText() ~= activeShift then return end
            setStatus("Mencari kasur kosong...")
            placePrompt, targetRoomName, targetRoomNum, targetRoomPath = getPlacePatientPrompt()
            if not placePrompt then
                task.wait(1.5)
                waitLimit = waitLimit + 1
                _G.AutoDoctor_LastActionTick = tick()
            end
            task.wait(0.1) 
        end
        if placePrompt and targetRoomNum and targetRoomPath then
            setStatus("Membawa ke " .. targetRoomName .. "...")
            unequipAll()
            teleportToRoomCenter(targetRoomNum, targetRoomPath) 
            task.wait(0.3)
            setStatus("Meletakkan di kasur...")
            simpleInteract(placePrompt, 1, true)
            task.wait(1.5)
            setStatus("Berhasil menaruh pasien! Kembali bekerja...")
        else
            setStatus("GAGAL menaruh pasien. Kasur penuh / shift ganti.")
        end
    end

    local function executeTreatmentCore(roomPath, roomNum, activeShift)
        local minigame = roomPath:FindFirstChild("Minigame")
        if not minigame then return end
        local bed = minigame:FindFirstChild("Bed") and minigame.Bed:FindFirstChild("InBed")
        setStatus("--- MEMULAI PENGOBATAN: " .. roomPath.Name .. " ---")
        teleportToRoomCenter(roomNum, roomPath) 

        local lastProgressTime = tick()

        while true do
            task.wait(0.1) 
            if getShiftText() ~= activeShift then 
                setStatus("Shift berganti! Membatalkan pengobatan.")
                break 
            end
            if getFireEmergency() or getPlacePatientPrompt() then
                setStatus("INTERUPSI DARURAT! Menunda...")
                break
            end

            local currentPatient = getPatientInRoom(roomNum, roomPath)
            if not currentPatient then
                local signLight = roomPath:FindFirstChild("MainSign") and roomPath.MainSign:FindFirstChild("Light")
                local isLightRed = signLight and (signLight.BrickColor.Name == "Crimson" or signLight.Color == Color3.fromRGB(165, 0, 0))
                if isLightRed then
                    setStatus("Pasien sedang berjalan ke kasur... Menunggu.")
                    task.wait(1)
                else
                    setStatus("Kamar kosong / Ghost Prompt! Skip.")
                    BuggedRoomBlacklist[roomNum] = tick() 
                    break
                end
            end

            if isRoomDone(roomNum, minigame, roomPath, bed, currentPatient) then
                setStatus("Pengobatan Selesai! Meninggalkan pasien ke prioritas lain...")
                local patientToLog = currentPatient or "JobDone"
                _G.AutoDoctor_RoomMemory[roomNum] = patientToLog
                break
            end

            if tick() - lastProgressTime >= Config.StuckTimeout then
                setStatus("Timeout! Skip ruangan.")
                BuggedRoomBlacklist[roomNum] = tick()
                break
            end

            local tvUI = minigame:FindFirstChild("TV") and minigame.TV:FindFirstChild("Screen", true)
            local hasTasks, reason = isPatientReady(roomPath, bed)

            if hasTasks then
                if reason == "TV Aktif (Butuh Obat)" then
                    local patientIsAnomaly = checkAnomalyStatus(bed)
                    if patientIsAnomaly then
                        local prescribedMeds = {}
                        local tvInv = tvUI:FindFirstChild("inv", true)
                        if tvInv then
                            for _, req in ipairs(tvInv:GetChildren()) do
                                if table.find(ItemList, req.Name) then table.insert(prescribedMeds, req.Name) end
                            end
                        end
                        local wrongMedicine = nil
                        for _, item in ipairs(ItemList) do
                            if not table.find(prescribedMeds, item) then
                                local p = getPromptFromCache(item, false)
                                if p then wrongMedicine = item break end
                            end
                        end
                        if not wrongMedicine then wrongMedicine = "Medicine" end
                        local hasIt = LocalPlayer.Backpack:FindFirstChild(wrongMedicine) or LocalPlayer.Character:FindFirstChild(wrongMedicine)
                        if not hasIt then 
                            local successFetch = fetchItem(wrongMedicine, {wrongMedicine}) 
                            hasIt = successFetch and (LocalPlayer.Backpack:FindFirstChild(wrongMedicine) or LocalPlayer.Character:FindFirstChild(wrongMedicine))
                        end
                        if hasIt then
                            if bed and bed:FindFirstChild("PP") then
                                teleportToTarget(bed:FindFirstChild("PP").Parent)
                                if turboSafeEquip(wrongMedicine) then
                                    local activeTool = LocalPlayer.Character:FindFirstChildOfClass("Tool")
                                    if activeTool and activeTool.Name == wrongMedicine then
                                        setStatus("MENYUNTIKKAN RACUN: " .. wrongMedicine)
                                        simpleInteract(bed.PP, 0.1, false)
                                        lastProgressTime = tick() 
                                        task.wait(2) 
                                        setStatus("--- ANOMALI HANGUS! Menyimpan ke memori... ---")
                                        local patientToLog = currentPatient or "JobDone"
                                        _G.AutoDoctor_RoomMemory[roomNum] = patientToLog
                                        break 
                                    end
                                end
                            end
                        else
                            setStatus("Gagal mengambil racun. Menunggu putaran berikutnya...")
                        end
                    else
                        local currentPending = getPendingMedicines(tvUI)
                        for _, obat in ipairs(currentPending) do
                            local hasIt = LocalPlayer.Backpack:FindFirstChild(obat) or LocalPlayer.Character:FindFirstChild(obat)
                            if not hasIt then
                                local totalCount, currentItems = checkTotalInventory()
                                local hasTrash = false
                                for _, item in ipairs(currentItems) do
                                    if not table.find(currentPending, item.Name) then hasTrash = true break end
                                end
                                if totalCount < Config.MaxInventory or hasTrash then
                                    fetchItem(obat, currentPending)
                                    task.wait(0.1)
                                end
                            end
                        end
                        local medsWeHaveAndNeed = {}
                        currentPending = getPendingMedicines(tvUI)
                        for _, obat in ipairs(currentPending) do
                            if LocalPlayer.Backpack:FindFirstChild(obat) or LocalPlayer.Character:FindFirstChild(obat) then
                                table.insert(medsWeHaveAndNeed, obat)
                            end
                        end
                        if #medsWeHaveAndNeed > 0 then
                            local obatToInject = medsWeHaveAndNeed[1]
                            if bed and bed:FindFirstChild("PP") then
                                teleportToTarget(bed:FindFirstChild("PP").Parent)
                                if turboSafeEquip(obatToInject) then
                                    local activeTool = LocalPlayer.Character:FindFirstChildOfClass("Tool")
                                    if activeTool and activeTool.Name == obatToInject then
                                        setStatus("Suntik: " .. obatToInject)
                                        simpleInteract(bed.PP, 0.1, false)
                                        lastProgressTime = tick()
                                        task.wait(Config.InjectionDelay) 
                                    end
                                end
                            end
                        else
                            setStatus("Menunggu obat terisi / Memproses...")
                            task.wait(0.5)
                        end
                    end
                else
                    local acted = false
                    local prompts = getPromptsNearBed(roomPath, bed)
                    local handledBurn = false
                    for _, desc in ipairs(prompts) do
                        local actText = string.lower(desc.ActionText or "")
                        local name = string.lower(desc.Name or "")
                        if name == "firepp" or actText:match("burns") then
                            local hasOintment = LocalPlayer.Backpack:FindFirstChild("Ointment") or LocalPlayer.Character:FindFirstChild("Ointment")
                            if not hasOintment then 
                                local successFetch = fetchItem("Ointment", {"Ointment"}) 
                                hasOintment = successFetch and (LocalPlayer.Backpack:FindFirstChild("Ointment") or LocalPlayer.Character:FindFirstChild("Ointment"))
                            end
                            if hasOintment then
                                teleportToTarget(desc.Parent)
                                if turboSafeEquip("Ointment") then
                                    local activeTool = LocalPlayer.Character:FindFirstChildOfClass("Tool")
                                    if activeTool and activeTool.Name == "Ointment" then
                                        setStatus("Mengoleskan Ointment (Treat Burns)...")
                                        simpleInteract(desc, 3, false)
                                        acted = true
                                        handledBurn = true
                                        break
                                    end
                                end
                            else
                                setStatus("Gagal mengambil Ointment. Menunggu putaran berikutnya...")
                            end
                        end
                    end

                    if not handledBurn then
                        local monitor = minigame:FindFirstChild("Monitor")
                        local pp2_obj = monitor and monitor:FindFirstChild("PP2")
                        local actualPP2 = nil
                        if pp2_obj then
                            if pp2_obj:IsA("ProximityPrompt") then actualPP2 = pp2_obj
                            else actualPP2 = pp2_obj:FindFirstChildOfClass("ProximityPrompt") end
                        end

                        if actualPP2 then
                            local monitorScreen = monitor:FindFirstChild("Screen")
                            local monitorUI = monitorScreen and monitorScreen:FindFirstChild("UI")
                            local isMonitorBusy = false
                            if monitorUI and (monitorUI.Enabled or (monitorUI:FindFirstChild("Report") and monitorUI.Report.Visible)) then isMonitorBusy = true end
                            if monitorScreen then
                                for _, desc in ipairs(monitorScreen:GetDescendants()) do
                                    if desc:IsA("TextLabel") and desc.Name == "header" and string.match(desc.Text, "Finalizing") then
                                        isMonitorBusy = true break
                                    end
                                end
                            end
                            local tvScreen = minigame:FindFirstChild("TV") and minigame.TV:FindFirstChild("Screen")
                            local activeTvUI = tvScreen and tvScreen:FindFirstChild("UI")
                            local isTVBusy = false
                            if activeTvUI and activeTvUI:IsA("SurfaceGui") and activeTvUI.Enabled then isTVBusy = true end
                            
                            if isMonitorBusy or isTVBusy then
                                setStatus("Menunggu Data Lab/TV diproses...")
                                task.wait(1)
                                acted = true
                            else
                                unequipAll()
                                teleportToRoomCenter(roomNum, roomPath)
                                task.wait(0.5)
                                setStatus("BYPASS EXPLOIT: Memaksa Process Results...")
                                local bypassSuccess = false
                                for retry = 1, 3 do
                                    if type(fireproximityprompt) == "function" then
                                        fireproximityprompt(actualPP2)
                                    else
                                        local oldReq = actualPP2.RequiresLineOfSight
                                        local oldDist = actualPP2.MaxActivationDistance
                                        actualPP2.RequiresLineOfSight = false
                                        actualPP2.MaxActivationDistance = math.huge
                                        actualPP2:InputHoldBegan() task.wait(0.2) actualPP2:InputHoldEnded()
                                        actualPP2.RequiresLineOfSight = oldReq
                                        actualPP2.MaxActivationDistance = oldDist
                                    end
                                    task.wait(0.5)
                                    local cekMonitorScreen = monitor:FindFirstChild("Screen")
                                    if cekMonitorScreen then
                                        local ui = cekMonitorScreen:FindFirstChild("UI")
                                        if ui and ui:IsA("SurfaceGui") and ui.Enabled then bypassSuccess = true
                                        elseif ui and ui:FindFirstChild("Report") and ui.Report.Visible then bypassSuccess = true
                                        else
                                            for _, desc in ipairs(cekMonitorScreen:GetDescendants()) do
                                                if desc:IsA("TextLabel") and desc.Name == "header" and string.match(desc.Text, "Finalizing") then
                                                    bypassSuccess = true break
                                                end
                                            end
                                        end
                                    end
                                    if bypassSuccess then break end
                                    setStatus("Bypass meleset! Mencoba ulang (" .. retry .. "/3)...")
                                end
                                if bypassSuccess then setStatus("Bypass Berhasil! Data pasien diproses Monitor.")
                                else setStatus("GAGAL Bypass: Tidak ada respon dari Monitor.") end
                                acted = true
                            end
                        else
                            local reportFolder = tvUI and tvUI:FindFirstChild("Report")
                            if reportFolder and reportFolder.Visible then setStatus("Menunggu sinkronisasi TV (Loading Resep)...")
                            else setStatus("Menunggu Monitor Siap...") end
                            acted = false
                        end
                    end
                end
                if acted then lastProgressTime = tick() task.wait(0.5) end
            end
        else
            task.wait(1)
        end
    end

    local function botCycle()
        local activeShift = getShiftText()
        local fireNPC, firePP = getFireEmergency()
        if fireNPC then
            _G.AutoDoctor_IsIdle = false
            pcall(function() 
                unequipAll()
                local targetNode = fireNPC.PrimaryPart or fireNPC:FindFirstChildWhichIsA("BasePart")
                setStatus("! PRIORITAS 1: Memadamkan Pasien Terbakar !")
                simpleInteract(firePP, 3.2, targetNode)
                task.wait(1.5)
            end)
            return
        end

        local placePrompt, targetRoomName, _, _ = getPlacePatientPrompt()
        if placePrompt then
            _G.AutoDoctor_IsIdle = false
            pcall(function()
                unequipAll()
                setStatus("Membawa pasien pingsan ke " .. tostring(targetRoomName) .. "...")
                task.wait(0.2)
                setStatus("Meletakkan di kasur...")
                simpleInteract(placePrompt, 1, true)
                task.wait(1.5)
            end)
            return
        end

        local faintedPart, carryPP = getFaintedPatient()
        if faintedPart then
            _G.AutoDoctor_IsIdle = false
            pcall(function() processFaintedPatient(faintedPart, carryPP, activeShift) end)
            return
        end
        
        local room, roomNum = findActiveRoom()
        if room and roomNum then 
            _G.AutoDoctor_IsIdle = false
            pcall(function() executeTreatmentCore(room, roomNum, activeShift) end)
        else
            if not _G.AutoDoctor_IsIdle then
                unequipAll()
                teleportToIdle()
                _G.AutoDoctor_IsIdle = true
            end
            setStatus("Idle (Memantau )...")
            task.wait(Config.ScanDelay)
        end
    end

    local function startWorker()
        if _G.AutoDoctor_Worker then task.cancel(_G.AutoDoctor_Worker) end
        _G.AutoDoctor_Worker = task.spawn(function()
            while autoScanEnabled do
                if not isBusy then
                    isBusy = true
                    _G.AutoDoctor_LastActionTick = tick() 
                    pcall(botCycle)
                    isBusy = false
                end
                task.wait(0.1) 
            end
        end)
    end

    GUI_Btn_Med.MouseButton1Click:Connect(function()
        autoScanEnabled = not autoScanEnabled
        if autoScanEnabled then
            GUI_Btn_Med.Text = "Auto Medical (R1-5): ON"
            GUI_Btn_Med.BackgroundColor3 = Color3.fromRGB(70, 200, 70)
            setStatus("Auto-Scan menyala. Memantau...")
            isBusy = false 
            _G.AutoDoctor_IsIdle = false 
            _G.AutoDoctor_LastActionTick = tick()
            _G.LastRadarReport = ""
            BuggedRoomBlacklist = {}
            _G.AutoDoctor_RoomMemory = {} 
            startWorker()
            
            if _G.AutoDoctor_Watchdog then task.cancel(_G.AutoDoctor_Watchdog) end
            _G.AutoDoctor_Watchdog = task.spawn(function()
                local lastShift = getShiftText() 
                while autoScanEnabled do
                    task.wait(1)
                    local currentShift = getShiftText()
                    local isShiftChanged = (currentShift ~= lastShift and currentShift ~= nil and lastShift ~= nil)
                    local isStuck = isBusy and (tick() - _G.AutoDoctor_LastActionTick > Config.GlobalStuckTimeout)

                    if isShiftChanged or isStuck then
                        if isShiftChanged then
                            setStatus("Shift Berganti! AUTO HARD-RESET...")
                            Config.MaxInventory = 5
                        else
                            setStatus("SYSTEM STUCK DETECTED! AUTO HARD-RESET...")
                        end
                        if _G.AutoDoctor_Worker then task.cancel(_G.AutoDoctor_Worker) end
                        BuggedRoomBlacklist = {}
                        _G.AutoDoctor_RoomMemory = {}
                        isBusy = false
                        _G.AutoDoctor_IsIdle = false 
                        lastShift = currentShift
                        teleportToIdle()
                        task.wait(2)
                        if autoScanEnabled then
                            _G.AutoDoctor_LastActionTick = tick()
                            startWorker()
                        end
                    end
                    if currentShift then lastShift = currentShift end
                end
            end)
        else
            GUI_Btn_Med.Text = "Auto Medical (R1-5): OFF"
            GUI_Btn_Med.BackgroundColor3 = Color3.fromRGB(70, 70, 70)
            if _G.AutoDoctor_Watchdog then pcall(function() task.cancel(_G.AutoDoctor_Watchdog) end) end
            if _G.AutoDoctor_Worker then pcall(function() task.cancel(_G.AutoDoctor_Worker) end) end
            isBusy = false 
            _G.AutoDoctor_IsIdle = false 
            setStatus("Dimatikan.")
        end
    end)
    
    GUI_Btn_Radar.MouseButton1Click:Connect(function()
        isRadarVisible = not isRadarVisible
        if isRadarVisible then
            GUI_Btn_Radar.Text = "SHOW GLOBAL RADAR: ON"
            GUI_Btn_Radar.BackgroundColor3 = Color3.fromRGB(70, 200, 70)
        else
            GUI_Btn_Radar.Text = "SHOW GLOBAL RADAR: OFF"
            GUI_Btn_Radar.BackgroundColor3 = Color3.fromRGB(70, 70, 70)
            for _, radar in pairs(_G.AutoDoctor_Radars) do
                if radar then radar:Destroy() end
            end
            _G.AutoDoctor_Radars = {}
        end
    end)
end


