            if Players:GetPlayerFromCharacter(obj) then return nil end
            local part = obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")
            if part and (part.Position - centerPos).Magnitude <= radius then
                local activePP = nil
                for _, desc in ipairs(obj:GetDescendants()) do
                    if desc:IsA("ProximityPrompt") and desc.Enabled then
                        local act = string.lower(desc.ActionText or "")
                        if act:match("dna") or act:match("treat") or act:match("burns") or act:match("inject") or desc.Name == "PP" or desc.Name == "FirePP" then
                            return obj, desc
                        end
                        activePP = desc
                    end
                end
                if activePP then return obj, activePP end
                local fallbackPP = obj:FindFirstChild("PP") or obj:FindFirstChildWhichIsA("ProximityPrompt", true)
                if fallbackPP and fallbackPP.Enabled then return obj, fallbackPP end
            end
            return nil
        end
        if workspace:FindFirstChild("NPCs") then
            for _, npc in ipairs(workspace.NPCs:GetChildren()) do
                local found, pp = checkNPC(npc)
                if found then return found, pp end
            end
        end
        return nil, nil
    end

