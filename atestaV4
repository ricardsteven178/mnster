        "Herbs", "Medicine", "Maple Syrup", "Cough Syrup", "Bandages", 
        "Ointment", "Thermo", "Medkit", "IV Drops", "Eye Drops", 
        "Antibiotics", "Scalpel", "Scissors", "Organ", "Transplant"
    }

    local isBusy = false
    local autoScanEnabled = false
    local isRadarVisible = Config.ShowRadar
    local isBotIdle = false 
    local lastLoggedText = "" 
    _G.Room8Auto_LastActionTick = tick()

    local function setStatus(text)
        GUI_Status_R8.Text = "[Room 8] Status:\n" .. text
        if Config.ShowConsoleLogs and text ~= lastLoggedText then 
            print("[Room8-V16] " .. text) 
            lastLoggedText = text
        end
    end

    local function teleportToTarget(target)
        local char = LocalPlayer.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        if not root or not target then return end
        
        local posToTP = nil
        if typeof(target) == "CFrame" then posToTP = target.Position
        elseif typeof(target) == "Vector3" then posToTP = target
        elseif target:IsA("BasePart") then posToTP = target.Position
        elseif target:IsA("ProximityPrompt") then
            local p = target.Parent
            posToTP = p and (p:IsA("BasePart") and p.Position or (p:IsA("Model") and p.PrimaryPart and p.PrimaryPart.Position))
        end
        
        if posToTP then
            root.CFrame = CFrame.new(posToTP + Vector3.new(0, 3, 0))
            root.AssemblyLinearVelocity = Vector3.zero
            task.wait(0.1) 
        end
    end

    local function ensureInRoom8()
        local char = LocalPlayer.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        if root then
            local distance = (root.Position - Config.Room8BedCFrame.Position).Magnitude
            if distance > 20 then
                setStatus("Anchor: Mengembalikan ke kasur Room 8...")
                root.CFrame = Config.Room8BedCFrame
                root.AssemblyLinearVelocity = Vector3.zero
                task.wait(0.2)
            end
        end
    end

    local function unequipAll()
        pcall(function()
            local char = LocalPlayer.Character
            local hum = char and char:FindFirstChild("Humanoid")
            if hum then
                hum:UnequipTools()
                local t = 0
                while char:FindFirstChildOfClass("Tool") and t < 10 do
                    task.wait(0.05)
                    t = t + 1
                end
            end
        end)
    end

    local function safeEquip(itemName)
        local char = LocalPlayer.Character
        local backpack = LocalPlayer:FindFirstChild("Backpack")
        local hum = char and char:FindFirstChild("Humanoid")
        if not char or not backpack or not hum then return false end
        if char:FindFirstChild(itemName) then return true end
        hum:UnequipTools()
        local tool = backpack:FindFirstChild(itemName)
        if not tool then return false end
        hum:EquipTool(tool)
        local t2 = 0
        while not char:FindFirstChild(itemName) and t2 < 15 do
            task.wait(0.05)
            t2 = t2 + 1
        end
        task.wait(0.1) 
        return char:FindFirstChild(itemName) ~= nil
    end

    local function getShiftText()
        local pGui = LocalPlayer:FindFirstChild("PlayerGui")
        if pGui then
            local shiftUI = pGui:FindFirstChild("Shift")
            if shiftUI then
                local frame = shiftUI:FindFirstChild("Frame")
                local header = frame and frame:FindFirstChild("header")
                if header and header:IsA("TextLabel") then 
                    local txt = header.Text:gsub("^%s*(.-)%s*$", "%1")
                    if txt ~= "" then return txt end
                end
            end
        end
        return "Shift Aktif"
    end

    local function isRoom8HealingDone(room8)
        if not room8 then return false end
        local ui = room8:FindFirstChild("Minigame") and room8.Minigame:FindFirstChild("TV") and room8.Minigame.TV:FindFirstChild("Screen") and room8.Minigame.TV.Screen:FindFirstChild("UI")
        local healing = ui and ui:FindFirstChild("Healing")
        if healing and healing:IsA("GuiObject") and healing.Visible == true then return true end
        return false
    end

    local function getPendingMedicinesRoom8(reportFolder)
        local pending = {}
        if not reportFolder then return pending end
        local invFolder = reportFolder:FindFirstChild("inv")
        if not invFolder then return pending end
        for _, itemReq in ipairs(invFolder:GetChildren()) do
            if table.find(ItemList, itemReq.Name) then 
                local checkMark = itemReq:FindFirstChild("check")
                if not checkMark or (checkMark and checkMark.Visible == false) then
                    table.insert(pending, itemReq.Name) 
                end
            end
        end
        return pending
    end

    -- [INTEGRASI SCRIPT 1 NPC DETECTION]
    local function getPatientDataRoom8()
        local centerPos = Config.Room8BedCFrame.Position
        local radius = Config.PatientBedRadius
        local function checkNPC(obj)
            if Players:GetPlayerFromCharacter(obj) then return nil end
            local part = obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")
            if part and (part.Position - centerPos).Magnitude <= radius then
                local isRealPatient = false
                for _, pp in ipairs(obj:GetDescendants()) do
                    if pp:IsA("ProximityPrompt") then
                        local txt = string.lower(pp.ActionText or "")
                        if txt:match("dna") or txt:match("treat") or pp.Name == "FirePP" then
                            isRealPatient = true
                            break
                        end
                    end
                end
                if isRealPatient then return obj end
            end
            return nil
        end
        if workspace:FindFirstChild("NPCs") then
            for _, npc in ipairs(workspace.NPCs:GetChildren()) do
                local found = checkNPC(npc)
                if found then return found end
            end
        end
        for _, obj in ipairs(workspace:GetChildren()) do
            if obj:IsA("Model") and obj ~= LocalPlayer.Character and obj.Name ~= "Rooms" and obj.Name ~= "Misc" then
                local found = checkNPC(obj)
                if found then return found end
            end
        end
        return nil
    end

    local function checkAnomalyStatus()
        local npc = getPatientDataRoom8()
        if npc then
            local attr = npc:GetAttributes()
            if attr.Skinwalker or attr.SkinwalkerEasy or attr.PenaltyWhenLettingIn or attr.PhotoEffect == "CursedPhoto" or attr.PhotoEffect2 == "CursedPhoto" then 
                return true 
            end
        end
        return false
    end

    -- [INTEGRASI SCRIPT 1 FETCH/TRASH]
    local function checkTotalInventory()
        local targetCount = 0
        local targetItems = {} 
        local backpack = LocalPlayer:FindFirstChild("Backpack")
        local character = LocalPlayer.Character
        local function processTool(item)
            if item:IsA("Tool") and table.find(ItemList, item.Name) then
                targetCount = targetCount + 1
                table.insert(targetItems, item)
            end
        end
        if backpack then for _, item in ipairs(backpack:GetChildren()) do processTool(item) end end
        if character then for _, item in ipairs(character:GetChildren()) do processTool(item) end end
        return targetCount, targetItems
    end

    local function getPromptFromCache(targetName, isTrash)
        if isTrash then
            if _G.Room8_TrashCache and _G.Room8_TrashCache.Parent then return _G.Room8_TrashCache end
            for _, desc in ipairs(workspace:GetDescendants()) do
                if desc:IsA("ProximityPrompt") then
                    local actText = string.lower(desc.ActionText or "")
                    local objName = string.lower(desc.Parent and desc.Parent.Name or "")
                    if actText:match("trash") or actText:match("throw") or actText:match("dispose") or objName:match("trash") then
                        _G.Room8_TrashCache = desc
                        return desc
                    end
                end
            end
        else
            if _G.Room8_ItemCache[targetName] and _G.Room8_ItemCache[targetName].Parent then return _G.Room8_ItemCache[targetName] end
            local tLower = string.lower(targetName)
            for _, desc in ipairs(workspace:GetDescendants()) do
                if desc:IsA("ProximityPrompt") and desc.Enabled then
                    local pName = string.lower(desc.Parent and desc.Parent.Name or "")
                    local oText = string.lower(desc.ObjectText or "")
                    local aText = string.lower(desc.ActionText or "")
                    if pName:match(tLower) or oText:match(tLower) or aText:match(tLower) then
                        _G.Room8_ItemCache[targetName] = desc
                        return desc
                    end
                end
            end
        end
        return nil
    end

    local function trashItem(toolToTrash)
        local char = LocalPlayer.Character
        if not char then return false end
        local trashPrompt = getPromptFromCache("Trash", true)
        if trashPrompt then
            setStatus("Membuang item: " .. toolToTrash.Name)
            teleportToTarget(trashPrompt)
            if safeEquip(toolToTrash.Name) then
                local oldReq = trashPrompt.RequiresLineOfSight
                local oldDist = trashPrompt.MaxActivationDistance
                trashPrompt.RequiresLineOfSight = false
                trashPrompt.MaxActivationDistance = math.huge
                trashPrompt.HoldDuration = 0
                if type(fireproximityprompt) == "function" then fireproximityprompt(trashPrompt)
                else trashPrompt:InputHoldBegan() task.wait(0.05) trashPrompt:InputHoldEnded() end
                trashPrompt.RequiresLineOfSight = oldReq
                trashPrompt.MaxActivationDistance = oldDist
                _G.Room8Auto_LastActionTick = tick()
                task.wait(0.1) 
                return true
            end
        end
        setStatus("GAGAL: Tempat sampah tidak ditemukan / Gagal pegang item!")
        return false
    end

    local function fetchItem(targetName, pendingMedsList)
        local char = LocalPlayer.Character
        if not char then return false end
        setStatus("Mengambil (Insta-Fetch): " .. targetName)
        local totalAmount, currentItems = checkTotalInventory()
        if totalAmount >= Config.MaxInventory then
            local itemToThrowAway = nil
            if pendingMedsList then
                for _, item in ipairs(currentItems) do
                    if item.Name ~= targetName and not table.find(pendingMedsList, item.Name) then
                        itemToThrowAway = item
                        break
                    end
                end
            end
            if not itemToThrowAway then itemToThrowAway = currentItems[1] end
            local trashed = trashItem(itemToThrowAway)
            if not trashed then return false end 
        end
        local promptToUse = getPromptFromCache(targetName, false)
        if promptToUse then
            unequipAll() 
            teleportToTarget(promptToUse) 
            local oldReq = promptToUse.RequiresLineOfSight
            local oldDist = promptToUse.MaxActivationDistance
            local oldHold = promptToUse.HoldDuration
            promptToUse.RequiresLineOfSight = false
            promptToUse.MaxActivationDistance = math.huge
            promptToUse.HoldDuration = 0
            local gotItem = false
            for retry = 1, 15 do
                if type(fireproximityprompt) == "function" then fireproximityprompt(promptToUse)
                else promptToUse:InputHoldBegan() task.wait(0.05) promptToUse:InputHoldEnded() end
                task.wait(0.1) 
                if LocalPlayer.Backpack:FindFirstChild(targetName) or LocalPlayer.Character:FindFirstChild(targetName) then
                    gotItem = true
                    break
                end
            end
            promptToUse.RequiresLineOfSight = oldReq
            promptToUse.MaxActivationDistance = oldDist
            promptToUse.HoldDuration = oldHold
            if gotItem then
                setStatus("Berhasil Mengambil: " .. targetName)
                _G.Room8Auto_LastActionTick = tick()
                return true
            else
                setStatus("GAGAL Mengambil: " .. targetName)
                return false 
            end
        end
        setStatus("GAGAL: " .. targetName .. " tidak ditemukan.")
        return false
    end

    local function simpleInteract(prompt, customHold, autoLock)
        if prompt and prompt:IsA("ProximityPrompt") then
            if autoLock then ensureInRoom8() end
            local oldReq = prompt.RequiresLineOfSight
            local oldDist = prompt.MaxActivationDistance
            prompt.RequiresLineOfSight = false
            prompt.MaxActivationDistance = math.huge
            if type(fireproximityprompt) == "function" then fireproximityprompt(prompt, 1, true)
            else prompt:InputHoldBegan() task.wait(customHold or prompt.HoldDuration or 0.1) prompt:InputHoldEnded() end
            _G.Room8Auto_LastActionTick = tick() 
            prompt.RequiresLineOfSight = oldReq
            prompt.MaxActivationDistance = oldDist
        end
    end

    local function executeRoom8Treatment(room8, activeShift)
        local minigame = room8:FindFirstChild("Minigame")
        if not minigame or getShiftText() ~= activeShift then return end

        setStatus("--- TURBO SURGERY DIMULAI ---")
        local root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if root then
            root.CFrame = Config.Room8BedCFrame
            root.AssemblyLinearVelocity = Vector3.zero
        end

        local ui = minigame:FindFirstChild("TV") and minigame.TV:FindFirstChild("Screen") and minigame.TV.Screen:FindFirstChild("UI")
        local reportFolder = ui and ui:FindFirstChild("Report")
        local treatmentText = reportFolder and reportFolder:FindFirstChild("treatment")
        local bed = minigame:FindFirstChild("Bed") and minigame.Bed:FindFirstChild("InBed")

        setStatus("1/3 Menunggu fisik pasien di kasur...")
        local targetNPC = nil
        local waitNPC = 0
        while not targetNPC and waitNPC < 20 do
            ensureInRoom8() 
            if getShiftText() ~= activeShift then return end
            targetNPC = getPatientDataRoom8()
            if not targetNPC then
                task.wait(0.5)
                waitNPC = waitNPC + 1
            end
        end

        if not targetNPC then
            setStatus("BATAL: Pasien gagal sampai ke kasur.")
            return
        end

        setStatus("2/3 Menidurkan pasien...")
        local waitLimit = 0
        while treatmentText and treatmentText.Text ~= "BEGIN SURGERY:" and waitLimit < 40 do
            ensureInRoom8() 
            _G.Room8Auto_LastActionTick = tick() 
            if isRoom8HealingDone(room8) or getShiftText() ~= activeShift then return end
            local sleepPP = bed and bed:FindFirstChild("PP2")
            if sleepPP and sleepPP.Enabled then simpleInteract(sleepPP, 0.1, false) end
            task.wait(0.2) 
            waitLimit = waitLimit + 1
        end

        setStatus("3/3 Mulai Apply Treatment...")
        local lastProgressTime = tick()

        while true do
            task.wait(0.05) 
            _G.Room8Auto_LastActionTick = tick() 
            ensureInRoom8()

            if getShiftText() ~= activeShift then setStatus("Shift berganti. Stop.") break end
            if isRoom8HealingDone(room8) then setStatus("Surgery Selesai! Layar Hijau.") break end

            local signLight = room8:FindFirstChild("MainSign") and room8.MainSign:FindFirstChild("Light")
            if not signLight or (signLight.BrickColor.Name ~= "Crimson" and signLight.Color ~= Color3.fromRGB(165, 0, 0)) then break end

            if tick() - lastProgressTime >= Config.StuckTimeout then 
                setStatus("Local Loop Timeout. Skip.")
                break 
            end

            local patientIsAnomaly = checkAnomalyStatus()
            local currentPending = getPendingMedicinesRoom8(reportFolder)
            
            if patientIsAnomaly and #currentPending > 0 then
                local wrongMedicine = "Medicine"
                for _, item in ipairs(ItemList) do
                    if not table.find(currentPending, item) then wrongMedicine = item break end
                end
                local hasIt = LocalPlayer.Backpack:FindFirstChild(wrongMedicine) or LocalPlayer.Character:FindFirstChild(wrongMedicine)
                if not hasIt then 
                    setStatus("Telekinesis Racun: " .. wrongMedicine)
                    fetchItem(wrongMedicine, {wrongMedicine}) 
                end
                local hasItNow = LocalPlayer.Backpack:FindFirstChild(wrongMedicine) or LocalPlayer.Character:FindFirstChild(wrongMedicine)
                if hasItNow then
                    if bed and bed:FindFirstChild("PP") then
                        ensureInRoom8()
                        if safeEquip(wrongMedicine) then
                            setStatus("MENYUNTIKKAN RACUN: " .. wrongMedicine)
                            simpleInteract(bed.PP, 0.1, true)
                            lastProgressTime = tick() 
                            task.wait(1.5) 
                            setStatus("--- ANOMALI HANGUS! ---")
                            break 
                        else
                            setStatus("FAILSAFE: Gagal pegang racun.")
                            task.wait(0.5)
                        end
                    end
                else
                    setStatus("Gagal mengambil racun: " .. wrongMedicine)
                    task.wait(0.5)
                end
            else
                if #currentPending == 0 then continue end

                local reqCounts = {}
                for _, obat in ipairs(currentPending) do reqCounts[obat] = (reqCounts[obat] or 0) + 1 end
                local _, currentItems = checkTotalInventory()
                local haveCounts = {}
                for _, item in ipairs(currentItems) do haveCounts[item.Name] = (haveCounts[item.Name] or 0) + 1 end

                local isMissingItems = false
                for obat, needed in pairs(reqCounts) do
                    local have = haveCounts[obat] or 0
                    if have < needed then
                        for i = 1, (needed - have) do
                            setStatus("Telekinesis: " .. obat .. " ("..have+i.."/"..needed..")")
                            fetchItem(obat, currentPending)
                            isMissingItems = true
                        end
                    end
                end
                if isMissingItems then task.wait(0.1) end 

                local obatToInject = currentPending[1]
                local hasItNow = LocalPlayer.Backpack:FindFirstChild(obatToInject) or LocalPlayer.Character:FindFirstChild(obatToInject)
                
                if hasItNow then
                    local applyPP = bed and bed:FindFirstChild("PP")
                    if applyPP then
                        ensureInRoom8()
                        if safeEquip(obatToInject) then
                            task.wait(0.2)
                            local previousPendingCount = #currentPending
                            setStatus("Menerapkan: " .. obatToInject)
                            simpleInteract(applyPP, 0.1, true)
                            lastProgressTime = tick()
                            
                            setStatus("Menunggu obat terproses di TV...")
                            local waitCheckLimit = 0
                            while waitCheckLimit < 30 do 
                                local newPending = getPendingMedicinesRoom8(reportFolder)
                                if #newPending < previousPendingCount then break end
                                if isRoom8HealingDone(room8) or getShiftText() ~= activeShift then break end
                                task.wait(0.05) 
                                waitCheckLimit = waitCheckLimit + 1
                                _G.Room8Auto_LastActionTick = tick()
                            end
                        else
                            setStatus("FAILSAFE: Gagal pegang obat " .. obatToInject)
                            task.wait(0.5)
                        end
                    end
                else
                    setStatus("Gagal Telekinesis " .. obatToInject)
                    task.wait(0.5)
                end
            end
        end
    end

    local function botCycleRoom8()
        local activeShift = getShiftText()
        if activeShift == "" or not activeShift or activeShift:match("Istirahat") then
            if not isBotIdle then 
                teleportToTarget(Config.IdleCFrame)
                isBotIdle = true
            end
            setStatus("Istirahat/Luar Shift...")
            task.wait(2)
            return
        end

        local room8 = workspace:FindFirstChild("Rooms") and workspace.Rooms:FindFirstChild("Emergency") and workspace.Rooms.Emergency:FindFirstChild("Room8")
        local roomActive = nil
        if room8 then
            local signLight = room8:FindFirstChild("MainSign") and room8.MainSign:FindFirstChild("Light")
            if signLight and signLight:IsA("BasePart") and (signLight.BrickColor.Name == "Crimson" or signLight.Color == Color3.fromRGB(165, 0, 0)) then
                if not isRoom8HealingDone(room8) then roomActive = room8 end
            end
        end

        if roomActive then
            isBotIdle = false 
            pcall(function() executeRoom8Treatment(roomActive, activeShift) end)
        else
            if not isBotIdle then 
                teleportToTarget(Config.IdleCFrame)
                isBotIdle = true
            end
            setStatus("Menunggu Kasus Room 8 (" .. activeShift .. ")...")
            task.wait(Config.ScanDelay)
        end
    end

    local function startWorkerRoom8()
        if _G.Room8Auto_Worker then task.cancel(_G.Room8Auto_Worker) end
        _G.Room8Auto_Worker = task.spawn(function()
            while autoScanEnabled do
                if not isBusy then
                    isBusy = true
                    _G.Room8Auto_LastActionTick = tick() 
                    local success, err = pcall(botCycleRoom8)
                    if not success then
                        setStatus("SYSTEM ERROR: " .. tostring(err))
                        task.wait(2)
                    end
                    isBusy = false
                end
                task.wait(0.2)
            end
        end)
    end

    GUI_Btn_R8.MouseButton1Click:Connect(function()
        autoScanEnabled = not autoScanEnabled
        if autoScanEnabled then
            GUI_Btn_R8.Text = "Auto Room 8: ON"
            GUI_Btn_R8.BackgroundColor3 = Color3.fromRGB(70, 200, 70)
            isBusy = false
            isBotIdle = false
            _G.Room8Auto_LastActionTick = tick()
            local lastShift = getShiftText()
            startWorkerRoom8()
            
            if _G.Room8Auto_Watchdog then task.cancel(_G.Room8Auto_Watchdog) end
            _G.Room8Auto_Watchdog = task.spawn(function()
                while autoScanEnabled do
                    task.wait(1)
                    local currentShift = getShiftText()
                    local isShiftChanged = (currentShift ~= lastShift and currentShift ~= nil and lastShift ~= nil)
                    local isStuck = isBusy and (tick() - _G.Room8Auto_LastActionTick > Config.GlobalStuckTimeout)

                    if isShiftChanged or isStuck then
                        if isShiftChanged then setStatus("Shift Berganti! HARD-RESET...")
                        else setStatus("SYSTEM STUCK! AUTO HARD-RESET...") end
                        if _G.Room8Auto_Worker then task.cancel(_G.Room8Auto_Worker) end
                        isBusy = false
                        isBotIdle = false
                        lastShift = currentShift
                        teleportToTarget(Config.IdleCFrame)
                        task.wait(2)
                        if autoScanEnabled then
                            _G.Room8Auto_LastActionTick = tick()
                            startWorkerRoom8()
                        end
                    end
                    if currentShift then lastShift = currentShift end
                end
            end)
        else
            GUI_Btn_R8.Text = "Auto Room 8: OFF"
            GUI_Btn_R8.BackgroundColor3 = Color3.fromRGB(70, 70, 70)
            if _G.Room8Auto_Watchdog then task.cancel(_G.Room8Auto_Watchdog) end
            if _G.Room8Auto_Worker then task.cancel(_G.Room8Auto_Worker) end
            isBusy = false 
            isBotIdle = false
            setStatus("Dimatikan.")
        end
    end)
