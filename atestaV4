    local function findPatientModel(bedPart)
        if not bedPart then return nil end
        local centerPos = bedPart.Position
        local radius = Config.PatientBedRadius
        local function checkNPC(obj)
            if Players:GetPlayerFromCharacter(obj) then return nil end
            local part = obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")
            if part and (part.Position - centerPos).Magnitude <= radius then
                local isRealPatient = false
                for _, pp in ipairs(obj:GetDescendants()) do
                    if pp:IsA("ProximityPrompt") then
                        local txt = string.lower(pp.ActionText or "")
                        if txt:match("dna") or txt:match("treat") or pp.Name == "FirePP" then
                            isRealPatient = true
                            break
                        end
                    end
                end
                if isRealPatient then return obj end
            end
            return nil
        end
        if workspace:FindFirstChild("NPCs") then
            for _, npc in ipairs(workspace.NPCs:GetChildren()) do
                local found = checkNPC(npc)
                if found then return found end
            end
        end
        for _, obj in ipairs(workspace:GetChildren()) do
            if obj:IsA("Model") and obj ~= LocalPlayer.Character and obj.Name ~= "Rooms" and obj.Name ~= "Misc" then
                local found = checkNPC(obj)
                if found then return found end
            end
        end
        return nil
    end

