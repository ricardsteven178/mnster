        if healingUI and healingUI.Visible == true then
            uiLog("R6", "✅ Healing selesai! Cabut...")
            isDone = true; break
        end

        if not R6_CheckActive(path, minigame) then
            emptyCounter = emptyCounter + 1
            if emptyCounter >= 3 then uiLog("R6", "✅ Clear! Cabut..."); isDone = true; break end
        else emptyCounter = 0 end

        local patientNPC = getRealPatient(Config.Room6PatientStand.Position, 9)
        
        -- CEK SUNTIK
        local invUI = tvScreen and tvScreen:FindFirstChild("inv", true)
        if invUI and #invUI:GetChildren() > 1 then
            local pending = {}
            for _, req in ipairs(invUI:GetChildren()) do
                if not req:IsA("UIListLayout") then
                    local chk = req:FindFirstChild("check")
                    if not chk or not chk.Visible then table.insert(pending, req.Name) end
                end
            end
            
            if #pending ~= lastPendingCount then lastPendingCount = #pending; lastProgressTime = tick() end

            if #pending == 0 then
                uiLog("R6", "Menunggu Healing...")
                continue 
            else
                if not patientNPC then uiLog("R6", "Menunggu NPC disuntik..."); continue end
                
                -- Cari PP pasien
                local patientPP = nil
                for _, pp in ipairs(patientNPC:GetDescendants()) do
                    if pp:IsA("ProximityPrompt") and pp.Enabled then patientPP = pp; break end
                end

                if patientPP then
                    if isPatientAnomaly(patientNPC) then
                        uiLog("R6", "!! [ALGOJO] PASIEN ANOMALI !!")
                        local wrongMedicine = "Medicine"
                        for _, item in ipairs(ItemList) do
                            if not table.find(pending, item) then wrongMedicine = item break end
                        end
                        smartFetch(wrongMedicine, {wrongMedicine})
                        teleportToTarget(Config.Room6CFrame)
                        if safeEquip(wrongMedicine) then
                            uiLog("R6", "Suntik Racun: " .. wrongMedicine)
                            simpleInteract(patientPP, 0.25, false)
                        end
                        continue
                    end

                    for _, obat in ipairs(pending) do
                        smartFetch(obat, pending)
                        teleportToTarget(Config.Room6CFrame)
                        if safeEquip(obat) then
                            uiLog("R6", "Menyuntikkan: " .. obat)
                            simpleInteract(patientPP, 0.25, false)
                        end
                    end
                    task.wait(1.5); continue 
                end
            end
        end

        -- CEK COLLECT
        local collected = false
        for _, pp in ipairs(minigame:GetDescendants()) do
            if pp:IsA("ProximityPrompt") and pp.ActionText:match("Collect") and pp.Enabled then
                uiLog("R6", "Collect Hasil...")
                teleportToTarget(Config.Room6CFrame) 
                simpleInteract(pp, 0.5, false)
                lastProgressTime = tick(); collected = true; task.wait(1.5); break
            end
        end
        if collected then continue end 

        -- PROCESS BYPASS
        local bypassBerhasil = false
        local monitor = minigame:FindFirstChild("Monitor")
        if monitor then
            for _, pp in ipairs(monitor:GetDescendants()) do
                if pp:IsA("ProximityPrompt") and string.lower(pp.ActionText or ""):match("process") then
                    uiLog("R6", "BYPASS Process Instan...")
                    teleportToTarget(Config.Room6CFrame)
                    
                    local oldReq = pp.RequiresLineOfSight
                    local oldDist = pp.MaxActivationDistance
                    local oldEnabled = pp.Enabled 
                    pp.RequiresLineOfSight = false
                    pp.MaxActivationDistance = math.huge
                    pp.Enabled = true 
                    
                    if type(fireproximityprompt) == "function" then fireproximityprompt(pp, 1, true)
                    else pp:InputHoldBegan() task.wait(0.25) pp:InputHoldEnded() end
                    
                    pp.RequiresLineOfSight = oldReq
                    pp.MaxActivationDistance = oldDist
                    pp.Enabled = oldEnabled 
                    
                    lastProgressTime = tick(); task.wait(1.5); bypassBerhasil = true; break
                end
            end
        end
        if bypassBerhasil then continue end

        -- ANTI-STUCK
        if tick() - lastProgressTime >= Config.StuckTimeout then
            uiLog("R6", "⚠️ Timeout! Force reset minigame...")
            teleportToTarget(Config.Room6CFrame)
            R6_ForceFailMinigame()
            isDone = true 
            break
        else
            uiLog("R6", "Menunggu bypass/collect...")
        end
    end

    if not GlobalState.R6_Idle then
        unequipAll(); teleportToTarget(Config.IdleCFrame); GlobalState.R6_Idle = true
    end
end

