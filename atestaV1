        end
        uiLog("R6", "Standby...")
        task.wait(Config.ScanDelay)
        return 
    end

    GlobalState.R6_Idle = false
    uiLog("R6", "Aktif! Menyiapkan R6...")
    local isDone = false
    local lastProgressTime = tick() 
    local lastPendingCount = -1
    local emptyCounter = 0
    
    while not isDone and GlobalState.R6_Auto do
        task.wait(1)
        local root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if root and (root.Position - Config.Room6CFrame.Position).Magnitude > 5 then
            teleportToTarget(Config.Room6CFrame)
        end

