local function executeRoom7(room7)
    local mgUI = PlayerGui:FindFirstChild("Minigame")
    if mgUI and mgUI:FindFirstChild("UnlockMouse") and mgUI.UnlockMouse:IsA("GuiObject") and mgUI.UnlockMouse.Visible then
        uiLog("R7", "Minigame Berjalan...")
        GlobalState.R7_LastAction = tick(); task.wait(1); return
    end
    local hbUI = PlayerGui:FindFirstChild("HeartbeatMinigameUI")
    if hbUI then
        local txt = hbUI:FindFirstChild("text") or hbUI:FindFirstChild("Text")
        if txt and txt:IsA("TextLabel") and txt.Visible and string.match(string.upper(txt.Text), "HEART SCAN COMPLETE") then
            uiLog("R7", "Minigame Selesai...")
            GlobalState.R7_LastAction = tick(); task.wait(1); return
        end
    end

    local minigame = room7:FindFirstChild("Minigame")
    if not minigame then return end
    local bedPart = minigame:FindFirstChild("Bed") and minigame.Bed:FindFirstChild("InBed")
    local currentPatient = getRealPatient(Config.Room7Bed.Position, 15)

    if not currentPatient then
        local signLight = room7:FindFirstChild("MainSign") and room7.MainSign:FindFirstChild("Light")
        if signLight and (signLight.BrickColor.Name == "Crimson" or signLight.Color == Color3.fromRGB(165, 0, 0)) then
            uiLog("R7", "Menunggu pasien datang...")
        else uiLog("R7", "Pasien pergi. Idle...") end
        task.wait(1); return
    end

    local tv = minigame:FindFirstChild("TV") and minigame.TV:FindFirstChild("Screen")
    local healingUI = tv and tv:FindFirstChild("UI") and tv.UI:FindFirstChild("Healing")
    if healingUI and healingUI.Visible == true then
        uiLog("R7", "Pasien Clear. Cabut...")
        task.wait(1); return 
    end

    teleportToTarget(Config.Room7Step2)
    
    -- 1. Luka Bakar / DNA
    for _, desc in ipairs(currentPatient:GetDescendants()) do
        if desc:IsA("ProximityPrompt") and desc.Enabled then
            local actText = string.lower(desc.ActionText or "")
            local name = string.lower(desc.Name or "")
            if name == "firepp" or actText:match("burns") then
                smartFetch("Ointment", {"Ointment"})
                teleportToTarget(desc.Parent)
                if safeEquip("Ointment") then uiLog("R7", "Treat Burns..."); simpleInteract(desc, 3, false); task.wait(1.5) end
                return
            elseif actText:match("dna") or name:match("dna") then
                unequipAll(); uiLog("R7", "Take DNA..."); simpleInteract(desc, 0.5, true); task.wait(1.5); return
            end
        end
    end

    -- 2. TV Meds
    local reportUI = tv and tv:FindFirstChild("UI") and tv.UI:FindFirstChild("Report")
    local invFolder = reportUI and reportUI:FindFirstChild("inv", true)
    if reportUI and reportUI.Visible and invFolder and #invFolder:GetChildren() > 1 then
        local pending = {}
        for _, req in ipairs(invFolder:GetChildren()) do
            if table.find(ItemList, req.Name) then 
                local chk = req:FindFirstChild("check")
                if not chk or not chk.Visible then table.insert(pending, req.Name) end
            end
        end
        local inBedPP = minigame:FindFirstChild("InBed", true) and minigame.InBed:FindFirstChildOfClass("ProximityPrompt")

        if #pending > 0 and isPatientAnomaly(currentPatient) then
            local wrongMedicine = "Medicine"
            for _, item in ipairs(ItemList) do if not table.find(pending, item) then wrongMedicine = item break end end
            smartFetch(wrongMedicine, {wrongMedicine})
            teleportToTarget(Config.Room7Step2)
            if safeEquip(wrongMedicine) then
                uiLog("R7", "SUNTIK RACUN!"); if inBedPP then simpleInteract(inBedPP, 0.25, false) end; task.wait(2)
            end
            return
        end

        if #pending > 0 then
            for _, obat in ipairs(pending) do
                smartFetch(obat, pending); teleportToTarget(Config.Room7Step2)
                if safeEquip(obat) then uiLog("R7", "Suntik " .. obat); if inBedPP then simpleInteract(inBedPP, 0.25, false) end; task.wait(Config.InjectionDelay) end
            end
        else
            uiLog("R7", "Obat Tercentang, Tunggu Healing...")
            if inBedPP then simpleInteract(inBedPP, 0.25, false) end; task.wait(1) 
        end
        return 
    end

    -- 3. BYPASS PROCESS
    for _, prompt in ipairs(minigame:GetDescendants()) do
        if prompt:IsA("ProximityPrompt") and prompt.Enabled and string.lower(prompt.ActionText or ""):match("collect") then
            uiLog("R7", "Collect Hasil..."); unequipAll(); simpleInteract(prompt, 0.5, true); task.wait(1); return
        end
    end

    local processPrompt = nil; local hasEarlyStep = false
    for _, prompt in ipairs(minigame:GetDescendants()) do
        if prompt:IsA("ProximityPrompt") then
            local actText = string.lower(prompt.ActionText or "")
            if actText:match("process") then processPrompt = prompt end
            if prompt.Enabled and (actText:match("prepare") or actText:match("set up") or actText:match("turn on") or actText:match("begin")) then hasEarlyStep = true end
        end
    end

    if hasEarlyStep and processPrompt then
        uiLog("R7", "🔥 BYPASS Process..."); unequipAll()
        local oldEnabled = processPrompt.Enabled
        processPrompt.Enabled = true 
        simpleInteract(processPrompt, 0.5, true) 
        processPrompt.Enabled = oldEnabled
        task.wait(1); return
    elseif processPrompt and processPrompt.Enabled then
        uiLog("R7", "Mengeksekusi Process..."); unequipAll(); simpleInteract(processPrompt, 0.5, true); task.wait(1); return
    end

    uiLog("R7", "Menunggu Reaksi...")
    task.wait(0.5)
end

