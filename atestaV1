            if desc:IsA("ProximityPrompt") and desc.Enabled then table.insert(prompts, desc) end
        end
    end
    local pt = getRealPatient(bedPart.Position, Config.PatientBedRadius)
    if pt then
        for _, desc in ipairs(pt:GetDescendants()) do
            if desc:IsA("ProximityPrompt") and desc.Enabled then table.insert(prompts, desc) end
        end
    end
    return prompts
end

local function isPatientReadyMed(roomPath, bedPart)
    local minigame = roomPath:FindFirstChild("Minigame")
    local tvUI = minigame and minigame:FindFirstChild("TV") and minigame.TV:FindFirstChild("Screen", true)
    local pending = getPendingMedicinesTV(tvUI)
    if #pending > 0 then return true, "TV Aktif (Butuh Obat)" end
    local prompts = getPromptsNearBed(roomPath, bedPart)
    for _, desc in ipairs(prompts) do
        local actText = string.lower(desc.ActionText or "")
        local name = string.lower(desc.Name or "")
        if actText:match("dna") or name:match("dna") then return true, "Tombol DNA" 
        elseif actText:match("burns") or name == "firepp" then return true, "Tombol Luka Bakar" 
        elseif actText:match("analyze") or actText:match("process") or name:match("analyze") then return true, "Mesin Lab" end
    end
    return false, "Kosong/Healing"
end

local function isRoomDoneMed(roomNum, minigame, roomPath, bedPart, currentPatient)
    if not minigame then return false end
    if roomPath and bedPart then
        local ready, reason = isPatientReadyMed(roomPath, bedPart)
        if ready and reason == "Tombol Luka Bakar" then return false end
    end
    if currentPatient then
        if currentPatient:FindFirstChild("PE", true) then return false end
        if currentPatient:FindFirstChild("Heal", true) then return true end
    end
    local tv = minigame:FindFirstChild("TV")
    local screen = tv and tv:FindFirstChild("Screen")
    local ui = screen and screen:FindFirstChild("UI")
    if ui and ui:IsA("SurfaceGui") and ui.Enabled and ui:FindFirstChild("inv", true) then
        local invFolder = ui:FindFirstChild("inv", true)
        local totalItems = 0
        for _, itemReq in ipairs(invFolder:GetChildren()) do
            if table.find(ItemList, itemReq.Name) then totalItems = totalItems + 1 end
        end
        local pending = getPendingMedicinesTV(ui)
        if totalItems > 0 and #pending == 0 then return true end
    end
    return false
end

local function getPlacePatientPromptMed()
    local roomsFolder = workspace:FindFirstChild("Rooms")
    local medicalFolder = roomsFolder and roomsFolder:FindFirstChild("Medical")
    if medicalFolder then
        for i = 1, Config.MaxRooms do
            local room = medicalFolder:FindFirstChild("Room" .. i)
            if room then
                for _, desc in ipairs(room:GetDescendants()) do
                    if desc:IsA("ProximityPrompt") and desc.Enabled and string.lower(desc.ActionText or ""):match("place") then 
                        return desc, room.Name, i, room 
                    end
                end
            end
        end
    end
    local emergencyFolder = roomsFolder and roomsFolder:FindFirstChild("Emergency")
    if emergencyFolder and Config.EmergencyRooms then
        for _, i in ipairs(Config.EmergencyRooms) do
            local room = emergencyFolder:FindFirstChild("Room" .. i)
            if room then
                for _, desc in ipairs(room:GetDescendants()) do
                    if desc:IsA("ProximityPrompt") and desc.Enabled and string.lower(desc.ActionText or ""):match("place") then 
                        return desc, room.Name, tonumber(i), room 
                    end
                end
            end
        end
    end
    return nil, nil, nil, nil
end

