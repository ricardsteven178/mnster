local function safeEquip(itemName)
    local char = LocalPlayer.Character
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    local hum = char and char:FindFirstChild("Humanoid")
    if not char or not backpack or not hum then return false end
    if char:FindFirstChild(itemName) then return true end

    hum:UnequipTools()
    local t1 = 0
    while char:FindFirstChildOfClass("Tool") and t1 < 10 do task.wait(0.05); t1 = t1 + 1 end

    local tool = backpack:FindFirstChild(itemName) or char:FindFirstChild(itemName)
    if not tool then return false end

    hum:EquipTool(tool)
    local t2 = 0
    while not char:FindFirstChild(itemName) and t2 < 15 do task.wait(0.05); t2 = t2 + 1 end
    task.wait(0.1) 
    return char:FindFirstChild(itemName) ~= nil
end

local function simpleInteract(prompt, customHold, autoLock)
    if prompt and prompt:IsA("ProximityPrompt") then
        if autoLock then teleportToTarget(prompt) end
        local oldReq = prompt.RequiresLineOfSight
        local oldDist = prompt.MaxActivationDistance
        prompt.RequiresLineOfSight = false
        prompt.MaxActivationDistance = math.huge
        
        if type(fireproximityprompt) == "function" then fireproximityprompt(prompt, 1, true)
        else prompt:InputHoldBegan() task.wait(customHold or prompt.HoldDuration or 0.1) prompt:InputHoldEnded() end
        
        prompt.RequiresLineOfSight = oldReq
        prompt.MaxActivationDistance = oldDist
        task.wait(0.1)
    end
    return true
end

-- [ UNIFIED SMART INVENTORY FETCH/TRASH ]
local function checkTotalInventory()
    local targetCount = 0
    local targetItems = {} 
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    local character = LocalPlayer.Character
    local function processTool(item)
        if item:IsA("Tool") and table.find(ItemList, item.Name) then
            targetCount = targetCount + 1
            table.insert(targetItems, item)
        end
    end
    if backpack then for _, item in ipairs(backpack:GetChildren()) do processTool(item) end end
    if character then for _, item in ipairs(character:GetChildren()) do processTool(item) end end
    return targetCount, targetItems
end

local function smartTrash(toolToTrash)
    local char = LocalPlayer.Character
    if not char or not toolToTrash then return false end
    local trashPrompt = nil
    if _G.UltimateDoc_TrashCache and _G.UltimateDoc_TrashCache.Parent then 
        trashPrompt = _G.UltimateDoc_TrashCache 
    else
        for _, desc in ipairs(workspace:GetDescendants()) do
            if desc:IsA("ProximityPrompt") then
                local actText = string.lower(desc.ActionText or "")
                local objName = string.lower(desc.Parent and desc.Parent.Name or "")
                if actText:match("trash") or actText:match("throw") or objName:match("trash") then
                    trashPrompt = desc
                    _G.UltimateDoc_TrashCache = desc
                    break
                end
            end
        end
    end
    if trashPrompt then
        teleportToTarget(trashPrompt)
        if safeEquip(toolToTrash.Name) then
            simpleInteract(trashPrompt, 0, false)
            task.wait(0.2)
            return true
        end
    end
    return false
end

local function smartFetch(targetName, pendingMedsList)
    local char = LocalPlayer.Character
    if not char then return false end

    local totalAmount, currentItems = checkTotalInventory()
    if totalAmount >= Config.MaxInventory then
        local itemToThrowAway = nil
        local reqCounts = {}
        if pendingMedsList then
            for _, o in ipairs(pendingMedsList) do reqCounts[o] = (reqCounts[o] or 0) + 1 end
        end
        local haveCounts = {}
        for _, item in ipairs(currentItems) do
            haveCounts[item.Name] = (haveCounts[item.Name] or 0) + 1
            local needed = reqCounts[item.Name] or 0
            if haveCounts[item.Name] > needed then itemToThrowAway = item end
        end
        if not itemToThrowAway then itemToThrowAway = currentItems[1] end
        smartTrash(itemToThrowAway)
    end

    local promptToUse = nil
    if _G.UltimateDoc_ItemCache[targetName] and _G.UltimateDoc_ItemCache[targetName].Parent then
        promptToUse = _G.UltimateDoc_ItemCache[targetName]
    else
        for _, desc in ipairs(workspace:GetDescendants()) do
            if desc:IsA("ProximityPrompt") then
                local pName = desc.Parent and desc.Parent.Name or ""
                local oText = desc.ObjectText or ""
                local aText = desc.ActionText or ""
                if pName == targetName or oText:match(targetName) or aText:match(targetName) then
                    promptToUse = desc
                    _G.UltimateDoc_ItemCache[targetName] = desc
                    break
                end
            end
        end
    end

    if promptToUse then
        unequipAll() 
        teleportToTarget(promptToUse) 
        simpleInteract(promptToUse, 0, false)
        task.wait(0.2)
        return true 
    end
    return false
end

-- [ UNIFIED SMART NPC DETECTOR (Anti-Ghost) ]
local function getRealPatient(centerPos, radius)
    local function checkNPC(obj)
        if Players:GetPlayerFromCharacter(obj) then return nil end
        local part = obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")
        if part and (part.Position - centerPos).Magnitude <= radius then
            local isRealPatient = false
            for _, pp in ipairs(obj:GetDescendants()) do
                if pp:IsA("ProximityPrompt") and pp.Enabled then
                    local txt = string.lower(pp.ActionText or "")
                    if txt:match("dna") or txt:match("treat") or txt:match("burns") or txt:match("inject") or pp.Name == "FirePP" or pp.Name == "PP" then
                        isRealPatient = true
                        break
                    end
                end
            end
            if isRealPatient then return obj end
        end
        return nil
    end

    if workspace:FindFirstChild("NPCs") then
        for _, npc in ipairs(workspace.NPCs:GetChildren()) do
            local found = checkNPC(npc)
            if found then return found end
        end
    end
    for _, obj in ipairs(workspace:GetChildren()) do
        if obj:IsA("Model") and obj ~= LocalPlayer.Character and obj.Name ~= "Rooms" and obj.Name ~= "Misc" then
            local found = checkNPC(obj)
            if found then return found end
        end
    end
    return nil
end

local function isPatientAnomaly(npc)
    if not npc then return false end
    local attr = npc:GetAttributes()
    if attr.Skinwalker or attr.SkinwalkerEasy or attr.PenaltyWhenLettingIn or attr.PhotoEffect == "CursedPhoto" or attr.PhotoEffect2 == "CursedPhoto" then 
        return true 
    end
    return false
end

