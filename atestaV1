-- ==========================================
local function executeRoom8Treatment(room8)
    local minigame = room8:FindFirstChild("Minigame")
    if not minigame then return end

    uiLog("R8", "TURBO SURGERY DIMULAI")
    teleportToTarget(Config.Room8BedCFrame)

    local ui = minigame:FindFirstChild("TV") and minigame.TV:FindFirstChild("Screen") and minigame.TV.Screen:FindFirstChild("UI")
    local reportFolder = ui and ui:FindFirstChild("Report")
    local treatmentText = reportFolder and reportFolder:FindFirstChild("treatment")
    local bed = minigame:FindFirstChild("Bed") and minigame.Bed:FindFirstChild("InBed")

    uiLog("R8", "1/3 Tunggu fisik di kasur...")
    local targetNPC = nil; local waitNPC = 0
    while not targetNPC and waitNPC < 20 do
        teleportToTarget(Config.Room8BedCFrame)
        targetNPC = getRealPatient(Config.Room8BedCFrame.Position, 10)
        if not targetNPC then task.wait(0.5); waitNPC = waitNPC + 1 end
    end
    if not targetNPC then uiLog("R8", "BATAL: Pasien ga nyampe."); return end

    uiLog("R8", "2/3 Menidurkan pasien...")
    local waitLimit = 0
    while treatmentText and treatmentText.Text ~= "BEGIN SURGERY:" and waitLimit < 40 do
        teleportToTarget(Config.Room8BedCFrame)
        _G.UltimateDoc_LastActionTick = tick() 
        local heal = ui and ui:FindFirstChild("Healing")
        if heal and heal:IsA("GuiObject") and heal.Visible then return end
        
        local sleepPP = bed and bed:FindFirstChild("PP2")
        if sleepPP and sleepPP.Enabled then simpleInteract(sleepPP, 0.1, false) end
        task.wait(0.2); waitLimit = waitLimit + 1
    end

    uiLog("R8", "3/3 Apply Treatment...")
    local lastProgressTime = tick()

    while GlobalState.R8_Auto do
        task.wait(0.05) 
        _G.UltimateDoc_LastActionTick = tick() 
        teleportToTarget(Config.Room8BedCFrame)

        local heal = ui and ui:FindFirstChild("Healing")
        if heal and heal:IsA("GuiObject") and heal.Visible then uiLog("R8", "Selesai! Layar Hijau."); break end

        local signLight = room8:FindFirstChild("MainSign") and room8.MainSign:FindFirstChild("Light")
        if not signLight or (signLight.BrickColor.Name ~= "Crimson" and signLight.Color ~= Color3.fromRGB(165, 0, 0)) then break end
        if tick() - lastProgressTime >= Config.StuckTimeout then uiLog("R8", "Timeout Loop."); break end

        local patientIsAnomaly = isPatientAnomaly(targetNPC)
        
        -- Get Pending Obat R8
        local currentPending = {}
        if reportFolder then
            local invFolder = reportFolder:FindFirstChild("inv")
            if invFolder then
                for _, itemReq in ipairs(invFolder:GetChildren()) do
                    if table.find(ItemList, itemReq.Name) then 
                        local checkMark = itemReq:FindFirstChild("check")
                        if not checkMark or (checkMark and checkMark.Visible == false) then table.insert(currentPending, itemReq.Name) end
                    end
                end
            end
        end
        
        if patientIsAnomaly and #currentPending > 0 then
            local wrongMedicine = "Medicine"
            for _, item in ipairs(ItemList) do if not table.find(currentPending, item) then wrongMedicine = item break end end
            smartFetch(wrongMedicine, {wrongMedicine}) 
            if bed and bed:FindFirstChild("PP") then
                teleportToTarget(Config.Room8BedCFrame)
                if safeEquip(wrongMedicine) then
                    uiLog("R8", "SUNTIK RACUN: " .. wrongMedicine)
                    simpleInteract(bed.PP, 0.1, true)
                    lastProgressTime = tick(); task.wait(1.5); break 
                end
            end
        else
            if #currentPending == 0 then continue end
            local reqCounts = {}
            for _, obat in ipairs(currentPending) do reqCounts[obat] = (reqCounts[obat] or 0) + 1 end
            
            local _, currentItems = checkTotalInventory()
            local haveCounts = {}
            for _, item in ipairs(currentItems) do haveCounts[item.Name] = (haveCounts[item.Name] or 0) + 1 end

            local isMissing = false
            for obat, needed in pairs(reqCounts) do
                local have = haveCounts[obat] or 0
                if have < needed then
                    for i = 1, (needed - have) do smartFetch(obat, currentPending); isMissing = true end
                end
            end
            if isMissing then task.wait(0.1) end 

            local obatToInject = currentPending[1]
            local applyPP = bed and bed:FindFirstChild("PP")
            if (LocalPlayer.Backpack:FindFirstChild(obatToInject) or LocalPlayer.Character:FindFirstChild(obatToInject)) and applyPP then
                teleportToTarget(Config.Room8BedCFrame)
                if safeEquip(obatToInject) then
                    task.wait(0.2) 
                    local prevCount = #currentPending
                    uiLog("R8", "Menerapkan: " .. obatToInject)
                    simpleInteract(applyPP, 0.1, true)
                    lastProgressTime = tick()
                    
                    uiLog("R8", "Menunggu TV memproses...")
                    local wcl = 0
                    while wcl < 30 do 
                        local np = {}
                        if reportFolder and reportFolder:FindFirstChild("inv") then
                            for _, ir in ipairs(reportFolder.inv:GetChildren()) do
                                if table.find(ItemList, ir.Name) then 
                                    local cm = ir:FindFirstChild("check")
                                    if not cm or (cm and cm.Visible == false) then table.insert(np, ir.Name) end
                                end
                            end
                        end
                        if #np < prevCount then break end
                        local h = ui and ui:FindFirstChild("Healing")
                        if h and h:IsA("GuiObject") and h.Visible then break end
                        task.wait(0.05); wcl = wcl + 1
                    end
                end
            end
        end
    end
end

