local function findActiveRoomMed()
    local medicalFolder = workspace:FindFirstChild("Rooms") and workspace.Rooms:FindFirstChild("Medical")
    if not medicalFolder then return nil, nil end
    for i = 1, Config.MaxRooms do
        local room = medicalFolder:FindFirstChild("Room" .. i)
        if room then
            local minigame = room:FindFirstChild("Minigame")
            local bed = minigame and minigame:FindFirstChild("Bed") and minigame.Bed:FindFirstChild("InBed")
            local currentPatient = getRealPatient(Config.RoomCFrames[i].Position, Config.PatientBedRadius)
            local mem = _G.UltimateDoc_RoomMemory[i]

            if mem then
                if not currentPatient then _G.UltimateDoc_RoomMemory[i] = nil
                elseif typeof(mem) == "Instance" and currentPatient ~= mem then _G.UltimateDoc_RoomMemory[i] = nil
                elseif currentPatient:FindFirstChild("PE", true) then _G.UltimateDoc_RoomMemory[i] = nil end
            end

            local isBlacklisted = BuggedRoomBlacklist[i] and (tick() - BuggedRoomBlacklist[i] < Config.BlacklistDuration)
            if not isBlacklisted and not _G.UltimateDoc_RoomMemory[i] then
                local ready, _ = isPatientReadyMed(room, bed)
                if ready then return room, i end
            end
        end
    end
    return nil, nil 
end

local function executeTreatmentMed(roomPath, roomNum)
    local minigame = roomPath:FindFirstChild("Minigame")
    if not minigame then return end
    local bed = minigame:FindFirstChild("Bed") and minigame.Bed:FindFirstChild("InBed")
    
    uiLog("Med", "MEMULAI PENGOBATAN: " .. roomPath.Name)
    teleportToTarget(Config.RoomCFrames[roomNum])
    local lastProgressTime = tick()

    while GlobalState.Med_Auto do
        task.wait(0.1) 
        if getFireEmergencyMed() or getPlacePatientPromptMed() then
            uiLog("Med", "INTERUPSI DARURAT! Menunda R"..roomNum)
            break
        end

        local currentPatient = getRealPatient(Config.RoomCFrames[roomNum].Position, Config.PatientBedRadius)
        if not currentPatient then
            local signLight = roomPath:FindFirstChild("MainSign") and roomPath.MainSign:FindFirstChild("Light")
            if signLight and (signLight.BrickColor.Name == "Crimson" or signLight.Color == Color3.fromRGB(165, 0, 0)) then
                uiLog("Med", "Pasien berjalan ke kasur...")
                task.wait(1)
            else
                BuggedRoomBlacklist[roomNum] = tick() 
                break
            end
        end

        if isRoomDoneMed(roomNum, minigame, roomPath, bed, currentPatient) then
            uiLog("Med", "Selesai R" .. roomNum)
            _G.UltimateDoc_RoomMemory[roomNum] = currentPatient or "JobDone"
            break
        end

        if tick() - lastProgressTime >= Config.StuckTimeout then
            uiLog("Med", "Timeout! Skip R"..roomNum)
            BuggedRoomBlacklist[roomNum] = tick()
            break
        end

        local tvUI = minigame:FindFirstChild("TV") and minigame.TV:FindFirstChild("Screen", true)
        local hasTasks, reason = isPatientReadyMed(roomPath, bed)

        if hasTasks then
            if reason == "TV Aktif (Butuh Obat)" then
                if isPatientAnomaly(currentPatient) then
                    local prescribedMeds = {}
                    local tvInv = tvUI:FindFirstChild("inv", true)
                    if tvInv then
                        for _, req in ipairs(tvInv:GetChildren()) do
                            if table.find(ItemList, req.Name) then table.insert(prescribedMeds, req.Name) end
                        end
                    end
                    local wrongMedicine = "Medicine"
                    for _, item in ipairs(ItemList) do
                        if not table.find(prescribedMeds, item) then wrongMedicine = item break end
                    end
                    uiLog("Med", "Menyuntik Racun Anomali: " .. wrongMedicine)
                    smartFetch(wrongMedicine, {wrongMedicine})
                    if bed and bed:FindFirstChild("PP") then
                        teleportToTarget(bed:FindFirstChild("PP").Parent)
                        if safeEquip(wrongMedicine) then
                            simpleInteract(bed.PP, 0.1, false)
                            lastProgressTime = tick(); task.wait(2) 
                            _G.UltimateDoc_RoomMemory[roomNum] = currentPatient or "JobDone"
                            break
                        end
                    end
                else
                    local currentPending = getPendingMedicinesTV(tvUI)
                    for _, obat in ipairs(currentPending) do
                        if not (LocalPlayer.Backpack:FindFirstChild(obat) or LocalPlayer.Character:FindFirstChild(obat)) then
                            smartFetch(obat, currentPending)
                        end
                    end
                    local medsWeHaveAndNeed = {}
                    currentPending = getPendingMedicinesTV(tvUI)
                    for _, obat in ipairs(currentPending) do
                        if LocalPlayer.Backpack:FindFirstChild(obat) or LocalPlayer.Character:FindFirstChild(obat) then table.insert(medsWeHaveAndNeed, obat) end
                    end
                    if #medsWeHaveAndNeed > 0 then
                        local obatToInject = medsWeHaveAndNeed[1]
                        if bed and bed:FindFirstChild("PP") then
                            teleportToTarget(bed:FindFirstChild("PP").Parent)
                            if safeEquip(obatToInject) then
                                uiLog("Med", "Suntik: " .. obatToInject)
                                simpleInteract(bed.PP, 0.1, false)
                                lastProgressTime = tick(); task.wait(Config.InjectionDelay) 
                            end
                        end
                    else
                        uiLog("Med", "Menunggu obat...") task.wait(0.5)
                    end
                end
            else
                local acted = false
                local prompts = getPromptsNearBed(roomPath, bed)
                local handledBurn = false
                for _, desc in ipairs(prompts) do
                    local actText = string.lower(desc.ActionText or "")
                    local name = string.lower(desc.Name or "")
                    if name == "firepp" or actText:match("burns") then
                        if not (LocalPlayer.Backpack:FindFirstChild("Ointment") or LocalPlayer.Character:FindFirstChild("Ointment")) then smartFetch("Ointment", {"Ointment"}) end
                        teleportToTarget(desc.Parent)
                        if safeEquip("Ointment") then
                            uiLog("Med", "Mengoleskan Ointment...")
                            simpleInteract(desc, 3, false)
                            acted = true; handledBurn = true; break
                        end
                    end
                end

                if not handledBurn then
                    local monitor = minigame:FindFirstChild("Monitor")
                    local pp2_obj = monitor and monitor:FindFirstChild("PP2")
                    local actualPP2 = pp2_obj and (pp2_obj:IsA("ProximityPrompt") and pp2_obj or pp2_obj:FindFirstChildOfClass("ProximityPrompt"))
                    if actualPP2 then
                        local monitorScreen = monitor:FindFirstChild("Screen")
                        local monitorUI = monitorScreen and monitorScreen:FindFirstChild("UI")
                        local isMonitorBusy = monitorUI and (monitorUI.Enabled or (monitorUI:FindFirstChild("Report") and monitorUI.Report.Visible))
                        
                        local activeTvUI = minigame:FindFirstChild("TV") and minigame.TV:FindFirstChild("Screen") and minigame.TV.Screen:FindFirstChild("UI")
                        local isTVBusy = activeTvUI and activeTvUI:IsA("SurfaceGui") and activeTvUI.Enabled

                        if isMonitorBusy or isTVBusy then
                            uiLog("Med", "Menunggu Data Lab...") task.wait(1); acted = true
                        else
                            unequipAll()
                            teleportToTarget(Config.RoomCFrames[roomNum])
                            uiLog("Med", "Bypass Process Results...")
                            simpleInteract(actualPP2, 0.2, false)
                            task.wait(0.5); acted = true
                        end
                    else
                        local reportFolder = tvUI and tvUI:FindFirstChild("Report")
                        if reportFolder and reportFolder.Visible then uiLog("Med", "Menunggu Loading Resep...")
                        else uiLog("Med", "Menunggu Monitor...") end
                        acted = false
                    end
                end
                if acted then lastProgressTime = tick() task.wait(0.5) end
            end
        else
            task.wait(1)
        end
    end
end

local function botCycleMed()
    local fireNPC, firePP = getFireEmergencyMed()
    if fireNPC then
        GlobalState.Med_Idle = false
        pcall(function() 
            unequipAll()
            uiLog("Med", "PRIORITAS: Memadamkan Pasien Terbakar!")
            simpleInteract(firePP, 3.2, fireNPC.PrimaryPart or fireNPC:FindFirstChildWhichIsA("BasePart"))
            task.wait(1.5)
        end)
        return
    end

    local placePrompt, targetRoomName, targetRoomNum, targetRoomPath = getPlacePatientPromptMed()
    if placePrompt then
        GlobalState.Med_Idle = false
        pcall(function()
            unequipAll()
            uiLog("Med", "Membawa pingsan ke " .. tostring(targetRoomName))
            simpleInteract(placePrompt, 1, true)
            task.wait(1.5)
        end)
        return
    end

    local faintedPart, carryPP = getFaintedPatientMed()
    if faintedPart then
        GlobalState.Med_Idle = false
        pcall(function()
            uiLog("Med", "Menggendong pasien pingsan...")
            unequipAll()
            simpleInteract(carryPP, 0, true)
            task.wait(1.5)
        end)
        return
    end
    
    local room, roomNum = findActiveRoomMed()
    if room and roomNum then 
        GlobalState.Med_Idle = false
        pcall(function() executeTreatmentMed(room, roomNum) end)
    else
        if not GlobalState.Med_Idle then
            unequipAll()
            teleportToTarget(Config.IdleCFrame)
            GlobalState.Med_Idle = true
        end
        uiLog("Med", "Idle memantau...")
        task.wait(Config.ScanDelay)
    end
end

local function startMedWorker()
    if _G.UltimateDoc_Worker_Med then task.cancel(_G.UltimateDoc_Worker_Med) end
    _G.UltimateDoc_Worker_Med = task.spawn(function()
        while GlobalState.Med_Auto do
            if not GlobalState.Med_Busy then
                GlobalState.Med_Busy = true
                GlobalState.Med_LastAction = tick() 
                pcall(botCycleMed)
                GlobalState.Med_Busy = false
            end
            task.wait(0.1) 
        end
    end)
end

