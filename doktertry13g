local function isHealingDone(minigame, roomPath, roomNum)
    if not minigame then return false end
    local tv = minigame:FindFirstChild("TV")
    local screen = tv and tv:FindFirstChild("Screen")
    local ui = screen and screen:FindFirstChild("UI")
    local healing = ui and ui:FindFirstChild("Healing")

    -- Jika layar Healing.Visible menyala
    if healing and healing:IsA("GuiObject") and healing.Visible == true then
        -- CEK 1: Pastikan ini bukan bug visual gamenya di awal masuk
        local pending = getPendingMedicines(ui)
        if #pending > 0 then 
            return false -- Masih ada obat, ini bug visual, hiraukan!
        end 
        
        -- CEK 2: Lulus. Memang benar-benar sembuh. Langsung cabut!
        return true
    end
    return false
end

local function checkAnomalyStatus(roomNum, roomPath)
    local centerPos = getRoomCenter(roomNum, roomPath)
    if not centerPos then return false end

    if workspace:FindFirstChild("NPCs") then
        for _, npc in ipairs(workspace.NPCs:GetChildren()) do
            local p = npc.PrimaryPart or npc:FindFirstChildWhichIsA("BasePart")
            if p and (p.Position - centerPos).Magnitude <= Config.PatientBedRadius then
                local attr = npc:GetAttributes()
                if attr.Skinwalker or attr.SkinwalkerEasy or attr.PenaltyWhenLettingIn or attr.PhotoEffect == "CursedPhoto" or attr.PhotoEffect2 == "CursedPhoto" then
                    return true
                end
            end
        end
    end
    return false
end

local function printRadarReport()
    if not Config.ShowConsoleLogs then return end
    local report = "[RADAR] Live Scan: "
    local roomList = getRoomList()
    
    table.sort(roomList, function(a, b) return a.num < b.num end)
    
    for _, data in ipairs(roomList) do
        local i = data.num
        local room = data.room
        local status = "[-]"
        
        if room then
            local minigame = room:FindFirstChild("Minigame")
            local isBlacklisted = BuggedRoomBlacklist[i] and (tick() - BuggedRoomBlacklist[i] < Config.BlacklistDuration)
            local isHealing = isHealingDone(minigame, room, i)
            local ready, reason = isPatientReady(room, i)

            if ready and not isHealing then
                _G.AutoDoctor_RoomMemory[i] = nil
                status = "[" .. reason .. "]"
            elseif isBlacklisted then
                status = "[BLACKLIST]"
            elseif _G.AutoDoctor_RoomMemory[i] == "PatientLeaving" then
                status = "[MEMORI: Pasien Lama Keluar]"
            elseif isHealing then
                status = "[HEALING]"
            else
                local signLight = room:FindFirstChild("MainSign") and room.MainSign:FindFirstChild("Light")
                local isLightRed = signLight and (signLight.BrickColor.Name == "Crimson" or signLight.Color == Color3.fromRGB(165, 0, 0))
                if isLightRed then
                    status = "[Lampu Merah: Pasien Baru Menuju]"
                else
                    status = "[Kosong]"
                end
            end
        end
        report = report .. "R" .. i .. ":" .. status .. " "
    end

    if _G.LastRadarReport ~= report then
        _G.LastRadarReport = report
        local timeStamp = os.date("%H:%M:%S")
        print("[" .. timeStamp .. "] [Auto-Doctor] " .. report)
    end
end

-- ==========================================
-- INVENTORY & ITEM FETCHING
-- ==========================================
local function checkTotalInventory()
    local targetCount = 0
    local targetItems = {}
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    local character = LocalPlayer.Character

    local function processTool(item)
        if item:IsA("Tool") and table.find(ItemList, item.Name) then
            targetCount = targetCount + 1
            table.insert(targetItems, item)
        end
    end

    if backpack then for _, item in ipairs(backpack:GetChildren()) do processTool(item) end end
    if character then for _, item in ipairs(character:GetChildren()) do processTool(item) end end
    return targetCount, targetItems
end

local function trashItem(toolToTrash)
    local char = LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not char or not root or not toolToTrash then return false end

    local trashPrompt = getPromptFromCache("Trash", true)
    if trashPrompt then
        setStatus("Membuang item: " .. toolToTrash.Name)

        if turboSafeEquip(toolToTrash.Name) then
            local originalPos = root.CFrame

            root.CFrame = Config.Room8BedCFrame
            root.AssemblyLinearVelocity = Vector3.zero
            task.wait(0.2) 

            if type(fireproximityprompt) == "function" then
                fireproximityprompt(trashPrompt)
            else
                local oldReq = trashPrompt.RequiresLineOfSight
                local oldDist = trashPrompt.MaxActivationDistance
                trashPrompt.RequiresLineOfSight = false
                trashPrompt.MaxActivationDistance = math.huge
                trashPrompt:InputHoldBegan() task.wait(0.05) trashPrompt:InputHoldEnded()
                trashPrompt.RequiresLineOfSight = oldReq
                trashPrompt.MaxActivationDistance = oldDist
            end

            _G.AutoDoctor_LastActionTick = tick()
            task.wait(0.1)

            root.CFrame = originalPos
            root.AssemblyLinearVelocity = Vector3.zero
            task.wait(0.05)

            return true
        end
    end
    return false
end

local function fetchItem(targetName, pendingMedsList)
    local char = LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not char or not root then return false end

    local totalAmount, currentItems = checkTotalInventory()

    if totalAmount >= Config.MaxInventory then
        local itemToThrowAway = nil
        local reqCounts = {}
        if pendingMedsList then
            for _, o in ipairs(pendingMedsList) do reqCounts[o] = (reqCounts[o] or 0) + 1 end
        end
        local haveCounts = {}
        for _, item in ipairs(currentItems) do
            haveCounts[item.Name] = (haveCounts[item.Name] or 0) + 1
            local needed = reqCounts[item.Name] or 0
            if haveCounts[item.Name] > needed then itemToThrowAway = item end
        end
        if not itemToThrowAway then itemToThrowAway = currentItems[1] end
        local trashed = trashItem(itemToThrowAway)
        if not trashed then return false end
    end

    local promptToUse = getPromptFromCache(targetName, false)
    if not promptToUse then
        setStatus("GAGAL: " .. targetName .. " tidak ditemukan di map.")
        return false
    end

    unequipAll()
    local isRoom8Item = table.find(Room8Items, targetName) ~= nil

    local function countInBag()
        local n = 0
        local bp = LocalPlayer:FindFirstChild("Backpack")
        local ch = LocalPlayer.Character
        if bp then for _, v in ipairs(bp:GetChildren()) do if v:IsA("Tool") and v.Name == targetName then n = n + 1 end end end
        if ch then for _, v in ipairs(ch:GetChildren()) do if v:IsA("Tool") and v.Name == targetName then n = n + 1 end end end
        return n
    end

    local beforeCount = countInBag()

    if isRoom8Item then
        setStatus("Fetch (Gudang R8): " .. targetName)
        root.CFrame = Config.Room8BedCFrame
        root.AssemblyLinearVelocity = Vector3.zero
        task.wait(0.2) 
    else
        setStatus("Fetch (Rak): " .. targetName)
        local itemPart = promptToUse.Parent:IsA("BasePart") and promptToUse.Parent or promptToUse.Parent:FindFirstChildWhichIsA("BasePart", true)
        if itemPart then
            root.CFrame = itemPart.CFrame * CFrame.new(0, 3, 0)
        end
        root.AssemblyLinearVelocity = Vector3.zero
        task.wait(0.1) 
    end

    local function firePrompt(p)
        if type(fireproximityprompt) == "function" then
            fireproximityprompt(p)
        else
            local oldReq = p.RequiresLineOfSight
            local oldDist = p.MaxActivationDistance
            p.RequiresLineOfSight = false
            p.MaxActivationDistance = math.huge
            p:InputHoldBegan() task.wait(0.05) p:InputHoldEnded()
            p.RequiresLineOfSight = oldReq
            p.MaxActivationDistance = oldDist
        end
        _G.AutoDoctor_LastActionTick = tick()
    end

    firePrompt(promptToUse)

    local verified = false
    for _ = 1, 20 do
        task.wait(0.05)
        if countInBag() > beforeCount then verified = true; break end
        _G.AutoDoctor_LastActionTick = tick()
    end

    if not verified then
        setStatus("RETRY: " .. targetName)
        firePrompt(promptToUse)
        for _ = 1, 20 do
            task.wait(0.05)
            if countInBag() > beforeCount then verified = true; break end
            _G.AutoDoctor_LastActionTick = tick()
        end
    end

    return verified
end

local function simpleInteract(prompt, customHold, autoLock)
    if prompt and prompt:IsA("ProximityPrompt") then
        if autoLock then teleportToTarget(prompt) end

        local oldReq = prompt.RequiresLineOfSight
        local oldDist = prompt.MaxActivationDistance
        prompt.RequiresLineOfSight = false
        prompt.MaxActivationDistance = math.huge

        if type(fireproximityprompt) == "function" then
            fireproximityprompt(prompt)
        else
            prompt:InputHoldBegan()
            task.wait(customHold or prompt.HoldDuration or 0.1)
            prompt:InputHoldEnded()
        end

        prompt.RequiresLineOfSight = oldReq
        prompt.MaxActivationDistance = oldDist

        _G.AutoDoctor_LastActionTick = tick()
        task.wait(0.1)
    end
    return true
end

