local function getRoomList()
    local list = {}
    local roomsFolder = workspace:FindFirstChild("Rooms")
    if not roomsFolder then return list end
    
    local medFolder = roomsFolder:FindFirstChild("Medical")
    if medFolder then
        for i = 1, Config.MaxRooms do
            local r = medFolder:FindFirstChild("Room"..i)
            if r then table.insert(list, {room = r, num = i, type = "Medical"}) end
        end
    end
    
    local emergFolder = roomsFolder:FindFirstChild("Emergency")
    if emergFolder then
        for _, i in ipairs({6, 7, 8}) do
            local r = emergFolder:FindFirstChild("Room"..i)
            if r then table.insert(list, {room = r, num = i, type = "Emergency"}) end
        end
    end
    return list
end

