local function turboSafeEquip(itemName)
    local char = LocalPlayer.Character
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    local hum = char and char:FindFirstChild("Humanoid")
    if not char or not backpack or not hum then return false end
    if char:FindFirstChild(itemName) then return true end

    hum:UnequipTools()
    local t1 = 0
    while char:FindFirstChildOfClass("Tool") and t1 < 10 do task.wait(0.05); t1 = t1 + 1 end

    local tool = backpack:FindFirstChild(itemName) or char:FindFirstChild(itemName)
    if not tool then return false end

    hum:EquipTool(tool)
    local t2 = 0
    while not char:FindFirstChild(itemName) and t2 < 15 do task.wait(0.05); t2 = t2 + 1 end
    task.wait(0.05)
    return char:FindFirstChild(itemName) ~= nil
end

local function getPromptFromCache(targetName, isTrash)
    if isTrash then
        if _G.AutoDoctor_TrashCache and _G.AutoDoctor_TrashCache.Parent then return _G.AutoDoctor_TrashCache end
        local bestPrompt, minDist = nil, math.huge
        for _, desc in ipairs(workspace:GetDescendants()) do
            if desc:IsA("ProximityPrompt") then
                local actText = string.lower(desc.ActionText or "")
                local objName = string.lower(desc.Parent and desc.Parent.Name or "")
                if actText:match("trash") or actText:match("throw") or actText:match("dispose") or objName:match("trash") then
                    local pos = desc.Parent:IsA("BasePart") and desc.Parent.Position or (desc.Parent:FindFirstChildWhichIsA("BasePart", true) and desc.Parent:FindFirstChildWhichIsA("BasePart", true).Position)
                    if pos then
                        local dist = (pos - Config.Room8BedCFrame.Position).Magnitude
                        if dist < minDist then
                            minDist = dist; bestPrompt = desc
                        end
                    end
                end
            end
        end
        if bestPrompt then _G.AutoDoctor_TrashCache = bestPrompt end
        return bestPrompt
    else
        if _G.AutoDoctor_ItemCache[targetName] and _G.AutoDoctor_ItemCache[targetName].Parent then return _G.AutoDoctor_ItemCache[targetName] end
        local tLower = string.lower(targetName)
        local isRoom8Item = table.find(Room8Items, targetName) ~= nil
        local root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        local charPos = root and root.Position or Vector3.zero

        local bestPrompt, minDist = nil, math.huge

        for _, desc in ipairs(workspace:GetDescendants()) do
            if desc:IsA("ProximityPrompt") and desc.Enabled then
                local pName = string.lower(desc.Parent and desc.Parent.Name or "")
                local oText = string.lower(desc.ObjectText or "")
                local aText = string.lower(desc.ActionText or "")

                if pName:match(tLower) or oText:match(tLower) or aText:match(tLower) then
                    local pos = desc.Parent:IsA("BasePart") and desc.Parent.Position or (desc.Parent:FindFirstChildWhichIsA("BasePart", true) and desc.Parent:FindFirstChildWhichIsA("BasePart", true).Position)
                    if pos then
                        local dist = isRoom8Item and (pos - Config.Room8BedCFrame.Position).Magnitude or (pos - charPos).Magnitude
                        if dist < minDist then
                            minDist = dist; bestPrompt = desc
                        end
                    end
                end
            end
        end
        if bestPrompt then _G.AutoDoctor_ItemCache[targetName] = bestPrompt end
        return bestPrompt
    end
end

