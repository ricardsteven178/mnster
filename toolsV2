-- ==========================================
-- CORE LOGIC 1: AUTO EXTINGUISH FIRE (FLOOR GAP SCANNER)
-- ==========================================
getgenv().AutoFireLoop = task.spawn(function()
    while true do
        task.wait(Config.ScanDelay)
        
        if getgenv().AutoFireIsRunning then
            local char = LocalPlayer.Character
            local hrp = char and char:FindFirstChild("HumanoidRootPart")
            
            if hrp then
                local allFires = {}
                
                -- Mengumpulkan semua objek api di dalam map
                for _, obj in ipairs(workspace:GetDescendants()) do
                    if obj:IsA("ProximityPrompt") and obj.ActionText == "Put out fire" then
                        table.insert(allFires, obj)
                    end
                end
                
                if #allFires > 0 then
                    FireStatusLabel.Text = "Fire: Memadamkan!"
                    FireStatusLabel.TextColor3 = Color3.fromRGB(255, 85, 85)
                    
                    local originalCFrame = hrp.CFrame
                    hrp.Anchored = true -- Anchor diperlukan agar tidak terseret saat nembak api
                    
                    for _, prompt in ipairs(allFires) do
                        if not getgenv().AutoFireIsRunning then break end
                        
                        local firePart = prompt.Parent
                        if firePart and firePart:IsA("BasePart") then
                            
                            -- Jarak maksimal jangkauan prompt (di area biru pada gambarmu)
                            local maxRadius = prompt.MaxActivationDistance
                            if maxRadius <= 0 or maxRadius > 20 then maxRadius = 10 end
                            
                            -- Berapa jarak yang dianggap "kena damage" oleh kotak api cyan
                            local dangerHitboxRadius = 4.5 
                            
                            local safeFloorPos = nil
                            
                            -- [ ALGORITMA PEMINDAI CELAH LANTAI ]
                            -- Cek setiap sudut (0 sampai 360 derajat)
                            -- Prioritaskan jarak yang paling jauh dari tengah api (maxRadius - 1)
                            for checkDist = maxRadius - 1.5, 3, -1.5 do 
                                for angle = 0, 360, 30 do
                                    local rad = math.rad(angle)
                                    -- Hitung titik kandidat di lantai (berdasarkan sumbu Y dari kotak api)
                                    local candidatePos = firePart.Position + Vector3.new(math.cos(rad) * checkDist, 0, math.sin(rad) * checkDist)
                                    
                                    local isThisSpotSafe = true
                                    
                                    -- Cek titik ini terhadap SEMUA api lain di ruangan
                                    for _, otherPrompt in ipairs(allFires) do
                                        local otherPart = otherPrompt.Parent
                                        if otherPart and otherPart:IsA("BasePart") then
                                            -- Kalkulasi jarak secara 2 Dimensi (abaikan tinggi)
                                            local distToOtherFire = (Vector3.new(candidatePos.X, 0, candidatePos.Z) - Vector3.new(otherPart.Position.X, 0, otherPart.Position.Z)).Magnitude
                                            
                                            -- Jika titik ini masuk ke hitbox kotak api lain, batalkan!
                                            if distToOtherFire < dangerHitboxRadius then
                                                isThisSpotSafe = false
                                                break
                                            end
                                        end
                                    end
                                    
                                    -- Jika lolos dari semua api, kita temukan spot sempurna!
                                    if isThisSpotSafe then
                                        safeFloorPos = candidatePos
                                        break
                                    end
                                end
                                if safeFloorPos then break end
                            end
                            
                            -- Jika map benar-benar tertutup rapat tanpa celah (sangat jarang), paksa berdiri di ujung
                            if not safeFloorPos then
                                safeFloorPos = firePart.Position + Vector3.new(maxRadius - 1.5, 0, 0)
                            end
                            
                            -- Teleport karakter ke Celah Lantai yang aman
                            -- Ketinggian (Y) diset 3.2 Studs di atas kotak api agar kaki pas menapak lantai
                            local finalPosition = Vector3.new(safeFloorPos.X, firePart.Position.Y + 3.2, safeFloorPos.Z)
                            hrp.CFrame = CFrame.new(finalPosition, Vector3.new(firePart.Position.X, finalPosition.Y, firePart.Position.Z))
                            
                            task.wait(0.25) -- Tunggu server menyadari kamu sudah berada di lantai yang sah
                            
                            -- Tembak Proximity dengan Bypass
                            firePromptSafe(prompt)
                            
                            -- Tunggu api benar-benar hilang dari layar
                            local timeOut = 0
                            while prompt.Parent and timeOut < 15 do
                                task.wait(0.1)
                                timeOut = timeOut + 1
                            end
                        end
                    end
                    
                    task.wait(0.5)
                    
                    -- Selesai, kembalikan posisi secara instan!
                    hrp.Anchored = false
                    hrp.CFrame = originalCFrame
                    task.wait(1) 
                else
                    if hrp.Anchored and FireStatusLabel.Text ~= "Fire: PAUSED" then
                        hrp.Anchored = false
                    end
                    FireStatusLabel.Text = "Fire: Mencari..."
                    FireStatusLabel.TextColor3 = Color3.fromRGB(80, 200, 80)
                end
            end
        end
    end
end)

-- ==========================================
-- CORE LOGIC 2: AUTO DELETE EYEMASS
-- ==========================================
getgenv().AutoEyeLoop = task.spawn(function()
    while true do
        task.wait(Config.ScanDelay)
        if getgenv().AutoEyeIsRunning then
            local foundAndDeleted = false
            for _, pathTable in ipairs(EyeMassRooms) do
                local room = getRoomFromPath(pathTable)
                if room then
                    for _, obj in ipairs(room:GetDescendants()) do
                        if obj.Name == "EyeMass" then
                            pcall(function()
                                obj:Destroy()
                            end)
                            foundAndDeleted = true
                        end
                    end
                end
            end
            if foundAndDeleted then
                EyeStatusLabel.Text = "EyeMass: Dihapus!"
                EyeStatusLabel.TextColor3 = Color3.fromRGB(85, 255, 255)
                task.wait(0.5)
            else
                EyeStatusLabel.Text = "EyeMass: Scanning..."
                EyeStatusLabel.TextColor3 = Color3.fromRGB(80, 200, 80)
            end
        end
    end
end)
