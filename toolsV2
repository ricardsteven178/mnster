local function debugLog(message, isWarning)
    if Config.ShowConsoleLogs then
        if isWarning then warn(message) else print(message) end
    end
end

local function getRoomFromPath(pathTable)
    local current = workspace
    for _, name in ipairs(pathTable) do
        if current then current = current:FindFirstChild(name) end
    end
    return current
end

-- ==========================================
-- PROXIMITY BYPASS SECURE
-- ==========================================
local function firePromptSafe(prompt)
    if not prompt or not prompt:IsA("ProximityPrompt") then return end
    
    local oldReq = prompt.RequiresLineOfSight
    local oldDist = prompt.MaxActivationDistance
    local oldDur = prompt.HoldDuration
    
    prompt.RequiresLineOfSight = false
    prompt.MaxActivationDistance = math.huge
    prompt.HoldDuration = 0
    
    pcall(function()
        if type(fireproximityprompt) == "function" then
            fireproximityprompt(prompt, 1, true)
        else
            prompt:InputHoldBegan()
            task.wait(0.1)
            prompt:InputHoldEnded()
        end
    end)
    
    prompt.RequiresLineOfSight = oldReq
    prompt.MaxActivationDistance = oldDist
    prompt.HoldDuration = oldDur
end

