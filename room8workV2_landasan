-- [ FIX ]: Anti-Spam Console Logging
local function setStatus(text)
    StatusLabel.Text = "Status: " .. text
    if Config.ShowConsoleLogs and text ~= lastLoggedText then 
        print("[Room8-Safe] " .. text) 
        lastLoggedText = text
    end
end

local function getShiftText()
    local pGui = LocalPlayer:FindFirstChild("PlayerGui")
    if pGui then
        local shiftUI = pGui:FindFirstChild("Shift")
        if shiftUI then
            local frame = shiftUI:FindFirstChild("Frame")
            local header = frame and frame:FindFirstChild("header")
            if header and header:IsA("TextLabel") then return header.Text end
        end
    end
    return nil
end

local function updateVisualRadar(id, pos, radius, color, isVisible)
    if not isVisible then
        if _G.Room8Auto_Radars[id] then
            _G.Room8Auto_Radars[id]:Destroy()
            _G.Room8Auto_Radars[id] = nil
        end
        return
    end
    
    local radar = _G.Room8Auto_Radars[id]
    if not radar or not radar.Parent then
        radar = Instance.new("Part")
        radar.Name = "Radar_" .. id
        radar.Shape = Enum.PartType.Cylinder
        radar.Anchored = true
        radar.CanCollide = false
        radar.CanQuery = false
        radar.CastShadow = false
        radar.Material = Enum.Material.Neon
        radar.Transparency = 0.85
        radar.Color = color
        radar.Parent = workspace
        _G.Room8Auto_Radars[id] = radar
    end
    
    radar.Size = Vector3.new(0.1, radius * 2, radius * 2)
    radar.CFrame = CFrame.new(pos.X, pos.Y - 1.45, pos.Z) * CFrame.Angles(0, 0, math.rad(90))
end

