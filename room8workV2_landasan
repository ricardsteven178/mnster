    local root = char and char:FindFirstChild("HumanoidRootPart")
    local hum = char and char:FindFirstChild("Humanoid")
    local trashBin = workspace:FindFirstChild("Trash", true) 
    
    if not root or not hum or not toolToTrash or not trashBin then return false end
    
    local prompt = trashBin:FindFirstChild("PP") or trashBin:FindFirstChildWhichIsA("ProximityPrompt", true)
    if prompt then
        hum:EquipTool(toolToTrash)
        
