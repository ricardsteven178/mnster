-- MEDICAL & ROOM 8 LOGIC
-- ==========================================
local function simpleInteract(prompt, customHold)
    if prompt and prompt:IsA("ProximityPrompt") then
        local oldReq = prompt.RequiresLineOfSight
        local oldDist = prompt.MaxActivationDistance
        prompt.RequiresLineOfSight = false
        prompt.MaxActivationDistance = math.huge
        
        if type(fireproximityprompt) == "function" then fireproximityprompt(prompt, 1, true)
        else prompt:InputHoldBegan() task.wait(customHold or prompt.HoldDuration or 0.25) prompt:InputHoldEnded() end
        
        _G.Room8Auto_LastActionTick = tick() 
        prompt.RequiresLineOfSight = oldReq
        prompt.MaxActivationDistance = oldDist
        task.wait(0.25) 
    end
end

local function isRoom8Active()
    local room = workspace:FindFirstChild("Rooms") and workspace.Rooms:FindFirstChild("Emergency") and workspace.Rooms.Emergency:FindFirstChild("Room8")
    if room then
        local signLight = room:FindFirstChild("MainSign") and room.MainSign:FindFirstChild("Light")
        if signLight and signLight:IsA("BasePart") and (signLight.BrickColor.Name == "Crimson" or signLight.Color == Color3.fromRGB(165, 0, 0)) then
            if not isRoom8HealingDone(room) then return room end
        end
    end
    return nil
end

local function executeRoom8Treatment(room8, activeShift)
    local minigame = room8:FindFirstChild("Minigame")
    if not minigame or getShiftText() ~= activeShift then return end

    setStatus("--- SURGERY DIMULAI ---")
    teleportTo(Config.Room8CFrame)

    local ui = minigame:FindFirstChild("TV") and minigame.TV:FindFirstChild("Screen") and minigame.TV.Screen:FindFirstChild("UI")
    local reportFolder = ui and ui:FindFirstChild("Report")
    local treatmentText = reportFolder and reportFolder:FindFirstChild("treatment")
    local bed = minigame:FindFirstChild("Bed") and minigame.Bed:FindFirstChild("InBed")
    local bedPart = bed and (bed:IsA("BasePart") and bed or bed:FindFirstChildWhichIsA("BasePart"))

    setStatus("1/3 Menunggu fisik pasien di kasur...")
    local targetNPC = nil
    local waitNPC = 0
    while not targetNPC and waitNPC < 20 do
        if getShiftText() ~= activeShift then return end
        if workspace:FindFirstChild("NPCs") then
            for _, npc in ipairs(workspace.NPCs:GetChildren()) do
                local part = npc.PrimaryPart or npc:FindFirstChildWhichIsA("BasePart")
                if part and bedPart and (part.Position - bedPart.Position).Magnitude < 40 then
                    targetNPC = npc
                    break
                end
            end
        end
        if not targetNPC then
            task.wait(0.5)
            waitNPC = waitNPC + 1
        end
    end

    if not targetNPC then
        setStatus("BATAL: Pasien gagal sampai ke kasur.")
        return
    end

    setStatus("2/3 Menidurkan pasien...")
    local sleepPP = bed and bed:FindFirstChild("PP2")
    if sleepPP then
        simpleInteract(sleepPP, 0.25)
    end
        
    local waitLimit = 0
    while treatmentText and treatmentText.Text ~= "BEGIN SURGERY:" and waitLimit < 20 do
        _G.Room8Auto_LastActionTick = tick() 
        if isRoom8HealingDone(room8) or getShiftText() ~= activeShift then return end
        task.wait(1) 
        waitLimit = waitLimit + 1
    end

    setStatus("3/3 Mulai Apply Treatment...")
    local lastProgressTime = tick()
    local lastPendingCount = -1

    while true do
        _G.Room8Auto_LastActionTick = tick() 

        if getShiftText() ~= activeShift then setStatus("Shift berganti. Stop.") break end
        if isRoom8HealingDone(room8) then setStatus("Surgery Selesai! Layar Hijau.") break end

        local signLight = room8:FindFirstChild("MainSign") and room8.MainSign:FindFirstChild("Light")
        if not signLight or (signLight.BrickColor.Name ~= "Crimson" and signLight.Color ~= Color3.fromRGB(165, 0, 0)) then break end

        local pendingMeds = getPendingMedicinesRoom8(reportFolder)
        if #pendingMeds ~= lastPendingCount then
            lastPendingCount = #pendingMeds
            lastProgressTime = tick() 
        end

        if tick() - lastProgressTime >= Config.StuckTimeout then 
            setStatus("Local Loop Timeout. Skip.")
            break 
        end

        if #pendingMeds == 0 then
            task.wait(1)
            continue
        end

        local medsReadyToGive = {}
        for _, obat in ipairs(pendingMeds) do
            local totalInv, _ = checkTotalInventory()
            if LocalPlayer.Backpack:FindFirstChild(obat) or LocalPlayer.Character:FindFirstChild(obat) then
                table.insert(medsReadyToGive, obat)
            elseif totalInv < Config.MaxInventory then
                if fetchItem(obat) then table.insert(medsReadyToGive, obat) end
            end
        end

        if #medsReadyToGive > 0 then
            local applyPP = bed and bed:FindFirstChild("PP")
            if applyPP then
                teleportTo(Config.Room8CFrame) 
                
                for _, obat in ipairs(medsReadyToGive) do
                    local tool = LocalPlayer.Backpack:FindFirstChild(obat) or LocalPlayer.Character:FindFirstChild(obat)
                    if tool then 
                        LocalPlayer.Character.Humanoid:EquipTool(tool) 
                        task.wait(0.4)
                    end
                    
                    setStatus("Menerapkan: " .. obat)
                    simpleInteract(applyPP, 0.25) 
                end
                task.wait(1.5) 
            end
        else
            task.wait(1)
        end
    end
end

-- ==========================================
-- SAFE MAIN EXECUTOR (WORKER THREAD)
-- ==========================================
local function botCycleRoom8()
    local activeShift = getShiftText()
    
    if not activeShift then
        if not isBotIdle then -- Hanya teleport jika sebelumnya belum idle
            teleportTo(Config.IdleCFrame)
            isBotIdle = true
        end
        setStatus("Istirahat/Luar Shift...")
        task.wait(2)
        return
    end

    local room8 = isRoom8Active()
    if room8 then
        isBotIdle = false -- Bot menemukan kerjaan, status idle dibatalkan
        pcall(function() executeRoom8Treatment(room8, activeShift) end)
    else
        if not isBotIdle then -- Hanya teleport 1x jika sebelumnya tidak di posisi idle
            teleportTo(Config.IdleCFrame)
            isBotIdle = true
        end
        setStatus("Menunggu Kasus Room 8 (" .. activeShift .. ")...")
        task.wait(Config.ScanDelay)
    end
end

local function startWorkerRoom8()
    if _G.Room8Auto_Worker then task.cancel(_G.Room8Auto_Worker) end
    _G.Room8Auto_Worker = task.spawn(function()
        while autoScanEnabled do
            if not isBusy then
                isBusy = true
                _G.Room8Auto_LastActionTick = tick() 
                pcall(botCycleRoom8)
                isBusy = false
            else
                task.wait(0.5)
            end
        end
    end)
end

