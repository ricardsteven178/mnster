        if targetPart then root.CFrame = targetPart.CFrame * CFrame.new(0, 3, 0) end
        
        root.AssemblyLinearVelocity = Vector3.zero
        task.wait(Config.WaitTime)
        
        prompt.RequiresLineOfSight = false
        prompt.MaxActivationDistance = math.huge
        if type(fireproximityprompt) == "function" then fireproximityprompt(prompt, 1, true) else prompt:InputHoldBegan() task.wait(0.2) prompt:InputHoldEnded() end
        
        _G.Room8Auto_LastActionTick = tick()
