local function fetchItem(targetName)
    local rootPart = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return false end

    setStatus("Mengambil: " .. targetName)

    local totalAmount, currentItems = checkTotalInventory()
    if totalAmount >= Config.MaxInventory and #currentItems > 0 then
        local trashed = trashItem(currentItems[1])
        if not trashed then return false end 
    end

    for _, item in ipairs(workspace:GetDescendants()) do
        if item.Name == targetName then
            local prompt = item:FindFirstChild("PP") or item:FindFirstChildWhichIsA("ProximityPrompt")
            local itemPart = item:IsA("BasePart") and item or item:FindFirstChildWhichIsA("BasePart")
            
            if prompt and itemPart then
                rootPart.CFrame = itemPart.CFrame * CFrame.new(0, 3, 0)
                rootPart.AssemblyLinearVelocity = Vector3.zero
                task.wait(Config.WaitTime)
                
                prompt.RequiresLineOfSight = false
                prompt.MaxActivationDistance = math.huge
                if type(fireproximityprompt) == "function" then fireproximityprompt(prompt, 1, true) else prompt:InputHoldBegan() task.wait(0.2) prompt:InputHoldEnded() end
                
                _G.Room8Auto_LastActionTick = tick() 
                task.wait(0.3) 
                return true
            end
        end
    end
    return false
end

