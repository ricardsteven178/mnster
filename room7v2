local function isRoom7Active()
    local room7 = workspace:FindFirstChild("Rooms") and workspace.Rooms:FindFirstChild("Emergency") and workspace.Rooms.Emergency:FindFirstChild("Room7")
    if not room7 then return nil end

    local minigame = room7:FindFirstChild("Minigame")
    local bed = minigame and minigame:FindFirstChild("Bed") and minigame.Bed:FindFirstChild("InBed")
    local signLight = room7:FindFirstChild("MainSign") and room7.MainSign:FindFirstChild("Light")
    
    local hasPhysicalPatient = false
    if bed and workspace:FindFirstChild("NPCs") then
        for _, npc in ipairs(workspace.NPCs:GetChildren()) do
            local part = npc.PrimaryPart or npc:FindFirstChildWhichIsA("BasePart")
            if part and (part.Position - bed.Position).Magnitude < 15 then
                hasPhysicalPatient = true; break
            end
        end
    end

    if hasPhysicalPatient then return room7 end

    local isLightRed = signLight and (signLight.BrickColor.Name == "Crimson" or signLight.Color == Color3.fromRGB(165, 0, 0))
    if isLightRed then return room7 end

    return nil
end

local function getRoom7PendingMedicines(reportUI)
    local pending = {}
    if not reportUI then return pending end
    local invFolder = reportUI:FindFirstChild("inv", true)
    if not invFolder then return pending end
    
    for _, itemReq in ipairs(invFolder:GetChildren()) do
        if not itemReq:IsA("UIListLayout") then 
            local checkMark = itemReq:FindFirstChild("check")
            if not checkMark or (checkMark and checkMark.Visible == false) then table.insert(pending, itemReq.Name) end
        end
    end
    return pending
end

-- ==========================================
-- EKSEKUSI PINTAR (NO FALSE ALARMS)
-- ==========================================
local function executeRoom7(room7, activeShift)
    -- [1] ANTI-CULLING TELEPORT
    -- PENTING: Masuk ruangan dulu agar Server memunculkan tombol-tombol E-nya!
    local char = LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if root and (root.Position - Room7_CFrames.Step2.Position).Magnitude > 20 then
        setStatus("Proses Room 7", "Memasuki Ruangan...")
        teleport(Room7_CFrames.Step2)
        task.wait(0.5)
    end

    local minigame = room7:FindFirstChild("Minigame")
    if not minigame then return end
    local tv = minigame:FindFirstChild("TV") and minigame.TV:FindFirstChild("Screen")
    
    -- [2] CEK STATUS SELESAI
    local healingUI = tv and tv:FindFirstChild("UI") and tv.UI:FindFirstChild("Healing")
    if healingUI and healingUI.Visible == true then
        setStatus("Selesai", "Pasien Sembuh / Clear")
        return 
    end

    -- [3] CEK PRIORITAS ABSOLUT: TV MEDS (Obat Tampil di Layar TV)
    local reportUI = tv and tv:FindFirstChild("UI") and tv.UI:FindFirstChild("Report")
    local invFolder = reportUI and reportUI:FindFirstChild("inv", true)
    local tvHasMeds = (reportUI and reportUI.Visible and invFolder and #invFolder:GetChildren() > 1)
    local inBedPP = getActivePrompt(minigame, "Bed", "InBed", "PP")

    if tvHasMeds then
        local pendingMeds = getRoom7PendingMedicines(reportUI)
        if #pendingMeds > 0 then
            for _, obat in ipairs(pendingMeds) do
                local hasIt = LocalPlayer.Backpack:FindFirstChild(obat) or LocalPlayer.Character:FindFirstChild(obat)
                if not hasIt then fetchItem(obat) end
                
                teleport(Room7_CFrames.Step2)
                local tool = LocalPlayer.Backpack:FindFirstChild(obat) or LocalPlayer.Character:FindFirstChild(obat)
                if tool then 
                    LocalPlayer.Character.Humanoid:EquipTool(tool)
                    task.wait(0.2)
                    setStatus("Proses Room 7", "Menyuntikkan " .. obat)
                    if inBedPP then simpleInteract(inBedPP, 0.25) end
                    task.wait(0.5)
                end
            end
        else
            setStatus("Proses Room 7", "Obat Tercentang, Tunggu Healing...")
            if inBedPP then simpleInteract(inBedPP, 0.25) end
        end
        return -- Jangan baca tombol lain kalau lagi nyuntik obat!
    end

    -- [4] BACA SEMUA TOMBOL HARDCODED YANG SEDANG AKTIF SAAT INI
    -- Menggunakan getActivePrompt untuk memastikan tombolnya benar-benar .Enabled = true
    local pp2        = getActivePrompt(minigame, "Bed", "InBed", "PP2")
    local standIV    = getActivePrompt(minigame, "StandIV", "PP")
    local machine    = getActivePrompt(minigame, "Machine", "PP")
    local hm         = getActivePrompt(minigame, "HeartMonitor", "PP")
    local monitorPP2 = getActivePrompt(minigame, "Monitor", "PP2")
    local collectPP  = getCollectPrompt(minigame)
    
    -- [5] STATE MACHINE: Eksekusi satu-satu sesuai mana yang muncul di ruangan!
    if pp2 then
        setStatus("Proses Room 7", "Mengeksekusi: Prepare Patient")
        teleport(Room7_CFrames.Step1)
        simpleInteract(pp2, 0.25)
        
    elseif standIV then
        setStatus("Proses Room 7", "Mengeksekusi: Set Up IV")
        teleport(Room7_CFrames.Step1)
        simpleInteract(standIV, 0.5)
        
    elseif machine then
        setStatus("Proses Room 7", "Mengeksekusi: Turn On Machine")
        teleport(Room7_CFrames.Step2)
        simpleInteract(machine, 0.5)
        
    elseif hm then
        setStatus("Proses Room 7", "Mengeksekusi: Begin Minigame")
        teleport(Room7_CFrames.Step2)
        simpleInteract(hm, 0.25)
        task.wait(0.5)
        
    elseif monitorPP2 then
        setStatus("Proses Room 7", "Mengeksekusi: Process Results")
        teleport(Room7_CFrames.Step3)
        simpleInteract(monitorPP2, 0.25)
        task.wait(1)
        
    elseif collectPP then
        setStatus("Proses Room 7", "Mengeksekusi: Collect Results")
        teleport(Room7_CFrames.Step3)
        simpleInteract(collectPP, 0.5)
        task.wait(0.5)
        
    elseif inBedPP then
        -- Jika tombol Apply Treatment muncul TAPI layar TV kosong, berarti harus di-klik biar resepnya muncul!
        setStatus("Proses Room 7", "Membuka Resep TV (Apply Treatment)...")
        teleport(Room7_CFrames.Step2)
        simpleInteract(inBedPP, 0.25)
        task.wait(1)
        
    else
        -- [6] IDLE DI DALAM RUANGAN (Termasuk saat Minigame sedang berlangsung!)
        -- Karena saat minigame, semua tombol E pasti disembunyikan game (Enabled = false)
        -- Jadi script akan otomatis santai rebahan sambil nunggu background auto-clicker namatin minigamenya.
        setStatus("Proses Room 7", "Menunggu Reaksi Server / Minigame...")
        task.wait(0.5)
    end
end

