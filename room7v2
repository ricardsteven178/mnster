local function teleport(cframe)
    local char = LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if root then
        root.CFrame = cframe
        root.Velocity = Vector3.zero
        task.wait(0.2)
    end
end

local function simpleInteract(prompt, customHold)
    if prompt and prompt:IsA("ProximityPrompt") then
        local oldReq = prompt.RequiresLineOfSight
        local oldDist = prompt.MaxActivationDistance
        
        prompt.RequiresLineOfSight = false
        prompt.MaxActivationDistance = math.huge
        
        if type(fireproximityprompt) == "function" then
            fireproximityprompt(prompt, 1, true)
        else
            prompt:InputHoldBegan()
            task.wait(customHold or prompt.HoldDuration or 0.25)
            prompt:InputHoldEnded()
        end
        
        _G.AutoRoom7_LastActionTick = tick()
        prompt.RequiresLineOfSight = oldReq
        prompt.MaxActivationDistance = oldDist
        task.wait(0.2)
    end
end

local function getNilPrompt(name, class)
    if type(getnilinstances) == "function" then
        for _, v in next, getnilinstances() do
            if v.ClassName == class and v.Name == name then return v end
        end
    end
    return nil
end

local function checkTotalInventory()
    local count = 0
    local items = {} 
    local bp = LocalPlayer:FindFirstChild("Backpack")
    local char = LocalPlayer.Character
    local function process(item)
        if item:IsA("Tool") and table.find(ItemList, item.Name) then
            count = count + 1; table.insert(items, item)
        end
    end
    if bp then for _, v in ipairs(bp:GetChildren()) do process(v) end end
    if char then for _, v in ipairs(char:GetChildren()) do process(v) end end
    return count, items
end

local function trashItem(tool)
    local char = LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    local trashBin = workspace:FindFirstChild("Trash")
    if root and tool and trashBin then
        local prompt = trashBin:FindFirstChildWhichIsA("ProximityPrompt", true)
        if prompt then
            char.Humanoid:EquipTool(tool)
            task.wait(0.2)
            teleport(trashBin:IsA("Model") and trashBin.PrimaryPart.CFrame * CFrame.new(0,3,0) or trashBin:FindFirstChildWhichIsA("BasePart").CFrame * CFrame.new(0,3,0))
            simpleInteract(prompt, 0)
            return true
        end
    end
    return false
end

local function fetchItem(targetName)
    local root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not root then return false end
    setStatus(nil, "Mengambil " .. targetName)

    local total, items = checkTotalInventory()
    if total >= Config.MaxInventory and #items > 0 then trashItem(items[1]) end

    for _, item in ipairs(workspace:GetDescendants()) do
        if item.Name == targetName then
            local prompt = item:FindFirstChildWhichIsA("ProximityPrompt")
            local part = item:IsA("BasePart") and item or item:FindFirstChildWhichIsA("BasePart")
            if prompt and part then
                teleport(part.CFrame * CFrame.new(0, 3, 0))
                simpleInteract(prompt, 0)
                return true
            end
        end
    end
    return false
end

-- ==========================================
-- SMART PROMPT FINDER (Anti Disabled Prompts)
-- ==========================================
local function getActivePrompt(parent, ...)
    local current = parent
    local path = {...}
    for _, name in ipairs(path) do
        if not current then return nil end
        current = current:FindFirstChild(name)
    end
    -- Harus valid & sedang aktif/muncul di layar
    if current and current:IsA("ProximityPrompt") and current.Enabled then
        return current
    end
    return nil
end

local function getCollectPrompt(minigame)
    for _, desc in ipairs(minigame:GetDescendants()) do
        if desc:IsA("ProximityPrompt") and desc.Enabled and (desc.ActionText:match("Collect") or desc.ActionText:match("collect")) then
            return desc
        end
    end
    if type(getnilinstances) == "function" then
        for _, v in ipairs(getnilinstances()) do
            if v:IsA("ProximityPrompt") and v.Enabled and (v.ActionText:match("Collect") or v.ActionText:match("collect")) then
                return v
            end
        end
    end
    return nil
end

