        task.wait(0.3)
        HookMinigameGui(c)
    end
end))

local mgExists = PlayerGui:FindFirstChild("Minigame")
if mgExists then HookMinigameGui(mgExists) end

ToggleAutoBtn.MouseButton1Click:Connect(function()
    isAutoPlaying = not isAutoPlaying
    if isAutoPlaying then
        ToggleAutoBtn.Text = "⏸ AUTO PLAY: ON"
        ToggleAutoBtn.BackgroundColor3 = Color3.fromRGB(70, 200, 70)
        isBusy = false
        _G.AutoRoom7_LastActionTick = tick()
        local lastShift = getShiftText()
        startWorker()
        
        -- Watchdog (Anti-Stuck & Shift Reset)
        if _G.AutoRoom7_Watchdog then task.cancel(_G.AutoRoom7_Watchdog) end
        _G.AutoRoom7_Watchdog = task.spawn(function()
            while isAutoPlaying do
                task.wait(1)
                local currentShift = getShiftText()
                local isShiftChanged = (currentShift ~= lastShift and currentShift ~= nil and lastShift ~= nil)
                local isStuck = isBusy and (tick() - _G.AutoRoom7_LastActionTick > Config.GlobalStuckTimeout)

                if isShiftChanged or isStuck then
                    if isShiftChanged then setStatus("Shift Berganti!", "Resetting...")
                    else setStatus("System Stuck!", "Auto Hard-Reset...") end
                    
                    if _G.AutoRoom7_Worker then task.cancel(_G.AutoRoom7_Worker) end
                    isBusy = false
                    lastShift = currentShift
                    teleport(Config.IdleCFrame)
                    task.wait(2)
                    if isAutoPlaying then
                        _G.AutoRoom7_LastActionTick = tick()
                        startWorker()
                    end
                end
                if currentShift then lastShift = currentShift end
            end
        end)
    else
        ToggleAutoBtn.Text = "▶ AUTO PLAY: OFF"
        ToggleAutoBtn.BackgroundColor3 = Color3.fromRGB(70, 70, 70)
        if _G.AutoRoom7_Worker then task.cancel(_G.AutoRoom7_Worker) end
        if _G.AutoRoom7_Watchdog then task.cancel(_G.AutoRoom7_Watchdog) end
        setStatus("Dimatikan", "-")
    end
end)

RadarBtn.MouseButton1Click:Connect(function()
    isRadarVisible = not isRadarVisible
    if isRadarVisible then
        RadarBtn.Text = "📡 RADAR: ON"
        RadarBtn.BackgroundColor3 = Color3.fromRGB(70, 200, 70)
    else
        RadarBtn.Text = "📡 RADAR: OFF"
        RadarBtn.BackgroundColor3 = Color3.fromRGB(70, 70, 70)
        for _, radar in pairs(_G.AutoRoom7_Radars) do
            if radar then radar:Destroy() end
        end
        _G.AutoRoom7_Radars = {}
    end
end)

CloseBtn.MouseButton1Click:Connect(function()
    isAutoPlaying = false
    isRadarVisible = false
    if _G.AutoRoom7_Worker then task.cancel(_G.AutoRoom7_Worker) end
    if _G.AutoRoom7_Watchdog then task.cancel(_G.AutoRoom7_Watchdog) end
    if _G.AutoRoom7_RadarLoop then task.cancel(_G.AutoRoom7_RadarLoop) end
    for _, radar in pairs(_G.AutoRoom7_Radars) do if radar then radar:Destroy() end end
    for _, c in ipairs(minigameConnections) do pcall(function() c:Disconnect() end) end
    ScreenGui:Destroy()
end)

print("✅ Auto Room 7 Standalone (V55 Anti-Stuck & No False Alarm) Loaded!")
