-- WORKER THREAD & EVENT BINDINGS
-- ==========================================
local function startWorker()
    if _G.AutoRoom7_Worker then task.cancel(_G.AutoRoom7_Worker) end
    _G.AutoRoom7_Worker = task.spawn(function()
        while isAutoPlaying do
            if not isBusy then
                isBusy = true
                _G.AutoRoom7_LastActionTick = tick()
                
                local activeShift = getShiftText()
                if not activeShift then
                    setStatus("Menunggu shift dimulai...", "-")
                    teleport(Config.IdleCFrame)
                    task.wait(2)
                else
                    local activeRoom = isRoom7Active()
                    if activeRoom then
                        pcall(function() executeRoom7(activeRoom, activeShift) end)
                    else
                        setStatus("Standby", "Menunggu Room 7 Aktif...")
                        teleport(Config.IdleCFrame)
                        task.wait(Config.ScanDelay)
                    end
                end
                isBusy = false
            else
                task.wait(0.5)
            end
        end
    end)
end

