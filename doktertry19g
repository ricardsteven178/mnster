local function turboSafeEquip(itemName)
    local char = LocalPlayer.Character
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    local hum = char and char:FindFirstChild("Humanoid")
    if not char or not backpack or not hum then return false end

    if char:FindFirstChild(itemName) then return true end

    hum:UnequipTools()
    local t1 = 0
    while char:FindFirstChildOfClass("Tool") and t1 < 10 do
        task.wait(0.05)
        t1 = t1 + 1
    end

    local tool = backpack:FindFirstChild(itemName) or char:FindFirstChild(itemName)
    if not tool then return false end

    hum:EquipTool(tool)
    local t2 = 0
    while not char:FindFirstChild(itemName) and t2 < 15 do
        task.wait(0.05)
        t2 = t2 + 1
    end

    task.wait(0.05)
    return char:FindFirstChild(itemName) ~= nil
end

local function firePromptRaw(prompt)
    if not prompt or not prompt:IsA("ProximityPrompt") then return end
    
    local oldReq = prompt.RequiresLineOfSight
    local oldDist = prompt.MaxActivationDistance
    prompt.RequiresLineOfSight = false
    prompt.MaxActivationDistance = math.huge
    
    if type(fireproximityprompt) == "function" then
        fireproximityprompt(prompt, 1, true)
    else
        prompt:InputHoldBegan()
        task.wait(prompt.HoldDuration > 0 and prompt.HoldDuration or 0.2)
        prompt:InputHoldEnded()
    end
    
    prompt.RequiresLineOfSight = oldReq
    prompt.MaxActivationDistance = oldDist
    _G.AutoDoctor_LastActionTick = tick()
end

local function teleportToTarget(target)
    local char = LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root or not target then return end

    local posToTP = nil
    if typeof(target) == "CFrame" then posToTP = target.Position
    elseif typeof(target) == "Vector3" then posToTP = target
    elseif target:IsA("BasePart") then posToTP = target.Position
    elseif target:IsA("Model") then
        local p = target.PrimaryPart or target:FindFirstChildWhichIsA("BasePart", true)
        if p then posToTP = p.Position end
    elseif target:IsA("Attachment") then posToTP = target.WorldPosition
    elseif target:IsA("ProximityPrompt") then
        local parent = target.Parent
        if parent then
            if parent:IsA("Attachment") then posToTP = parent.WorldPosition
            elseif parent:IsA("BasePart") then posToTP = parent.Position
            elseif parent:IsA("Model") then
                local pt = parent.PrimaryPart or parent:FindFirstChildWhichIsA("BasePart", true)
                if pt then posToTP = pt.Position end
            end
        end
    end

    if posToTP then
        root.CFrame = CFrame.new(posToTP + Vector3.new(0, 3, 0))
        root.AssemblyLinearVelocity = Vector3.zero
        task.wait(0.2)
    end
end

local function teleportToRoomCenter(roomNum, roomPath)
    local root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not root then return end

    -- [ FIX ]: Gunakan CFrame akurat yang ada di list agar jarak dengan kasur pas!
    if RoomCFrames[roomNum] then
        root.CFrame = RoomCFrames[roomNum]
        root.AssemblyLinearVelocity = Vector3.zero
        task.wait(0.2)
        return
    end

    if roomPath then
        local minigame = roomPath:FindFirstChild("Minigame")
        local target = minigame and (minigame:FindFirstChild("Bed") or minigame:FindFirstChild("Scanner") or minigame:FindFirstChild("MRI") or minigame:FindFirstChildWhichIsA("Model"))
        local pos = target and (target:IsA("Model") and (target.PrimaryPart and target.PrimaryPart.Position or target:FindFirstChildWhichIsA("BasePart").Position) or target.Position)
        
        if not pos and roomPath.PrimaryPart then pos = roomPath.PrimaryPart.Position end
        
        if pos then 
            root.CFrame = CFrame.new(pos + Vector3.new(0, 3, 0)) 
            root.AssemblyLinearVelocity = Vector3.zero
            task.wait(0.2)
        end
    end
end

