local function getPendingMedicines(activeUI)
    local pending = {}
    if not activeUI then return pending end
    local invFolder = activeUI:FindFirstChild("inv", true)
    if not invFolder then return pending end

    for _, itemReq in ipairs(invFolder:GetChildren()) do
        if table.find(ItemList, itemReq.Name) then
            local checkMark = itemReq:FindFirstChild("check")
            if not checkMark or (checkMark and checkMark.Visible == false) then
                table.insert(pending, itemReq.Name)
            end
        end
    end
    return pending
end

local function getPromptsNearCenter(roomNum, roomPath)
    local prompts = {}
    if not roomPath then return prompts end

    local minigame = roomPath:FindFirstChild("Minigame")
    if minigame then
        for _, desc in ipairs(minigame:GetDescendants()) do
            if desc:IsA("ProximityPrompt") and desc.Enabled then
                table.insert(prompts, desc)
            end
        end
    end

    local centerPos = RoomCFrames[roomNum] and RoomCFrames[roomNum].Position
    if centerPos and workspace:FindFirstChild("NPCs") then
        for _, npc in ipairs(workspace.NPCs:GetChildren()) do
            local p = npc.PrimaryPart or npc:FindFirstChildWhichIsA("BasePart")
            if p and (p.Position - centerPos).Magnitude <= Config.PatientBedRadius then
                for _, desc in ipairs(npc:GetDescendants()) do
                    if desc:IsA("ProximityPrompt") and desc.Enabled then
                        table.insert(prompts, desc)
                    end
                end
            end
        end
    end

    return prompts
end

local function isPatientReady(roomPath, roomNum)
    local minigame = roomPath:FindFirstChild("Minigame")
    local activeUI = getActiveUI(minigame)

    local pending = getPendingMedicines(activeUI)
    if #pending > 0 then return true, "Layar Aktif (Butuh Obat)" end

    local prompts = getPromptsNearCenter(roomNum, roomPath)
    for _, desc in ipairs(prompts) do
        local actText = string.lower(desc.ActionText or "")
        local name = string.lower(desc.Name or "")

        if actText:match("inspect") then
            -- Skip inspect
        elseif actText:match("dna") or name:match("dna") then
            return true, "Tombol DNA"
        elseif actText:match("burns") or name == "firepp" then
            return true, "Tombol Luka Bakar"
        elseif actText:match("analyze") or actText:match("process") or name:match("analyze") then
            return true, "Mesin Lab"
        elseif roomNum == 6 or roomNum == 7 then
            if actText:match("x%-ray") or actText:match("prepare") or actText:match("collect") or name == "pp2" then
                return true, "Emergency Bypass"
            end
        end
    end

    return false, "Kosong/Healing"
end

local function getPatientInRoom(roomNum, roomPath)
    local centerPos = RoomCFrames[roomNum] and RoomCFrames[roomNum].Position
    if not centerPos then return nil end

    local function checkNPC(obj)
        if Players:GetPlayerFromCharacter(obj) then return nil end
        local part = obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")
        if part and (part.Position - centerPos).Magnitude <= Config.PatientBedRadius then
            local isRealPatient = false
            for _, pp in ipairs(obj:GetDescendants()) do
                if pp:IsA("ProximityPrompt") then
                    local txt = string.lower(pp.ActionText or "")
                    if txt:match("dna") or txt:match("treat") or pp.Name == "FirePP" then
                        isRealPatient = true
                        break
                    end
                end
            end
            if isRealPatient then return obj end
        end
        return nil
    end

    if workspace:FindFirstChild("NPCs") then
        for _, npc in ipairs(workspace.NPCs:GetChildren()) do
            local found = checkNPC(npc)
            if found then return found end
        end
    end

    return nil
end

local function isHealingDone(minigame)
    if not minigame then return false end
    local activeUI = getActiveUI(minigame)
    if not activeUI then return false end
    
    local ui = activeUI:FindFirstChild("UI")
    local healing = ui and ui:FindFirstChild("Healing")

    if healing and healing:IsA("GuiObject") and healing.Visible == true then
        -- Cek bug visual: Masih ada obat?
        local pending = getPendingMedicines(activeUI)
        if #pending > 0 then return false end 
        
        -- LULUS SEMUA CEK. CABUT!
        return true
    end
    return false
end

local function checkAnomalyStatus(roomNum, roomPath)
    local centerPos = RoomCFrames[roomNum] and RoomCFrames[roomNum].Position
    if not centerPos then return false end

    if workspace:FindFirstChild("NPCs") then
        for _, npc in ipairs(workspace.NPCs:GetChildren()) do
            local p = npc.PrimaryPart or npc:FindFirstChildWhichIsA("BasePart")
            if p and (p.Position - centerPos).Magnitude <= Config.PatientBedRadius then
                local attr = npc:GetAttributes()
                if attr.Skinwalker or attr.SkinwalkerEasy or attr.PenaltyWhenLettingIn or attr.PhotoEffect == "CursedPhoto" or attr.PhotoEffect2 == "CursedPhoto" then
                    return true
                end
            end
        end
    end
    return false
end

local function printRadarReport()
    if not Config.ShowConsoleLogs then return end
    local report = "[RADAR] Live Scan: "
    local roomsFolder = workspace:FindFirstChild("Rooms")
    
    for i = 1, 8 do
        local room = nil
        if i <= 5 then
            room = roomsFolder and roomsFolder:FindFirstChild("Medical") and roomsFolder.Medical:FindFirstChild("Room"..i)
        else
            room = roomsFolder and roomsFolder:FindFirstChild("Emergency") and roomsFolder.Emergency:FindFirstChild("Room"..i)
        end
        
        local status = "[-]"
        if room then
            local minigame = room:FindFirstChild("Minigame")
            local isBlacklisted = BuggedRoomBlacklist[i] and (tick() - BuggedRoomBlacklist[i] < Config.BlacklistDuration)
            local isHealing = isHealingDone(minigame)
            local ready, reason = isPatientReady(room, i)

            if ready and not isHealing then
                _G.AutoDoctor_RoomMemory[i] = nil
                status = "[" .. reason .. "]"
            elseif isBlacklisted then
                status = "[BLACKLIST]"
            elseif _G.AutoDoctor_RoomMemory[i] == "PatientLeaving" then
                status = "[MEMORI: Pasien Keluar]"
            elseif isHealing then
                status = "[HEALING]"
            else
                local signLight = room:FindFirstChild("MainSign") and room.MainSign:FindFirstChild("Light")
                local isLightRed = signLight and (signLight.BrickColor.Name == "Crimson" or signLight.Color == Color3.fromRGB(165, 0, 0))
                if isLightRed then
                    status = "[AKTIF: Pasien Menuju]"
                else
                    status = "[Kosong]"
                end
            end
        end
        report = report .. "R" .. i .. ":" .. status .. " "
    end

    if _G.LastRadarReport ~= report then
        _G.LastRadarReport = report
        local timeStamp = os.date("%H:%M:%S")
        print("[" .. timeStamp .. "] [Auto-Doctor] " .. report)
    end
end

