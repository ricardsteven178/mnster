local function findActiveRoom()
    local roomsFolder = workspace:FindFirstChild("Rooms")
    if not roomsFolder then return nil, nil end

    for i = 1, 8 do
        local room = nil
        if i <= 5 then
            room = roomsFolder:FindFirstChild("Medical") and roomsFolder.Medical:FindFirstChild("Room" .. i)
        else
            room = roomsFolder:FindFirstChild("Emergency") and roomsFolder.Emergency:FindFirstChild("Room" .. i)
        end
        
        if room then
            local isBlacklisted = BuggedRoomBlacklist[i] and (tick() - BuggedRoomBlacklist[i] < Config.BlacklistDuration)
            if not isBlacklisted then
                local minigame = room:FindFirstChild("Minigame")
                
                if i == 8 then
                    local signLight = room:FindFirstChild("MainSign") and room.MainSign:FindFirstChild("Light")
                    local isLightRed = signLight and (signLight.BrickColor.Name == "Crimson" or signLight.Color == Color3.fromRGB(165, 0, 0))
                    if isLightRed and not isHealingDone(minigame) then
                        return room, i
                    end
                else
                    local ready, reason = isPatientReady(room, i)
                    local isHealing = isHealingDone(minigame)

                    if ready and not isHealing then
                        _G.AutoDoctor_RoomMemory[i] = nil
                        if Config.ShowConsoleLogs then print("[RADAR] ➔ Target Dikunci: " .. room.Name .. " (" .. reason .. ")") end
                        return room, i
                    end

                    local signLight = room:FindFirstChild("MainSign") and room.MainSign:FindFirstChild("Light")
                    local isLightRed = signLight and (signLight.BrickColor.Name == "Crimson" or signLight.Color == Color3.fromRGB(165, 0, 0))

                    if not isLightRed and _G.AutoDoctor_RoomMemory[i] == "PatientLeaving" then
                        _G.AutoDoctor_RoomMemory[i] = nil
                    end
                end
            end
        end
    end

    return nil, nil
end

-- ==========================================
-- THE ULTIMATE TREATMENT ENGINE (R1-R7)
-- ==========================================
local function executeTreatmentCore(roomPath, roomNum, activeShift)
    local minigame = roomPath:FindFirstChild("Minigame")
    if not minigame then return end

    setStatus("--- MEMULAI PENGOBATAN: " .. roomPath.Name .. " ---")
    teleportToRoomCenter(roomNum, roomPath)

    local lastProgressTime = tick()

    while true do
        task.wait(0.1)

        if getShiftText() ~= activeShift then
            setStatus("Shift berganti! Membatalkan pengobatan.")
            break
        end

        if getFireEmergency() or getPlacePatientPrompt() or getFaintedPatient() then
            setStatus("INTERUPSI DARURAT! Pindah Prioritas...")
            break
        end

        local currentPatient = getPatientInRoom(roomNum, roomPath)
        if not currentPatient then
            local signLight = roomPath:FindFirstChild("MainSign") and roomPath.MainSign:FindFirstChild("Light")
            local isLightRed = signLight and (signLight.BrickColor.Name == "Crimson" or signLight.Color == Color3.fromRGB(165, 0, 0))

            if isLightRed then
                setStatus("Pasien sedang berjalan ke kasur/mesin... Menunggu.")
                task.wait(1)
            else
                setStatus("Kamar kosong / Ghost Prompt! Skip.")
                BuggedRoomBlacklist[roomNum] = tick()
                break
            end
        end

        -- [ INSTANT MOVE-ON ]: Jika sudah dipastikan 100% healing, langsung cabut dari ruangan!
        if isHealingDone(minigame) then
            setStatus("Pasien Sembuh! Lanjut ke ruangan lain...")
            _G.AutoDoctor_RoomMemory[roomNum] = "PatientLeaving"
            break
        end

        if tick() - lastProgressTime >= Config.StuckTimeout then
            setStatus("Timeout! Skip ruangan.")
            BuggedRoomBlacklist[roomNum] = tick()
            break
        end

        local activeUI = getActiveUI(minigame)
        local pendingMeds = getPendingMedicines(activeUI)

        local hasTasks, reason = isPatientReady(roomPath, roomNum)

        if hasTasks then
            if reason == "Layar Aktif (Butuh Obat)" then
                local patientIsAnomaly = checkAnomalyStatus(roomNum, roomPath)

                if patientIsAnomaly then
                    local prescribedMeds = {}
                    if activeUI then
                        local tvInv = activeUI:FindFirstChild("inv", true)
                        if tvInv then
                            for _, req in ipairs(tvInv:GetChildren()) do
                                if table.find(ItemList, req.Name) then table.insert(prescribedMeds, req.Name) end
                            end
                        end
                    end

                    local wrongMedicine = nil
                    for _, item in ipairs(ItemList) do
                        if not table.find(prescribedMeds, item) then
                            local p = getPromptFromCache(item, false)
                            if p then wrongMedicine = item; break end
                        end
                    end
                    if not wrongMedicine then wrongMedicine = "Medicine" end

                    local hasIt = LocalPlayer.Backpack:FindFirstChild(wrongMedicine) or LocalPlayer.Character:FindFirstChild(wrongMedicine)
                    if not hasIt then fetchItem(wrongMedicine, {wrongMedicine}) end

                    local applyPP = getApplyPrompt(minigame, roomNum, roomPath)
                    if applyPP then
                        teleportToRoomCenter(roomNum, roomPath)
                        if turboSafeEquip(wrongMedicine) then
                            local activeTool = LocalPlayer.Character:FindFirstChildOfClass("Tool")
                            if activeTool and activeTool.Name == wrongMedicine then
                                setStatus("MENYUNTIKKAN RACUN: " .. wrongMedicine)
                                -- [PENTING]: autoLock = false agar bot tidak terpental/menabrak pasien
                                simpleInteract(applyPP, 0.1, false) 
                                lastProgressTime = tick()
                                task.wait(2)

                                setStatus("--- ANOMALI HANGUS! Menyimpan ke memori... ---")
                                _G.AutoDoctor_RoomMemory[roomNum] = "PatientLeaving"
                                break
                            end
                        else
                            setStatus("FAILSAFE: Gagal pegang racun. Server Lag.")
                        end
                    end
                else
                    if #pendingMeds > 0 then
                        local reqCounts = {}
                        for _, obat in ipairs(pendingMeds) do reqCounts[obat] = (reqCounts[obat] or 0) + 1 end

                        setStatus("FETCH PHASE: Mengumpulkan semua obat...")
                        for obat, needed in pairs(reqCounts) do
                            local haveCount = 0
                            local bp = LocalPlayer:FindFirstChild("Backpack")
                            local ch = LocalPlayer.Character
                            if bp then for _, v in ipairs(bp:GetChildren()) do if v:IsA("Tool") and v.Name == obat then haveCount = haveCount + 1 end end end
                            if ch then for _, v in ipairs(ch:GetChildren()) do if v:IsA("Tool") and v.Name == obat then haveCount = haveCount + 1 end end end

                            for _ = 1, math.max(0, needed - haveCount) do
                                setStatus("Fetch " .. obat .. " (" .. haveCount .. "/" .. needed .. ")...")
                                fetchItem(obat, pendingMeds)
                                haveCount = haveCount + 1
                            end
                        end

                        setStatus("INJECT PHASE: Semua obat siap, menuju pasien...")
                        local applyPP = getApplyPrompt(minigame, roomNum, roomPath)
                        if not applyPP then
                            setStatus("GAGAL: PP bed/alat tidak ditemukan!")
                        else
                            teleportToRoomCenter(roomNum, roomPath)
                            task.wait(0.15)

                            local injectAttempts = 0
                            while injectAttempts < 20 do
                                if getShiftText() ~= activeShift then break end

                                local freshPending = getPendingMedicines(activeUI)
                                if #freshPending == 0 then
                                    setStatus("Semua obat sudah dicentang TV! Menunggu Healing...")
                                    lastProgressTime = tick()
                                    break
                                end

                                local nextObat = freshPending[1]

                                local hasInBag = LocalPlayer.Backpack:FindFirstChild(nextObat)
                                    or LocalPlayer.Character:FindFirstChild(nextObat)

                                if not hasInBag then
                                    setStatus("EDGE CASE: " .. nextObat .. " gak ada, fetch ulang...")
                                    fetchItem(nextObat, freshPending)
                                    local ev = 0
                                    while ev < 30 do
                                        task.wait(0.05)
                                        if LocalPlayer.Backpack:FindFirstChild(nextObat) or LocalPlayer.Character:FindFirstChild(nextObat) then break end
                                        ev = ev + 1
                                        _G.AutoDoctor_LastActionTick = tick()
                                    end
                                    teleportToRoomCenter(roomNum, roomPath)
                                    task.wait(0.15)
                                end

                                if turboSafeEquip(nextObat) then
                                    local activeTool = LocalPlayer.Character:FindFirstChildOfClass("Tool")
                                    if activeTool and activeTool.Name == nextObat then
                                        setStatus("Suntik: " .. nextObat .. " (" .. #freshPending .. " sisa)")
                                        -- [PENTING]: autoLock = false agar bot tidak menabrak pasien saat nyuntik R6/R7
                                        simpleInteract(applyPP, 0.1, false)
                                        lastProgressTime = tick()

                                        local verifyInject = 0
                                        local prevCount = #freshPending
                                        while verifyInject < 40 do
                                            task.wait(0.05)
                                            local afterPending = getPendingMedicines(activeUI)
                                            if #afterPending < prevCount then
                                                setStatus("TV Confirm: " .. nextObat .. " berhasil masuk!")
                                                lastProgressTime = tick()
                                                break
                                            end
                                            if isHealingDone(minigame) then break end
                                            if getShiftText() ~= activeShift then break end
                                            verifyInject = verifyInject + 1
                                            _G.AutoDoctor_LastActionTick = tick()
                                        end
                                    end
                                else
                                    setStatus("FAILSAFE: Gagal equip " .. nextObat .. ". Server lag, retry...")
                                    task.wait(0.3)
                                end

                                injectAttempts = injectAttempts + 1
                                task.wait(0.05)
                            end
                        end
                    end
                end
            else
                local acted = false
                local prompts = getPromptsNearCenter(roomNum, roomPath)

                local handledBurn = false
                for _, desc in ipairs(prompts) do
                    local actText = string.lower(desc.ActionText or "")
                    local name = string.lower(desc.Name or "")

                    if name == "firepp" or actText:match("burns") then
                        local hasOintment = LocalPlayer.Backpack:FindFirstChild("Ointment") or LocalPlayer.Character:FindFirstChild("Ointment")
                        if not hasOintment then fetchItem("Ointment", {"Ointment"}) end

                        teleportToRoomCenter(roomNum, roomPath)
                        if turboSafeEquip("Ointment") then
                            local activeTool = LocalPlayer.Character:FindFirstChildOfClass("Tool")
                            if activeTool and activeTool.Name == "Ointment" then
                                setStatus("Mengoleskan Ointment (Treat Burns)...")
                                simpleInteract(desc, 3, false)
                                handledBurn = true
                                break
                            end
                        else
                            setStatus("Menunggu Ointment (Server Lag)...")
                        end
                    end
                end

                if not handledBurn then
                    local monitor = minigame:FindFirstChild("Monitor")
                    
                    local pp2_obj = monitor and monitor:FindFirstChild("PP2")
                    local actualPP2 = nil
                    if pp2_obj then
                        if pp2_obj:IsA("ProximityPrompt") then
                            actualPP2 = pp2_obj
                        else
                            actualPP2 = pp2_obj:FindFirstChildOfClass("ProximityPrompt")
                        end
                    end
                    if not actualPP2 then
                        actualPP2 = getNil("PP2", "ProximityPrompt")
                    end

                    if actualPP2 then
                        if roomNum == 6 or roomNum == 7 then
                            -- ===============================================
                            -- [ FIX: BYPASS R6/R7 - DINAMIS COLLECT PROMPT ]
                            -- ===============================================
                            unequipAll()
                            teleportToRoomCenter(roomNum, roomPath)
                            task.wait(0.5)

                            setStatus("BYPASS EMERG: Memaksa Monitor (PP2)...")
                            firePromptRaw(actualPP2)
                            task.wait(1.5)

                            local collectPP = nil
                            local waitPrinter = 0
                            
                            while waitPrinter < 20 do
                                setStatus("Menunggu Printer Ready...")
                                -- Dynamic Scan untuk mencari tulisan "Collect" di seluruh ruangan
                                for _, pp in ipairs(minigame:GetDescendants()) do
                                    if pp:IsA("ProximityPrompt") and pp.Enabled and string.match(string.lower(pp.ActionText or ""), "collect") then
                                        collectPP = pp
                                        break
                                    end
                                end
                                if collectPP then break end
                                
                                -- Fallback ke nama getNil("PP")
                                local pPP = getNil("PP", "ProximityPrompt")
                                if pPP and pPP.Enabled then collectPP = pPP; break end
                                
                                task.wait(0.2)
                                waitPrinter = waitPrinter + 1
                            end
                            
                            if collectPP then
                                setStatus("BYPASS EMERG: Mengambil Hasil (Collect)...")
                                firePromptRaw(collectPP)
                                task.wait(0.5)
                            end
                            
                            acted = true
                        else
                            -- ===============================================
                            -- MEDICAL ROOMS (ROOM 1-5) BYPASS LOGIC
                            -- ===============================================
                            local monitorScreen = monitor:FindFirstChild("Screen")
                            local monitorUI = monitorScreen and monitorScreen:FindFirstChild("UI")
                            local isMonitorBusy = false

                            if monitorUI and (monitorUI.Enabled or (monitorUI:FindFirstChild("Report") and monitorUI.Report.Visible)) then
                                isMonitorBusy = true
                            end
                            if monitorScreen then
                                for _, desc in ipairs(monitorScreen:GetDescendants()) do
                                    if desc:IsA("TextLabel") and desc.Name == "header" and string.match(desc.Text, "Finalizing") then
                                        isMonitorBusy = true
                                        break
                                    end
                                end
                            end

                            local tvScreen = minigame:FindFirstChild("TV") and minigame.TV:FindFirstChild("Screen")
                            local activeTvUI = tvScreen and tvScreen:FindFirstChild("UI")
                            local isTVBusy = false
                            if activeTvUI and activeTvUI:IsA("SurfaceGui") and activeTvUI.Enabled then
                                isTVBusy = true
                            end

                            if isMonitorBusy or isTVBusy then
                                setStatus("Menunggu Data Lab/TV diproses...")
                                task.wait(1)
                                acted = true
                            else
                                unequipAll()
                                teleportToRoomCenter(roomNum, roomPath)
                                task.wait(0.5)

                                setStatus("BYPASS MEDICAL: Memaksa Process Results...")
                                local bypassSuccess = false

                                for retry = 1, 3 do
                                    firePromptRaw(actualPP2)
                                    task.wait(0.5)

                                    local cekMonitorScreen = monitor:FindFirstChild("Screen")
                                    if cekMonitorScreen then
                                        local ui = cekMonitorScreen:FindFirstChild("UI")
                                        if ui and ui:IsA("SurfaceGui") and ui.Enabled then
                                            bypassSuccess = true
                                        elseif ui and ui:FindFirstChild("Report") and ui.Report.Visible then
                                            bypassSuccess = true
                                        else
                                            for _, desc in ipairs(cekMonitorScreen:GetDescendants()) do
                                                if desc:IsA("TextLabel") and desc.Name == "header" and string.match(desc.Text, "Finalizing") then
                                                    bypassSuccess = true
                                                    break
                                                end
                                            end
                                        end
                                    end

                                    if bypassSuccess then break end
                                    setStatus("Bypass meleset! Mencoba ulang (" .. retry .. "/3)...")
                                end

                                if bypassSuccess then
                                    setStatus("Bypass Berhasil! Data diproses.")
                                else
                                    setStatus("GAGAL Bypass: Tidak ada respon dari Monitor.")
                                end
                                acted = true
                            end
                        end
                    else
                        setStatus("Menunggu Monitor Siap...")
                        acted = false
                    end
                else
                    acted = true
                end

                if acted then 
                    lastProgressTime = tick() 
                    task.wait(0.5) 
                end
            end
        else
            task.wait(1)
        end
    end
end

-- ==========================================
-- ROOM 8 SURGERY TREATMENT (STANDALONE LOGIC)
-- ==========================================
local function executeRoom8Treatment(room8, activeShift)
    local minigame = room8:FindFirstChild("Minigame")
    if not minigame or getShiftText() ~= activeShift then return end

    setStatus("--- ROOM 8: TURBO SURGERY ---")
    local root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if root then
        root.CFrame = Config.Room8BedCFrame
        root.AssemblyLinearVelocity = Vector3.zero
    end

    local tvUI = minigame:FindFirstChild("TV") and minigame.TV:FindFirstChild("Screen") and minigame.TV.Screen:FindFirstChild("UI")
    local reportFolder = tvUI and tvUI:FindFirstChild("Report")
    local treatmentText = reportFolder and reportFolder:FindFirstChild("treatment")
    local bed = minigame:FindFirstChild("Bed") and minigame.Bed:FindFirstChild("InBed")

    setStatus("R8: Menunggu pasien...")
    local waitNPC = 0
    while waitNPC < 30 do
        if getShiftText() ~= activeShift then return end
        
        if getFireEmergency() or getPlacePatientPrompt() or getFaintedPatient() then
            setStatus("INTERUPSI DARURAT! Pindah Prioritas...")
            return
        end
        
        if workspace:FindFirstChild("NPCs") then
            for _, npc in ipairs(workspace.NPCs:GetChildren()) do
                local part = npc.PrimaryPart or npc:FindFirstChildWhichIsA("BasePart")
                if part and (part.Position - Config.Room8BedCFrame.Position).Magnitude < Config.PatientBedRadius then
                    waitNPC = 999; break
                end
            end
        end
        if waitNPC ~= 999 then 
            task.wait(0.5)
            waitNPC = waitNPC + 1
            _G.AutoDoctor_LastActionTick = tick() 
        end
    end

    if waitNPC ~= 999 and waitNPC >= 30 then 
        setStatus("BATAL R8: Pasien gagal sampai.")
        return 
    end

    setStatus("R8: Menidurkan pasien...")
    local sleepLimit = 0
    while treatmentText and treatmentText.Text ~= "BEGIN SURGERY:" and sleepLimit < 40 do
        if isHealingDone(minigame) or getShiftText() ~= activeShift then return end
        if getFireEmergency() or getPlacePatientPrompt() or getFaintedPatient() then return end
        
        local sleepPP = bed and bed:FindFirstChild("PP2")
        if sleepPP and sleepPP.Enabled then 
            simpleInteract(sleepPP, 0.1, false) 
        end
        _G.AutoDoctor_LastActionTick = tick()
        task.wait(0.2)
        sleepLimit = sleepLimit + 1
    end

    setStatus("R8: Mulai Treatment Loop...")
    local lastProgressTime = tick()

    while true do
        task.wait(0.05)
        _G.AutoDoctor_LastActionTick = tick()
        
        if getShiftText() ~= activeShift then 
            setStatus("Shift berganti. Stop.")
            break 
        end
        
        if getFireEmergency() or getPlacePatientPrompt() or getFaintedPatient() then
            setStatus("INTERUPSI DARURAT! Pindah Prioritas...")
            break
        end
        
        if isHealingDone(minigame) then 
            setStatus("R8: Surgery Selesai!")
            break 
        end
        
        local signLight = room8:FindFirstChild("MainSign") and room8.MainSign:FindFirstChild("Light")
        if not signLight or (signLight.BrickColor.Name ~= "Crimson" and signLight.Color ~= Color3.fromRGB(165, 0, 0)) then 
            break 
        end
        
        if tick() - lastProgressTime >= Config.StuckTimeout then 
            setStatus("R8: Timeout! Skip.")
            break 
        end

        local pendingMeds = getPendingMedicines(reportFolder)
        
        if checkAnomalyStatus(8, room8) and #pendingMeds > 0 then
            local wrongMedicine = "Medicine"
            for _, item in ipairs(ItemList) do
                if not table.find(pendingMeds, item) then 
                    wrongMedicine = item
                    break 
                end
            end
            
            local hasIt = LocalPlayer.Backpack:FindFirstChild(wrongMedicine) or LocalPlayer.Character:FindFirstChild(wrongMedicine)
            if not hasIt then 
                fetchItem(wrongMedicine, {wrongMedicine}) 
            end
            
            if root then 
                root.CFrame = Config.Room8BedCFrame
                root.AssemblyLinearVelocity = Vector3.zero
                task.wait(0.1) 
            end
            
            if turboSafeEquip(wrongMedicine) then
                setStatus("R8: MENYUNTIKKAN RACUN: " .. wrongMedicine)
                simpleInteract(bed.PP, 0.1, false)
                lastProgressTime = tick()
                task.wait(1.5)
                setStatus("R8: ANOMALI HANGUS!")
                break
            end
            
        elseif #pendingMeds > 0 then
            local reqCounts = {}
            local _, currentItems = checkTotalInventory()
            local haveCounts = {}
            
            for _, obat in ipairs(pendingMeds) do 
                reqCounts[obat] = (reqCounts[obat] or 0) + 1 
            end
            for _, item in ipairs(currentItems) do 
                haveCounts[item.Name] = (haveCounts[item.Name] or 0) + 1 
            end
            
            for obat, needed in pairs(reqCounts) do
                local have = haveCounts[obat] or 0
                for _ = 1, math.max(0, needed - have) do 
                    fetchItem(obat, pendingMeds) 
                end
            end
            
            if root then 
                root.CFrame = Config.Room8BedCFrame
                root.AssemblyLinearVelocity = Vector3.zero
                task.wait(0.1) 
            end
            
            local obatToInject = pendingMeds[1]
            local hasItNow = LocalPlayer.Backpack:FindFirstChild(obatToInject) or LocalPlayer.Character:FindFirstChild(obatToInject)
            
            if hasItNow and bed and bed:FindFirstChild("PP") then
                if turboSafeEquip(obatToInject) then
                    task.wait(0.1)
                    local prevCount = #pendingMeds
                    setStatus("R8: Apply: " .. obatToInject)
                    simpleInteract(bed.PP, 0.1, false)
                    lastProgressTime = tick()
                    
                    local wc = 0
                    while wc < 30 do
                        if #getPendingMedicines(reportFolder) < prevCount then break end
                        if isHealingDone(minigame) or getShiftText() ~= activeShift then break end
                        task.wait(0.05)
                        wc = wc + 1
                        _G.AutoDoctor_LastActionTick = tick()
                    end
                else
                    setStatus("R8: FAILSAFE equip " .. obatToInject)
                    task.wait(0.5)
                end
            else
                setStatus("R8: Retry fetch " .. obatToInject)
                task.wait(0.5)
            end
        end
    end
end

-- ==========================================
-- SAFE MAIN EXECUTOR (WORKER THREAD)
-- ==========================================
local function botCycle()
    local activeShift = getShiftText()
    local fireNPC, firePP = getFireEmergency()
    if fireNPC then
        _G.AutoDoctor_IsIdle = false
        pcall(function()
            unequipAll()
            local targetNode = fireNPC.PrimaryPart or fireNPC:FindFirstChildWhichIsA("BasePart")
            setStatus("! PRIORITAS 1: Memadamkan Pasien Terbakar !")
            simpleInteract(firePP, 3.2, false)
            task.wait(1.5)
        end)
        return
    end

    local placePrompt, targetRoomName, _, _ = getPlacePatientPrompt()
    if placePrompt then
        _G.AutoDoctor_IsIdle = false
        pcall(function()
            -- [ FITUR 4: ANTI-DROP FAINT ] 
            setStatus("Membawa pasien pingsan ke " .. tostring(targetRoomName) .. "...")
            teleportToTarget(placePrompt)
            task.wait(0.3)
            setStatus("Meletakkan di kasur...")
            simpleInteract(placePrompt, 1, false)
            task.wait(1.5)
        end)
        return
    end

    local faintedPart, carryPP = getFaintedPatient()
    if faintedPart then
        _G.AutoDoctor_IsIdle = false
        pcall(function() 
            setStatus("! PRIORITAS 2: Menggendong Pasien Pingsan !")
            unequipAll()
            teleportToTarget(faintedPart.PrimaryPart or faintedPart:FindFirstChildWhichIsA("BasePart"))
            simpleInteract(carryPP, 0, false)
            task.wait(1.5)
        end)
        return
    end

    local room, roomNum = findActiveRoom()
    if room and roomNum then
        _G.AutoDoctor_IsIdle = false
        if roomNum == 8 then
            pcall(function() executeRoom8Treatment(room, activeShift) end)
        else
            pcall(function() executeTreatmentCore(room, roomNum, activeShift) end)
        end
    else
        if not _G.AutoDoctor_IsIdle then
            unequipAll()
            teleportToIdle()
            _G.AutoDoctor_IsIdle = true
        end
        setStatus("Idle (Memantau)...")
        printRadarReport()
        task.wait(Config.ScanDelay)
    end
end

local function startWorker()
    if _G.AutoDoctor_Worker then task.cancel(_G.AutoDoctor_Worker) end
    _G.AutoDoctor_Worker = task.spawn(function()
        while autoScanEnabled do
            if not isBusy then
                isBusy = true
                _G.AutoDoctor_LastActionTick = tick()
                pcall(botCycle)
                isBusy = false
            end
            task.wait(0.1)
        end
    end)
end

