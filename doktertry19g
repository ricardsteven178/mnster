-- INVENTORY & ITEM FETCHING
-- ==========================================
local function checkTotalInventory()
    local targetCount = 0
    local targetItems = {}
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    local character = LocalPlayer.Character

    local function processTool(item)
        if item:IsA("Tool") and table.find(ItemList, item.Name) then
            targetCount = targetCount + 1
            table.insert(targetItems, item)
        end
    end

    if backpack then for _, item in ipairs(backpack:GetChildren()) do processTool(item) end end
    if character then for _, item in ipairs(character:GetChildren()) do processTool(item) end end
    return targetCount, targetItems
end

local function trashItem(toolToTrash)
    local char = LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not char or not root or not toolToTrash then return false end

    local trashPrompt = getPromptFromCache("Trash", true)
    if trashPrompt then
        setStatus("Membuang item: " .. toolToTrash.Name)

        if turboSafeEquip(toolToTrash.Name) then
            local originalPos = root.CFrame

            root.CFrame = Config.Room8BedCFrame
            root.AssemblyLinearVelocity = Vector3.zero
            task.wait(0.2) 

            firePromptRaw(trashPrompt)

            _G.AutoDoctor_LastActionTick = tick()
            task.wait(0.1)

            root.CFrame = originalPos
            root.AssemblyLinearVelocity = Vector3.zero
            task.wait(0.05)

            return true
        end
    end

    setStatus("GAGAL: Tempat sampah tidak ditemukan!")
    return false
end

local function fetchItem(targetName, pendingMedsList)
    local char = LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not char or not root then return false end

    local totalAmount, currentItems = checkTotalInventory()

    if totalAmount >= Config.MaxInventory then
        local itemToThrowAway = nil
        local reqCounts = {}
        if pendingMedsList then
            for _, o in ipairs(pendingMedsList) do reqCounts[o] = (reqCounts[o] or 0) + 1 end
        end
        local haveCounts = {}
        for _, item in ipairs(currentItems) do
            haveCounts[item.Name] = (haveCounts[item.Name] or 0) + 1
            local needed = reqCounts[item.Name] or 0
            if haveCounts[item.Name] > needed then
                itemToThrowAway = item
            end
        end
        if not itemToThrowAway then itemToThrowAway = currentItems[1] end
        local trashed = trashItem(itemToThrowAway)
        if not trashed then return false end
    end

    local promptToUse = getPromptFromCache(targetName, false)
    if not promptToUse then
        setStatus("GAGAL: " .. targetName .. " tidak ditemukan di map.")
        return false
    end

    unequipAll()
    local isRoom8Item = table.find(Room8Items, targetName) ~= nil

    local function countInBag()
        local n = 0
        local bp = LocalPlayer:FindFirstChild("Backpack")
        local ch = LocalPlayer.Character
        if bp then for _, v in ipairs(bp:GetChildren()) do if v:IsA("Tool") and v.Name == targetName then n = n + 1 end end end
        if ch then for _, v in ipairs(ch:GetChildren()) do if v:IsA("Tool") and v.Name == targetName then n = n + 1 end end end
        return n
    end

    local beforeCount = countInBag()

    if isRoom8Item then
        setStatus("Fetch (Gudang R8): " .. targetName)
        root.CFrame = Config.Room8BedCFrame
        root.AssemblyLinearVelocity = Vector3.zero
        task.wait(0.2) 
    else
        setStatus("Fetch (Rak): " .. targetName)
        local itemPart = promptToUse.Parent:IsA("BasePart") and promptToUse.Parent or promptToUse.Parent:FindFirstChildWhichIsA("BasePart", true)
        if itemPart then
            root.CFrame = itemPart.CFrame * CFrame.new(0, 3, 0)
        end
        root.AssemblyLinearVelocity = Vector3.zero
        task.wait(0.1) 
    end

    firePromptRaw(promptToUse)

    local verified = false
    for _ = 1, 20 do
        task.wait(0.05)
        if countInBag() > beforeCount then
            verified = true
            break
        end
        _G.AutoDoctor_LastActionTick = tick()
    end

    if not verified then
        setStatus("RETRY: " .. targetName)
        firePromptRaw(promptToUse)
        for _ = 1, 20 do
            task.wait(0.05)
            if countInBag() > beforeCount then
                verified = true
                setStatus("CONFIRMED (retry): " .. targetName)
                break
            end
            _G.AutoDoctor_LastActionTick = tick()
        end
    else
        setStatus("CONFIRMED: " .. targetName)
    end

    return verified
end

