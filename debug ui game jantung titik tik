local Players = game:GetService("Players")
local GuiService = game:GetService("GuiService")
local PlayerGui = Players.LocalPlayer:WaitForChild("PlayerGui")
local guiParent = (gethui and gethui()) or game:GetService("CoreGui") or PlayerGui

local ID_HAND = "rbxassetid://76833679466645"
local ID_SKULL = "rbxassetid://2766332187"

-- 1. CLEANUP
if guiParent:FindFirstChild("LaserSpy") then guiParent.LaserSpy:Destroy() end
