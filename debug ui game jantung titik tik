-- 3. FUNGSI GAMBAR LASER (RUMUS V3 KAMU)
local function CreateDot(target, color)
	if not target then return end
	
	local pos = target.AbsolutePosition
	local size = target.AbsoluteSize
	local inset = GuiService:GetGuiInset()

	-- Kordinat Asli + Fix Topbar
	local rawX = pos.X + (size.X / 2)
	local rawY = pos.Y + (size.Y / 2)
	local fixedY = rawY + inset.Y -- Menambahkan 36 Pixel Topbar agar pas di tengah

	local dot = Instance.new("Frame")
	dot.Size = UDim2.new(0, 14, 0, 14)
	dot.AnchorPoint = Vector2.new(0.5, 0.5) -- Tetap pakai AnchorPoint agar tidak meleset ke samping
	dot.Position = UDim2.new(0, rawX, 0, fixedY) 
	dot.BackgroundColor3 = color
	Instance.new("UICorner", dot).CornerRadius = UDim.new(1, 0)
	dot.Parent = laserDotsGui
	
	-- Musnahkan setelah 1.5 detik
	task.delay(1.5, function() if dot then dot:Destroy() end end)
end

-- 4. FILTER DETEKSI CERDAS (LOGIKA V8 AKU)
local function OnChildAdded(child)
	-- Tunggu sebentar agar game selesai mengatur visibilitas tengkorak/jari
	task.wait(0.05)
	if not child or not child.Parent then return end

	local isHand = false
	local isSkull = false

	-- Cari gambar di dalam template yang sedang Visible = true
	local itemsToCheck = {child}
	for _, desc in ipairs(child:GetDescendants()) do
		table.insert(itemsToCheck, desc)
	end

	for _, obj in ipairs(itemsToCheck) do
		if (obj:IsA("ImageLabel") or obj:IsA("ImageButton")) and obj.Visible then
			if obj.Image == ID_HAND then
				isHand = true
			elseif obj.Image == ID_SKULL then
				isSkull = true
			end
		end
	end

	-- Eksekusi Laser
	if isHand then
		CreateDot(child, Color3.fromRGB(50, 255, 50)) -- JARI = HIJAU
	elseif isSkull then
		CreateDot(child, Color3.fromRGB(255, 50, 50)) -- TENGKORAK = MERAH
	end
end

-- 5. EVENT HOOK
local function HookMinigame(gui)
	local frame = gui:FindFirstChild("Frame")
	if frame then 
		table.insert(connections, frame.ChildAdded:Connect(OnChildAdded)) 
	end
end

local minigame = PlayerGui:FindFirstChild("Minigame")
if minigame then HookMinigame(minigame) end

table.insert(connections, PlayerGui.ChildAdded:Connect(function(c) 
	if c.Name == "Minigame" then 
		task.wait(0.5)
		HookMinigame(c) 
	end 
end))

